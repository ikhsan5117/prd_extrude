                                     && n.Machine == noDoc.Machine 
                                     && n.Formulasi == noDoc.Formulasi)
                            .ToListAsync();
                        
                        int totalAffectedItems = 0;
                        
                        // Update semua SpsNoDocs yang match
                        foreach (var relatedNoDoc in relatedNoDocs)
                        {
                            // Copy properties dari item yang di-edit (kecuali Id, ExcelId, No, ItemList)
                            relatedNoDoc.DocumentNumber = item.DocumentNumber;
                            relatedNoDoc.Machine = item.Machine;
                            relatedNoDoc.MachineCode = item.MachineCode;
                            relatedNoDoc.RevisionNumber = item.RevisionNumber;
                            relatedNoDoc.RevisionDate = item.RevisionDate;
                            relatedNoDoc.Customer = item.Customer;
