            if (id != item.Id) return NotFound();

            if (ModelState.IsValid)
            {
                try
                {
                    var noDoc = await _context.SpsNoDocs.Include(x => x.ItemLists).FirstOrDefaultAsync(x => x.Id == id);
                    if (noDoc == null) return NotFound();

                    if (syncToAll)
                    {
                        // SYNC MODE: Update SEMUA SpsNoDocs yang punya NO.DOC + Machine + Formulasi sama
