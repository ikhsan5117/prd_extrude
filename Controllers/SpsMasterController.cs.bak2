                            relatedNoDoc.Material = item.Material;
                            relatedNoDoc.InnerTube = item.InnerTube;
                            relatedNoDoc.OuterCover = item.OuterCover;
                            relatedNoDoc.MiddleTube = item.MiddleTube;
                            relatedNoDoc.UseLimitsInner = item.UseLimitsInner;
                            relatedNoDoc.UseLimitsOuter = item.UseLimitsOuter;
                            relatedNoDoc.UseLimitsMiddle = item.UseLimitsMiddle;
                            relatedNoDoc.Yarn = item.Yarn;
                            relatedNoDoc.TensionYarnInner = item.TensionYarnInner;
                            relatedNoDoc.TensionYarnOuter = item.TensionYarnOuter;
                            relatedNoDoc.MarkingSort = item.MarkingSort;
                            relatedNoDoc.TextMarkingMaterial = item.TextMarkingMaterial;
                            relatedNoDoc.MarkingColour = item.MarkingColour;
                            
                            // Copy all tolerance/technical fields
                            relatedNoDoc.PitchYarn_Min = item.PitchYarn_Min;
                            relatedNoDoc.PitchYarn_Asli = item.PitchYarn_Asli;
                            relatedNoDoc.PitchYarn_Max = item.PitchYarn_Max;
