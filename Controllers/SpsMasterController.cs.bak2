                            relatedNoDoc.CuttingSpeed_Max = item.CuttingSpeed_Max;
                            
                            _context.Update(relatedNoDoc);
                            
                            // Hitung total items
                            totalAffectedItems += relatedNoDoc.ItemLists?.Count ?? 0;
                            
                            // TIDAK update ItemLists karena itu unique per SpsNoDocs
                        }
                        
                        await _context.SaveChangesAsync();
                        
                        TempData["SuccessMessage"] = $"✅ Berhasil! {totalAffectedItems} item dengan NO.DOC '{noDoc.DocumentNumber}' telah disinkronkan.";
                    }
                    else
                    {
                        // SINGLE EDIT MODE: Create new SpsNoDocs for this item only
                        var newNoDoc = SpsMapper.ToSpsNoDoc(item);
                        // Don't copy Id - let EF generate new one
                        newNoDoc.Id = 0;
                        _context.SpsNoDocs.Add(newNoDoc);
                        await _context.SaveChangesAsync(); // Save to get new Id
                        
                        // Find current item in old parent's ItemLists
                        var currentItemList = noDoc.ItemLists?
                            .FirstOrDefault(il => il.ItemList == item.ItemList);
                        if (currentItemList != null)
                        {
                            _context.SpsItemLists.Remove(currentItemList);
                        }
                        
                        // Add item to new parent
                        if (!string.IsNullOrEmpty(item.ItemList))
                        {
                            var items = item.ItemList.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(i => i.Trim()).Distinct();
                            foreach (var i in items)
                            {
                                _context.SpsItemLists.Add(new SpsItemList { 
                                    SpsNoDocId = newNoDoc.Id, 
                                    ItemList = i 
                                });
                            }
                        }
                        
                        await _context.SaveChangesAsync();
                        TempData["SuccessMessage"] = "✅ Item ini berhasil diupdate (tidak mempengaruhi item lain dengan NO.DOC sama).";
                    }
                }
                catch (DbUpdateConcurrencyException)
                {
                    if (!ItemExists(item.Id)) return NotFound();
                    else throw;
                }
                return RedirectToAction(nameof(Index));
            }
            return View(item);
        }

        // POST: SpsMasters/Delete/5
        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> Delete(int id)
        {
            var item = await _context.SpsNoDocs.FindAsync(id);
            if (item != null)
            {
                _context.SpsNoDocs.Remove(item);
                await _context.SaveChangesAsync();
                TempData["SuccessMessage"] = "Data SPS berhasil dihapus!";
            }
            return RedirectToAction(nameof(Index));
        }

        // POST: SpsMasters/DeleteMultiple
        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> DeleteMultiple([FromBody] int[] ids)
        {
            if (ids == null || ids.Length == 0)
            {
                return Json(new { success = false, message = "Tidak ada data yang dipilih." });
            }

            try
            {
                var itemsToDelete = await _context.SpsNoDocs
                    .Where(m => ids.Contains(m.Id))
                    .ToListAsync();

                if (itemsToDelete.Any())
                {
                    _context.SpsNoDocs.RemoveRange(itemsToDelete);
                    await _context.SaveChangesAsync();
                }

                return Json(new { success = true, message = $"{itemsToDelete.Count} data berhasil dihapus." });
            }
            catch (Exception ex)
            {
                return Json(new { success = false, message = "Terjadi kesalahan: " + ex.Message });
            }
        }

        private async Task SavePendingImportsAsync(List<SpsMaster> newMasters, List<SpsMaster> updateMasters)
        {
            try {
                // Group by DocumentNumber, Machine, Formulasi to avoid creating duplicate SpsNoDocs
                var allImports = newMasters.Concat(updateMasters).ToList();
                _logger.LogInformation($"SavePendingImports: Processing {allImports.Count} total items ({newMasters.Count} new, {updateMasters.Count} updates)");
                
                var grouped = allImports.GroupBy(m => new { 
                    DocNo = m.DocumentNumber ?? "", 
                    Machine = m.Machine ?? "", 
                    Formulasi = m.Formulasi ?? "" 
                }).ToList();
                
                _logger.LogInformation($"SavePendingImports: Grouped into {grouped.Count} unique documents");

                int groupIndex = 0;
                foreach (var group in grouped)
                {
                    groupIndex++;
                    var docNo = group.Key.DocNo;
                    var machine = group.Key.Machine;
                    var formulasi = group.Key.Formulasi;
                    
                    _logger.LogInformation($"Processing group {groupIndex}/{grouped.Count}: Doc={docNo}, Machine={machine}, Items={group.Count()}");

                    try {
                        // Cari SpsNoDoc yang cocok (WITH TRACKING)
                        var noDoc = await _context.SpsNoDocs
                            .FirstOrDefaultAsync(n => 
                                (n.DocumentNumber ?? "") == docNo && 
                                (n.Machine ?? "") == machine && 
                                (n.Formulasi ?? "") == formulasi);
                        
                        bool isNewDoc = noDoc == null;

                        if (isNewDoc)
                        {
                            // Create new document
                            noDoc = SpsMapper.ToSpsNoDoc(group.First());
                            _context.SpsNoDocs.Add(noDoc);
                            await _context.SaveChangesAsync(); // Save to get Id
                            _logger.LogInformation($"Created new SpsNoDoc Id={noDoc.Id} for Doc={docNo}");
                        }
                        else
                        {
                            // Update existing document - entity already tracked, just update properties
                            _logger.LogInformation($"Updating existing SpsNoDoc Id={noDoc!.Id} for Doc={docNo}");
                            SpsMapper.CopyPropertiesForUpdate(group.First(), noDoc!);
                            // No need to call Update(), EF will auto-detect changes
                        }

                        // Handle Item Lists (Merge them, avoid duplicates)
                        var existingItems = await _context.SpsItemLists
                            .Where(i => i.SpsNoDocId == noDoc!.Id)
                            .Select(i => i.ItemList)
                            .ToListAsync();
                        
                        _logger.LogInformation($"Existing items for Doc Id={noDoc!.Id}: {existingItems.Count}");
                            
                        var incomingItems = group.Where(x => !string.IsNullOrEmpty(x.ItemList))
                                                 .Select(x => x.ItemList!.Trim())
                                                 .Distinct()
                                                 .ToList();
                        
                        _logger.LogInformation($"Incoming items: {incomingItems.Count}");

                        int addedItems = 0;
                        foreach (var item in incomingItems)
                        {
                            if (!existingItems.Contains(item))
                            {
                                _context.SpsItemLists.Add(new SpsItemList { SpsNoDocId = noDoc!.Id, ItemList = item });
                                addedItems++;
                            }
                        }
                        
                        _logger.LogInformation($"Adding {addedItems} new items for Doc={docNo}");
                        
                        // Save all changes for this group
                        await _context.SaveChangesAsync();
                        _logger.LogInformation($"Group {groupIndex} saved successfully");
                        
                    } catch (Exception groupEx) {
                        _logger.LogError(groupEx, $"Error processing group {groupIndex}: Doc={docNo}");
                        throw new Exception($"Error processing document '{docNo}': {groupEx.Message}", groupEx);
                    }
                }
                
                _logger.LogInformation("SavePendingImports completed successfully");
                
            } catch (Exception ex) {
                _logger.LogError(ex, "Fatal error in SavePendingImportsAsync");
                throw;
            }
        }

        private bool ItemExists(int id)
        {
            return _context.SpsNoDocs.Any(e => e.Id == id);
        }

        // GET: SpsMasters/DownloadEmptyTemplate - Template LENGKAP dengan 216 kolom (MIN|STN|MAX)
        [HttpGet]
        public IActionResult DownloadEmptyTemplate()
        {
            using var package = new OfficeOpenXml.ExcelPackage();
            var ws = package.Workbook.Worksheets.Add("SPS Parameter Setting");

            // ROW 1: FRIENDLY LABELS - LENGKAP 216 KOLOM
            var friendlyLabels = new List<string>
            {
                // Kolom 1-14: Basic Info
                "ID (Wajib)", "No Urut", "Mesin (Wajib)", "No.Dokumen (Wajib)", 
                "No. Revisi", "Customer", "Tgl Revisi", 
                "Formulasi", "Tipe Hose", "Dimensi", "Material", 
                "Inner Tube", "Middle Tube", "Outer Cover",
                
                // Kolom 15-20: Limits & Yarn
                "Limit Inner", "Limit Middle", "Limit Outer", 
                "Yarn", "Tension Inner", "Tension Outer",
                
                // Kolom 21-23: Text fields (Nipple, Tube Die, Middle Die)
                "Nipple (Text)", "Tube Die (Text)", "Middle Die (Text)",
                
                // Kolom 24-26: MIN/STN/MAX Pitch Yarn
                "MIN Pitch Yarn", "STN Pitch Yarn", "MAX Pitch Yarn",
                
                // Kolom 27-29: MIN/STN/MAX Nipple
                "MIN Nipple", "STN Nipple", "MAX Nipple",
                
                // Kolom 30-32: MIN/STN/MAX Tube Die  
                "MIN Tube Die", "STN Tube Die", "MAX Tube Die",
                
                // Kolom 33-35: MIN/STN/MAX Middle Die
                "MIN Middle Die", "STN Middle Die", "MAX Middle Die",
                
                // Kolom 36-38: MIN/STN/MAX Cover Die
                "MIN Cover Die", "STN Cover Die", "MAX Cover Die",
                
                // Kolom 39-41: MIN/STN/MAX Spacer
                "MIN Spacer", "STN Spacer", "MAX Spacer",
                
                // Kolom 42-44: MIN/STN/MAX A Distance
                "MIN A Distance", "STN A Distance", "MAX A Distance",
                
                // Kolom 45-53: Mesh (3 params × 3 = 9)
                "MIN Mesh Dim 1", "STN Mesh Dim 1", "MAX Mesh Dim 1",
                "Mesh Screen 1",
                "MIN Mesh Dim 2", "STN Mesh Dim 2", "MAX Mesh Dim 2",
                "Mesh Screen 2",
                "MIN Mesh Dim 3", "STN Mesh Dim 3", "MAX Mesh Dim 3",
                "Mesh Screen 3",
                
                // Kolom 54-68: Temperature Material 1 (5 params × 3 = 15)
                "MIN Head Temp 1", "STN Head Temp 1", "MAX Head Temp 1",
                "MIN Cylinder 1-1", "STN Cylinder 1-1", "MAX Cylinder 1-1",
                "MIN Cylinder 2-1", "STN Cylinder 2-1", "MAX Cylinder 2-1",
                "MIN Cylinder 3-1", "STN Cylinder 3-1", "MAX Cylinder 3-1",
                "MIN Screw Temp 1", "STN Screw Temp 1", "MAX Screw Temp 1",
                
                // Kolom 69-83: Temperature Material 2 (5 params × 3 = 15)
                "MIN Head Temp 2", "STN Head Temp 2", "MAX Head Temp 2",
                "MIN Cylinder 1-2", "STN Cylinder 1-2", "MAX Cylinder 1-2",
                "MIN Cylinder 2-2", "STN Cylinder 2-2", "MAX Cylinder 2-2",
                "MIN Cylinder 3-2", "STN Cylinder 3-2", "MAX Cylinder 3-2",
                "MIN Screw Temp 2", "STN Screw Temp 2", "MAX Screw Temp 2",
                
                // Kolom 84-98: Temperature Material 3 (5 params × 3 = 15)
                "MIN Head Temp 3", "STN Head Temp 3", "MAX Head Temp 3",
                "MIN Cylinder 1-3", "STN Cylinder 1-3", "MAX Cylinder 1-3",
                "MIN Cylinder 2-3", "STN Cylinder 2-3", "MAX Cylinder 2-3",
                "MIN Cylinder 3-3", "STN Cylinder 3-3", "MAX Cylinder 3-3",
                "MIN Screw Temp 3", "STN Screw Temp 3", "MAX Screw Temp 3",
                
                // Kolom 99-104: Feed (2 params × 3 = 6)
                "MIN Feed 1", "STN Feed 1", "MAX Feed 1",
                "MIN Feed 2", "STN Feed 2", "MAX Feed 2",
                
                // Kolom 105-113: Screw Speed (3 params × 3 = 9)
                "MIN Screw Speed 1", "STN Screw Speed 1", "MAX Screw Speed 1",
                "MIN Screw Speed 2", "STN Screw Speed 2", "MAX Screw Speed 2",
                "MIN Screw Speed 3", "STN Screw Speed 3", "MAX Screw Speed 3",
                
                // Kolom 114-119: Feed Roll Ratio (2 params × 3 = 6)
                "MIN Feed Roll 1", "STN Feed Roll 1", "MAX Feed Roll 1",
                "MIN Feed Roll 2", "STN Feed Roll 2", "MAX Feed Roll 2",
                
                // Kolom 120-122: Feed 3
                "MIN Feed 3", "STN Feed 3", "MAX Feed 3",
                
                // Kolom 123-131: Pressure (3 params × 3 = 9)
                "MIN Pressure 1", "STN Pressure 1", "MAX Pressure 1",
                "MIN Pressure 2", "STN Pressure 2", "MAX Pressure 2",
                "MIN Pressure 3", "STN Pressure 3", "MAX Pressure 3",
                
                // Kolom 132-140: Am Meter (3 params × 3 = 9)
                "MIN Am Meter 1", "STN Am Meter 1", "MAX Am Meter 1",
                "MIN Am Meter 2", "STN Am Meter 2", "MAX Am Meter 2",
                "MIN Am Meter 3", "STN Am Meter 3", "MAX Am Meter 3",
                
                // Kolom 141-158: Output Parameters (6 params × 3 = 18)
                "MIN Preset Value", "STN Preset Value", "MAX Preset Value",
                "MIN Control Value", "STN Control Value", "MAX Control Value",
                "MIN Spiral Pitch Set", "STN Spiral Pitch Set", "MAX Spiral Pitch Set",
                "MIN Spiral Pitch Disp", "STN Spiral Pitch Disp", "MAX Spiral Pitch Disp",
                "MIN Spiral Speed", "STN Spiral Speed", "MAX Spiral Speed",
                "MIN Hose Speed", "STN Hose Speed", "MAX Hose Speed",
                
                // Kolom 159-161: Unsmooth/OD Sensor
                "Unsmooth",
                "MIN OD Sensor", "STN OD Sensor", "MAX OD Sensor",
                
                // Kolom 162-164: Marking
                "Marking Sort", "Text Marking", "Marking Color",
                
                // Kolom 165-167: Chiller
                "MIN Chiller Temp", "STN Chiller Temp", "MAX Chiller Temp",
                
                // Kolom 168-185: Final Process (6 params × 3 = 18)
                "MIN Dancer", "STN Dancer", "MAX Dancer",
                "MIN Caterpillar Gap", "STN Caterpillar Gap", "MAX Caterpillar Gap",
                "MIN Cutting Speed", "STN Cutting Speed", "MAX Cutting Speed",
                "MIN Takeup Speed", "STN Takeup Speed", "MAX Takeup Speed",
                "MIN Cool Speed 1", "STN Cool Speed 1", "MAX Cool Speed 1",
                "MIN Cool Speed 2", "STN Cool Speed 2", "MAX Cool Speed 2",
                
                // Kolom 186-188: Conveyor Ratio
                "MIN Conveyor Ratio", "STN Conveyor Ratio", "MAX Conveyor Ratio",
                
                // Kolom 189-209: Quality Matrix (7 params × 3 = 21)
                "MIN Tolerance Inner", "STN Tolerance Inner", "MAX Tolerance Inner",
                "MIN Tolerance Outer", "STN Tolerance Outer", "MAX Tolerance Outer",
                "MIN Tebal Inner", "STN Tebal Inner", "MAX Tebal Inner",
                "MIN Tebal Inner+Mid", "STN Tebal Inner+Mid", "MAX Tebal Inner+Mid",
                "MIN Tebal Outer", "STN Tebal Outer", "MAX Tebal Outer",
                "MIN Tebal Total", "STN Tebal Total", "MAX Tebal Total",
                "MIN Selisih Tebal", "STN Selisih Tebal", "MAX Selisih Tebal",
                
                // Kolom 210-215: Inner/InnerMid/Total (legacy quality fields)
                "Inner Min", "Inner STN", "Inner Max",
                "InnerMid Min", "InnerMid STN", "InnerMid Max",
                
                // Kolom 216: Item List
                "Item List (OPSIONAL - pisah dengan koma)"
            };
            
            // Write friendly labels to Row 1 (header langsung)
            for (int i = 0; i < friendlyLabels.Count; i++)
            {
                ws.Cells[1, i + 1].Value = friendlyLabels[i];
                ws.Cells[1, i + 1].Style.Font.Bold = true;
                ws.Cells[1, i + 1].Style.Font.Size = 9;
                ws.Cells[1, i + 1].Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                
                // Color coding: MIN=green, STN=blue, MAX=red
                string label = friendlyLabels[i];
                if (label.StartsWith("MIN"))
                {
                    ws.Cells[1, i + 1].Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.FromArgb(40, 167, 69)); // Green
                    ws.Cells[1, i + 1].Style.Font.Color.SetColor(System.Drawing.Color.White);
                }
                else if (label.StartsWith("STN"))
                {
                    ws.Cells[1, i + 1].Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.FromArgb(13, 110, 253)); // Blue
                    ws.Cells[1, i + 1].Style.Font.Color.SetColor(System.Drawing.Color.White);
                }
                else if (label.StartsWith("MAX"))
                {
                    ws.Cells[1, i + 1].Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.FromArgb(220, 53, 69)); // Red
                    ws.Cells[1, i + 1].Style.Font.Color.SetColor(System.Drawing.Color.White);
                }
                else
                {
                    ws.Cells[1, i + 1].Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.FromArgb(68, 114, 196)); // Default blue
                    ws.Cells[1, i + 1].Style.Font.Color.SetColor(System.Drawing.Color.White);
                }
                
                ws.Cells[1, i + 1].Style.Border.BorderAround(OfficeOpenXml.Style.ExcelBorderStyle.Thin);
            }

            // ROW 2: COLUMN INDEX (untuk referensi mapping)
            for (int i = 1; i <= friendlyLabels.Count; i++)
            {
                ws.Cells[2, i].Value = i;
                ws.Cells[2, i].Style.Font.Bold = true;
                ws.Cells[2, i].Style.Font.Size = 8;
                ws.Cells[2, i].Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                ws.Cells[2, i].Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.LightGray);
                ws.Cells[2, i].Style.HorizontalAlignment = OfficeOpenXml.Style.ExcelHorizontalAlignment.Center;
            }

            // ROW 3 onwards: Kosong, siap diisi user

            // Auto fit columns
            for (int col = 1; col <= friendlyLabels.Count; col++)
            {
                ws.Column(col).Width = col == friendlyLabels.Count ? 30 : 12; // Item List wider
            }
            
            // Freeze panes at Row 3 (after 2 header rows)
            ws.View.FreezePanes(3, 1);

            var content = package.GetAsByteArray();
            return File(content, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", 
                $"Template_SPS_Full_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx");
        }

        // GET: SpsMasters/ExportExcel
        [HttpGet]
        public async Task<IActionResult> ExportExcel()
        {
            var rawData = await GetSpsMastersAsync();
            var data = rawData
                .OrderBy(m => m.DocumentNumber)
                .ThenBy(m => m.ItemList)
                .ToList();

            using var package = new OfficeOpenXml.ExcelPackage();
            var ws = package.Workbook.Worksheets.Add("SPS Master");

            // --- Title ---
            ws.Cells[1, 1].Value = "SPS MASTER - Standard Parameter Setting (216 Columns: 45 Basic + 171 Tolerance Split)";
            ws.Cells[1, 1, 1, 50].Merge = true;
            ws.Cells[1, 1].Style.Font.Bold = true;
            ws.Cells[1, 1].Style.Font.Size = 14;
            ws.Cells[1, 1].Style.HorizontalAlignment = OfficeOpenXml.Style.ExcelHorizontalAlignment.Center;
            ws.Cells[1, 1].Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
            ws.Cells[1, 1].Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.FromArgb(15, 25, 45));
            ws.Cells[1, 1].Style.Font.Color.SetColor(System.Drawing.Color.FromArgb(100, 160, 255));

            ws.Cells[2, 1].Value = $"Export Date: {DateTime.Now:dd MMM yyyy HH:mm} | Total: {data.Count} records | Format: MIN|STN|MAX for all tolerance fields";
            ws.Cells[2, 1, 2, 50].Merge = true;
            ws.Cells[2, 1].Style.HorizontalAlignment = OfficeOpenXml.Style.ExcelHorizontalAlignment.Center;
            ws.Cells[2, 1].Style.Font.Italic = true;
            ws.Cells[2, 1].Style.Font.Color.SetColor(System.Drawing.Color.Gray);

            // --- Headers (216 total: 45 basic + 171 tolerance split) ---
            var headersList = new List<string>
            {
                // Basic Info (10 cols)
                "No", "Excel ID", "No", "Machine", "Machine Code", "Doc Number", "Rev Number", "Rev Date",  
                "Item List", "Formulasi", "Customer", "Hose Type", "Dimensi", "Material",
                
                // Material (9 cols)
                "Inner Tube", "Middle Tube", "Outer Cover", 
                "Use Limits Inner", "Use Limits Middle", "Use Limits Outer",
                "Yarn", "Tension Yarn Inner", "Tension Yarn Outer",
                
                // Mesh Screens (3 cols string)
                "Mesh Screen 1", "Mesh Screen 2", "Mesh Screen 3"
            };

            // Add 186 Tolerance Columns (62 fields × 3)
            // Section: Spesifikasi & Dies (7 fields = 21 cols)
            var toleranceFields = new[] { "PitchYarn", "Nipple", "TubeDie", "MiddleDie", "CoverDie", "SpacerDie", "ADistance" };
            foreach (var field in toleranceFields)
            {
                headersList.Add($"{field}_MIN");
                headersList.Add($"{field}_STN");
                headersList.Add($"{field}_MAX");
            }
            
            // Section: Mesh (3 fields = 9 cols)
            for (int i = 1; i <= 3; i++)
            {
                headersList.Add($"MeshDim{i}_MIN");
                headersList.Add($"MeshDim{i}_STN");
                headersList.Add($"MeshDim{i}_MAX");
            }
            
            // Section: Suhu (21 fields = 63 cols)
            for (int i = 1; i <= 3; i++) // HeadTemp 1-3
            {
                headersList.Add($"HeadTemp{i}_MIN");
                headersList.Add($"HeadTemp{i}_STN");
                headersList.Add($"HeadTemp{i}_MAX");
            }
            // Cylinder: 3 extruders × 3 materials = 9 fields
            for (int ext = 1; ext <= 3; ext++)
            {
                for (int mat = 1; mat <= 3; mat++)
                {
                    headersList.Add($"Cylinder{ext}_{mat}_MIN");
                    headersList.Add($"Cylinder{ext}_{mat}_STN");
                    headersList.Add($"Cylinder{ext}_{mat}_MAX");
                }
            }
            for (int i = 1; i <= 3; i++) // ScrewTemp 1-3
            {
                headersList.Add($"ScrewTemp{i}_MIN");
                headersList.Add($"ScrewTemp{i}_STN");
                headersList.Add($"ScrewTemp{i}_MAX");
            }
            headersList.Add("ChillerWaterTemp_MIN");
            headersList.Add("ChillerWaterTemp_STN");
            headersList.Add("ChillerWaterTemp_MAX");
            
            // Section: Output Mesin (25 fields = 75 cols)
            var outputFields = new[] { 
                "Feed1", "Feed2", "Feed3",
                "ScrewSpeed1", "ScrewSpeed2", "ScrewSpeed3",
                "Pressure1", "Pressure2", "Pressure3",
                "FeedRollRatio1", "FeedRollRatio2", "FeedRollRatio3",
                "HoseSpeed", "TakeUpConveyorSpeed", "CaterpillarGap", "SpiralSpeed",
                "TebalInner", "TebalOuter", "TebalTotal", "TebalInnerMiddle",
                "AmMeter", "AmMeter2", "AmMeter3",
                "PresetValue", "ControlValue", "SpiralPitchSetting", "SpiralPitchDisplay",
                "CoolConveyorSpeed", "CoolConveyorSpeed2", "ConveyorRatio"
            };
            foreach (var field in outputFields)
            {
                headersList.Add($"{field}_MIN");
                headersList.Add($"{field}_STN");
                headersList.Add($"{field}_MAX");
            }
            
            // Section: Quality (6 fields = 18 cols)
            var qualityFields = new[] { "ToleranceInner", "ToleranceOuter", "SelisihTebal", "DancerPosition", "OdSensor", "CuttingSpeed" };
            foreach (var field in qualityFields)
            {
                headersList.Add($"{field}_MIN");
                headersList.Add($"{field}_STN");
                headersList.Add($"{field}_MAX");
            }
            
            var headers = headersList.ToArray();

            for (int i = 0; i < headers.Length; i++)
            {
                var cell = ws.Cells[4, i + 1];
                cell.Value = headers[i];
                cell.Style.Font.Bold = true;
                cell.Style.Font.Color.SetColor(System.Drawing.Color.White);
                cell.Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                cell.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.FromArgb(13, 60, 120));
                cell.Style.Border.BorderAround(OfficeOpenXml.Style.ExcelBorderStyle.Thin, System.Drawing.Color.FromArgb(60, 100, 200));
                cell.Style.HorizontalAlignment = OfficeOpenXml.Style.ExcelHorizontalAlignment.Center;
                cell.Style.WrapText = false;
            }

            // --- Data rows ---
            int row = 5;
            int no = 1;
            foreach (var m in data)
            {
                bool isOdd = (no % 2 == 0);
                var bgColor = isOdd
                    ? System.Drawing.Color.FromArgb(18, 25, 38)
                    : System.Drawing.Color.FromArgb(23, 32, 50);

                var valuesList = new List<object>
                {
                    // Basic Info
                    no, m.ExcelId ?? "", m.No ?? "", m.Machine ?? "", m.MachineCode ?? "", 
                    m.DocumentNumber ?? "", m.RevisionNumber ?? "", m.RevisionDate ?? "",
                    m.ItemList ?? "", m.Formulasi ?? "", m.Customer ?? "", m.HoseType ?? "", 
                    m.Dimensi ?? "", m.Material ?? "",
                    
                    // Material
                    m.InnerTube ?? "", m.MiddleTube ?? "", m.OuterCover ?? "",
                    m.UseLimitsInner ?? "", m.UseLimitsMiddle ?? "", m.UseLimitsOuter ?? "",
                    m.Yarn ?? "", m.TensionYarnInner ?? "", m.TensionYarnOuter ?? "",
                    
                    // Mesh Screens (string)
                    m.MeshScreen1 ?? "", m.MeshScreen2 ?? "", m.MeshScreen3 ?? ""
                };

                // Add 186 Tolerance Values
                #pragma warning disable CS8604 // Null values are acceptable for Excel cells
                // Spesifikasi & Dies (7 fields)
                valuesList.Add(m.PitchYarn_Min); valuesList.Add(m.PitchYarn_Asli); valuesList.Add(m.PitchYarn_Max);
                valuesList.Add(m.Nipple_Min); valuesList.Add(m.Nipple_Asli); valuesList.Add(m.Nipple_Max);
                valuesList.Add(m.TubeDie_Min); valuesList.Add(m.TubeDie_Asli); valuesList.Add(m.TubeDie_Max);
                valuesList.Add(m.MiddleDie_Min); valuesList.Add(m.MiddleDie_Asli); valuesList.Add(m.MiddleDie_Max);
                valuesList.Add(m.CoverDie_Min); valuesList.Add(m.CoverDie_Asli); valuesList.Add(m.CoverDie_Max);
                valuesList.Add(m.SpacerDie_Min); valuesList.Add(m.SpacerDie_Asli); valuesList.Add(m.SpacerDie_Max);
                valuesList.Add(m.ADistance_Min); valuesList.Add(m.ADistance_Asli); valuesList.Add(m.ADistance_Max);
                
                // Mesh (3 fields)
                valuesList.Add(m.MeshDim1_Min); valuesList.Add(m.MeshDim1_Asli); valuesList.Add(m.MeshDim1_Max);
                valuesList.Add(m.MeshDim2_Min); valuesList.Add(m.MeshDim2_Asli); valuesList.Add(m.MeshDim2_Max);
                valuesList.Add(m.MeshDim3_Min); valuesList.Add(m.MeshDim3_Asli); valuesList.Add(m.MeshDim3_Max);
                
                // Suhu - Head Temp (3 fields)
                valuesList.Add(m.HeadTemp1_Min); valuesList.Add(m.HeadTemp1_Asli); valuesList.Add(m.HeadTemp1_Max);
                valuesList.Add(m.HeadTemp2_Min); valuesList.Add(m.HeadTemp2_Asli); valuesList.Add(m.HeadTemp2_Max);
                valuesList.Add(m.HeadTemp3_Min); valuesList.Add(m.HeadTemp3_Asli); valuesList.Add(m.HeadTemp3_Max);
                
                // Suhu - Cylinder: 3 extruders × 3 materials = 9 fields
                valuesList.Add(m.Cylinder1_1_Min); valuesList.Add(m.Cylinder1_1_Asli); valuesList.Add(m.Cylinder1_1_Max);
                valuesList.Add(m.Cylinder1_2_Min); valuesList.Add(m.Cylinder1_2_Asli); valuesList.Add(m.Cylinder1_2_Max);
                valuesList.Add(m.Cylinder1_3_Min); valuesList.Add(m.Cylinder1_3_Asli); valuesList.Add(m.Cylinder1_3_Max);
                valuesList.Add(m.Cylinder2_1_Min); valuesList.Add(m.Cylinder2_1_Asli); valuesList.Add(m.Cylinder2_1_Max);
                valuesList.Add(m.Cylinder2_2_Min); valuesList.Add(m.Cylinder2_2_Asli); valuesList.Add(m.Cylinder2_2_Max);
                valuesList.Add(m.Cylinder2_3_Min); valuesList.Add(m.Cylinder2_3_Asli); valuesList.Add(m.Cylinder2_3_Max);
                valuesList.Add(m.Cylinder3_1_Min); valuesList.Add(m.Cylinder3_1_Asli); valuesList.Add(m.Cylinder3_1_Max);
                valuesList.Add(m.Cylinder3_2_Min); valuesList.Add(m.Cylinder3_2_Asli); valuesList.Add(m.Cylinder3_2_Max);
                valuesList.Add(m.Cylinder3_3_Min); valuesList.Add(m.Cylinder3_3_Asli); valuesList.Add(m.Cylinder3_3_Max);
                
                // Suhu - Screw Temp (3 fields)
                valuesList.Add(m.ScrewTemp1_Min); valuesList.Add(m.ScrewTemp1_Asli); valuesList.Add(m.ScrewTemp1_Max);
                valuesList.Add(m.ScrewTemp2_Min); valuesList.Add(m.ScrewTemp2_Asli); valuesList.Add(m.ScrewTemp2_Max);
                valuesList.Add(m.ScrewTemp3_Min); valuesList.Add(m.ScrewTemp3_Asli); valuesList.Add(m.ScrewTemp3_Max);
                
                // Suhu - Chiller (1 field)
                valuesList.Add(m.ChillerWaterTemp_Min); valuesList.Add(m.ChillerWaterTemp_Asli); valuesList.Add(m.ChillerWaterTemp_Max);
                
                // Output - Feed (3 fields)
                valuesList.Add(m.Feed1_Min); valuesList.Add(m.Feed1_Asli); valuesList.Add(m.Feed1_Max);
                valuesList.Add(m.Feed2_Min); valuesList.Add(m.Feed2_Asli); valuesList.Add(m.Feed2_Max);
                valuesList.Add(m.Feed3_Min); valuesList.Add(m.Feed3_Asli); valuesList.Add(m.Feed3_Max);
                
                // Output - Screw Speed (3 fields)
                valuesList.Add(m.ScrewSpeed1_Min); valuesList.Add(m.ScrewSpeed1_Asli); valuesList.Add(m.ScrewSpeed1_Max);
                valuesList.Add(m.ScrewSpeed2_Min); valuesList.Add(m.ScrewSpeed2_Asli); valuesList.Add(m.ScrewSpeed2_Max);
                valuesList.Add(m.ScrewSpeed3_Min); valuesList.Add(m.ScrewSpeed3_Asli); valuesList.Add(m.ScrewSpeed3_Max);
                
                // Output - Pressure (3 fields)
                valuesList.Add(m.Pressure1_Min); valuesList.Add(m.Pressure1_Asli); valuesList.Add(m.Pressure1_Max);
                valuesList.Add(m.Pressure2_Min); valuesList.Add(m.Pressure2_Asli); valuesList.Add(m.Pressure2_Max);
                valuesList.Add(m.Pressure3_Min); valuesList.Add(m.Pressure3_Asli); valuesList.Add(m.Pressure3_Max);
                
                // Output - Feed Roll Ratio (3 fields)
                valuesList.Add(m.FeedRollRatio1_Min); valuesList.Add(m.FeedRollRatio1_Asli); valuesList.Add(m.FeedRollRatio1_Max);
                valuesList.Add(m.FeedRollRatio2_Min); valuesList.Add(m.FeedRollRatio2_Asli); valuesList.Add(m.FeedRollRatio2_Max);
                valuesList.Add(m.FeedRollRatio3_Min); valuesList.Add(m.FeedRollRatio3_Asli); valuesList.Add(m.FeedRollRatio3_Max);
                
                // Output - Speeds & Gaps (4 fields)
                valuesList.Add(m.HoseSpeed_Min); valuesList.Add(m.HoseSpeed_Asli); valuesList.Add(m.HoseSpeed_Max);
                valuesList.Add(m.TakeUpConveyorSpeed_Min); valuesList.Add(m.TakeUpConveyorSpeed_Asli); valuesList.Add(m.TakeUpConveyorSpeed_Max);
                valuesList.Add(m.CaterpillarGap_Min); valuesList.Add(m.CaterpillarGap_Asli); valuesList.Add(m.CaterpillarGap_Max);
                valuesList.Add(m.SpiralSpeed_Min); valuesList.Add(m.SpiralSpeed_Asli); valuesList.Add(m.SpiralSpeed_Max);
                
                // Output - Thickness (4 fields)
                valuesList.Add(m.TebalInner_Min); valuesList.Add(m.TebalInner_Asli); valuesList.Add(m.TebalInner_Max);
                valuesList.Add(m.TebalOuter_Min); valuesList.Add(m.TebalOuter_Asli); valuesList.Add(m.TebalOuter_Max);
                valuesList.Add(m.TebalTotal_Min); valuesList.Add(m.TebalTotal_Asli); valuesList.Add(m.TebalTotal_Max);
                valuesList.Add(m.TebalInnerMiddle_Min); valuesList.Add(m.TebalInnerMiddle_Asli); valuesList.Add(m.TebalInnerMiddle_Max);
                
                // Output - AmMeter (3 fields)
                valuesList.Add(m.AmMeter_Min); valuesList.Add(m.AmMeter_Asli); valuesList.Add(m.AmMeter_Max);
                valuesList.Add(m.AmMeter2_Min); valuesList.Add(m.AmMeter2_Asli); valuesList.Add(m.AmMeter2_Max);
                valuesList.Add(m.AmMeter3_Min); valuesList.Add(m.AmMeter3_Asli); valuesList.Add(m.AmMeter3_Max);
                
                // Output - Control Values (2 fields)
                valuesList.Add(m.PresetValue_Min); valuesList.Add(m.PresetValue_Asli); valuesList.Add(m.PresetValue_Max);
                valuesList.Add(m.ControlValue_Min); valuesList.Add(m.ControlValue_Asli); valuesList.Add(m.ControlValue_Max);
                
                // Output - Spiral Pitch (2 fields)
                valuesList.Add(m.SpiralPitchSetting_Min); valuesList.Add(m.SpiralPitchSetting_Asli); valuesList.Add(m.SpiralPitchSetting_Max);
                valuesList.Add(m.SpiralPitchDisplay_Min); valuesList.Add(m.SpiralPitchDisplay_Asli); valuesList.Add(m.SpiralPitchDisplay_Max);
                
                // Output - Conveyor Speeds (3 fields)
                valuesList.Add(m.CoolConveyorSpeed_Min); valuesList.Add(m.CoolConveyorSpeed_Asli); valuesList.Add(m.CoolConveyorSpeed_Max);
                valuesList.Add(m.CoolConveyorSpeed2_Min); valuesList.Add(m.CoolConveyorSpeed2_Asli); valuesList.Add(m.CoolConveyorSpeed2_Max);
                valuesList.Add(m.ConveyorRatio_Min); valuesList.Add(m.ConveyorRatio_Asli); valuesList.Add(m.ConveyorRatio_Max);
                
                // Quality (6 fields)
                valuesList.Add(m.ToleranceInner_Min); valuesList.Add(m.ToleranceInner_Asli); valuesList.Add(m.ToleranceInner_Max);
                valuesList.Add(m.ToleranceOuter_Min); valuesList.Add(m.ToleranceOuter_Asli); valuesList.Add(m.ToleranceOuter_Max);
                valuesList.Add(m.SelisihTebal_Min); valuesList.Add(m.SelisihTebal_Asli); valuesList.Add(m.SelisihTebal_Max);
                valuesList.Add(m.DancerPosition_Min); valuesList.Add(m.DancerPosition_Asli); valuesList.Add(m.DancerPosition_Max);
                valuesList.Add(m.OdSensor_Min); valuesList.Add(m.OdSensor_Asli); valuesList.Add(m.OdSensor_Max);
                valuesList.Add(m.CuttingSpeed_Min); valuesList.Add(m.CuttingSpeed_Asli); valuesList.Add(m.CuttingSpeed_Max);
                #pragma warning restore CS8604

                var values = valuesList.ToArray();

                for (int col = 1; col <= values.Length; col++)
                {
                    var cell = ws.Cells[row, col];
                    cell.Value = values[col - 1];
                    cell.Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                    cell.Style.Fill.BackgroundColor.SetColor(bgColor);
                    cell.Style.Font.Color.SetColor(System.Drawing.Color.FromArgb(210, 210, 210));
                    cell.Style.Border.BorderAround(OfficeOpenXml.Style.ExcelBorderStyle.Hair, System.Drawing.Color.FromArgb(40, 55, 80));
                    cell.Style.VerticalAlignment = OfficeOpenXml.Style.ExcelVerticalAlignment.Center;
                }
                // Highlight Item List & Doc columns
                ws.Cells[row, 2].Style.Font.Color.SetColor(System.Drawing.Color.FromArgb(120, 180, 255));
                ws.Cells[row, 3].Style.Font.Bold = true;
                ws.Cells[row, 3].Style.Font.Color.SetColor(System.Drawing.Color.FromArgb(100, 220, 255));

                row++;
                no++;
            }

            // Column widths - 231 total columns
            ws.Column(1).Width = 5;   // No
            ws.Column(2).Width = 12;  // Excel ID
            ws.Column(3).Width = 8;   // No
            ws.Column(4).Width = 12;  // Machine
            ws.Column(5).Width = 12;  // Machine Code
            ws.Column(6).Width = 18;  // Doc Number
            ws.Column(7).Width = 10;  // Rev Number
            ws.Column(8).Width = 12;  // Rev Date
            ws.Column(9).Width = 16;  // Item List
            ws.Column(10).Width = 15; // Formulasi
            
            // Set remaining columns width 11 (for tolerance and other data)
            for (int c = 11; c <= headers.Length; c++) 
            {
                ws.Column(c).Width = 11;
            }
            ws.Row(4).Height = 24;

            var fileName = $"SPS_Master_{DateTime.Now:yyyyMMddHHmmss}.xlsx";
            return File(package.GetAsByteArray(),
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                fileName);
        }

        // GET: SpsMasters/DownloadTemplate
        public IActionResult DownloadTemplate(string type = "3L")
        {
            try
            {
                using (var package = new OfficeOpenXml.ExcelPackage())
                {
                    var worksheet = package.Workbook.Worksheets.Add("SPS Parameter Setting");
                    
                    bool is3Layer = (type == "3L");
                    bool is2Layer = (type == "2L");
                    bool isDoubleLayer = (type == "DL");
                    
                    // Determine column count and Item List position
                    int itemColIndex;
                    string titleText;
                    
                    if (is3Layer) {
                        itemColIndex = 108;
                        titleText = "PARAMETER SETTING CHS 3 LAYER DIGITALISASI";
                    } else if (is2Layer) {
                        itemColIndex = 90;
                        titleText = "PARAMETER SETTING CHS 2 LAYER DIGITALISASI";
                    } else { // Double Layer (Legacy/Non-CHS)
                        itemColIndex = 51;
                        titleText = "PARAMETER SETTING DOUBLE LAYER (NON-CHS)";
                    }
                    
                    // ROW 1: Title
                    worksheet.Cells[1, 2].Value = titleText;
                    worksheet.Cells[1, 2].Style.Font.Bold = true;
                    worksheet.Cells[1, 2].Style.Font.Size = 14;
                    
                    // ROW 2-5: Additional info (optional, can be left empty)
                    worksheet.Cells[2, 2].Value = "Velasto Production System";
                    
                    // ROW 6: Column Headers (Index Row)
                    // This helps users know which column is which during data entry
                    for (int i = 1; i <= itemColIndex; i++)
                    {
                        worksheet.Cells[6, i].Value = i.ToString();
                        worksheet.Cells[6, i].Style.Font.Bold = true;
                        worksheet.Cells[6, i].Style.Font.Size = 8;
                        worksheet.Cells[6, i].Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                        worksheet.Cells[6, i].Style.Fill.BackgroundColor.SetColor(255, 211, 211, 211); // LightGray ARGB
                    }
                    
                    // ROW 5: Header Labels (Detailed column names)
                    SetHeaderLabel(worksheet, 5, 1, "ID");
                    SetHeaderLabel(worksheet, 5, 2, "No");
                    SetHeaderLabel(worksheet, 5, 3, "Machine");
                    SetHeaderLabel(worksheet, 5, 4, "No. Doc");
                    SetHeaderLabel(worksheet, 5, 5, "");
                    SetHeaderLabel(worksheet, 5, 6, "");
                    SetHeaderLabel(worksheet, 5, 7, "No. Rev");
                    SetHeaderLabel(worksheet, 5, 8, "Customer");
