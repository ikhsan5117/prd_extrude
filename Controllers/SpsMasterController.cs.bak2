using Microsoft.AspNetCore.Mvc;
using Microsoft.EntityFrameworkCore;
using ExcelDataReader;
using System.Data;
using System.Text;
using System.Globalization;
using VelastoProductionSystem.Data;
using VelastoProductionSystem.Models;
using VelastoProductionSystem.Helpers;

namespace VelastoProductionSystem.Controllers
{
    public class SpsMasterController : Controller
    {
        private readonly ApplicationDbContext _context;
        private readonly ILogger<SpsMasterController> _logger;

        public SpsMasterController(ApplicationDbContext context, ILogger<SpsMasterController> logger)
        {
            _context = context;
            _logger = logger;
        }

        private async Task<List<SpsMaster>> GetSpsMastersAsync()
        {
            // FILTER: Hanya ambil data dengan DocumentNumber tidak kosong dan bukan "-"
            var nodocs = await _context.SpsNoDocs
                .Include(n => n.ItemLists)
                .Where(n => !string.IsNullOrWhiteSpace(n.DocumentNumber) && n.DocumentNumber != "-")
                .ToListAsync();
            
            var result = new List<SpsMaster>();
            foreach (var n in nodocs)
            {
                if (n.ItemLists != null && n.ItemLists.Any())
                {
                    foreach (var item in n.ItemLists)
                    {
                        result.Add(SpsMapper.ToSpsMaster(n, item.ItemList));
                    }
                }
                else
                {
                    result.Add(SpsMapper.ToSpsMaster(n, ""));
                }
            }
            return result;
        }

        private async Task<SpsMaster?> GetSpsMasterByIdAsync(int id)
        {
            var n = await _context.SpsNoDocs.Include(x => x.ItemLists).FirstOrDefaultAsync(x => x.Id == id);
            if (n == null) return null;
            var items = n.ItemLists != null ? string.Join(", ", n.ItemLists.Select(x => x.ItemList)) : "";
            return SpsMapper.ToSpsMaster(n, items);
        }

        public async Task<IActionResult> Index()
        {
            // Ambil semua data SPS dari SpsNoDoc (JOIN SpsItemLists)
            var data = await GetSpsMastersAsync();

            // Ambil daftar mesin yang benar-benar ada di data SPS untuk dropdown filter
            var machinesInData = data
                .Select(m => m.Machine)
                .Where(m => !string.IsNullOrEmpty(m))
                .Distinct()
                .OrderBy(m => m)
                .ToList();

            // Juga tambahkan MachineCode jika Machine-nya kosong tapi MC ada
            var codesInData = data
                .Where(m => string.IsNullOrEmpty(m.Machine) && !string.IsNullOrEmpty(m.MachineCode))
                .Select(m => m.MachineCode)
                .Distinct()
                .ToList();

            ViewBag.AuthorizedMachines = machinesInData.Concat(codesInData).Distinct().OrderBy(x => x).ToList();
            
            // Tambahkan daftar untuk autocomplete (hilangkan dash sesuai request)
            ViewBag.ItemList = data.Select(m => m.ItemList != null ? m.ItemList.Replace("-", "") : null)
                .Where(i => !string.IsNullOrEmpty(i))
                .Distinct()
                .OrderBy(i => i)
                .ToList();
            ViewBag.DocList = data.Select(m => m.DocumentNumber).Where(d => !string.IsNullOrEmpty(d)).Distinct().OrderBy(d => d).ToList();

            return View(data);
        }

        public async Task<IActionResult> Details(int? id)
        {
            if (id == null) return NotFound();

            var item = await GetSpsMasterByIdAsync(id.Value);
            
            if (item == null) return NotFound();

            return View(item);
        }

        // GET: SpsMasters/Create
        public IActionResult Create()
        {
            return View();
        }

        // POST: SpsMasters/Create
        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> Create(SpsMaster item)
        {
            if (ModelState.IsValid)
            {
                var noDoc = SpsMapper.ToSpsNoDoc(item);
                _context.Add(noDoc);
                await _context.SaveChangesAsync(); // Save to get Id

                if (!string.IsNullOrEmpty(item.ItemList))
                {
                    var items = item.ItemList.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(i => i.Trim()).Distinct();
                    foreach (var i in items)
                    {
                        _context.SpsItemLists.Add(new SpsItemList { SpsNoDocId = noDoc.Id, ItemList = i });
                    }
                    await _context.SaveChangesAsync();
                }

                TempData["SuccessMessage"] = "Data SPS berhasil ditambahkan!";
                return RedirectToAction(nameof(Index));
            }
            return View(item);
        }

        // GET: SpsMasters/BulkEditByDoc?docNo=xxx
        public async Task<IActionResult> BulkEditByDoc(string docNo)
        {
            if (string.IsNullOrEmpty(docNo)) return NotFound();
            // Ambil data dari SpsNoDocs
            var noDoc = await _context.SpsNoDocs.FirstOrDefaultAsync(m => m.DocumentNumber == docNo);
            if (noDoc == null) return NotFound();
            var item = SpsMapper.ToSpsMaster(noDoc, "");
            ViewBag.DocNo = docNo;
            ViewBag.ItemCount = 1;
            return View("BulkEditByDoc", item);
        }

        // POST: SpsMasters/BulkEditByDoc
        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> BulkEditByDoc(string docNo, SpsMaster model)
        {
            if (string.IsNullOrEmpty(docNo)) return NotFound();

            if (!ModelState.IsValid)
            {
                ViewBag.DocNo = docNo;
                ViewBag.ItemCount = 1;
                return View("BulkEditByDoc", model);
            }

            var noDoc = await _context.SpsNoDocs.FirstOrDefaultAsync(m => m.DocumentNumber == docNo);
            if (noDoc == null) return NotFound();

            noDoc.Machine = model.Machine;
            noDoc.MachineCode = model.MachineCode;
            noDoc.RevisionNumber = model.RevisionNumber;
            noDoc.RevisionDate = model.RevisionDate;
            noDoc.Customer = model.Customer;
            noDoc.Formulasi = model.Formulasi;
            noDoc.HoseType = model.HoseType;
            noDoc.Dimensi = model.Dimensi;
            noDoc.Material = model.Material;

            await _context.SaveChangesAsync();
            TempData["SuccessMessage"] = $"✅ Update berhasil! Dokumen '{docNo}' telah diperbarui.";
            return RedirectToAction("Index");
        }

        // GET: SpsMasters/Edit/5
        public async Task<IActionResult> Edit(int? id)
        {
            if (id == null) return NotFound();

            var noDoc = await _context.SpsNoDocs
                .Include(x => x.ItemLists)
                .FirstOrDefaultAsync(x => x.Id == id);
            if (noDoc == null) return NotFound();
            
            var item = await GetSpsMasterByIdAsync(id.Value);
            if (item == null) return NotFound();

            // Hitung jumlah items lain yang akan terpengaruh oleh sync
            // Hitung berdasarkan SEMUA SpsNoDocs (dan ItemLists-nya) yang punya NO.DOC + Machine + Formulasi sama
            int syncCount = 0;
            if (!string.IsNullOrEmpty(noDoc.DocumentNumber))
            {
                // Ambil semua SpsNoDocs dengan NO.DOC + Machine + Formulasi yang sama
                var relatedNoDocs = await _context.SpsNoDocs
                    .Include(n => n.ItemLists)
                    .Where(n => n.DocumentNumber == noDoc.DocumentNumber 
                             && n.Machine == noDoc.Machine 
                             && n.Formulasi == noDoc.Formulasi)
                    .ToListAsync();
                
                // Hitung total items (ItemLists) dari semua SpsNoDocs tersebut
                int totalItems = relatedNoDocs.Sum(n => n.ItemLists?.Count ?? 0);
                
                // Exclude current item (1 item)
                syncCount = totalItems - 1;
                if (syncCount < 0) syncCount = 0;
            }
            ViewBag.SyncItemCount = syncCount;
            
            return View(item);
        }

        // POST: SpsMasters/Edit/5
        [HttpPost]
        [ValidateAntiForgeryToken]
