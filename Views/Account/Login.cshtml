@{
    Layout = null; // Separate layout for login
}

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Velasto Production System</title>
    <link rel="stylesheet" href="~/lib/offline-cdn/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/offline-cdn/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/lib/offline-cdn/sweetalert2.min.css" />
    <link href="~/lib/offline-cdn/plus-jakarta-sans.css" rel="stylesheet">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#020b13">
    <style>
        :root {
            --bg-accent: #064052;
            --bg-deep: #020b13;
            --accent-cyan: #00d2fe;
            --text-dim: #94a3b8;
        }

        body, html {
            height: 100%;
            margin: 0;
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #01060a;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        /* --- CENTERED CARD --- */
        .login-card {
            display: flex;
            width: 860px;
            max-width: 95%;
            min-height: 520px;
            background: linear-gradient(135deg, #132f4c 0%, #051424 50%, #010810 100%);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 40px 100px rgba(0,0,0,0.8);
            border: 1px solid rgba(255,255,255,0.08);
            position: relative;
        }

        /* --- LEFT PANEL --- */
        .left-panel {
            width: 45%;
            background: linear-gradient(145deg, #021a2c 0%, #015d86 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: relative;
            padding: 40px;
            color: #fff;
            text-align: center;
            border-right: 1px solid rgba(255,255,255,0.05);
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .logo-container {
            background: #fff;
            padding: 10px 22px;
            border-radius: 10px;
            margin-bottom: 10px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.4);
            z-index: 2;
        }

        .logo-container img { height: 30px; }

        .left-panel h1 {
            font-size: 1.6rem;
            font-weight: 800;
            letter-spacing: 2px;
            margin-bottom: 5px;
            text-transform: uppercase;
            z-index: 2;
        }

        .left-panel p {
            font-size: 0.75rem;
            opacity: 0.6;
            margin-bottom: 10px;
            z-index: 2;
        }

        .pill-container {
            display: flex;
            gap: 10px;
            z-index: 2;
            flex-wrap: wrap;
            justify-content: center;
        }

        .badge-pill {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 5px 15px;
            border-radius: 50px;
            font-size: 0.7rem;
            font-weight: 600;
        }

        /* --- RIGHT PANEL --- */
        .right-panel {
            flex: 1;
            padding: 35px 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: radial-gradient(circle at top right, rgba(0, 210, 254, 0.08) 0%, transparent 60%);
        }

        .welcome-text {
            font-size: 0.75rem;
            color: var(--accent-cyan);
            letter-spacing: 2.5px;
            text-transform: uppercase;
            font-weight: 800;
            margin-bottom: 5px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .main-heading {
            font-size: 1.6rem;
            font-weight: 800;
            color: #fff;
            margin-bottom: 5px;
        }

        .sub-heading {
            font-size: 0.85rem;
            color: var(--text-dim);
            margin-bottom: 15px;
        }

        .form-label {
            color: var(--text-dim);
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            margin-bottom: 6px;
        }

        .input-wrapper {
            position: relative;
            margin-bottom: 12px;
        }

        .input-icon {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--accent-cyan);
            font-size: 1.1rem;
            z-index: 10;
            pointer-events: none;
        }

        .form-control, .form-select {
            background-color: rgba(11, 26, 41, 0.7) !important;
            background-repeat: no-repeat !important;
            border: 1.5px solid rgba(255,255,255,0.1) !important;
            height: 52px;
            border-radius: 10px;
            padding-left: 48px !important;
            color: #fff !important;
            font-size: 0.85rem;
            transition: all 0.3s;
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--accent-cyan) !important;
            background-color: #122a3d !important;
            box-shadow: 0 0 20px rgba(0, 210, 254, 0.2) !important;
        }

        .form-control::placeholder { color: rgba(255, 255, 255, 0.4) !important; }

        /* Fix Select Arrow */
        .form-select {
            appearance: none;
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%2300d2fe' stroke-linecap='round' stroke-linejoin='round' stroke-width='2.5' d='m2 5 6 6 6-6'/%3e%3c/svg%3e") !important;
            background-repeat: no-repeat !important;
            background-position: right 15px center !important;
            background-size: 14px 10px !important;
        }

        .form-select option { background-color: #020b13; color: #fff; }

        .pw-toggle {
            position: absolute;
            right: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-dim);
            cursor: pointer;
            font-size: 1.1rem;
            z-index: 10;
        }

        .form-check-input {
            background-color: rgba(255,255,255,0.1) !important;
            border: 1px solid rgba(255,255,255,0.2) !important;
            width: 1.1rem;
            height: 1.1rem;
            margin-top: 0.15rem;
            cursor: pointer;
        }

        .form-check-input:checked {
            background-color: var(--accent-cyan) !important;
            border-color: var(--accent-cyan) !important;
        }

        .btn-submit {
            background: var(--accent-cyan);
            border: none;
            height: 54px;
            border-radius: 12px;
            color: #020b13;
            font-weight: 800;
            font-size: 1.1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            width: 100%;
            transition: 0.3s;
            text-transform: uppercase;
            box-shadow: 0 4px 15px rgba(0, 210, 254, 0.2);
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            background: #fff;
            box-shadow: 0 8px 30px rgba(0, 210, 254, 0.4);
        }

        .footer-links {
            margin-top: 25px;
            text-align: center;
        }

        .footer-links a {
            color: var(--text-dim);
            text-decoration: none;
            font-size: 0.8rem;
            margin: 0 15px;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: 0.3s;
        }

        .footer-links a:hover { color: var(--accent-cyan); }

        .error-msg {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444; padding: 12px 15px; border-radius: 10px; margin-bottom: 20px; font-size: 0.85rem;
            border-left: 4px solid #ef4444;
            backdrop-filter: blur(5px);
        }

        /* --- ANIMATIONS DISABLED FOR PERFORMANCE --- */

        .role-btn:hover {
            background: rgba(0, 210, 254, 0.1) !important;
            border-color: var(--accent-cyan) !important;
            transform: translateX(5px);
        }

        .role-btn:active {
            transform: scale(0.98);
        }

        /* --- TABLET & DESKTOP (Side-by-Side) --- */
        @@media screen and (min-width: 992px) {
            .login-card { width: 860px; }
        }

        /* --- TABLET PORTRAIT (600px - 991px) --- */
        @@media screen and (min-width: 600px) and (max-width: 991px) {
            body { padding: 40px 20px !important; height: auto !important; overflow-y: auto !important; }
            .login-card { 
                width: 550px !important; 
                flex-direction: column !important;
                margin: 20px auto !important;
            }
            .left-panel {
                width: 100% !important;
                padding: 50px 40px !important;
                border-right: none !important;
                border-bottom: 1px solid rgba(255,255,255,0.05) !important;
            }
            .right-panel {
                width: 100% !important;
                padding: 45px 50px !important;
            }
            .left-panel h1 { font-size: 2rem; }
            .main-heading { font-size: 1.8rem; }
        }

        /* --- MOBILE (below 600px) --- */
        @@media screen and (max-width: 599px) {
            body { padding: 15px !important; height: auto !important; overflow-y: auto !important; align-items: flex-start !important; }
            .login-card { 
                width: 100% !important; 
                max-width: 100% !important;
                flex-direction: column !important;
                border-radius: 20px !important;
            }
            .left-panel, .right-panel { 
                width: 100% !important; 
                padding: 35px 20px !important;
            }
            .left-panel { border-bottom: 1px solid rgba(255,255,255,0.05) !important; border-right: none !important; }
            .main-heading { font-size: 1.6rem; }
            .logo-container img { height: 28px; }
            .badge-pill { padding: 4px 10px; font-size: 0.65rem; }
        }
    </style>
</head>
<body>

<!-- 3D SHARDS BACKGROUND - DISABLED FOR PERFORMANCE -->

<div class="login-card">
    <div class="left-panel">
        <div class="logo-container">
            <img src="~/images/velasto-logo-e1700056160273.png" alt="Velasto Logo">
        </div>
        <h1>EXTRUDE SYSTEM</h1>
        <p>Production Monitoring Platform</p>
        <div class="pill-container">
            <div class="badge-pill">Aman</div>
            <div class="badge-pill">Multi-Role</div>
            <div class="badge-pill">Analitik</div>
        </div>
    </div>

    <div class="right-panel">
        <div class="right-panel-header">
            <div class="welcome-text">
                <i class="bi bi-shield-check"></i> SELAMAT DATANG
            </div>
            <h2 class="main-heading">Login Operator</h2>
            <p class="sub-heading">Masukkan kredensial Anda untuk melanjutkan</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="error-msg">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-exclamation-circle-fill"></i>
                        <span>@error.ErrorMessage</span>
                    </div>
                }
            </div>
        }

        <form asp-action="Login" method="post" id="loginForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="adminUsername" id="adminUsername" value="" />

            <div id="operatorFields">
                <label class="form-label">USERNAME</label>
                <div class="input-wrapper">
                    <i class="bi bi-person input-icon"></i>
                    <select name="userId" id="userId" class="form-select">
                        <option value="" disabled selected>Pilih User...</option>
                        @foreach (var user in ViewBag.Users)
                        {
                            <option value="@user.Id">@user.FullName (@user.NPK)</option>
                        }
                    </select>
                </div>
            </div>

            <div id="adminFields" style="display:none;">
                <label class="form-label">ADMIN USERNAME</label>
                <div class="input-wrapper">
                    <i class="bi bi-shield-lock input-icon"></i>
                    <input type="text" id="adminUsernameInput" class="form-control" placeholder="Masukkan username admin" autocomplete="off" />
                </div>
            </div>

            <label class="form-label">MESIN PRODUKSI</label>
            <div class="input-wrapper">
                <i class="bi bi-gear input-icon"></i>
                <select name="machineId" id="machineId" class="form-select">
                    <option value="" disabled selected>Pilih Mesin...</option>
                    @foreach (var m in ViewBag.Machines)
                    {
                        <option value="@m.Id">@m.KodeMesin - @m.NamaMesin</option>
                    }
                </select>
            </div>

            <label class="form-label">PASSWORD</label>
            <div class="input-wrapper">
                <i class="bi bi-lock input-icon"></i>
                <input type="password" name="password" id="password" class="form-control" placeholder="Masukkan password" required />
                <i class="bi bi-eye-slash pw-toggle" id="togglePassword"></i>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="rememberMe" checked>
                    <label class="form-check-label ms-2" for="rememberMe" style="color: var(--text-dim); font-size: 0.8rem; cursor: pointer;">Ingat Saya</label>
                </div>
                <a href="#" id="adminToggle" style="color: var(--text-dim); font-size: 0.8rem; text-decoration: none; transition: 0.3s;">
                    <i class="bi bi-person-badge"></i> Login Admin
                </a>
            </div>

            <button type="submit" class="btn-submit">
                <i class="bi bi-box-arrow-in-right"></i> MASUK
            </button>
        </form>

        <div id="credentialsGuide" style="margin-top: 25px; display: none;">
            <div style="display: flex; flex-direction: column; gap: 8px;">
                <div onclick="fillAdminCredentials('adm_prod', 'produksi123!')" style="display: flex; justify-content: space-between; align-items: center; padding: 6px 20px; background: rgba(255,255,255,0.03); border-radius: 8px; border: 1px solid rgba(255,255,255,0.05); cursor: pointer; transition: all 0.2s;" onmouseover="this.style.background='rgba(0,210,254,0.08)'; this.style.borderColor='rgba(0,210,254,0.3)';" onmouseout="this.style.background='rgba(255,255,255,0.03)'; this.style.borderColor='rgba(255,255,255,0.05)';">
                    <span style="font-size: 0.75rem; color: var(--text-dim); font-weight: 600;">Admin Prod</span>
                    <div style="display: flex; gap: 20px; font-family: monospace; font-size: 0.8rem;">
                        <span style="color: var(--accent-cyan);">adm_prod</span>
                        <span style="color: #fff; opacity: 0.5;">produksi123!</span>
                    </div>
                </div>
                <div onclick="fillAdminCredentials('adm_eng', 'engineering123!')" style="display: flex; justify-content: space-between; align-items: center; padding: 6px 20px; background: rgba(255,255,255,0.03); border-radius: 8px; border: 1px solid rgba(255,255,255,0.05); cursor: pointer; transition: all 0.2s;" onmouseover="this.style.background='rgba(0,210,254,0.08)'; this.style.borderColor='rgba(0,210,254,0.3)';" onmouseout="this.style.background='rgba(255,255,255,0.03)'; this.style.borderColor='rgba(255,255,255,0.05)';">
                    <span style="font-size: 0.75rem; color: var(--text-dim); font-weight: 600;">Admin Eng</span>
                    <div style="display: flex; gap: 20px; font-family: monospace; font-size: 0.8rem;">
                        <span style="color: var(--accent-cyan);">adm_eng</span>
                        <span style="color: #fff; opacity: 0.5;">engineering123!</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="footer-links">
            <a href="#"><i class="bi bi-headset"></i> Support</a>
            <a href="/"><i class="bi bi-house"></i> Home</a>
        </div>
    </div>
</div>

<script src="~/lib/offline-cdn/jquery-3.6.0.min.js"></script>
<script src="~/lib/offline-cdn/sweetalert2.all.min.js"></script>
<script src="~/lib/offline-cdn/dexie.min.js"></script>

<script>
    // Inisialisasi Dexie — HARUS sama dengan VelastoOfflineDB di offline-sync.js
    const db = new Dexie('VelastoOfflineDB');
    db.version(2).stores({
        syncQueue: '++id, url, timestamp, retryCount',
        apiCache: 'key, timestamp'
    });

    $(document).ready(function() {
        const defaultPassword = "extrude123!";
        let isAdminMode = false;

        // Cek jika OFFLINE atau DB server tidak terjangkau
        const isDbOffline = @(ViewBag.DbOffline == true ? "true" : "false");
        const needLoadFromCache = !navigator.onLine || isDbOffline;

        if (needLoadFromCache) {
            const msg = isDbOffline
                ? 'Server database tidak terjangkau. Memuat data dari cache lokal...'
                : 'Mencoba memuat data pengguna dari Cache Lokal...';

            Swal.fire({
                title: '⚡ Mode Offline',
                text: msg,
                icon: 'info',
                timer: 2000,
                showConfirmButton: false
            });

            // Load dropdown data dari VelastoOfflineDB
            db.apiCache.get('LOGIN_DATA').then(data => {
                if (data && data.data) {
                    const users = data.data.users;
                    const machines = data.data.machines;

                    let userHtml = '<option value="">-- Pilih Operator --</option>';
                    users.forEach(u => {
                        userHtml += `<option value="${u.id}">${u.fullName}</option>`;
                    });
                    $('#userId').html(userHtml);

                    let machineHtml = '<option value="">-- Pilih Mesin --</option>';
                    machines.forEach(m => {
                        machineHtml += `<option value="${m.id}">${m.kodeMesin} - ${m.namaMesin}</option>`;
                    });
                    $('#machineId').html(machineHtml);
                } else {
                    Swal.fire(
                        'Cache Tidak Ditemukan',
                        'Belum ada data yang tersinkron di perangkat ini. Hubungkan ke jaringan lalu lakukan Sync Master Data terlebih dahulu.',
                        'warning'
                    );
                }
            }).catch(e => console.error('[Offline Login] Error membaca IndexedDB:', e));
        }

        // Toggle Admin Mode
        $('#adminToggle').on('click', function(e) {
            e.preventDefault();
            isAdminMode = !isAdminMode;
            if (isAdminMode) {
                $('.main-heading').text('Login Admin');
                $('#operatorFields').hide();
                $('#adminFields').show();
                // Hide Machine selection for Admin
                $('#machineId').closest('.input-wrapper').hide();
                $('label[for="machineId"], label:contains("MESIN PRODUKSI")').hide();
                
                $('#userId').removeAttr('required');
                $('#machineId').removeAttr('required');
                $('#password').val('');
                $('#adminUsernameInput').val('');
                $('#credentialsGuide').fadeIn();
                $(this).html('<i class="bi bi-person"></i> Login Operator').css('color', 'var(--accent-cyan)');
                $('#adminUsernameInput').focus();
            } else {
                $('.main-heading').text('Login Operator');
                $('#operatorFields').show();
                $('#adminFields').hide();
                // Show Machine selection for Operator
                $('#machineId').closest('.input-wrapper').show();
                $('label:contains("MESIN PRODUKSI")').show();
                
                $('#userId').attr('required', 'required');
                $('#machineId').attr('required', 'required');
                $('#password').val('');
                $('#adminUsernameInput').val('');
                $('#adminUsername').val('');
                $('#credentialsGuide').hide();
                $(this).html('<i class="bi bi-person-badge"></i> Login Admin').css('color', '');
            }
        });

        // On form submit, handle online/offline intelligently
        $('#loginForm').on('submit', async function(e) {
            e.preventDefault(); // ALWAYS stop normal POST to handle it via AJAX/Offline

            if (isAdminMode) {
                $('#adminUsername').val($('#adminUsernameInput').val());
            }

            const pw = $('#password').val();
            let isServerReachable = false;
            
            // Coba ping server untuk cek apakah benar-benar online
            try {
                const ping = await fetch('/Account/Login', { method: 'HEAD', cache: 'no-store', headers: { 'Cache-Control': 'no-cache' }});
                if (ping.ok || ping.redirected || ping.status === 405) {
                    isServerReachable = true;
                }
            } catch (err) {
                isServerReachable = false;
            }

            // Jika server reachable, submit form secara normal (DOM submit)
            if (isServerReachable) {
                this.submit();
                return;
            }

            // Jika server tidak reachable (OFFLINE)
            let userRole = "OPERATOR";
            let displayName = "";
            let machineName = "";

            if (isAdminMode) {
                const lowerAdmin = $('#adminUsernameInput').val().toLowerCase();
                if (lowerAdmin === "admin" && pw === "admin123!") { userRole = "SUPERADMIN"; displayName = "Super Admin"; machineName = "ADMIN"; }
                else if (lowerAdmin === "adm_prod" && pw === "produksi123!") { userRole = "ADMIN_PROD"; displayName = "Admin Produksi"; machineName = "ADMIN"; }
                else if (lowerAdmin === "adm_eng" && pw === "engineering123!") { userRole = "ADMIN_ENG"; displayName = "Admin Engineering"; machineName = "ADMIN"; }
                else if (lowerAdmin === "eng_temp" && pw === "engtemp123!") { userRole = "ENGINEERING"; displayName = "Engineering Temporary"; machineName = "ENG"; }
                else {
                    Swal.fire('Login Gagal', 'Password Admin salah atau user tidak valid!', 'error');
                    return;
                }
            } else {
                if (pw !== "extrude123!") {
                    Swal.fire('Login Gagal', 'Password Operator salah!', 'error');
                    return;
                }
                const userId = $('#userId').val();
                const machId = $('#machineId').val();
                if (!userId || !machId) {
                    Swal.fire('Perhatian', 'Pilih User dan Mesin terlebih dahulu.', 'warning');
                    return;
                }
                displayName = $('#userId option:selected').text();
                machineName = $('#machineId option:selected').text().split(' - ')[0]; // Ambil kode mesin
                if (displayName.toUpperCase().includes('TRIAL')) {
                    userRole = "ENGINEERING";
                }
            }

            // SIMPAN SESSION KE LOCAL STORAGE
            const sessionData = {
                userName: displayName,
                userRole: userRole,
                isAdmin: userRole.includes('ADMIN') ? "true" : "false",
                machineName: machineName,
                loginTime: new Date().getTime()
            };
            localStorage.setItem('offline_session', JSON.stringify(sessionData));

            Swal.fire({
                title: 'Login Offline Berhasil',
                text: `Selamat datang, ${displayName}!`,
                icon: 'success',
                timer: 1500,
                showConfirmButton: false
            }).then(() => {
                // Redirect ke halaman yang bisa diakses offline
                if (userRole === 'SUPERADMIN' || userRole === 'ADMIN_PROD' || userRole === 'ADMIN_ENG') {
                    window.location.href = '/Dimensi/App';
                } else {
                    window.location.href = '/Dimensi/App';
                }
            });
        });

        // Fitur 1: Auto-Fill Password saat User Dipilih (Operator mode)
        $('#userId').on('change', function() {
            if ($(this).val() && !isAdminMode) {
                $('#password').val(defaultPassword);
                $('#password').css('border-color', 'var(--accent-cyan)');
                setTimeout(() => {
                    $('#password').css('border-color', '');
                }, 500);
                $('#password').focus();
            }
        });

        // Fitur 2: Toggle Password View
        $('#togglePassword').on('click', function() {
            const pwField = $('#password');
            const icon = $(this);
            if (pwField.attr('type') === 'password') {
                pwField.attr('type', 'text');
                icon.removeClass('bi-eye-slash').addClass('bi-eye');
            } else {
                pwField.attr('type', 'password');
                icon.removeClass('bi-eye').addClass('bi-eye-slash');
            }
        });

        // Fitur 3: Enter key support for quick login
        $('#password').on('keypress', function(e) {
            if (e.which === 13) {
                $('#loginForm').submit();
            }
        });
        // Fitur 4: Click-to-Fill credential cards
        window.fillAdminCredentials = function(username, password) {
            $('#adminUsernameInput').val(username).trigger('input');
            $('#password').val(password);

            // Visual feedback - flash cyan border
            $('#adminUsernameInput, #password').css('border-color', 'var(--accent-cyan)');
            setTimeout(() => {
                $('#adminUsernameInput, #password').css('border-color', '');
            }, 600);
        };
    });

</script>

<script>
    if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
            navigator.serviceWorker.register('/sw.js')
                .then(reg => console.log('[SW] Registered on Login:', reg.scope))
                .catch(err => console.warn('[SW] Registration failed on Login:', err));
        });
    }
</script>

</body>
</html>
