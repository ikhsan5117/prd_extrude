@model IEnumerable<VelastoProductionSystem.Models.DailyPlanExecution>

@{
    ViewData["Title"] = "Daily Execution Records";
}

<style>
    .table-container {
        max-height: 75vh; overflow-y: auto; overflow-x: auto;
        border-radius: 15px; background: rgba(25, 30, 40, 0.4);
        backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.05);
    }
</style>

<div class="row fade-in">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="text-white fw-bold mb-1"><i class="bi bi-ui-checks-grid text-primary me-2"></i> Extrude Plan Execution History</h2>
                <p class="text-white-50 small mb-0">Riwayat Pengisian Form Aktual Produksi Harian</p>
            </div>
            <a asp-action="Start" class="btn btn-primary d-flex align-items-center gap-2 px-4 shadow-primary">
                <i class="bi bi-plus-circle-fill"></i>
                <span>Tarik Planning Baru</span>
            </a>
        </div>

        <div class="table-container shadow-lg">
            <table class="table table-dark table-hover mb-0 align-middle">
                <thead>
                    <tr style="background: rgba(15, 23, 42, 0.5);">
                        <th class="ps-4">Tanggal Kerja</th>
                        <th>Shift</th>
                        <th>Line / Machine</th>
                        <th>Group / Regu</th>
                        <th>PIC Kontrol</th>
                        <th>Line Stop (Mnt)</th>
                        <th class="text-center" style="width: 220px;">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    @if(!Model.Any()) {
                        <tr><td colspan="7" class="text-center text-white-50 py-5">Belum ada data execution form. <br> <a asp-action="Start" class="text-info mt-2 d-inline-block">Buat Laporan Pertama Anda</a></td></tr>
                    }
                    @foreach (var item in Model) {
                        <tr>
                            <td class="ps-4">
                                <div class="text-warning fw-bold">@item.ExecutionDate.ToString("dd MMM yyyy")</div>
                            </td>
                            <td><span class="badge bg-secondary">Shift @item.Shift</span></td>
                            <td><div class="text-info fw-bold">@item.MachineName</div></td>
                            <td><span class="text-white-50 small">@item.GroupName</span></td>
                            <td>
                                @if(!string.IsNullOrEmpty(item.Pic1)) {
                                    <div class="small">@item.Pic1 @(!string.IsNullOrEmpty(item.Pic2)? $", {item.Pic2}" : "")</div>
                                } else {
                                    <span class="text-white-50 italic small">Belum diisi</span>
                                }
                            </td>
                            <td class="text-danger fw-bold">@(item.LineStopMinutes ?? 0)</td>
                            <td class="text-center pe-4">
                                <div class="d-flex gap-2 justify-content-center">
                                    <a asp-action="Execution" asp-route-id="@item.Id" class="btn btn-info btn-sm rounded-pill px-3">
                                        <i class="bi bi-pencil-square me-1"></i> Buka Form
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirmAction(event)">
                                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                                            <i class="bi bi-trash3 me-1"></i> Hapus
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .shadow-primary { box-shadow: 0 4px 15px rgba(59, 130, 246, 0.4); }
    .table-container table thead th { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 1px; color: #94a3b8; font-weight: 800; border-bottom: 2px solid #1e293b; padding: 15px 10px; }
    .table-container table tbody td { padding: 15px 10px; border-bottom: 1px solid rgba(255, 255, 255, 0.03); }
</style>

<script>
    function confirmAction(e) {
        if (!confirm("Apakah Anda yakin ingin menghapus data laporan AKTUAL ini? Hal ini tidak dapat dibatalkan.")) {
            e.preventDefault();
            return false;
        }
        return true;
    }
</script>
