@model VelastoProductionSystem.Models.DailyPlanExecution

@{
    ViewData["Title"] = "Laporan Aktual Produksi";
}

<style>
    :root {
        --bg: #080c14;
        --card-bg: rgba(15, 23, 42, 0.7);
        --accent: #3b82f6;
        --accent-orange: #f59e0b;
        --success: #10b981;
        --danger: #ef4444;
        --border: rgba(255,255,255,0.07);
    }

    body { background: var(--bg); color: #e2e8f0; font-family: 'Inter', sans-serif; }

    /* ─── HEADER ─── */
    .exec-header {
        background: rgba(15,23,42,0.8);
        backdrop-filter: blur(20px);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 20px 28px;
        margin-bottom: 20px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.4);
    }
    .lbl-small { font-size: 0.65rem; color: #64748b; text-transform: uppercase; letter-spacing: 1.5px; font-weight: 700; display: block; margin-bottom: 4px; }
    .badge-shift { background: rgba(59,130,246,0.15); color: #60a5fa; border: 1px solid rgba(59,130,246,0.3); padding: 4px 12px; border-radius: 6px; font-size: 0.85rem; font-weight: 700; }
    .pic-input { background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.1); color: #fff; border-radius: 10px; padding: 9px 14px; font-size: 0.95rem; width: 100%; }
    .pic-input:focus { border-color: var(--accent); outline: none; }

    /* ─── SECTION TITLE ─── */
    .section-label {
        font-size: 0.7rem; font-weight: 900; letter-spacing: 3px; color: #64748b;
        text-transform: uppercase; padding: 6px 0 14px 2px;
        display: flex; align-items: center; gap: 10px;
    }
    .section-label::after { content:''; flex:1; height:1px; background: var(--border); }

    /* ─── ACTIVITY CARD ─── */
    .act-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 0;
        margin-bottom: 12px;
        overflow: hidden;
        transition: border-color 0.3s;
        backdrop-filter: blur(10px);
    }
    .act-card:hover { border-color: rgba(59,130,246,0.3); }
    .act-card.is-dandori { border-left: 4px solid var(--accent-orange); }
    .act-card.is-prod    { border-left: 4px solid var(--accent); }

    /* Card top bar */
    .card-topbar {
        display: flex; align-items: center; gap: 16px;
        padding: 14px 20px;
        background: rgba(0,0,0,0.2);
        border-bottom: 1px solid var(--border);
    }
    .card-num {
        width: 32px; height: 32px; border-radius: 8px;
        background: rgba(255,255,255,0.05);
        display: flex; align-items: center; justify-content: center;
        font-size: 12px; font-weight: 900; color: #64748b; flex-shrink: 0;
    }
    .card-vin-display {
        font-size: 1.2rem; font-weight: 900; color: #93c5fd; letter-spacing: 1px;
    }
    .card-vin-input {
        background: transparent; border: none; border-bottom: 2px solid rgba(96,165,250,0.3);
        color: #93c5fd; font-size: 1.2rem; font-weight: 900; letter-spacing: 1px;
        padding: 2px 4px; width: 160px; outline: none;
    }
    .card-vin-input:focus { border-bottom-color: #60a5fa; }
    .card-part { font-size: 0.8rem; color: #475569; margin-left: 4px; }
    .dandori-badge {
        background: rgba(245,158,11,0.1); color: #fbbf24;
        border: 1px solid rgba(245,158,11,0.3);
        border-radius: 6px; padding: 3px 12px; font-size: 10px; font-weight: 900; letter-spacing: 2px;
    }
    .btn-del-card {
        margin-left: auto; background: transparent; border: none; color: #374151;
        cursor: pointer; padding: 4px 8px; border-radius: 6px; transition: all 0.2s;
    }
    .btn-del-card:hover { background: rgba(239,68,68,0.1); color: #f87171; }

    /* Card body */
    .card-body-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr 1.4fr 1fr;
        gap: 0;
    }
    .card-cell {
        padding: 16px 20px;
        border-right: 1px solid var(--border);
        display: flex; flex-direction: column; gap: 6px;
    }
    .card-cell:last-child { border-right: none; }
    .cell-lbl { font-size: 8px; font-weight: 900; letter-spacing: 2px; text-transform: uppercase; color: #475569; }
    .cell-plan { font-size: 10px; color: #334155; margin-bottom: 4px; }

    /* Big Number Input */
    .big-input {
        background: rgba(0,0,0,0.3);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 10px;
        color: #fff;
        font-size: 1.6rem;
        font-weight: 900;
        text-align: center;
        padding: 10px 8px;
        width: 100%;
        outline: none;
        transition: all 0.2s;
    }
    .big-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(59,130,246,0.15); }
    .big-input.is-act { border-color: rgba(59,130,246,0.3); background: rgba(59,130,246,0.05); color: #60a5fa; }
    .big-input.is-dur-dan { border-color: rgba(245,158,11,0.3); color: #fbbf24; }

    /* Time pair */
    .time-pair { display: flex; align-items: center; gap: 6px; }
    .time-input {
        background: rgba(0,0,0,0.4);
        border: 1px solid var(--border);
        border-radius: 8px; color: #fff;
        font-size: 1rem; font-weight: 700;
        text-align: center; padding: 8px 6px;
        width: 80px; outline: none;
    }
    .time-input:focus { border-color: var(--accent); }
    .time-sep { color: #475569; font-size: 1rem; }

    /* Remarks input */
    .remarks-input {
        background: rgba(0,0,0,0.3); border: 1px solid var(--border);
        border-radius: 8px; color: #cbd5e1; font-size: 0.85rem;
        padding: 8px 12px; width: 100%; outline: none; resize: none;
        transition: border-color 0.2s;
    }
    .remarks-input:focus { border-color: var(--accent); }

    /* ─── ADD CARD BUTTON ─── */
    .btn-add-card {
        width: 100%; padding: 16px;
        background: rgba(59,130,246,0.04);
        border: 2px dashed rgba(59,130,246,0.2);
        border-radius: 16px; color: #3b82f6;
        font-size: 13px; font-weight: 700;
        cursor: pointer; transition: all 0.25s;
        display: flex; align-items: center; justify-content: center; gap: 10px;
        margin-bottom: 30px;
    }
    .btn-add-card:hover { background: rgba(59,130,246,0.1); border-color: rgba(59,130,246,0.5); }

    /* ─── EMPTY STATE ─── */
    .empty-state {
        text-align: center; padding: 60px 20px;
        background: var(--card-bg); border: 1px solid var(--border);
        border-radius: 20px; margin-bottom: 20px;
    }
    .empty-icon { font-size: 3rem; color: #1e293b; margin-bottom: 16px; }
    .empty-title { font-size: 16px; font-weight: 800; color: #334155; margin-bottom: 8px; }
    .empty-sub { font-size: 12px; color: #1e293b; margin-bottom: 24px; }

    /* ─── FOOTER SUMMARY ─── */
    .summary-grid {
        display: grid; grid-template-columns: repeat(4, 1fr);
        border-bottom: 1px solid var(--border);
    }
    .sum-tile {
        padding: 22px 20px; text-align: center;
        border-right: 1px solid var(--border);
    }
    .sum-tile:last-child { border-right: none; }
    .sum-lbl { font-size: 8px; font-weight: 900; letter-spacing: 2px; text-transform: uppercase; color: #475569; margin-bottom: 10px; }
    .sum-val { font-size: 2.2rem; font-weight: 900; color: #fff; line-height: 1; }

    .info-grid {
        display: grid; grid-template-columns: 1fr 1fr;
    }
    .info-pane { padding: 22px; border-right: 1px solid var(--border); }
    .info-pane:last-child { border-right: none; }

    .foot-input {
        background: rgba(0,0,0,0.4); border: 1px solid var(--border);
        color: #fff; border-radius: 10px; padding: 10px 14px;
        font-size: 1rem; width: 100%; outline: none;
    }
    .foot-input:focus { border-color: var(--accent); }
    .foot-textarea { height: 65px; resize: none; }

    .achieve-bar { height: 8px; background: rgba(255,255,255,0.05); border-radius: 4px; overflow: hidden; margin: 10px 0 18px 0; }
    .achieve-fill { height: 100%; background: var(--success); border-radius: 4px; transition: width 0.5s; }

    .stat-box {
        border-radius: 10px; padding: 14px 16px; text-align: center;
        border: 1px solid var(--border);
    }
    .stat-box.red { border-color: rgba(239,68,68,0.2); background: rgba(239,68,68,0.04); }

    .btn-save {
        background: linear-gradient(135deg, #10b981, #059669);
        border: none; color: white; padding: 20px;
        font-weight: 900; border-radius: 16px; width: 100%;
        font-size: 1rem; letter-spacing: 2px; text-transform: uppercase;
        box-shadow: 0 10px 25px rgba(16,185,129,0.4); transition: transform 0.2s;
        display: flex; flex-direction: column; align-items: center; gap: 8px;
    }
    .btn-save:active { transform: scale(0.98); }
    .btn-save i { font-size: 2.5rem; }

    /* Responsive */
    @@media (max-width: 900px) {
        .card-body-grid { grid-template-columns: 1fr 1fr; }
        .summary-grid { grid-template-columns: 1fr 1fr; }
        .info-grid { grid-template-columns: 1fr; }
        .info-pane { border-right: none; border-bottom: 1px solid var(--border); }
    }
</style>

<form asp-action="SaveExecution" method="post" id="execForm" class="px-3 pb-5">
    <input type="hidden" asp-for="Id" />

    <!-- ── HEADER ── -->
    <div class="exec-header d-flex justify-content-between align-items-center flex-wrap gap-4 mt-3">
        <div class="d-flex align-items-center gap-5">
            <div>
                <span class="lbl-small">Production Line</span>
                <div style="font-size: 1.8rem; font-weight: 900; color: #60a5fa;">@Model.MachineName</div>
            </div>
            <div>
                <span class="lbl-small">Current Date</span>
                <div style="font-size: 1.3rem; font-weight: 800;">@Model.ExecutionDate.ToString("dd MMMM yyyy")</div>
            </div>
            <div>
                <span class="lbl-small">Shift / Regu</span>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge-shift">SHIFT @Model.Shift</span>
                    <span style="font-size: 1.3rem; font-weight: 800; margin-left: 6px;">@Model.GroupName</span>
                </div>
            </div>
        </div>
        <div class="d-flex gap-3">
            <div style="width: 200px;">
                <span class="lbl-small">Operator PIC 1</span>
                <input type="text" asp-for="Pic1" class="pic-input" placeholder="Nama Lengkap" />
            </div>
            <div style="width: 200px;">
                <span class="lbl-small">Operator PIC 2</span>
                <input type="text" asp-for="Pic2" class="pic-input" placeholder="Nama Lengkap" />
            </div>
        </div>
    </div>

    <!-- ── ACTIVITY CARDS ── -->
    <div class="section-label"><i class="bi bi-grid-3x3-gap-fill"></i> AKTIVITAS PRODUKSI</div>

    <div id="cardContainer">
        @if(Model.Activities.Count == 0)
        {
            <div class="empty-state" id="emptyState">
                <div class="empty-icon"><i class="bi bi-inbox-fill"></i></div>
                <div class="empty-title">Belum Ada Aktivitas</div>
                <div class="empty-sub">Data planning untuk shift ini belum dimuat atau belum tersedia.</div>
                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <form asp-action="RegenerateActivities" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" style="background:rgba(59,130,246,0.15);border:1px solid rgba(59,130,246,0.4);color:#60a5fa;padding:12px 24px;border-radius:10px;font-weight:800;font-size:13px;cursor:pointer;">
                            <i class="bi bi-arrow-clockwise me-2"></i> Reload dari Planning Master
                        </button>
                    </form>
                    <button type="button" onclick="addCard()" style="background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#34d399;padding:12px 24px;border-radius:10px;font-weight:800;font-size:13px;cursor:pointer;">
                        <i class="bi bi-plus-circle me-2"></i> Tambah Manual
                    </button>
                </div>
            </div>
        }


        @for(int i = 0; i < Model.Activities.Count; i++)
        {
            var act = Model.Activities[i];
            var isDandori = act.PartName1?.ToUpper().Contains("DANDORI") == true;
            <div class="act-card @(isDandori ? "is-dandori" : "is-prod")" id="card-@i">
                <!-- Top Bar -->
                <div class="card-topbar">
                    <div class="card-num">@(i+1)</div>
                    @if(isDandori) {
                        <span class="dandori-badge">⚙ DANDORI</span>
                        <input type="hidden" name="activities[@i].PartName1" value="@act.PartName1" />
                    } else {
                        <input type="text" name="activities[@i].PartName1" value="@act.PartName1"
                               class="card-vin-input" placeholder="VIN Code..." />
                        <span class="card-part">@act.PartName2</span>
                    }
                    <input type="hidden" name="activities[@i].PartName2" value="@act.PartName2" />
                    <input type="hidden" name="activities[@i].Id" value="@act.Id" />
                    <button type="button" class="btn-del-card" onclick="removeCard(this)"><i class="bi bi-x-lg"></i></button>
                </div>
                <!-- Body -->
                <div class="card-body-grid">
                    <!-- QTY PLAN -->
                    <div class="card-cell">
                        <span class="cell-lbl">QTY Plan</span>
                        <input type="number" name="activities[@i].PlanQty" value="@act.PlanQty"
                               class="big-input plan-qty-input" placeholder="0" @(isDandori?"readonly":"") />
                    </div>
                    <!-- ACT PROD -->
                    <div class="card-cell">
                        <span class="cell-lbl" style="color:#60a5fa;">Actual Prod</span>
                        <input type="number" name="activities[@i].ActualQty" value="@act.ActualQty"
                               class="big-input is-act act-qty" placeholder="0" @(isDandori?"readonly":"") />
                    </div>
                    <!-- DURATION -->
                    <div class="card-cell">
                        <span class="cell-lbl" style="@(isDandori?"color:#fbbf24;":"")">Duration (menit)</span>
                        <span class="cell-plan">Plan: @act.PlanDurationMinutes m</span>
                        <input type="number" name="activities[@i].ActualDurationMinutes"
                               value="@act.ActualDurationMinutes"
                               class="big-input act-dur @(isDandori ? "is-dur-dan act-dand" : "")"
                               placeholder="0" />
                    </div>
                    <!-- ACTUAL TIME -->
                    <div class="card-cell">
                        <span class="cell-lbl">Jam Aktual</span>
                        <span class="cell-plan">Plan: @act.PlanStart – @act.PlanEnd</span>
                        <div class="time-pair">
                            <input type="text" name="activities[@i].ActualStart" value="@act.ActualStart"
                                   class="time-input" placeholder="07:30" />
                            <span class="time-sep">→</span>
                            <input type="text" name="activities[@i].ActualEnd" value="@act.ActualEnd"
                                   class="time-input" placeholder="08:30" />
                        </div>
                    </div>
                    <!-- REMARKS -->
                    <div class="card-cell">
                        <span class="cell-lbl">Catatan / Kendala</span>
                        <textarea name="activities[@i].Remarks" class="remarks-input"
                                  placeholder="Tulis kendala...">@act.Remarks</textarea>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Add Card Button -->
    <button type="button" class="btn-add-card" onclick="addCard()">
        <i class="bi bi-plus-circle" style="font-size:1.3rem;"></i>
        Tambah Kartu Aktivitas
    </button>

    <!-- ── FOOTER SUMMARY ── -->
    <div class="section-label"><i class="bi bi-bar-chart-line-fill"></i> RINGKASAN PRODUKSI</div>

    <div class="row g-4">
        <div class="col-md-9">
            <div style="background: #0a1020; border: 1px solid var(--border); border-radius: 20px; overflow: hidden;">
                <!-- Metric tiles -->
                <div class="summary-grid">
                    <div class="sum-tile" style="border-top: 3px solid #475569;">
                        <div class="sum-lbl">Plan Produksi</div>
                        <div class="sum-val" id="lblPlanProd">0</div>
                        <div style="font-size:10px;color:#334155;margin-top:6px;">TOTAL PCS</div>
                    </div>
                    <div class="sum-tile" style="border-top: 3px solid #3b82f6; background: rgba(59,130,246,0.03);">
                        <div class="sum-lbl" style="color:#60a5fa;">Actual Produksi</div>
                        <div class="sum-val" style="color:#60a5fa;" id="lblActProd">0</div>
                        <div style="font-size:10px;color:#1e3a5f;margin-top:6px;">TOTAL PCS</div>
                    </div>
                    <div class="sum-tile" style="border-top: 3px solid #475569;">
                        <div class="sum-lbl">Plan Dandori</div>
                        <div class="sum-val" id="lblPlanDandori">0</div>
                        <div style="font-size:10px;color:#334155;margin-top:6px;">TOTAL MENIT</div>
                    </div>
                    <div class="sum-tile" style="border-top: 3px solid #f59e0b; background: rgba(245,158,11,0.03);">
                        <div class="sum-lbl" style="color:#fbbf24;">Actual Dandori</div>
                        <div class="sum-val" style="color:#fbbf24;" id="lblActDandori">0</div>
                        <div style="font-size:10px;color:#451a03;margin-top:6px;">TOTAL MENIT</div>
                    </div>
                </div>
                <!-- Timing + Achievement -->
                <div class="info-grid">
                    <div class="info-pane">
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px;">
                            <div>
                                <label class="lbl-small">Start Mesin</label>
                                <input type="text" asp-for="StartMesin" class="foot-input" placeholder="16:30" />
                            </div>
                            <div>
                                <label class="lbl-small">Finish Mesin</label>
                                <input type="text" asp-for="FinishMesin" class="foot-input" placeholder="01:30" />
                            </div>
                        </div>
                        <label class="lbl-small text-danger">Line Stop Note</label>
                        <textarea asp-for="LineStopNote" class="foot-input foot-textarea" placeholder="Jelaskan kendala mesin..."></textarea>
                    </div>
                    <div class="info-pane">
                        <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:4px;">
                            <span style="font-size:13px;font-weight:700;color:#64748b;">Production Achievement</span>
                            <span id="lblAchieve" style="font-size:2rem;font-weight:900;color:#10b981;">0.0%</span>
                        </div>
                        <div class="achieve-bar">
                            <div class="achieve-fill" id="progressAchieve" style="width:0%"></div>
                        </div>
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                            <div class="stat-box red">
                                <div class="lbl-small text-danger">Total Line Stop</div>
                                <input type="number" asp-for="LineStopMinutes"
                                       style="background:transparent;border:none;color:#f87171;font-size:1.8rem;font-weight:900;text-align:center;width:100%;outline:none;"
                                       placeholder="0" />
                            </div>
                            <div class="stat-box">
                                <div class="lbl-small">Frekuensi Dandori</div>
                                <div id="lblFreq" style="font-size:1.8rem;font-weight:900;color:#fff;margin-top:4px;">0 / 0</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn-save h-100">
                <i class="bi bi-check-all"></i>
                SIMPAN LAPORAN
                <span style="font-size:0.7rem;font-weight:500;opacity:0.75;letter-spacing:1px;">Data disimpan ke riwayat produksi</span>
            </button>
        </div>
    </div>
</form>

@section Scripts {
<script>
$(document).ready(function() {
    function hitungTotal() {
        let planProd = 0, actProd = 0, planDandori = 0, actDandori = 0, freq = 0;

        $('.plan-qty-input').each(function() {
            let v = parseFloat($(this).val()); if(!isNaN(v)) planProd += v;
        });
        $('.act-qty').each(function() {
            let v = parseFloat($(this).val()); if(!isNaN(v)) actProd += v;
        });
        $('.act-dand').each(function() {
            freq++;
            let v = parseFloat($(this).val()); if(!isNaN(v)) actDandori += v;
        });
        // Plan dandori from labels
        $('.cell-plan').each(function() {
            let txt = $(this).text();
            if(txt.startsWith('Plan:')) {
                let v = parseFloat(txt.replace('Plan:','').replace('m','').replace('–','').split('–')[0].trim());
                // only for dandori cards: check parent card
                if($(this).closest('.act-card').hasClass('is-dandori')) {
                    if(!isNaN(v)) planDandori += v;
                }
            }
        });

        $('#lblPlanProd').text(planProd);
        $('#lblActProd').text(actProd);
        $('#lblPlanDandori').text(planDandori);
        $('#lblActDandori').text(actDandori);
        $('#lblFreq').text(freq + ' / ' + freq);

        let achieve = planProd > 0 ? (actProd / planProd) * 100 : 0;
        $('#lblAchieve').text(achieve.toFixed(1) + '%');
        $('#progressAchieve').css('width', Math.min(achieve, 100) + '%');

        let achieveEl = $('#lblAchieve');
        let barEl = $('#progressAchieve');
        if (achieve >= 100) {
            achieveEl.css('color', '#10b981'); barEl.css('background', '#10b981');
        } else if (achieve >= 80) {
            achieveEl.css('color', '#f59e0b'); barEl.css('background', '#f59e0b');
        } else {
            achieveEl.css('color', '#ef4444'); barEl.css('background', '#ef4444');
        }
    }

    $(document).on('input', '.act-qty, .act-dur, .plan-qty-input', hitungTotal);
    hitungTotal();
});

let cardIndex = @Model.Activities.Count;

function addCard() {
    document.getElementById('emptyState') && (document.getElementById('emptyState').style.display = 'none');
    const idx = cardIndex++;
    const num = document.querySelectorAll('.act-card').length + 1;

    const html = `
    <div class="act-card is-prod" id="card-manual-${idx}">
        <div class="card-topbar">
            <div class="card-num">${num}</div>
            <input type="text" name="activities[${idx}].PartName1"
                   class="card-vin-input" placeholder="VIN Code...">
            <input type="hidden" name="activities[${idx}].PartName2" value="">
            <input type="hidden" name="activities[${idx}].Id" value="0">
            <span class="card-part" style="color:#64748b;">Part Nomor</span>
            <button type="button" class="btn-del-card" onclick="removeCard(this)"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="card-body-grid">
            <div class="card-cell">
                <span class="cell-lbl">QTY Plan</span>
                <input type="number" name="activities[${idx}].PlanQty" class="big-input plan-qty-input" placeholder="0">
            </div>
            <div class="card-cell">
                <span class="cell-lbl" style="color:#60a5fa;">Actual Prod</span>
                <input type="number" name="activities[${idx}].ActualQty" class="big-input is-act act-qty" placeholder="0">
            </div>
            <div class="card-cell">
                <span class="cell-lbl">Duration (menit)</span>
                <input type="number" name="activities[${idx}].ActualDurationMinutes" class="big-input act-dur" placeholder="0">
            </div>
            <div class="card-cell">
                <span class="cell-lbl">Jam Aktual</span>
                <div class="time-pair">
                    <input type="text" name="activities[${idx}].ActualStart" class="time-input" placeholder="07:30">
                    <span class="time-sep">→</span>
                    <input type="text" name="activities[${idx}].ActualEnd" class="time-input" placeholder="08:30">
                </div>
            </div>
            <div class="card-cell">
                <span class="cell-lbl">Catatan / Kendala</span>
                <textarea name="activities[${idx}].Remarks" class="remarks-input" placeholder="Tulis kendala..."></textarea>
            </div>
        </div>
    </div>`;

    document.getElementById('cardContainer').insertAdjacentHTML('beforeend', html);
    updateCardNumbers();
}

function removeCard(btn) {
    btn.closest('.act-card').remove();
    updateCardNumbers();
}

function updateCardNumbers() {
    document.querySelectorAll('.act-card .card-num').forEach((el, i) => {
        el.textContent = i + 1;
    });
}
</script>
}
