@model VelastoProductionSystem.Models.DailyPlanExecution
@{
    ViewData["Title"] = "Laporan Aktual Produksi";
}

<style>
:root {
    --bg: #090c14;
    --surface: rgba(12,18,32,0.98);
    --surface2: rgba(20,30,55,0.85);
    --border: rgba(255,255,255,0.08);
    --accent: #4f6ef7;
    --accent-glow: rgba(79,110,247,0.4);
    --cyan: #00f2fe;
    --cyan-glow: rgba(0,242,254,0.4);
    --ok: #00e676;
    --ok-glow: rgba(0,230,118,0.4);
    --ng: #ff4d4d;
    --ng-glow: rgba(255,77,77,0.4);
    --warn: #ffaa00;
    --muted: #64748b;
    --glass: rgba(255,255,255,0.03);
}
body { 
    background: var(--bg); 
    color: #e2e8f0; 
    font-family:'Outfit', 'Segoe UI', sans-serif;
    background-image: 
        radial-gradient(circle at 0% 0%, rgba(79,110,247,0.1) 0%, transparent 40%),
        radial-gradient(circle at 100% 100%, rgba(0,230,118,0.06) 0%, transparent 40%);
    overflow-x: hidden;
}

/* HEADER PILLS */
.exec-header { 
    background: linear-gradient(180deg, rgba(10,20,38,0.9) 0%, rgba(5,10,20,0.95) 100%);
    backdrop-filter: blur(40px); 
    border-bottom: 1px solid var(--border); 
    padding: 24px 40px; 
    margin: -1rem -1rem 2rem;
    position: sticky;
    top: 0;
    z-index: 100;
}
.h-pill { 
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.05);
    padding: 12px 20px;
    border-radius: 18px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    transition: all 0.3s;
    box-shadow: inset 0 1px 5px rgba(255,255,255,0.02);
}
.h-pill:hover { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.1); }
.h-label { font-size: 0.65rem; font-weight: 800; letter-spacing: 2px; color: #94a3b8; text-transform: uppercase; display: flex; align-items: center; gap: 8px; }
.h-val   { font-size: 1.35rem; font-weight: 1000; color: #fff; letter-spacing: -0.5px; }
.h-val-sub { font-size: 0.9rem; font-weight: 900; color: #a855f7; margin-left: 6px; }
.i-cyan { color: var(--cyan); text-shadow: 0 0 10px var(--cyan-glow); }
.i-gold { color: #facc15; text-shadow: 0 0 10px rgba(250,204,21,0.4); }
.i-mag  { color: #d946ef; text-shadow: 0 0 10px rgba(217,70,239,0.4); }

.pic-input {
    background: transparent !important;
    border: none !important;
    color: #fff !important;
    font-weight: 700;
    font-size: 1.1rem;
    width: 100%;
    outline: none !important;
    padding: 0 !important;
    box-shadow: none !important;
    border-bottom: 1px dashed rgba(255,255,255,0.2) !important;
    padding-bottom: 4px !important;
    transition: all 0.3s;
}
.pic-input:focus { border-bottom-style: solid !important; border-color: var(--accent) !important; }
.pic-input::placeholder { color: rgba(255,255,255,0.15); font-weight: 500; font-size: 0.95rem; }

/* OVERVIEW BAR MOVED TO DASHBOARD */
.prog-track { width:100%; height:8px; background:rgba(255,255,255,0.03); border-radius:99px; overflow:hidden; border: 1px solid rgba(255,255,255,0.02); }
.prog-fill  { height:100%; border-radius:99px; background:linear-gradient(90deg, #4f6ef7, #9d7cfc); box-shadow:0 0 25px var(--accent-glow); transition:width .7s cubic-bezier(.4,0,.2,1); }

/* CARD REFINEMENT */
.act-card { 
    background: var(--surface); 
    border: 1px solid var(--border); 
    border-radius: 32px; 
    margin-bottom: 24px; 
    padding: 28px;
    position: relative;
    box-shadow: 0 15px 45px rgba(0,0,0,0.35);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.1);
}
.act-card:hover { 
    transform: translateY(-4px);
    border-color: rgba(79,110,247,0.3);
    box-shadow: 0 25px 70px rgba(79,110,247,0.15);
}
.card-hdr { display:flex; align-items:flex-start; gap:18px; margin-bottom:28px; }
.card-num { 
    width:42px; height:42px; border-radius:14px; 
    background:rgba(79,110,247,0.12); border:1px solid rgba(79,110,247,0.25); 
    display:flex; align-items:center; justify-content:center; 
    font-weight:1000; font-size:14px; color:var(--accent); 
}
.card-inner {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 32px;
}
.card-left { display: flex; flex-direction: column; }
.card-right { 
    display: flex; 
    flex-direction: column; 
    gap: 16px; 
    border-left: 1px dashed var(--border);
    padding-left: 32px;
}
.part-input {
    background: transparent !important;
    border: none !important;
    color: #fff !important;
    font-weight: 900;
    width: 100%;
    outline: none !important;
    border-bottom: 2px solid transparent !important;
    transition: all 0.3s;
    padding: 0 !important;
    box-shadow: none !important;
}
.part-input:focus { border-bottom: 2px solid var(--accent) !important; }
.quick-btn-row { display: flex; gap: 12px; }
.meta-tile {
    background: linear-gradient(145deg, rgba(20,30,55,0.4) 0%, rgba(10,15,25,0.6) 100%);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 20px;
    padding: 24px;
    box-shadow: inset 0 2px 15px rgba(0,0,0,0.4), 0 5px 15px rgba(0,0,0,0.2);
    position: relative;
    overflow: hidden;
}
.meta-tile::after {
    content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 2px;
    background: linear-gradient(90deg, transparent, var(--cyan), transparent);
    opacity: 0.3;
}
.meta-inp {
    background: transparent !important;
    border: none !important;
    color: #fff !important;
    font-weight: 900;
    width: 100px;
    outline: none !important;
    border-bottom: 1px solid rgba(255,255,255,0.2) !important;
    padding: 0 !important;
    box-shadow: none !important;
}
.meta-inp:focus { border-color: var(--accent) !important; }
.time-row { display: flex; align-items: center; gap: 12px; }
.btn-override-q {
    background: rgba(255,255,255,0.05);
    border: 1px dashed rgba(255,255,255,0.2);
    border-radius: 16px;
    color: var(--muted);
    font-weight: 800;
    transition: all 0.3s;
}
.btn-override-q:hover { color: #fff; background: rgba(255,255,255,0.1); }


/* OUTPUT REFINEMENT -> HUD METERS */
.hud-meters { display: flex; gap: 20px; align-items: stretch; margin-bottom: 24px; }
.lcd-meter {
    background: rgba(10,15,25, 0.6);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 20px;
    padding: 24px 30px;
    box-shadow: inset 0 2px 15px rgba(0,0,0,0.5);
    display: flex; flex-direction: column; justify-content: center;
    position: relative; overflow: hidden;
}
.lcd-meter.ok-meter { flex: 2; border-color: rgba(0,230,118, 0.15); border-left: 4px solid var(--ok); }
.lcd-meter.ng-meter { flex: 1; border-color: rgba(255,77,77, 0.15); border-right: 4px solid var(--ng); }

.lcd-label { font-size: 0.75rem; font-weight: 800; letter-spacing: 2px; color: var(--muted); padding-bottom: 8px; margin-bottom: 12px; }
.lcd-label.border-ok { border-bottom: 1px solid rgba(0,230,118,0.2); }
.lcd-label.border-ng { border-bottom: 1px solid rgba(255,77,77,0.2); }

.lcd-val { font-size: 6rem; font-weight: 1000; line-height: 0.95; letter-spacing: -3px; }
.lcd-val.ok-val { color: var(--ok); text-shadow: 0 0 45px var(--ok-glow); }
.lcd-val.ng-val { color: var(--ng); text-shadow: 0 0 30px var(--ng-glow); font-size: 4.5rem; }
.lcd-sub { font-size: 0.85rem; font-weight: 700; color: #64748b; }

/* PREMIUM TACTILE BUTTONS */
.btn-ok-q { 
    flex:1; padding:20px; 
    background: linear-gradient(180deg, rgba(0,230,118,0.2) 0%, rgba(0,230,118,0.05) 100%);
    border: 1px solid rgba(0,230,118,0.4);
    border-radius:18px; color:#fff; 
    font-weight:900; font-size:1.3rem; letter-spacing: 1px;
    box-shadow: 0 10px 25px rgba(0,230,118,0.1), inset 0 2px 5px rgba(0,230,118,0.3);
    backdrop-filter: blur(10px);
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.25);
}
.btn-ok-q:active { transform: scale(0.96); box-shadow: none; }
.btn-ok-q:hover { background: rgba(0,230,118,0.25); box-shadow: 0 15px 35px rgba(0,230,118,0.3), inset 0 2px 10px rgba(0,230,118,0.5); }

.btn-ng-q { 
    flex:1; padding:20px; 
    background: linear-gradient(180deg, rgba(255,77,77,0.15) 0%, rgba(255,77,77,0.02) 100%);
    border:1px solid rgba(255,77,77,0.3); border-radius:18px; color:var(--ng); 
    font-weight:900; font-size:1.3rem; 
    box-shadow: 0 10px 25px rgba(255,77,77,0.1), inset 0 2px 5px rgba(255,77,77,0.2);
    backdrop-filter: blur(10px);
    transition: all 0.3s;
}
.btn-ng-q:hover { background: rgba(255,77,77,0.2); box-shadow: 0 15px 35px rgba(255,77,77,0.25), inset 0 2px 10px rgba(255,77,77,0.3); }

/* FOOTER DOWNTIME */
.downtime-footer {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    margin-top: 40px;
}
.downtime-footer .btn-save {
    /* pointer-events override not needed anymore */
}

/* INPUT REFINEMENT */
.time-inp { 
    background: rgba(10,15,25,0.8); 
    border: 1px solid rgba(0,242,254,0.2); 
    color: var(--cyan); font-size: 1.5rem; font-weight: 1000; 
    width: 105px; padding: 14px; border-radius: 14px;
    text-align: center;
    transition: all 0.3s;
    box-shadow: inset 0 2px 10px rgba(0,0,0,0.5), 0 0 10px rgba(0,242,254,0.05);
    text-shadow: 0 0 10px var(--cyan-glow);
}
.time-inp:focus {
    border-color: var(--cyan);
    box-shadow: 0 0 20px rgba(0,242,254,0.3), inset 0 2px 10px rgba(0,0,0,0.5);
    transform: translateY(-2px);
    outline: none;
}
.remarks-inp { 
    background: transparent !important;
    border: none !important;
    border-radius: 16px; padding: 16px 20px; color: #fff !important; 
    width: 100% !important; height: auto !important; min-height: 56px;
    outline: none !important;
    resize: none;
}
.remarks-inp:focus { outline: none !important; }

.btn-add-part {
    background: linear-gradient(90deg, rgba(79,110,247,0.1) 0%, rgba(79,110,247,0.05) 100%);
    border: 1px dashed rgba(79,110,247,0.4);
    border-radius: 24px; color: var(--accent);
    padding: 20px; font-weight: 1000; letter-spacing: 2px;
    transition: all 0.4s;
    flex: 1;
}
.btn-add-part:hover { background: rgba(79,110,247,0.12); border-style: solid; box-shadow: 0 0 30px var(--accent-glow); }


/* Telemetry */
.telemetry-panel { background:var(--surface); border:1px solid var(--border); border-radius:22px; padding:26px 30px; margin-bottom:20px; }
.metric-big { font-size:3rem; font-weight:1000; letter-spacing:-3px; }
.achieve-track { width:100%; height:6px; background:rgba(255,255,255,.05); border-radius:99px; margin-top:10px; overflow:hidden; }
.achieve-fill  { height:100%; border-radius:99px; transition:width .7s; }

/* Save btn */
.btn-save { width:100%; padding:28px; background:linear-gradient(135deg,#10b981,#065f46); border:none; border-radius:22px; color:#fff; font-weight:950; font-size:1.1rem; letter-spacing:4px; text-transform:uppercase; cursor:pointer; box-shadow:0 20px 50px rgba(16,185,129,.3); transition:all .4s; display:flex; justify-content:center; align-items:center; }
.btn-save:hover { transform:translateY(-6px); box-shadow:0 30px 70px rgba(16,185,129,.4); }

/* Add card btn */
.btn-add { width:100%; padding:18px; background:linear-gradient(90deg,rgba(79,110,247,.03),rgba(79,110,247,.07)); border:2px dashed rgba(79,110,247,.2); border-radius:22px; color:var(--accent); font-size:.85rem; font-weight:900; letter-spacing:3px; cursor:pointer; transition:all .4s; display:flex; align-items:center; justify-content:center; gap:12px; margin-bottom:20px; }
.btn-add:hover { border-color:var(--accent); background:rgba(79,110,247,.1); transform:scale(1.01); }

/* Remove btn */
.btn-rm { background:none; border:none; color:var(--muted); font-size:1.3rem; cursor:pointer; transition:all .3s; padding:4px; }
.btn-rm:hover { color:var(--ng); }

/* MODAL */
.modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.7); backdrop-filter:blur(10px); z-index:9999; align-items:center; justify-content:center; }
.modal-overlay.show { display:flex; }
.modal-box { background:rgba(15,25,48,.98); border:1px solid var(--border); border-radius:24px; padding:36px; width:360px; box-shadow:0 40px 100px rgba(0,0,0,.6); }
.modal-inp { background:rgba(0,0,0,.4); border:1px solid var(--border); border-radius:14px; color:#fff; font-size:2.5rem; font-weight:900; text-align:center; padding:16px; width:100%; outline:none; margin:16px 0; }
.modal-inp:focus { border-color:var(--accent); }
.modal-btn-row { display:flex; gap:10px; }
.modal-btn-ok { flex:1; padding:14px; background:var(--accent); border:none; border-radius:12px; color:#fff; font-weight:900; cursor:pointer; transition:.3s; }
.modal-btn-ok:hover { filter:brightness(1.15); }
.modal-btn-cancel { flex:1; padding:14px; background:rgba(255,255,255,.05); border:1px solid var(--border); border-radius:12px; color:var(--muted); font-weight:700; cursor:pointer; }

/* empty */
.empty-state { text-align:center; padding:50px 20px; background:var(--surface); border:2px dashed rgba(255,255,255,.05); border-radius:22px; margin-bottom:20px; }

/* HUD ACTION BUTTONS */
.hud-actions { display: flex; gap: 10px; margin-top: 16px; }
.btn-hud { 
    flex: 1; padding: 16px 8px; border-radius: 16px; 
    font-size: 0.65rem; font-weight: 1000; letter-spacing: 2px;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.25);
    background: rgba(10,15,25, 0.6);
    border: 1px solid rgba(255,255,255,0.05);
    color: var(--muted);
    cursor: pointer;
    box-shadow: inset 0 2px 8px rgba(0,0,0,0.4);
}
.btn-hud i { font-size: 1.2rem; }
.btn-hud:active { transform: scale(0.95); }

/* VIBRANT IDLE STATES */
.btn-run { border: 1px solid rgba(0,230,118,0.2) !important; color: rgba(0,230,118,0.4); }
.btn-stop { border: 1px solid rgba(255,77,77,0.2) !important; color: rgba(255,77,77,0.4); }
.btn-break { border: 1px solid rgba(250,204,21,0.2) !important; color: rgba(250,204,21,0.4); }

.btn-hud:hover { transform: translateY(-3px); background: rgba(255,255,255,0.05); color: #fff; }

.btn-hud.active-run { 
    background: linear-gradient(180deg, rgba(0,230,118,0.25) 0%, rgba(0,230,118,0.05) 100%);
    border-color: var(--ok) !important; color: #fff !important;
    box-shadow: 0 0 25px rgba(0,230,118,0.3), inset 0 2px 5px rgba(0,230,118,0.5);
    animation: pulse-run 2s infinite;
}
.btn-hud.active-stop { 
    background: linear-gradient(180deg, rgba(255,77,77,0.25) 0%, rgba(255,77,77,0.05) 100%);
    border-color: var(--ng) !important; color: #fff !important;
    box-shadow: 0 0 25px rgba(255,77,77,0.3), inset 0 2px 5px rgba(255,77,77,0.5);
}
.btn-hud.active-break { 
    background: linear-gradient(180deg, rgba(250,204,21,0.25) 0%, rgba(250,204,21,0.05) 100%);
    border-color: #facc15 !important; color: #fff !important;
    box-shadow: 0 0 25px rgba(250,204,21,0.3), inset 0 2px 5px rgba(250,204,21,0.5);
}

@@keyframes pulse-run { 0% { opacity: 1; } 50% { opacity: 0.7; } 100% { opacity: 1; } }

@@media (max-width:1100px) { 
    .card-inner { grid-template-columns:1fr; gap: 16px; } 
    .card-right { flex-direction:column; border-left:none; border-top:1px dashed var(--border); padding-left:0; padding-top:20px; } 
    .meta-tile { width: 100%; }
}
</style>

<!-- OVERRIDE MODAL -->
<div class="modal-overlay" id="overrideModal">
    <div class="modal-box">
        <div class="lbl" style="font-size:.6rem;font-weight:900;letter-spacing:3px;color:var(--muted);text-transform:uppercase;">OVERRIDE COUNT</div>
        <div style="font-size:.9rem;color:#94a3b8;margin-top:6px;">Masukkan jumlah aktual yang benar</div>
        <input type="number" class="modal-inp" id="modalInput" placeholder="0" />
        <div style="font-size:.65rem;color:var(--muted);margin-top:-6px;margin-bottom:10px;text-align:center;" id="modalSubtext"></div>
        <div class="modal-btn-row">
            <button class="modal-btn-ok" onclick="applyOverride()">APPLY</button>
            <button class="modal-btn-cancel" onclick="closeModal()">CANCEL</button>
        </div>
    </div>
</div>

<form asp-action="SaveExecution" method="post" id="execForm" class="px-3 pb-5">
<input type="hidden" asp-for="Id" />

<!-- ── VIBRANT HUD HEADER ── -->
<div class="exec-header mt-3">
    <!-- Top Row: Line & Shift Sejajar -->
    <div class="row g-4 mb-3">
        <div class="col-6">
            <div class="h-pill w-100" style="border-left: 3px solid var(--cyan);">
                <span class="h-label"><i class="bi bi-cpu i-cyan"></i> PRODUCTION LINE</span>
                <span class="h-val i-cyan">@Model.MachineName</span>
            </div>
        </div>
        <div class="col-6">
            <div class="h-pill w-100" style="border-left: 3px solid #d946ef;">
                <span class="h-label"><i class="bi bi-clock-history i-mag"></i> CURRENT SHIFT</span>
                <span class="h-val">SHIFT @(Model.Shift?.ToUpper().Replace("SHIFT", "").Trim()) <span class="h-val-sub" style="color:#d946ef;">@Model.GroupName</span></span>
            </div>
        </div>
    </div>

    <!-- Middle Row: Reporting Date Full Width -->
    <div class="row g-4 mb-3">
        <div class="col-12">
            <div class="h-pill w-100" style="border-left: 3px solid #facc15;">
                <span class="h-label"><i class="bi bi-calendar3 i-gold"></i> REPORTING DATE</span>
                <span class="h-val">@Model.ExecutionDate.ToString("dd MMMM yyyy")</span>
            </div>
        </div>
    </div>
    
    <!-- Bottom Row: PIC Sejajar -->
    <div class="row g-4">
        <div class="col-6">
            <div class="h-pill w-100" style="background: rgba(0,242,254,0.03); border: 1px solid rgba(0,242,254,0.15);">
                <span class="h-label" style="color:var(--cyan);"><i class="bi bi-person-badge"></i> OPERATOR PIC 1</span>
                <input type="text" asp-for="Pic1" class="pic-input mt-1" style="font-size:1.3rem; border-color:rgba(0,242,254,0.2) !important;" placeholder="Ketik nama PIC 1..." />
            </div>
        </div>
        <div class="col-6">
            <div class="h-pill w-100" style="background: rgba(217,70,239,0.03); border: 1px solid rgba(217,70,239,0.15);">
                <span class="h-label" style="color:#d946ef;"><i class="bi bi-person-badge"></i> OPERATOR PIC 2</span>
                <input type="text" asp-for="Pic2" class="pic-input mt-1" style="font-size:1.3rem; border-color:rgba(217,70,239,0.2) !important;" placeholder="Ketik nama PIC 2..." />
            </div>
        </div>
    </div>
</div>

<!-- ── GLOBAL PROGRESS HUD (Moved to Dashboard) ── -->


<!-- ── ACTIVITY CARDS ── -->
<div class="sec-lbl"><i class="bi bi-layers-half"></i> Aktivitas Produksi</div>

<div id="cardContainer">
@for (int i = 0; i < Model.Activities.Count; i++)
{
    var act = Model.Activities[i];
    bool isDetailsDandori = (act.PartName1 ?? "").ToUpper().Contains("DANDORI");
    var actPct = (act.PlanQty > 0 && act.ActualQty.HasValue) ? Math.Min(100, (int)(act.ActualQty.Value * 100.0 / act.PlanQty.Value)) : 0;

    <div class="act-card @(isDetailsDandori?"is-dandori":"is-prod")" id="card-@i">
        <div class="card-inner">
            <div class="card-left">
                <div class="card-hdr" style="margin-bottom:20px;">
                    <div class="card-num">@(i+1)</div>
                    <div style="flex:1;">
                        <input type="text" name="activities[@i].PartName1" value="@act.PartName1" class="part-input" style="font-size:1.8rem;" />
                        <div class="h-label" style="font-size:0.75rem;margin-top:2px;">@act.PartName2</div>
                    </div>
                    <button type="button" class="btn-rm ms-auto" onclick="removeCard(this)"><i class="bi bi-x-circle-fill"></i></button>
                    <input type="hidden" name="activities[@i].PartName2" value="@act.PartName2" />
                    <input type="hidden" name="activities[@i].Id" value="@act.Id" />
                </div>

                <div class="hud-meters">
                    <!-- Unified Output Meter -->
                    <div class="lcd-meter w-100 cursor-pointer" onclick="openModal(@i)" style="border-color: rgba(0,230,118, 0.15); border-left: 4px solid var(--ok); border-right: 4px solid var(--ng);">
                        <div class="d-flex justify-content-between align-items-start">
                            <!-- OK Section (Left) -->
                            <div>
                                <div class="lcd-label border-ok d-inline-block"><i class="bi bi-bullseye"></i> OUTPUT AKTUAL (OK)</div>
                                <div class="d-flex align-items-baseline gap-3">
                                    <div class="lcd-val ok-val" id="onum-@i">@(act.ActualQty ?? 0)</div>
                                    <div style="font-size:1.8rem; color:rgba(255,255,255,0.3); font-weight:900;">/ @act.PlanQty <span style="font-size:1rem;">pcs</span></div>
                                </div>
                            </div>
                            <!-- NG Section (Top Right) -->
                            <div class="text-center" style="min-width: 120px; display:flex; flex-direction:column; align-items:center;">
                                <div class="lcd-val ng-val" id="ngnum-@i" style="font-size:2.8rem; line-height:1; text-shadow:0 0 15px var(--ng-glow);">0</div>
                                <div class="lcd-label d-inline-block" style="border-top: 1px solid rgba(255,77,77,0.3); padding-top: 6px; padding-bottom: 0; margin-bottom: 0; margin-top: 6px;"><i class="bi bi-exclamation-triangle"></i> TOTAL NG</div>
                            </div>
                        </div>
                        <input type="hidden" name="activities[@i].ActualQty" id="qty-@i" value="@(act.ActualQty ?? 0)" />
                        
                        <div class="mt-4 pt-1">
                            <div class="d-flex justify-content-between align-items-end mb-2" style="font-size:0.75rem; font-weight:800; color:#64748b; letter-spacing:1px;">
                                <div>
                                    <i class="bi bi-flag me-1"></i>
                                    <span style="opacity:0.7;">Total OK:</span> <span id="totok-@i" style="color:var(--ok); font-size:0.85rem;">@(act.ActualQty ?? 0)</span> 
                                    <span style="margin:0 5px; color:rgba(255,255,255,0.15);">|</span> 
                                    <span style="opacity:0.7;">NG:</span> <span id="totng-@i" style="color:var(--ng); font-size:0.85rem;">0</span>
                                </div>
                                <div id="pcttxt-@i" style="color:var(--ok); font-size:0.9rem;">@actPct%</div>
                            </div>
                            <!-- Mini embedded prog track -->
                            <div class="prog-track" style="height:8px; background:rgba(255,255,255,0.08); border-radius:6px; overflow:hidden;">
                                <div class="prog-fill" id="cpfill-@i" style="width:@(actPct == 0 && act.ActualQty > 0 ? 1 : actPct)%; background:var(--ok); box-shadow:0 0 15px var(--ok-glow); border-radius:6px;"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="quick-btn-row mt-3">
                    <button type="button" class="btn-ok-q glossy" onclick="addOK(@i)"><i class="bi bi-check2-circle"></i> +1 OK</button>
                    <button type="button" class="btn-ng-q glossy" onclick="addNG(@i)"><i class="bi bi-x-circle"></i> +1 NG</button>
                    <button type="button" class="btn-override-q glossy ms-auto" style="padding:0 24px;" onclick="openModal(@i)"><i class="bi bi-sliders"></i> Override</button>
                </div>
                
                <input type="hidden" name="activities[@i].Remarks" value="@act.Remarks" />
            </div>

            <div class="card-right">
                <input type="hidden" class="run-status" value="STOPPED" />
                <div class="meta-tile">
                    <div class="h-label" style="color:var(--cyan); text-shadow:0 0 10px var(--cyan-glow); font-size:0.65rem; letter-spacing:3px;"><i class="bi bi-clock-history"></i> WINDOW TIMELINE</div>
                    <div class="time-row justify-content-between mt-3">
                        <input type="text" name="activities[@i].ActualStart" value="@act.ActualStart" class="time-inp act-start" placeholder="00:00" />
                        <div class="time-sep" style="font-weight:900; color:var(--cyan); opacity:0.6; font-size:1.5rem;">➔</div>
                        <input type="text" name="activities[@i].ActualEnd" value="@act.ActualEnd" class="time-inp act-end" placeholder="00:00" />
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-4 pt-3" style="border-top: 1px solid rgba(255,242,254,0.1);">
                        <div class="d-flex align-items-baseline gap-2">
                            <span style="font-size:0.75rem; color:var(--muted); font-weight:900; letter-spacing:1px; color:rgba(255,255,255,0.4);">PLAN:</span>
                            <input type="number" name="activities[@i].ActualDurationMinutes" value="@act.ActualDurationMinutes" class="meta-inp text-end act-minutes" placeholder="0" style="font-size:1.7rem; width:75px; background:transparent !important; border:none; padding:0; color:var(--ok); text-shadow:0 0 20px var(--ok-glow); font-weight:1000;" />
                            <span style="font-size:1.2rem; color:rgba(255,255,255,0.3); font-weight:900;">/ @act.PlanDurationMinutes <span style="font-size:0.75rem;">min</span></span>
                        </div>
                        <div class="meta-sub" style="font-size:.75rem; color:var(--cyan); opacity:0.8; letter-spacing:1px; font-weight:800; text-shadow:0 0 10px var(--cyan-glow);"><i class="bi bi-calendar3"></i> SCH: @act.PlanStart – @act.PlanEnd</div>
                    </div>
                </div>
                
                <div class="hud-actions">
                    <button type="button" class="btn-hud btn-run" onclick="toggleStatus(this, 'RUNNING')">
                        <i class="bi bi-play-circle-fill"></i>
                        <span>RUNNING</span>
                    </button>
                    <button type="button" class="btn-hud btn-stop" onclick="toggleStatus(this, 'STOP')">
                        <i class="bi bi-stop-circle-fill"></i>
                        <span>LINE STOP</span>
                    </button>
                    <button type="button" class="btn-hud btn-break" onclick="toggleStatus(this, 'BREAK')">
                        <i class="bi bi-cup-hot-fill"></i>
                        <span>BREAK</span>
                    </button>
                </div>

                <input type="hidden" name="activities[@i].PlanQty" value="@act.PlanQty" class="plan-qty-val" />
            </div>
        </div>
    </div>
}
</div>


<!-- ── ADD ACTIONS (Hidden per user request, empty spacer to keep margin) ── -->
<div class="mb-5 pb-5"></div>

<!-- ── FIXED DOWNTIME FOOTER ── -->
<div class="downtime-footer" style="justify-content: flex-end;">
    <button type="submit" class="btn-save" style="width:300px;height:90px;padding:0;">
        <div class="d-flex align-items-center justify-content-center gap-3">
            <i class="bi bi-shield-check" style="font-size:2.4rem;"></i>
            <div class="text-start">
                <div style="font-weight:1000;letter-spacing:1px;font-size:1.1rem;">SIMPAN LAPORAN</div>
                <div style="font-size:0.6rem;opacity:0.6;letter-spacing:2px;font-weight:700;">SYNC KE DATABASE</div>
            </div>
        </div>
    </button>
</div>
</form>

<!-- PART PICKER MODAL (Moved Outside) -->
<div class="modal-overlay" id="partPickerModal">
    <div class="modal-box" style="width:520px;max-width:95vw;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
            <div>
                <div style="font-size:.55rem;font-weight:900;letter-spacing:4px;color:var(--muted);text-transform:uppercase;">Pilih Part Code</div>
                <div style="font-size:1.1rem;font-weight:900;margin-top:2px;">Cari dari Part Master</div>
            </div>
            <button type="button" onclick="closePartPicker()" style="background:none;border:none;color:var(--muted);font-size:1.5rem;cursor:pointer;"><i class="bi bi-x-circle-fill"></i></button>
        </div>
        <div style="position:relative;">
            <i class="bi bi-search" style="position:absolute;left:14px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:1rem;"></i>
            <input type="text" id="partSearchInp" class="modal-inp" style="font-size:1rem;padding:14px 14px 14px 42px;text-align:left;margin:0;width:100%;" placeholder="Ketik Part Code, Part Number, atau Deskripsi..." oninput="searchParts(this.value)" />
        </div>
        <div style="font-size:.6rem;font-weight:700;letter-spacing:2px;color:var(--muted);margin:12px 0 8px;text-transform:uppercase;" id="partResultCount">Menunggu input...</div>
        <div id="partResultList" style="max-height:320px;overflow-y:auto;display:flex;flex-direction:column;gap:8px;">
            <div style="text-align:center;padding:40px 20px;color:var(--muted);font-size:.85rem;">Mulai ketik untuk mencari part</div>
        </div>
    </div>
</div>

@section Scripts {
<script>
// ─── State per card ───
const ngCounts = {};
let modalCardIdx = -1;
let cardIndex = @Model.Activities.Count;

function getQty(idx)  { return parseInt(document.getElementById(`qty-${idx}`)?.value || '0'); }
function setQty(idx, v) {
    const inp = document.getElementById(`qty-${idx}`);
    const num = document.getElementById(`onum-${idx}`);
    if(inp) inp.value = v;
    if(num) num.textContent = v;
    updateCard(idx);
}

function addOK(idx) {
    setQty(idx, getQty(idx) + 1);
    // flash
    const n = document.getElementById(`onum-${idx}`);
    if(n) { n.style.transform='scale(1.15)'; setTimeout(()=>n.style.transform='',200); }
}

function addNG(idx) {
    if(!ngCounts[idx]) ngCounts[idx] = 0;
    ngCounts[idx]++;
    const el = document.getElementById(`ngnum-${idx}`);
    const tot = document.getElementById(`totng-${idx}`);
    
    if(el) el.textContent = ngCounts[idx];
    if(tot) tot.textContent = ngCounts[idx];
    
    updateCard(idx);
}

function updateCard(idx) {
    const qty  = getQty(idx);
    const plan = parseInt(document.querySelector(`#card-${idx} .plan-qty-val`)?.value || '0');
    let pctRaw = plan > 0 ? (qty * 100 / plan) : 0;
    
    let pctDisplay = Math.round(pctRaw);
    let pctChart = pctDisplay;
    if (pctChart > 0 && pctChart < 1) pctChart = 1; // Minimum 1% to show indicator visible
    else if (pctChart > 100) pctChart = 100;
    
    const fill = document.getElementById(`cpfill-${idx}`);
    const frac = document.getElementById(`frac-${idx}`);
    const pctTxt = document.getElementById(`pcttxt-${idx}`);
    const totOK = document.getElementById(`totok-${idx}`);
    
    if(fill) fill.style.width = pctChart + '%';
    if(frac) frac.textContent = qty;
    if(pctTxt) pctTxt.textContent = pctDisplay + '%';
    if(totOK) totOK.textContent = qty;
    
    refreshGlobal();
}

function refreshGlobal() {
    let actProd=0, planProd=0, actDand=0, totalNg=0;
    document.querySelectorAll('[id^="qty-"]').forEach(inp => {
        const idx = inp.id.replace('qty-','');
        const card = document.getElementById(`card-${idx}`);
        if(!card) return;
        const isDand = card.classList.contains('is-dandori');
        const plan = parseInt(card.querySelector('.plan-qty-val')?.value || '0');
        const act  = parseInt(inp.value||'0');
        if(!isDand) { actProd += act; planProd += plan; }
        else {
            const dur = parseInt(card.querySelector('[name$=".ActualDurationMinutes"]')?.value||'0');
            actDand += dur;
        }
        const ng = ngCounts[idx] || 0;
        totalNg += ng;
    });

    const pct = planProd > 0 ? Math.min(100, (actProd/planProd*100)) : 0;
    
    const setEl = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
    const setStyle = (id, prop, val) => { const el = document.getElementById(id); if (el) el.style[prop] = val; };

    setStyle('globalProgFill', 'width', pct.toFixed(1)+'%');
    setEl('globalPct',     pct.toFixed(1)+'%');
    setEl('globalFrac',    `${actProd} / ${planProd} pcs`);
    setEl('globalOK',      actProd);
    setEl('globalNG',      totalNg);
    setEl('globalDandori', actDand+' min');

    const color = pct >= 100 ? 'var(--ok)' : pct >= 80 ? 'var(--warn)' : 'var(--ng)';
    setStyle('globalPct', 'color', color);
}

// ─── Override modal ───
function openModal(idx) {
    modalCardIdx = idx;
    document.getElementById('modalInput').value = getQty(idx);
    document.getElementById('modalSubtext').textContent = `Plan: ${document.querySelector(`#card-${idx} .plan-qty-val`)?.value || 0} pcs`;
    document.getElementById('overrideModal').classList.add('show');
    setTimeout(()=>document.getElementById('modalInput').focus(),100);
}
function closeModal() { document.getElementById('overrideModal').classList.remove('show'); }
function applyOverride() {
    const v = parseInt(document.getElementById('modalInput').value||'0');
    if(modalCardIdx >= 0 && !isNaN(v)) setQty(modalCardIdx, v);
    closeModal();
}
document.getElementById('overrideModal').addEventListener('click', function(e) { if(e.target===this) closeModal(); });
document.getElementById('modalInput').addEventListener('keydown', function(e) { if(e.key==='Enter') applyOverride(); });

// ─── Add/Remove card ───
function addCard() {
    document.getElementById('emptyState') && (document.getElementById('emptyState').style.display='none');
    const idx = cardIndex++;
    const num = document.querySelectorAll('.act-card').length + 1;
    const html = `
    <div class="act-card is-prod" id="card-manual-${idx}">
        <div class="card-inner">
            <div class="card-left">
                <div class="card-hdr" style="margin-bottom:20px;">
                    <div class="card-num">${num}</div>
                    <div style="flex:1;">
                        <input type="text" name="activities[${idx}].PartName1" class="part-input" placeholder="INPUT PART CODE" style="font-size:1.8rem;" />
                        <div class="h-label" style="font-size:0.75rem;margin-top:2px;">MANUAL ADDITION</div>
                    </div>
                    <button type="button" class="btn-rm ms-auto" onclick="removeCard(this)"><i class="bi bi-trash3-fill"></i></button>
                    <input type="hidden" name="activities[${idx}].PartName2" value="MANUAL" />
                    <input type="hidden" name="activities[${idx}].Id" value="0" />
                </div>

                <div class="hud-meters">
                    <div class="lcd-meter w-100 cursor-pointer" onclick="openModal(${idx})" style="border-color: rgba(0,230,118, 0.15); border-left: 4px solid var(--ok); border-right: 4px solid var(--ng);">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <div class="lcd-label border-ok d-inline-block"><i class="bi bi-bullseye"></i> OUTPUT AKTUAL (OK)</div>
                                <div class="d-flex align-items-baseline gap-3">
                                    <div class="lcd-val ok-val" id="onum-${idx}">0</div>
                                    <div style="font-size:1.8rem; color:rgba(255,255,255,0.3); font-weight:900;">/ 0 <span style="font-size:1rem;">pcs</span></div>
                                </div>
                            </div>
                            <div class="text-center" style="min-width: 120px; display:flex; flex-direction:column; align-items:center;">
                                <div class="lcd-val ng-val" id="ngnum-${idx}" style="font-size:2.8rem; line-height:1; text-shadow:0 0 15px var(--ng-glow);">0</div>
                                <div class="lcd-label d-inline-block" style="border-top: 1px solid rgba(255,77,77,0.3); padding-top: 6px; padding-bottom: 0; margin-bottom: 0; margin-top: 6px;"><i class="bi bi-exclamation-triangle"></i> TOTAL NG</div>
                            </div>
                        </div>
                        <input type="hidden" name="activities[${idx}].ActualQty" id="qty-${idx}" value="0" />
                        
                        <div class="mt-4 pt-1">
                            <div class="d-flex justify-content-between align-items-end mb-2" style="font-size:0.75rem; font-weight:800; color:#64748b; letter-spacing:1px;">
                                <div>
                                    <i class="bi bi-flag me-1"></i>
                                    <span style="opacity:0.7;">Total OK:</span> <span id="totok-${idx}" style="color:var(--ok); font-size:0.85rem;">0</span> 
                                    <span style="margin:0 5px; color:rgba(255,255,255,0.15);">|</span> 
                                    <span style="opacity:0.7;">NG:</span> <span id="totng-${idx}" style="color:var(--ng); font-size:0.85rem;">0</span>
                                </div>
                                <div id="pcttxt-${idx}" style="color:var(--ok); font-size:0.9rem;">0%</div>
                            </div>
                            <div class="prog-track" style="height:8px; background:rgba(255,255,255,0.08); border-radius:6px; overflow:hidden;">
                                <div class="prog-fill" id="cpfill-${idx}" style="width:0%; background:var(--ok); box-shadow:0 0 15px var(--ok-glow); border-radius:6px;"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="quick-btn-row mt-3 mb-2">
                    <button type="button" class="btn-ok-q glossy" onclick="addOK(${idx})"><i class="bi bi-check2-circle"></i> +1 OK</button>
                    <button type="button" class="btn-ng-q glossy" onclick="addNG(${idx})"><i class="bi bi-x-circle"></i> +1 NG</button>
                    <button type="button" class="btn-override-q glossy ms-auto" style="padding:0 24px;" onclick="openModal(${idx})"><i class="bi bi-sliders"></i> Override</button>
                </div>
                <input type="hidden" name="activities[${idx}].Remarks" value="" />
            </div>

            <div class="card-right">
                <input type="hidden" class="run-status" value="STOPPED" />
                <div class="meta-tile">
                    <div class="h-label" style="color:var(--cyan); text-shadow:0 0 10px var(--cyan-glow); font-size:0.65rem; letter-spacing:3px;"><i class="bi bi-clock-history"></i> WINDOW TIMELINE</div>
                    <div class="time-row justify-content-between mt-3">
                        <input type="text" name="activities[${idx}].ActualStart" class="time-inp act-start" placeholder="00:00" />
                        <div class="time-sep" style="font-weight:900; color:var(--cyan); opacity:0.6; font-size:1.5rem;">➔</div>
                        <input type="text" name="activities[${idx}].ActualEnd" class="time-inp act-end" placeholder="00:00" />
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-4 pt-3" style="border-top: 1px solid rgba(255,242,254,0.1);">
                        <div class="d-flex align-items-baseline gap-2">
                            <span style="font-size:0.75rem; color:var(--muted); font-weight:900; letter-spacing:1px; color:rgba(255,255,255,0.4);">PLAN:</span>
                            <input type="number" name="activities[${idx}].ActualDurationMinutes" class="meta-inp text-end act-minutes" placeholder="0" style="font-size:1.7rem; width:75px; background:transparent !important; border:none; padding:0; color:var(--ok); text-shadow:0 0 20px var(--ok-glow); font-weight:1000;" />
                            <span style="font-size:1.2rem; color:rgba(255,255,255,0.3); font-weight:900;">/ 0 <span style="font-size:0.75rem;">min</span></span>
                        </div>
                        <div class="meta-sub" style="font-size:.75rem; color:var(--cyan); opacity:0.8; letter-spacing:1px; font-weight:800; text-shadow:0 0 10px var(--cyan-glow);"><i class="bi bi-calendar3"></i> SCH: 00:00 – 00:00</div>
                    </div>
                </div>
                
                <div class="hud-actions">
                    <button type="button" class="btn-hud btn-run" onclick="toggleStatus(this, 'RUNNING')">
                        <i class="bi bi-play-circle-fill"></i>
                        <span>RUNNING</span>
                    </button>
                    <button type="button" class="btn-hud btn-stop" onclick="toggleStatus(this, 'STOP')">
                        <i class="bi bi-stop-circle-fill"></i>
                        <span>LINE STOP</span>
                    </button>
                    <button type="button" class="btn-hud btn-break" onclick="toggleStatus(this, 'BREAK')">
                        <i class="bi bi-cup-hot-fill"></i>
                        <span>BREAK</span>
                    </button>
                </div>
                
                <input type="hidden" name="activities[${idx}].PlanQty" value="0" class="plan-qty-val" />
            </div>
        </div>
    </div>`;
    document.getElementById('cardContainer').insertAdjacentHTML('beforeend', html);
    refreshGlobal();
}

function removeCard(btn) { btn.closest('.act-card').remove(); refreshGlobal(); }

// Init
document.addEventListener('DOMContentLoaded', () => refreshGlobal());
document.addEventListener('input', (e) => { if(e.target.matches('[name$=".ActualDurationMinutes"]')) refreshGlobal(); });

// ─── Part Code Picker ───
let searchTimer = null;

function openPartPicker() {
    document.getElementById('emptyState') && (document.getElementById('emptyState').style.display='none');
    document.getElementById('partPickerModal').classList.add('show');
    setTimeout(() => document.getElementById('partSearchInp').focus(), 150);
}
function closePartPicker() {
    document.getElementById('partPickerModal').classList.remove('show');
    document.getElementById('partSearchInp').value = '';
    document.getElementById('partResultList').innerHTML = '<div style="text-align:center;padding:40px 20px;color:var(--muted);font-size:.85rem;">Mulai ketik untuk mencari part</div>';
    document.getElementById('partResultCount').textContent = 'Menunggu input...';
}
document.getElementById('partPickerModal').addEventListener('click', function(e) { if(e.target===this) closePartPicker(); });

function searchParts(q) {
    clearTimeout(searchTimer);
    const list = document.getElementById('partResultList');
    const count = document.getElementById('partResultCount');
    if (!q || q.length < 1) {
        list.innerHTML = '<div style="text-align:center;padding:40px 20px;color:var(--muted);font-size:.85rem;">Mulai ketik untuk mencari part</div>';
        count.textContent = 'Menunggu input...';
        return;
    }
    list.innerHTML = '<div style="text-align:center;padding:24px;color:var(--muted);">Mencari...</div>';
    searchTimer = setTimeout(async () => {
        try {
            const res = await fetch(`/DailyPlanExecution/SearchPartCodes?q=${encodeURIComponent(q)}`);
            const data = await res.json();
            count.textContent = `${data.length} hasil ditemukan`;
            if (data.length === 0) {
                list.innerHTML = '<div style="text-align:center;padding:24px;color:var(--muted);">Tidak ada part yang cocok</div>';
                return;
            }
            list.innerHTML = data.map(p => `
                <div onclick="addCardFromPart(${JSON.stringify(p).replace(/"/g,'&quot;')})" style="
                    background:rgba(255,255,255,.03); border:1px solid rgba(255,255,255,.07);
                    border-radius:14px; padding:12px 18px; cursor:pointer; transition:all .2s;
                    display:flex; justify-content:space-between; align-items:center; gap:12px;"
                    onmouseover="this.style.borderColor='var(--accent)';this.style.background='rgba(79,110,247,.08)'"
                    onmouseout="this.style.borderColor='rgba(255,255,255,.07)';this.style.background='rgba(255,255,255,.03)'">
                    <div>
                        <div style="font-size:1.1rem;font-weight:900;color:#fff;">${p.partCode || '-'}</div>
                        <div style="font-size:.7rem;color:rgba(255,255,255,0.5);margin-top:2px;">${p.partNumber || ''} ${p.description ? '— '+p.description : ''}</div>
                    </div>
                </div>`).join('');
        } catch(e) {
            list.innerHTML = '<div style="text-align:center;padding:24px;color:var(--ng);">Gagal mengambil data</div>';
        }
    }, 300);
}

function addCardFromPart(part) {
    closePartPicker();
    const idx = cardIndex++;
    const num = document.querySelectorAll('.act-card').length + 1;
    const html = `
    <div class="act-card is-prod" id="card-manual-${idx}">
        <div class="card-inner">
            <div class="card-left">
                <div class="card-hdr" style="margin-bottom:20px;">
                    <div class="card-num">${num}</div>
                    <div style="flex:1;">
                        <input type="text" name="activities[${idx}].PartName1" value="${part.partCode || ''}" class="part-input" style="font-size:1.8rem;" />
                        <div class="h-label" style="font-size:0.75rem;margin-top:2px;">${part.partNumber || ''} ${part.description ? '— ' + part.description : ''}</div>
                    </div>
                    <button type="button" class="btn-rm ms-auto" onclick="removeCard(this)"><i class="bi bi-trash3-fill"></i></button>
                    <input type="hidden" name="activities[${idx}].PartName2" value="${part.partNumber || 'N/A'}" />
                    <input type="hidden" name="activities[${idx}].Id" value="0" />
                </div>

                <div class="hud-meters">
                    <div class="lcd-meter w-100 cursor-pointer" onclick="openModal(${idx})" style="border-color: rgba(0,230,118, 0.15); border-left: 4px solid var(--ok); border-right: 4px solid var(--ng);">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <div class="lcd-label border-ok d-inline-block"><i class="bi bi-bullseye"></i> OUTPUT AKTUAL (OK)</div>
                                <div class="d-flex align-items-baseline gap-3">
                                    <div class="lcd-val ok-val" id="onum-${idx}">0</div>
                                    <div style="font-size:1.8rem; color:rgba(255,255,255,0.3); font-weight:900;">/ 0 <span style="font-size:1rem;">pcs</span></div>
                                </div>
                            </div>
                            <div class="text-center" style="min-width: 120px; display:flex; flex-direction:column; align-items:center;">
                                <div class="lcd-val ng-val" id="ngnum-${idx}" style="font-size:2.8rem; line-height:1; text-shadow:0 0 15px var(--ng-glow);">0</div>
                                <div class="lcd-label d-inline-block" style="border-top: 1px solid rgba(255,77,77,0.3); padding-top: 6px; padding-bottom: 0; margin-bottom: 0; margin-top: 6px;"><i class="bi bi-exclamation-triangle"></i> TOTAL NG</div>
                            </div>
                        </div>
                        <input type="hidden" name="activities[${idx}].ActualQty" id="qty-${idx}" value="0" />
                        
                        <div class="mt-4 pt-1">
                            <div class="d-flex justify-content-between align-items-end mb-2" style="font-size:0.75rem; font-weight:800; color:#64748b; letter-spacing:1px;">
                                <div>
                                    <i class="bi bi-flag me-1"></i>
                                    <span style="opacity:0.7;">Total OK:</span> <span id="totok-${idx}" style="color:var(--ok); font-size:0.85rem;">0</span> 
                                    <span style="margin:0 5px; color:rgba(255,255,255,0.15);">|</span> 
                                    <span style="opacity:0.7;">NG:</span> <span id="totng-${idx}" style="color:var(--ng); font-size:0.85rem;">0</span>
                                </div>
                                <div id="pcttxt-${idx}" style="color:var(--ok); font-size:0.9rem;">0%</div>
                            </div>
                            <!-- Mini embedded prog track -->
                            <div class="prog-track" style="height:8px; background:rgba(255,255,255,0.08); border-radius:6px; overflow:hidden;">
                                <div class="prog-fill" id="cpfill-${idx}" style="width:0%; background:var(--ok); box-shadow:0 0 15px var(--ok-glow); border-radius:6px;"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="quick-btn-row mt-3 mb-2">
                    <button type="button" class="btn-ok-q glossy" onclick="addOK(${idx})"><i class="bi bi-check2-circle"></i> +1 OK</button>
                    <button type="button" class="btn-ng-q glossy" onclick="addNG(${idx})"><i class="bi bi-x-circle"></i> +1 NG</button>
                    <button type="button" class="btn-override-q glossy ms-auto" style="padding:0 24px;" onclick="openModal(${idx})"><i class="bi bi-sliders"></i> Override</button>
                </div>
                <input type="hidden" name="activities[${idx}].Remarks" value="" />
            </div>

            <div class="card-right">
                <input type="hidden" class="run-status" value="STOPPED" />
                <div class="meta-tile">
                    <div class="h-label" style="color:var(--cyan); text-shadow:0 0 10px var(--cyan-glow); font-size:0.65rem; letter-spacing:3px;"><i class="bi bi-clock-history"></i> WINDOW TIMELINE</div>
                    <div class="time-row justify-content-between mt-3">
                        <input type="text" name="activities[${idx}].ActualStart" class="time-inp act-start" placeholder="00:00" />
                        <div class="time-sep" style="font-weight:900; color:var(--cyan); opacity:0.6; font-size:1.5rem;">➔</div>
                        <input type="text" name="activities[${idx}].ActualEnd" class="time-inp act-end" placeholder="00:00" />
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-4 pt-3" style="border-top: 1px solid rgba(255,242,254,0.1);">
                        <div class="d-flex align-items-baseline gap-2">
                            <span style="font-size:0.75rem; color:var(--muted); font-weight:900; letter-spacing:1px; color:rgba(255,255,255,0.4);">PLAN:</span>
                            <input type="number" name="activities[${idx}].ActualDurationMinutes" class="meta-inp text-end act-minutes" placeholder="0" style="font-size:1.7rem; width:75px; background:transparent !important; border:none; padding:0; color:var(--ok); text-shadow:0 0 20px var(--ok-glow); font-weight:1000;" />
                            <span style="font-size:1.2rem; color:rgba(255,255,255,0.3); font-weight:900;">/ ${part.standardDurationMinutes || 0} <span style="font-size:0.75rem;">min</span></span>
                        </div>
                        <div class="meta-sub" style="font-size:.75rem; color:var(--cyan); opacity:0.8; letter-spacing:1px; font-weight:800; text-shadow:0 0 10px var(--cyan-glow);"><i class="bi bi-calendar3"></i> SCH: 00:00 – 00:00</div>
                    </div>
                </div>
                
                <div class="hud-actions">
                    <button type="button" class="btn-hud btn-run" onclick="toggleStatus(this, 'RUNNING')">
                        <i class="bi bi-play-circle-fill"></i>
                        <span>RUNNING</span>
                    </button>
                    <button type="button" class="btn-hud btn-stop" onclick="toggleStatus(this, 'STOP')">
                        <i class="bi bi-stop-circle-fill"></i>
                        <span>LINE STOP</span>
                    </button>
                    <button type="button" class="btn-hud btn-break" onclick="toggleStatus(this, 'BREAK')">
                        <i class="bi bi-cup-hot-fill"></i>
                        <span>BREAK</span>
                    </button>
                </div>
                
                <input type="hidden" name="activities[${idx}].PlanQty" value="0" class="plan-qty-val" />
            </div>
        </div>
    </div>`;
    document.getElementById('cardContainer').insertAdjacentHTML('beforeend', html);
    refreshGlobal();
    setTimeout(() => document.getElementById(`card-manual-${idx}`)?.scrollIntoView({behavior:'smooth', block:'center'}), 100);
}

// ── HUD COMMAND ENGINE ──
function toggleStatus(btn, status) {
    const card = btn.closest('.act-card');
    const metaTile = card.querySelector('.meta-tile');
    const hiddenStatus = card.querySelector('.run-status');
    const allBtns = card.querySelectorAll('.btn-hud');
    
    // Clear all active classes
    allBtns.forEach(b => b.classList.remove('active-run', 'active-stop', 'active-break'));
    metaTile.classList.remove('meta-running');
    
    if (hiddenStatus.value === status) {
        hiddenStatus.value = 'STOPPED';
    } else {
        hiddenStatus.value = status;
        if (status === 'RUNNING') {
            btn.classList.add('active-run');
            metaTile.classList.add('meta-running');
            const startInp = card.querySelector('.act-start');
            if (!startInp.value || startInp.value === '00:00' || startInp.value === '') {
                const now = new Date();
                startInp.value = now.getHours().toString().padStart(2, '0') + ':' + now.getMinutes().toString().padStart(2, '0');
            }
        } else if (status === 'STOP') {
            btn.classList.add('active-stop');
        } else if (status === 'BREAK') {
            btn.classList.add('active-break');
        }
    }
    refreshGlobal();
}

// Global Timer Heartbeat (Increments RUNNING cards every 1 min)
setInterval(() => {
    document.querySelectorAll('.act-card').forEach(card => {
        const status = card.querySelector('.run-status').value;
        if (status === 'RUNNING') {
            const minInp = card.querySelector('.act-minutes');
            const endInp = card.querySelector('.act-end');
            
            // Increment
            minInp.value = parseInt(minInp.value || 0) + 1;
            
            // Update End Time
            const now = new Date();
            endInp.value = now.getHours().toString().padStart(2, '0') + ':' + now.getMinutes().toString().padStart(2, '0');
            
            refreshGlobal();
        }
    });
}, 60000);

</script>
}
