@model VelastoProductionSystem.Models.DailyPlanExecution

@{
    ViewData["Title"] = "Laporan Aktual Produksi";
}

<style>
    :root {
        --bg: #03050a;
        --card-bg: rgba(13, 17, 28, 0.8);
        --accent: #0066ff;
        --accent-glow: rgba(0, 102, 255, 0.5);
        --accent-orange: #ffaa00;
        --orange-glow: rgba(255, 170, 0, 0.3);
        --success: #10b981;
        --success-glow: rgba(16, 185, 129, 0.4);
        --danger: #ef4444;
        --border: rgba(255,255,255,0.06);
        --glass-panel: rgba(15, 23, 42, 0.95);
    }

    body { 
        background: var(--bg); 
        color: #f1f5f9; 
        font-family: 'Outfit', sans-serif; 
        background-image: 
            radial-gradient(circle at 10% 20%, rgba(0, 102, 255, 0.03) 0%, transparent 40%),
            radial-gradient(circle at 90% 80%, rgba(16, 185, 129, 0.03) 0%, transparent 40%);
    }

    .fade-in-up { animation: fadeInUp 0.7s cubic-bezier(0.2, 1, 0.3, 1); }
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* ─── HEADER ─── */
    .exec-header {
        background: var(--glass-panel);
        backdrop-filter: blur(20px);
        border: 1px solid var(--border);
        border-radius: 30px;
        padding: 30px 40px;
        margin-bottom: 30px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.6);
        position: relative;
    }
    .header-pill { 
        background: rgba(255,255,255,0.03); 
        border: 1px solid var(--border); 
        padding: 12px 24px; 
        border-radius: 20px;
        transition: all 0.3s;
    }
    .header-pill:hover { border-color: var(--accent); background: rgba(0,102,255,0.05); }

    /* ─── ACTIVITY CARD (THE "ANTI-TABLE" REDESIGN) ─── */
    .act-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 32px;
        padding: 28px;
        margin-bottom: 24px;
        transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        gap: 24px;
    }
    .act-card:hover { 
        transform: translateY(-8px) scale(1.01); 
        border-color: rgba(255,255,255,0.15);
        box-shadow: 0 30px 70px rgba(0,0,0,0.5);
    }
    .act-card::after {
        content:''; position:absolute; top:0; left:0; width:100%; height:100%;
        background: linear-gradient(135deg, rgba(255,255,255,0.03) 0%, transparent 100%);
        pointer-events: none;
    }
    
    .act-card.is-dandori { border-top: 4px solid var(--accent-orange); }
    .act-card.is-prod    { border-top: 4px solid var(--accent); }

    /* Card Layout: Top Line */
    .card-id-strip {
        display: flex; align-items: center; justify-content: space-between;
    }
    .card-num-circle {
        width: 44px; height: 44px; border-radius: 50%;
        background: #000; border: 1px solid var(--border);
        display: flex; align-items: center; justify-content: center;
        font-weight: 800; font-size: 14px; color: var(--accent);
    }
    
    .card-main-title {
        background: transparent; border: none;
        font-size: 2.2rem; font-weight: 1000; color: #fff;
        letter-spacing: -2px; padding: 0; width: 100%; outline: none;
        text-transform: uppercase;
    }
    .card-main-title::placeholder { color: rgba(255,255,255,0.1); }

    /* Tile Groupings */
    .card-dashboard-grid {
        display: grid;
        grid-template-columns: 2fr 1.5fr 1.5fr;
        gap: 20px;
    }
    
    .dashboard-tile {
        background: rgba(0,0,0,0.3);
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        transition: all 0.3s;
    }
    .dashboard-tile:hover { background: rgba(255,255,255,0.02); border-color: rgba(255,255,255,0.1); }

    .tile-label { font-size: 0.65rem; font-weight: 800; letter-spacing: 3px; color: #4b5563; text-transform: uppercase; }
    
    /* Inputs */
    .dashboard-input {
        background: transparent; border: none;
        color: #fff; font-size: 2.4rem; font-weight: 900;
        width: 100%; padding: 0; outline: none; letter-spacing: -2px;
    }
    .input-sub-val { font-size: 0.75rem; font-weight: 600; color: #6b7280; margin-top: -6px; }

    .time-badge-container { display: flex; gap: 10px; align-items: center; margin-top: 10px; }
    .time-badge {
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--border);
        padding: 8px 12px; border-radius: 12px;
        font-size: 1.1rem; font-weight: 800; color: #fff;
        width: 90px; text-align: center; outline: none; transition: all 0.3s;
    }
    .time-badge:focus { border-color: var(--accent); background: rgba(0,102,255,0.15); box-shadow: 0 0 20px var(--accent-glow); }

    /* Remarks Area */
    .remarks-tile {
        grid-column: span 3;
        background: rgba(0,0,0,0.2);
        border: 1px dashed var(--border);
        border-radius: 20px;
        padding: 16px 24px;
        display: flex; align-items: center; gap: 20px;
    }
    .remarks-field {
        background: transparent; border: none; color: #9ca3af;
        width: 100%; font-size: 0.9rem; outline: none; resize: none; height: 24px;
        transition: all 0.3s;
    }
    .remarks-field:focus { color: #fff; }

    /* ─── ADD CARD BUTTON ─── */
    .btn-launcher {
        width: 100%; padding: 25px;
        background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(0,102,255,0.05));
        border: 2px dashed rgba(0,102,255,0.2);
        border-radius: 30px; color: var(--accent);
        font-size: 1rem; font-weight: 900; letter-spacing: 2px;
        cursor: pointer; transition: all 0.4s;
        display: flex; align-items: center; justify-content: center; gap: 15px;
        margin: 20px 0 50px 0;
    }
    .btn-launcher:hover { transform: scale(1.02); border-color: var(--accent); background: rgba(0,102,255,0.1); }

    /* ─── FOOTER TELEMETRY ─── */
    .telemetry-dashboard {
        background: var(--glass-panel);
        border: 1px solid var(--border);
        border-radius: 32px; padding: 40px;
        margin-bottom: 50px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    }
    .metric-ring-container { text-align: center; }
    .metric-val { font-size: 4rem; font-weight: 1000; letter-spacing: -4px; line-height: 1; }

    .btn-finalize {
        background: linear-gradient(135deg, var(--success), #065f46);
        border: none; color: white; padding: 40px;
        font-weight: 950; border-radius: 32px; width: 100%;
        font-size: 1.2rem; letter-spacing: 4px; text-transform: uppercase;
        box-shadow: 0 20px 50px rgba(16, 185, 129, 0.3);
        transition: all 0.4s;
        display: flex; flex-direction: column; align-items: center; gap: 15px;
    }
    .btn-finalize:hover { transform: translateY(-10px); box-shadow: 0 30px 70px rgba(16, 185, 129, 0.4); }
    /* ─── DYNAMIC RESPONSIVE HUD ─── */
    @@media (max-width: 1200px) {
        .card-dashboard-grid { grid-template-columns: 1fr 1fr; }
        .remarks-tile { grid-column: span 2; }
    }
    @@media (max-width: 800px) {
        .card-dashboard-grid { grid-template-columns: 1fr; }
        .remarks-tile { grid-column: span 1; }
        .exec-header { padding: 20px; flex-direction: column; align-items: flex-start !important; }
        .header-pill { width: 100%; }
        .telemetry-dashboard { padding: 20px; }
    }
</style>

<form asp-action="SaveExecution" method="post" id="execForm" class="px-3 pb-5">
    <input type="hidden" asp-for="Id" />

    <!-- ── HEADER ── -->
    <!-- ── HEADER HUD ── -->
    <div class="exec-header d-flex justify-content-between align-items-center flex-wrap gap-4 mt-3 fade-in-up">
        <div class="d-flex align-items-center gap-4">
            <div class="header-pill">
                <span class="lbl-small">Production Line</span>
                <div style="font-size: 2.4rem; font-weight: 1000; color: var(--accent); letter-spacing: -2px; line-height: 1;">@Model.MachineName</div>
            </div>
            <div class="header-pill">
                <span class="lbl-small">Reporting Date</span>
                <div style="font-size: 1.4rem; font-weight: 900; letter-spacing: -0.5px;">@Model.ExecutionDate.ToString("dd MMMM yyyy")</div>
            </div>
            <div class="header-pill">
                <span class="lbl-small">Current Shift</span>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge-shift" style="border-radius: 8px;">SHIFT @Model.Shift</span>
                    <span style="font-size: 1.4rem; font-weight: 900; color: #fff;">@Model.GroupName</span>
                </div>
            </div>
        </div>
        <div class="d-flex gap-3">
            <div style="width: 220px;">
                <span class="lbl-small">Operator PIC 1</span>
                <input type="text" asp-for="Pic1" class="pic-input" placeholder="Nama Lengkap" />
            </div>
            <div style="width: 220px;">
                <span class="lbl-small">Operator PIC 2</span>
                <input type="text" asp-for="Pic2" class="pic-input" placeholder="Nama Lengkap" />
            </div>
        </div>
    </div>

    <!-- ── DYNAMIC ACTIVITY HUD ── -->
    <div class="section-label fade-in-up" style="animation-delay: 0.1s;"><i class="bi bi-layers-half"></i> Aktivitas Produksi</div>

    <div id="cardContainer" class="fade-in-up" style="animation-delay: 0.2s;">
        @if(Model.Activities.Count == 0)
        {
            <div class="empty-state" id="emptyState">
                <div class="empty-icon"><i class="bi bi-slash-square"></i></div>
                <div class="empty-title">BELUM ADA DATA PLANNING</div>
                <div class="d-flex justify-content-center gap-3 mt-4">
                    <form asp-action="RegenerateActivities" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="header-pill text-white fw-bold" style="cursor:pointer; border-radius:12px;">MUAT DARI PLANNING</button>
                    </form>
                    <button type="button" onclick="addCard()" class="header-pill text-white fw-bold" style="cursor:pointer; border-radius:12px;">TAMBAH MANUAL</button>
                </div>
            </div>
        }

        @for(int i = 0; i < Model.Activities.Count; i++)
        {
            var act = Model.Activities[i];
            var isDandori = act.PartName1?.ToUpper().Contains("DANDORI") == true;
            <div class="act-card @(isDandori ? "is-dandori" : "is-prod")" id="card-@i">
                <!-- ID STRIP -->
                <div class="card-id-strip">
                    <div class="d-flex align-items-center gap-3">
                        <div class="card-num-circle">@(i+1)</div>
                        @if(isDandori) {
                            <div class="dandori-badge">DANDORI / SETUP</div>
                            <input type="hidden" name="activities[@i].PartName1" value="@act.PartName1" />
                        } else {
                            <div style="width: 400px;">
                                <input type="text" name="activities[@i].PartName1" value="@act.PartName1"
                                       class="card-main-title" placeholder="INPUT VIN CODE" />
                                <div class="lbl-small" style="color: #4b5563; margin-top: 4px;">REF PART: <span style="color:#94a3b8">@act.PartName2</span></div>
                            </div>
                        }
                    </div>
                    <button type="button" onclick="removeCard(this)" style="background:none; border:none; color:#4b5563; font-size:1.5rem; transition:0.3s;"><i class="bi bi-x-circle-fill"></i></button>
                    <input type="hidden" name="activities[@i].PartName2" value="@act.PartName2" />
                    <input type="hidden" name="activities[@i].Id" value="@act.Id" />
                </div>

                <!-- DASHBOARD TILES -->
                <div class="card-dashboard-grid">
                    <!-- QUANTITY TILE -->
                    <div class="dashboard-tile">
                        <span class="tile-label">OUTPUT ACTUAL</span>
                        <div class="d-flex align-items-baseline gap-2">
                            <input type="number" name="activities[@i].ActualQty" value="@act.ActualQty"
                                   class="dashboard-input act-qty" placeholder="0" @(isDandori?"readonly":"") />
                            <div class="input-sub-val">/ @(act.PlanQty ?? 0) PCS</div>
                        </div>
                        <input type="hidden" name="activities[@i].PlanQty" value="@act.PlanQty" class="plan-qty-input" />
                    </div>

                    <!-- DURATION TILE -->
                    <div class="dashboard-tile">
                        <span class="tile-label">WAKTU KERJA</span>
                        <div class="d-flex align-items-baseline gap-2">
                            <input type="number" name="activities[@i].ActualDurationMinutes" value="@act.ActualDurationMinutes"
                                   class="dashboard-input act-dur @(isDandori ? "act-dand" : "")" placeholder="0" />
                            <div class="input-sub-val">MENIT</div>
                        </div>
                        <div class="lbl-small" style="color:#4b5563;">PLAN: @act.PlanDurationMinutes MIN</div>
                    </div>

                    <!-- TIMELINE TILE -->
                    <div class="dashboard-tile">
                        <span class="tile-label">WINDOW TIMELINE</span>
                        <div class="time-badge-container">
                            <input type="text" name="activities[@i].ActualStart" value="@act.ActualStart"
                                   class="time-badge" placeholder="00:00" />
                            <div class="time-sep">SD</div>
                            <input type="text" name="activities[@i].ActualEnd" value="@act.ActualEnd"
                                   class="time-badge" placeholder="00:00" />
                        </div>
                        <div class="lbl-small" style="color:#4b5563;">SCHEDULED: @act.PlanStart - @act.PlanEnd</div>
                    </div>

                    <!-- REMARKS TILE -->
                    <div class="remarks-tile">
                        <i class="bi bi-chat-left-dots" style="color:var(--accent);"></i>
                        <textarea name="activities[@i].Remarks" class="remarks-field"
                                  placeholder="Catatan kendala / status...">@act.Remarks</textarea>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Launcher -->
    <button type="button" class="btn-launcher fade-in-up" onclick="addCard()" style="animation-delay: 0.3s;">
        <i class="bi bi-plus-square-fill"></i> TAMBAH AKTIVITAS MANUAL
    </button>

    <!-- ── ADVANCED TELEMETRY HUD ── -->
    <div class="section-label fade-in-up" style="animation-delay: 0.4s;"><i class="bi bi-broadcast"></i> Ringkasan Telemetri Produksi</div>

    <div class="row g-4 fade-in-up" style="animation-delay: 0.5s;">
        <div class="col-md-9">
            <div class="telemetry-dashboard">
                <div class="row g-4 align-items-center">
                    <div class="col-md-4 border-end border-white border-opacity-10 text-center">
                        <span class="tile-label">ACHIEVEMENT RATE</span>
                        <div class="metric-val mt-2" id="lblAchieve" style="color:var(--success);">0.0%</div>
                        <div class="achieve-bar mt-3">
                            <div class="achieve-fill" id="progressAchieve" style="width:0%"></div>
                        </div>
                        <div class="lbl-small" id="lblFreq">0 / 0 SESSIONS COMPLETED</div>
                    </div>
                    <div class="col-md-8 ps-4">
                        <div class="row g-4">
                            <!-- Production stats -->
                            <div class="col-6">
                                <div class="dashboard-tile" style="border-left: 2px solid var(--accent); background: rgba(0,102,255,0.03);">
                                    <span class="tile-label" style="color:var(--accent);">TOTAL PRODUKSI</span>
                                    <div class="d-flex align-items-baseline gap-2">
                                        <div class="metric-val" style="font-size:2.8rem; color:var(--accent);" id="lblActProd">0</div>
                                        <div class="input-sub-val" style="color:#3b82f6;">/ <span id="lblPlanProd">0</span> PCS</div>
                                    </div>
                                </div>
                            </div>
                            <!-- Dandori stats -->
                            <div class="col-6">
                                <div class="dashboard-tile" style="border-left: 2px solid var(--accent-orange); background: rgba(255,170,0,0.03);">
                                    <span class="tile-label" style="color:var(--accent-orange);">TOTAL DANDORI</span>
                                    <div class="d-flex align-items-baseline gap-2">
                                        <div class="metric-val" style="font-size:2.8rem; color:var(--accent-orange);" id="lblActDandori">0</div>
                                        <div class="input-sub-val" style="color:#fbbf24;">/ <span id="lblPlanDandori">0</span> MENIT</div>
                                    </div>
                                </div>
                            </div>
                            <!-- Machine Timings -->
                            <div class="col-12 mt-2">
                                <div class="remarks-tile" style="border:1px solid var(--border); background:rgba(0,0,0,0.2);">
                                    <div class="d-flex gap-4 border-end border-white border-opacity-10 pe-4">
                                        <div>
                                            <span class="lbl-small">START MESIN</span>
                                            <input type="text" asp-for="StartMesin" class="time-badge" style="width:110px; background:transparent;" placeholder="00:00" />
                                        </div>
                                        <div>
                                            <span class="lbl-small">STOP MESIN</span>
                                            <input type="text" asp-for="FinishMesin" class="time-badge" style="width:110px; background:transparent;" placeholder="00:00" />
                                        </div>
                                    </div>
                                    <div class="flex-grow-1 ps-2">
                                        <span class="lbl-small">LINE STOP (MENIT)</span>
                                        <input type="number" asp-for="LineStopMinutes" class="dashboard-input" style="font-size: 1.8rem; height: 35px; color:var(--danger);" placeholder="0" />
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 mt-2">
                                <span class="lbl-small text-danger">CATATAN KENDALA / DOWNTIME</span>
                                <textarea asp-for="LineStopNote" class="pic-input mt-2" style="height: 60px; resize: none; background: rgba(239, 68, 68, 0.03); border-color: rgba(239, 68, 68, 0.1);" placeholder="Jelaskan kendala mesin atau hambatan lainnya..."></textarea>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn-finalize h-100">
                <i class="bi bi-shield-lock-fill" style="font-size:4rem;"></i>
                SIMPAN LAPORAN
                <span class="lbl-small" style="color: rgba(255,255,255,0.5); opacity:0.7;">SYNC KE DATABASE PUSAT</span>
            </button>
        </div>
    </div>
</form>

@section Scripts {
<script>
$(document).ready(function() {
    function hitungTotal() {
        let planProd = 0, actProd = 0, planDandori = 0, actDandori = 0, freq = 0;

        $('.plan-qty-input').each(function() {
            let v = parseFloat($(this).val()); if(!isNaN(v)) planProd += v;
        });
        $('.act-qty').each(function() {
            let v = parseFloat($(this).val()); if(!isNaN(v)) actProd += v;
        });
        $('.act-dand').each(function() {
            freq++;
            let v = parseFloat($(this).val()); if(!isNaN(v)) actDandori += v;
        });
        // Plan dandori from labels
        $('.cell-plan').each(function() {
            let txt = $(this).text();
            if(txt.startsWith('Plan:')) {
                let v = parseFloat(txt.replace('Plan:','').replace('m','').replace('–','').split('–')[0].trim());
                // only for dandori cards: check parent card
                if($(this).closest('.act-card').hasClass('is-dandori')) {
                    if(!isNaN(v)) planDandori += v;
                }
            }
        });

        $('#lblPlanProd').text(planProd);
        $('#lblActProd').text(actProd);
        $('#lblPlanDandori').text(planDandori);
        $('#lblActDandori').text(actDandori);
        $('#lblFreq').text(freq + ' / ' + freq);

        let achieve = planProd > 0 ? (actProd / planProd) * 100 : 0;
        $('#lblAchieve').text(achieve.toFixed(1) + '%');
        $('#progressAchieve').css('width', Math.min(achieve, 100) + '%');

        let achieveEl = $('#lblAchieve');
        let barEl = $('#progressAchieve');
        if (achieve >= 100) {
            achieveEl.css('color', '#10b981'); barEl.css('background', '#10b981');
        } else if (achieve >= 80) {
            achieveEl.css('color', '#f59e0b'); barEl.css('background', '#f59e0b');
        } else {
            achieveEl.css('color', '#ef4444'); barEl.css('background', '#ef4444');
        }
    }

    $(document).on('input', '.act-qty, .act-dur, .plan-qty-input', hitungTotal);
    hitungTotal();
});

let cardIndex = @Model.Activities.Count;

function addCard() {
    document.getElementById('emptyState') && (document.getElementById('emptyState').style.display = 'none');
    const idx = cardIndex++;
    const num = document.querySelectorAll('.act-card').length + 1;

    const html = `
    <div class="act-card is-prod" id="card-manual-${idx}">
        <div class="card-id-strip">
            <div class="d-flex align-items-center gap-3">
                <div class="card-num-circle">${num}</div>
                <div style="width: 400px;">
                    <input type="text" name="activities[${idx}].PartName1"
                           class="card-main-title" placeholder="ENTER_VIN_CODE" />
                    <div class="lbl-small" style="color: #4b5563; margin-top: 4px;">REF: <span style="color:#94a3b8">MANUAL_ENTRY</span></div>
                </div>
            </div>
            <button type="button" onclick="removeCard(this)" style="background:none; border:none; color:#4b5563; font-size:1.5rem;"><i class="bi bi-x-circle-fill"></i></button>
            <input type="hidden" name="activities[${idx}].PartName2" value="N/A" />
            <input type="hidden" name="activities[${idx}].Id" value="0" />
        </div>
        <div class="card-dashboard-grid">
            <div class="dashboard-tile">
                <span class="tile-label">OUTPUT_VOLUME</span>
                <div class="d-flex align-items-baseline gap-2">
                    <input type="number" name="activities[${idx}].ActualQty" class="dashboard-input act-qty" placeholder="0" />
                    <div class="input-sub-val">UNITS</div>
                </div>
                <input type="hidden" name="activities[${idx}].PlanQty" value="0" class="plan-qty-input" />
            </div>
            <div class="dashboard-tile">
                <span class="tile-label">TIME_INVESTMENT</span>
                <div class="d-flex align-items-baseline gap-2">
                    <input type="number" name="activities[${idx}].ActualDurationMinutes" class="dashboard-input act-dur" placeholder="0" />
                    <div class="input-sub-val">MINUTES</div>
                </div>
            </div>
            <div class="dashboard-tile">
                <span class="tile-label">EXECUTION_WINDOW</span>
                <div class="time-badge-container">
                    <input type="text" name="activities[${idx}].ActualStart" class="time-badge" placeholder="00:00" />
                    <div class="time-sep">TO</div>
                    <input type="text" name="activities[${idx}].ActualEnd" class="time-badge" placeholder="00:00" />
                </div>
            </div>
            <div class="remarks-tile">
                <i class="bi bi-chat-left-dots" style="color:var(--accent);"></i>
                <textarea name="activities[${idx}].Remarks" class="remarks-field" placeholder="ADD_SITUATION_LOG..."></textarea>
            </div>
        </div>
    </div>`;

    document.getElementById('cardContainer').insertAdjacentHTML('beforeend', html);
    updateCardNumbers();
}

function removeCard(btn) {
    btn.closest('.act-card').remove();
    updateCardNumbers();
}

function updateCardNumbers() {
    document.querySelectorAll('.act-card .card-num').forEach((el, i) => {
        el.textContent = i + 1;
    });
}
</script>
}
