@model VelastoProductionSystem.Models.DailyPlanExecution

@{
    ViewData["Title"] = "Tablet Laporan Aktual Produksi";
}

<style>
    :root {
        --glass-bg: rgba(17, 24, 39, 0.8);
        --accent: #3b82f6;
        --accent-orange: #f59e0b;
        --success: #10b981;
    }
    body { background: #0b0f1a; color: #e2e8f0; font-family: 'Inter', sans-serif; }

    .header-info {
        background: var(--glass-bg);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 20px;
        padding: 24px;
        margin-bottom: 24px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }

    .table-exec { width: 100%; border-collapse: separate; border-spacing: 0 8px; }
    .table-exec thead th {
        background: #0f172a;
        color: #94a3b8;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        padding: 15px 12px;
        border-bottom: 2px solid #1e293b;
    }
    .tr-exec { background: rgba(30, 41, 59, 0.4); border-radius: 12px; transition: all 0.2s; }
    .tr-exec:hover { background: rgba(30, 41, 59, 0.6); }
    .tr-exec-dandori { border-left: 5px solid var(--accent-orange); }
    .tr-exec-prod { border-left: 5px solid var(--accent); }

    .table-exec td { padding: 15px 12px; vertical-align: middle; }
    
    .tablet-input {
        background: rgba(0, 0, 0, 0.5);
        border: 1px solid rgba(255, 255, 255, 0.12);
        color: #fff;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 1.1rem;
        width: 100%;
        text-align: center;
        transition: all 0.3s;
    }
    .tablet-input:focus { border-color: var(--accent); outline: none; background: #000; box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2); }
    
    .lbl-small { font-size: 0.7rem; color: #94a3b8; text-transform: uppercase; display: block; margin-bottom: 5px; font-weight: 600; }
    
    .summary-box {
        background: #0f172a;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        overflow: hidden;
        height: 100%;
    }
    .summary-header {
        background: rgba(31, 41, 55, 0.8);
        padding: 10px 15px;
        font-size: 0.8rem;
        font-weight: 800;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        color: #94a3b8;
        text-align: center;
    }
    .summary-body { padding: 20px; text-align: center; }
    .summary-val { font-size: 2.2rem; font-weight: 900; color: #fff; line-height: 1; }
    .summary-unit { font-size: 0.85rem; color: #64748b; margin-top: 5px; font-weight: bold; }

    .btn-save {
        background: linear-gradient(135deg, #10b981, #059669);
        border: none;
        color: white;
        padding: 20px;
        font-weight: 800;
        border-radius: 16px;
        width: 100%;
        text-transform: uppercase;
        letter-spacing: 2px;
        box-shadow: 0 10px 25px rgba(16, 185, 129, 0.4);
        transition: transform 0.2s;
    }
    .btn-save:active { transform: scale(0.98); }

    .badge-info { background: rgba(59, 130, 246, 0.15); color: #60a5fa; border: 1px solid rgba(59, 130, 246, 0.3); padding: 5px 12px; border-radius: 6px; font-size: 0.9rem; }
</style>

<form asp-action="SaveExecution" method="post" id="executionForm" class="fade-in px-3 pb-5">
    <input type="hidden" asp-for="Id" />
    
    <!-- Header Infographic -->
    <div class="header-info d-flex justify-content-between align-items-center flex-wrap gap-4 mt-3">
        <div class="d-flex align-items-center gap-5">
            <div>
                <span class="lbl-small">Production Line</span>
                <div class="fw-bold text-info fs-3">@Model.MachineName</div>
            </div>
            <div>
                <span class="lbl-small">Current Date</span>
                <div class="fw-bold fs-4">@Model.ExecutionDate.ToString("dd MMMM yyyy")</div>
            </div>
            <div>
                <span class="lbl-small">Shift / Regu</span>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge-info">SHIFT @Model.Shift</span>
                    <span class="fw-bold fs-4 ms-2">@Model.GroupName</span>
                </div>
            </div>
        </div>
        <div class="d-flex gap-4">
            <div style="width: 220px;">
                <span class="lbl-small">Operator PIC 1 (Manual)</span>
                <input type="text" asp-for="Pic1" class="tablet-input text-start" placeholder="Nama Lengkap" />
            </div>
            <div style="width: 220px;">
                <span class="lbl-small">Operator PIC 2 (Manual)</span>
                <input type="text" asp-for="Pic2" class="tablet-input text-start" placeholder="Nama Lengkap" />
            </div>
        </div>
    </div>

    <!-- Main Entry Table -->
    <div class="table-responsive">
        <table class="table-exec">
            <thead>
                <tr>
                    <th style="width: 60px;" class="text-center">No</th>
                    <th style="width: 150px;">VIN Code (Auto)</th>
                    <th style="width: 200px;">Part Nomor (Auto)</th>
                    <th style="width: 120px;">Qty Plan (Man)</th>
                    <th style="width: 140px;" class="text-primary">Act Prod (Man)</th>
                    <th style="width: 110px;">Duration</th>
                    <th style="width: 280px;">Actual Time (Input Jam)</th>
                    <th>Remarks / Catatan</th>
                </tr>
            </thead>
            <tbody>
                @for(int i=0; i<Model.Activities.Count; i++)
                {
                    var act = Model.Activities[i];
                    var isDandori = act.PartName1?.ToUpper().Contains("DANDORI") == true;
                    
                    <tr class="tr-exec @(isDandori ? "tr-exec-dandori" : "tr-exec-prod")">
                        <td class="text-center fw-bold text-white-50">@(i + 1)</td>
                        <td class="fw-bold">
                            <span class="text-white">@(isDandori ? "DANDORI" : act.PartName1)</span>
                        </td>
                        <td class="small">
                            <span class="text-white-50">@(isDandori ? "SETUP MESIN" : act.PartName2)</span>
                        </td>
                        <td>
                            @if(!isDandori) {
                                <input type="number" name="activities[@i].PlanQty" value="@act.PlanQty" class="tablet-input plan-qty-input fw-bold" style="background: rgba(255,255,255,0.03);" />
                            } else {
                                <input type="hidden" name="activities[@i].PlanQty" value="0" class="plan-qty-input" />
                                <div class="text-center text-white-50 small opacity-50">-</div>
                            }
                        </td>
                        <td>
                            @if(!isDandori) {
                                <input type="number" name="activities[@i].ActualQty" value="@act.ActualQty" class="tablet-input act-qty fw-bold" style="border-color: var(--accent); background: rgba(59, 130, 246, 0.1);" />
                            } else {
                                <input type="hidden" name="activities[@i].ActualQty" value="0" class="act-qty" />
                                <div class="text-center text-white-50 small opacity-50">-</div>
                            }
                        </td>
                        <td class="text-center">
                            <div class="lbl-small mb-1">Plan: @act.PlanDurationMinutes m</div>
                            <input type="number" name="activities[@i].ActualDurationMinutes" value="@act.ActualDurationMinutes" class="tablet-input act-dur @(isDandori?"act-dand":"") px-1" style="height: 38px; font-size:1rem; border-color: @(isDandori ? "var(--accent-orange)" : "rgba(255,255,255,0.1)");" />
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <input type="text" name="activities[@i].ActualStart" value="@act.ActualStart" class="tablet-input" placeholder="07:30" />
                                <span class="text-white-50 small">~</span>
                                <input type="text" name="activities[@i].ActualEnd" value="@act.ActualEnd" class="tablet-input" placeholder="08:30" />
                            </div>
                            <div class="text-center text-white-50 mt-1" style="font-size: 0.7rem;">Rencana: @act.PlanStart - @act.PlanEnd</div>
                        </td>
                        <td>
                            <input type="text" name="activities[@i].Remarks" value="@act.Remarks" class="tablet-input text-start" placeholder="Ketik kendala..." />
                            <input type="hidden" name="activities[@i].Id" value="@act.Id" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Smart Footer Summary -->
    <div class="row g-4 mt-2">
        <div class="col-md-9">
            <div class="header-info" style="margin-bottom:0; padding: 30px;">
                <div class="row g-4 text-center">
                    <div class="col-6 col-md-3">
                        <div class="summary-box">
                            <div class="summary-header">PLAN PRODUKSI</div>
                            <div class="summary-body">
                                <div class="summary-val text-white" id="lblPlanProd">0</div>
                                <div class="summary-unit">TOTAL PCS</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="summary-box" style="border-color: var(--accent);">
                            <div class="summary-header text-primary">ACTUAL PRODUKSI</div>
                            <div class="summary-body">
                                <div class="summary-val text-primary" id="lblActProd">0</div>
                                <div class="summary-unit">TOTAL PCS</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="summary-box">
                            <div class="summary-header">PLAN DANDORI</div>
                            <div class="summary-body">
                                <div class="summary-val text-white" id="lblPlanDandori">0</div>
                                <div class="summary-unit">TOTAL MENIT</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="summary-box" style="border-color: var(--accent-orange);">
                            <div class="summary-header text-warning">ACTUAL DANDORI</div>
                            <div class="summary-body">
                                <div class="summary-val text-warning" id="lblActDandori">0</div>
                                <div class="summary-unit">TOTAL MENIT</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-5 mt-3 align-items-center">
                    <div class="col-md-6 border-end border-secondary border-opacity-10">
                         <div class="row g-3">
                             <div class="col-6">
                                 <label class="lbl-small">Start Mesin (Manual)</label>
                                 <input type="text" asp-for="StartMesin" class="tablet-input" placeholder="16:30" />
                             </div>
                             <div class="col-6">
                                 <label class="lbl-small">Finish Mesin (Manual)</label>
                                 <input type="text" asp-for="FinishMesin" class="tablet-input" placeholder="01:30" />
                             </div>
                         </div>
                         <div class="mt-4">
                             <label class="lbl-small text-danger">Line Stop Note / Alasan Mesin Berhenti (Manual)</label>
                             <textarea asp-for="LineStopNote" class="tablet-input text-start" rows="2" style="font-size: 1rem;" placeholder="Jelaskan kendala mesin di sini..."></textarea>
                         </div>
                    </div>
                    <div class="col-md-6 px-lg-5 text-center">
                        <div class="d-flex justify-content-between align-items-end mb-2">
                            <span class="fs-5 fw-bold text-white-50">Production Achievement</span>
                            <div class="display-6 fw-bold text-success mb-0" id="lblAchieve">0%</div>
                        </div>
                        <div class="progress mb-4" style="height: 10px; background: rgba(255,255,255,0.05); border-radius: 10px;">
                            <div id="progressAchieve" class="progress-bar progress-bar-striped progress-bar-animated bg-success" role="progressbar" style="width: 0%"></div>
                        </div>
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="p-3 rounded-4 bg-black bg-opacity-30 border border-secondary border-opacity-10 shadow-sm">
                                    <span class="lbl-small text-danger mb-2">Total Line Stop</span>
                                    <input type="number" asp-for="LineStopMinutes" class="tablet-input border-0 bg-transparent text-danger fw-bold fs-3 p-0 m-0" placeholder="0" />
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-3 rounded-4 bg-black bg-opacity-30 border border-secondary border-opacity-10 shadow-sm">
                                    <span class="lbl-small mb-2">Frekuensi Dandori</span>
                                    <div class="fs-3 text-white fw-bold mb-0" id="lblFreq">0 / 0</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn-save h-100 d-flex flex-column align-items-center justify-content-center gap-3">
                <i class="bi bi-check-all" style="font-size: 4rem;"></i>
                <div class="fs-4">SIMPAN LAPORAN</div>
                <div class="small fw-normal opacity-75 text-center">Data akan disimpan ke riwayat produksi</div>
            </button>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        $(document).ready(function() {
            function hitungTotal() {
                let planProd = 0;
                let actProd = 0;
                let planDandori = 0;
                let actDandori = 0;
                let freq = 0;

                // Sum Plan Production Qty
                $('.plan-qty-input').each(function() {
                    let val = parseFloat($(this).val());
                    if(!isNaN(val)) planProd += val;
                });
                
                // Sum Actual Production Qty
                $('.act-qty').each(function() {
                    let val = parseFloat($(this).val());
                    if(!isNaN(val)) actProd += val;
                });

                // Sum Plan/Act Dandori and Frequency
                freq = $('tr.tr-exec-dandori').length;
                $('tr.tr-exec-dandori').each(function() {
                    let planText = $(this).find('.lbl-small').text().replace('Plan:','').replace('m','').trim();
                    let planVal = parseFloat(planText);
                    if(!isNaN(planVal)) planDandori += planVal;
                    
                    let actVal = parseFloat($(this).find('.act-dur').val());
                    if(!isNaN(actVal)) actDandori += actVal;
                });

                $('#lblPlanProd').text(planProd);
                $('#lblActProd').text(actProd);
                $('#lblPlanDandori').text(planDandori);
                $('#lblActDandori').text(actDandori);
                $('#lblFreq').text(freq + ' / ' + freq);

                let achieve = 0;
                if(planProd > 0) achieve = (actProd / planProd) * 100;
                
                let achieveElem = $('#lblAchieve');
                achieveElem.text(achieve.toFixed(1) + "%");
                $('#progressAchieve').css('width', Math.min(achieve, 100) + '%');
                
                if(achieve >= 100) {
                    achieveElem.attr('class', 'display-6 fw-bold text-success mb-0');
                    $('#progressAchieve').attr('class', 'progress-bar bg-success');
                } else if(achieve >= 80) {
                    achieveElem.attr('class', 'display-6 fw-bold text-warning mb-0');
                    $('#progressAchieve').attr('class', 'progress-bar bg-warning');
                } else {
                    achieveElem.attr('class', 'display-6 fw-bold text-danger mb-0');
                    $('#progressAchieve').attr('class', 'progress-bar bg-danger');
                }
            }

            $('.act-qty, .act-dur, .plan-qty-input').on('input', hitungTotal);
            hitungTotal(); // Initial run
        });
    </script>
}
