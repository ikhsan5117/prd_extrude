@model VelastoProductionSystem.Models.DailyPlanExecution

@{
    ViewData["Title"] = "Tablet Execution App";
}

<style>
    .app-header {
        background: linear-gradient(135deg, #1e293b, #0f172a);
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        border: 1px solid rgba(255,255,255,0.05);
        margin-bottom: 25px;
    }
    .app-header h3 { font-size: 1.2rem; color: #94a3b8; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 15px; }
    
    .task-card {
        background: #1e2229;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.05);
        box-shadow: 0 4px 20px rgba(0,0,0,0.2);
        margin-bottom: 20px;
        transition: transform 0.2s, box-shadow 0.2s;
        overflow: hidden;
    }
    .task-card:focus-within {
        border-color: #3b82f6;
        box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.3);
    }
    
    .card-header-dandori { background: rgba(245, 158, 11, 0.15); border-bottom: 1px solid rgba(245, 158, 11, 0.2); border-left: 4px solid #f59e0b; padding: 15px 20px; }
    .card-header-prod { background: rgba(59, 130, 246, 0.15); border-bottom: 1px solid rgba(59, 130, 246, 0.2); border-left: 4px solid #3b82f6; padding: 15px 20px; }
    
    .plan-badge {
        font-size: 0.8rem;
        background: rgba(255,255,255,0.1);
        padding: 6px 12px;
        border-radius: 8px;
        color: #cbd5e1;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }
    
    .tablet-input {
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #fff;
        border-radius: 10px;
        padding: 12px 15px;
        font-size: 1.1rem;
        width: 100%;
        transition: all 0.3s;
    }
    .tablet-input:focus {
        background: rgba(0, 0, 0, 0.5);
        border-color: #3b82f6;
        outline: none;
    }
    .input-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #94a3b8;
        font-weight: bold;
        margin-bottom: 8px;
        display: block;
    }
    
    .app-footer {
        background: #111827;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.05);
        padding: 24px;
        margin-top: 30px;
    }
    
    .stat-box {
        background: rgba(255,255,255,0.03);
        border-radius: 12px;
        padding: 15px;
        text-align: center;
        border: 1px solid rgba(255,255,255,0.05);
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    .stat-value { font-size: 1.8rem; font-weight: 800; color: #fff; line-height: 1.2; }
    .stat-label { font-size: 0.75rem; color: #94a3b8; text-transform: uppercase; margin-top: 5px; }
    
    .fab-save {
        border-radius: 12px;
        padding: 15px 0;
        font-size: 1.2rem;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 1px;
        box-shadow: 0 10px 25px rgba(16, 185, 129, 0.4);
        width: 100%;
    }
</style>

<form asp-action="SaveExecution" method="post" id="executionForm" class="fade-in">
    <input type="hidden" asp-for="Id" />
    
    <!-- App Header -->
    <div class="app-header">
        <h3 class="fw-bold mb-3"><i class="bi bi-tablet-landscape text-primary me-2"></i> Extrude Daily Planning</h3>
        <div class="row g-3">
            <div class="col-6 col-md-3">
                <div class="text-white-50 small text-uppercase">Line Mesin</div>
                <div class="fs-5 fw-bold text-info">@Model.MachineName</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="text-white-50 small text-uppercase">Tanggal</div>
                <div class="fs-5 fw-bold text-white">@Model.ExecutionDate.ToString("dd MMM yyyy")</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="text-white-50 small text-uppercase">Group / Shift</div>
                <div class="fs-5 fw-bold text-white">@Model.GroupName <span class="badge bg-secondary ms-2">S-@Model.Shift</span></div>
            </div>
            <div class="col-6 col-md-3">
                <div class="text-white-50 small text-uppercase">Operator PIC</div>
                <div class="d-flex gap-2 mt-1">
                    <input type="text" asp-for="Pic1" class="tablet-input py-1 px-2" style="font-size: 0.9rem" placeholder="PIC 1" />
                    <input type="text" asp-for="Pic2" class="tablet-input py-1 px-2" style="font-size: 0.9rem" placeholder="PIC 2" />
                </div>
            </div>
        </div>
    </div>

    <!-- Main Task Cards (Tablet Optimized) -->
    <div class="row">
        @for(int i=0; i<Model.Activities.Count; i++)
        {
            var act = Model.Activities[i];
            var isDandori = act.PartName1 != null && act.PartName1.ToUpper().Contains("DANDORI");
            var title = isDandori ? "DANDORI (SETUP MESIN)" : $"PRODUKSI: {act.PartName2} {act.PartName1}";
            var headerClass = isDandori ? "card-header-dandori" : "card-header-prod";
            var iconClass = isDandori ? "bi-tools text-warning" : "bi-box-seam text-primary";
            
            <div class="col-12">
                <div class="task-card">
                    <div class="@headerClass d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div class="d-flex align-items-center gap-3">
                            <div class="fs-4 fw-bold text-white opacity-50">#@(i+1)</div>
                            <div>
                                <h5 class="fw-bold text-white mb-0"><i class="bi @iconClass me-2"></i>@title</h5>
                            </div>
                        </div>
                        <div class="d-flex gap-2 flex-wrap">
                            @if(act.PlanQty > 0) {
                                <div class="plan-badge q-plan"><i class="bi bi-bullseye"></i> Target Qty: <strong class="text-white p-q">@act.PlanQty</strong> pcs</div>
                            }
                            <div class="plan-badge"><i class="bi bi-stopwatch"></i> Durasi Plan: <strong class="text-white d-dand">@act.PlanDurationMinutes</strong> m</div>
                            <div class="plan-badge"><i class="bi bi-clock"></i> Waktu Plan: <strong class="text-white">@act.PlanStart - @act.PlanEnd</strong></div>
                        </div>
                    </div>
                    
                    <div class="p-3 p-md-4">
                        <input type="hidden" name="activities[@i].Id" value="@act.Id" />
                        <div class="row g-3">
                            <!-- Data Aktual Kiri -->
                            <div class="col-md-5 border-end-md border-secondary border-opacity-25 pe-md-4">
                                <div class="row g-3">
                                    <div class="col-6">
                                        <label class="input-label"><i class="bi bi-play-circle text-success me-1"></i> Jam Mulai Act</label>
                                        <input type="text" name="activities[@i].ActualStart" value="@act.ActualStart" class="tablet-input" placeholder="00:00" />
                                    </div>
                                    <div class="col-6">
                                        <label class="input-label"><i class="bi bi-stop-circle text-danger me-1"></i> Jam Selesai Act</label>
                                        <input type="text" name="activities[@i].ActualEnd" value="@act.ActualEnd" class="tablet-input" placeholder="00:00" />
                                    </div>
                                    <div class="col-12">
                                        <label class="input-label"><i class="bi bi-hourglass-split text-info me-1"></i> Durasi Aktual (Menit)</label>
                                        <input type="number" name="activities[@i].ActualDurationMinutes" value="@act.ActualDurationMinutes" class="tablet-input act-dur @(isDandori?"act-dand":"")" placeholder="Cth: 15" />
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Data Aktual Kanan -->
                            <div class="col-md-7 ps-md-4">
                                <div class="row g-3">
                                    <div class="col-12 col-md-6">
                                        @if(!isDandori) {
                                            <label class="input-label text-primary"><i class="bi bi-check2-circle me-1"></i> QTY HASIL PRODUKSI ACTUAL</label>
                                            <input type="number" name="activities[@i].ActualQty" value="@act.ActualQty" class="tablet-input act-qty border-primary fw-bold" style="font-size: 1.5rem; height: 60px;" placeholder="0" />
                                        } else {
                                            <div class="d-flex align-items-center justify-content-center h-100 bg-dark rounded-3 border border-secondary border-opacity-25">
                                                <div class="text-white-50 small py-3"><i class="bi bi-info-circle me-1"></i> Tidak ada target Qty untuk Dandori</div>
                                            </div>
                                        }
                                    </div>
                                    <div class="col-12 col-md-6">
                                        <label class="input-label"><i class="bi bi-chat-left-text me-1"></i> Remarks / Kendala</label>
                                        <textarea name="activities[@i].Remarks" class="tablet-input" rows="2" style="height: 60px; resize: none;" placeholder="Catatan jik ada...">@act.Remarks</textarea>
                                    </div>
                                </div>
                            </div>
                            
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Footer App (Line Stop & Kalkulasi) -->
    <div class="app-footer shadow">
        <h5 class="text-white fw-bold mb-4"><i class="bi bi-calculator text-warning me-2"></i> Kalkulasi Pencapaian & Kesimpulan</h5>
        <div class="row g-4">
            <!-- Line Stop Form -->
            <div class="col-md-4 border-end-md border-secondary border-opacity-25">
                <div class="mb-3">
                    <label class="input-label text-danger"><i class="bi bi-exclamation-octagon-fill me-1"></i> Total Line Stop (Menit)</label>
                    <input type="number" asp-for="LineStopMinutes" class="tablet-input border-danger" placeholder="0" />
                </div>
                <div class="mb-3">
                    <label class="input-label text-warning"><i class="bi bi-journal-text me-1"></i> Catatan Line Stop / Kendala Mesin</label>
                    <textarea asp-for="LineStopNote" class="tablet-input" rows="3" placeholder="Deskripsikan alasan line stop di sini..."></textarea>
                </div>
                <div class="row g-2">
                    <div class="col-6">
                        <label class="input-label">Jam Start</label>
                        <input type="text" asp-for="StartMesin" class="tablet-input" placeholder="14:30" />
                    </div>
                    <div class="col-6">
                        <label class="input-label">Jam Finish</label>
                        <input type="text" asp-for="FinishMesin" class="tablet-input" placeholder="22:30" />
                    </div>
                </div>
            </div>
            
            <!-- Kalkulasi Boxes -->
            <div class="col-md-5">
                <div class="row g-3 h-100">
                    <div class="col-6">
                        <div class="stat-box">
                            <div class="stat-value text-white" id="lblPlanProd">0</div>
                            <div class="stat-label">Plan Qty Prod</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="stat-box" style="background: rgba(59, 130, 246, 0.1); border-color: rgba(59, 130, 246, 0.3);">
                            <div class="stat-value text-primary" id="lblActProd">0</div>
                            <div class="stat-label text-primary">Actual Qty Prod</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="stat-box">
                            <div class="stat-value text-white" id="lblPlanDandori">0<span class="fs-6">m</span></div>
                            <div class="stat-label">Plan Dandori</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="stat-box" style="background: rgba(245, 158, 11, 0.1); border-color: rgba(245, 158, 11, 0.3);">
                            <div class="stat-value text-warning" id="lblActDandori">0<span class="fs-6">m</span></div>
                            <div class="stat-label text-warning">Actual Dandori</div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Achievement -->
            <div class="col-md-3 d-flex flex-column">
                <div class="stat-box flex-grow-1 mb-3" style="background: rgba(16, 185, 129, 0.1); border-color: rgba(16, 185, 129, 0.3);">
                    <div class="stat-value text-success" id="lblAchieve" style="font-size: 3rem;">0%</div>
                    <div class="stat-label text-success fw-bold fs-6">ACHIEVEMENT QTY</div>
                </div>
                <button type="submit" class="btn btn-success fab-save">
                    <i class="bi bi-floppy-fill me-2"></i> SIMPAN DATA
                </button>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        $(document).ready(function() {
            function hitungTotal() {
                let planProd = 0;
                let actProd = 0;
                let planDandori = 0;
                let actDandori = 0;

                // Hitung Plan Prod
                $('.p-q').each(function() {
                    let val = parseFloat($(this).text().trim());
                    if(!isNaN(val)) planProd += val;
                });
                
                // Hitung Act Prod
                $('.act-qty').each(function() {
                    let val = parseFloat($(this).val());
                    if(!isNaN(val)) actProd += val;
                });

                // Hitung Plan Dandori
                $('.d-dand').each(function() {
                    let val = parseFloat($(this).text().trim());
                    if(!isNaN(val)) planDandori += val;
                });

                // Hitung Act Dandori
                $('.act-dand').each(function() {
                    let val = parseFloat($(this).val());
                    if(!isNaN(val)) actDandori += val;
                });

                $('#lblPlanProd').text(planProd);
                $('#lblActProd').text(actProd);
                $('#lblPlanDandori').html(planDandori + '<span class="fs-6">m</span>');
                $('#lblActDandori').html(actDandori + '<span class="fs-6">m</span>');

                let achieve = 0;
                if(planProd > 0) achieve = (actProd / planProd) * 100;
                
                let achieveElem = $('#lblAchieve');
                achieveElem.text(achieve.toFixed(1) + "%");
                
                // Ganti warna otomatis berdasarkan pencapaian
                if(achieve >= 100) {
                    achieveElem.removeClass('text-danger text-warning').addClass('text-success');
                } else if(achieve >= 80) {
                    achieveElem.removeClass('text-danger text-success').addClass('text-warning');
                } else {
                    achieveElem.removeClass('text-warning text-success').addClass('text-danger');
                }
            }

            $('.act-qty, .act-dur').on('input', hitungTotal);
            hitungTotal();
        });
    </script>
}
