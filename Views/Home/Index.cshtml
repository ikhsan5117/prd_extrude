@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .pulse-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-weight: 700;
        letter-spacing: 0.5px;
        padding: 4px 12px;
        background: rgba(16, 185, 129, 0.1);
        border: 1px solid rgba(16, 185, 129, 0.2);
        color: #10b981;
    }
    
    .status-dot.pulse {
        animation: pulse-green 2s infinite;
        box-shadow: 0 0 0 rgba(16, 185, 129, 0.4);
        border-radius: 50%;
    }

    @@keyframes pulse-green {
        0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7); }
        70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
    }

    .animate-slideInRight {
        animation: slideInRight 0.5s ease-out;
    }

    @@keyframes slideInRight {
        from { transform: translateX(100%); opacity: 0; }
        to { transform: translateX(0); opacity: 1; }
    }

    .xsmall { font-size: 0.7rem; }
    .uppercase { text-transform: uppercase; }
    .tracking-wider { letter-spacing: 0.05em; }

    .card-icon-bg {
        position: absolute;
        bottom: -25px;
        right: -10px;
        font-size: 7.5rem;
        opacity: 0.12;
        transform: rotate(-15deg);
        pointer-events: none;
        transition: all 0.5s ease;
    }
    
    .card:hover .card-icon-bg {
        transform: rotate(-5deg) scale(1.1);
        opacity: 0.15;
    }
</style>

<!-- Decorative Blobs -->
<div class="decoration-blob blob-1"></div>
<div class="decoration-blob blob-2"></div>

<!-- SignalR Notification Toast -->
<div id="updateToast" class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 9999; display: none;">
    <div class="glass-panel p-3 border-info border-opacity-50 shadow-lg d-flex align-items-center gap-3 animate-slideInRight" style="background: rgba(14, 165, 233, 0.2) !important; min-width: 300px;">
        <div class="status-dot pulse" style="width: 12px; height: 12px; background: #00ccff;"></div>
        <div>
            <div class="fw-900 text-info-glow xsmall tracking-widest uppercase mb-1">DATA SYNC COMPLETE</div>
            <div class="text-white small fw-bold">Data Produksi Baru Masuk!</div>
        </div>
        <button type="button" class="btn-close btn-close-white ms-auto small" onclick="$('#updateToast').fadeOut()"></button>
    </div>
</div>

<!-- Dashboard Header -->
<div class="dashboard-header mb-3 animate-fadeInUp">
    <div>
        <h1 class="dashboard-title h-auto py-2">
            Production Cockpit <span class="text-white-50 fw-light">v4.0</span>
        </h1>
        <p class="dashboard-subtitle py-2 shadow-sm d-flex align-items-center justify-content-center gap-3">
            <span><i class="bi bi-cpu-fill"></i> REAL-TIME MANUFACTURING INTELLIGENCE &bull; FACILITY 4</span>
            <span id="signalrStatus" class="badge rounded-pill bg-danger-subtle text-danger border border-danger-subtle xsmall px-2" style="font-size: 0.55rem;">
                <span class="status-dot me-1" style="width: 6px; height: 6px; display: inline-block; background: currentColor; border-radius: 50%;"></span>
                OFFLINE
            </span>
        </p>
    </div>
</div>


<!-- SPC Filters -->
<div class="px-0 pb-1 mb-4 bg-transparent animate-fadeInUp">
    <div class="row g-2">
        <div class="col-md-4">
            <label class="text-white-50 xsmall uppercase tracking-wider mb-1 ms-1" style="font-size: 0.6rem; font-weight: 800; opacity: 0.6;">PILIH PRODUK</label>
            <select id="productFilter" class="form-select form-select-sm bg-dark border-white border-opacity-10 text-white rounded-3 py-2">
                <option value="">Semua Produk</option>
            </select>
        </div>
        <div class="col-md-4">
            <label class="text-white-50 xsmall uppercase tracking-wider mb-1 ms-1" style="font-size: 0.6rem; font-weight: 800; opacity: 0.6;">KRITERIA DIMENSI</label>
            <select id="criteriaFilter" class="form-select form-select-sm bg-dark border-white border-opacity-10 text-white rounded-3 py-2">
                <option value="InnerThickness">Thickness</option>
                <option value="Diameter">Diameter</option>
                <option value="TotalThickness">Total Thickness</option>
                <option value="SpiralPitch">Spiral Pitch</option>
            </select>
        </div>
        <div class="col-md-4">
            <label class="text-white-50 xsmall uppercase tracking-wider mb-1 ms-1" style="font-size: 0.6rem; font-weight: 800; opacity: 0.6;">RENTANG WAKTU</label>
            <select id="rangeFilter" class="form-select form-select-sm bg-dark border-white border-opacity-10 text-white rounded-3 py-2">
                <option value="7">7 Hari Terakhir</option>
                <option value="30" selected>30 Hari Terakhir</option>
                <option value="90">90 Hari Terakhir</option>
            </select>
        </div>
    </div>
</div>

<!-- KPI Cards (SPC Metrics) -->
<div class="row g-3 mb-3">
    <div class="col-lg-4 animate-fadeInUp delay-1">
        <div class="card glass-panel h-100 border-0" style="background: linear-gradient(145deg, rgba(16, 185, 129, 0.1), rgba(0,0,0,0.4)) !important;">
            <div class="card-body text-center p-3">
                <i class="bi bi-gear-fill card-icon-bg"></i>
                <p class="text-white-50 small xsmall uppercase tracking-wider mb-2">CP (Process Capability)</p>
                <h2 id="cpValue" class="fs-1 fw-bold text-success mb-2">0.00</h2>
                <div id="cpBadge" class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3 py-2">Capable</div>
            </div>
        </div>
    </div>
    <div class="col-lg-4 animate-fadeInUp delay-2">
        <div class="card glass-panel h-100 border-0" style="background: linear-gradient(145deg, rgba(245, 158, 11, 0.1), rgba(0,0,0,0.4)) !important;">
            <div class="card-body text-center p-3">
                <i class="bi bi-speedometer2 card-icon-bg"></i>
                <p class="text-white-50 small xsmall uppercase tracking-wider mb-2">CPK (Process Capability Index)</p>
                <h2 id="cpkValue" class="fs-1 fw-bold text-warning mb-2">0.00</h2>
                <div id="cpkBadge" class="badge bg-warning-subtle text-warning border border-warning-subtle rounded-pill px-3 py-2">Not Capable</div>
            </div>
        </div>
    </div>
    <div class="col-lg-4 animate-fadeInUp delay-3">
        <div class="card glass-panel h-100 border-0">
            <div class="card-body p-3 d-flex flex-column justify-content-center">
                <i class="bi bi-clipboard-data-fill card-icon-bg"></i>
                <p class="text-white-50 small xsmall uppercase tracking-wider mb-3 text-center">Ringkasan Data</p>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-white-50">Rerata:</span>
                    <span id="meanValue" class="fw-bold text-info">0.00 mm</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-white-50">Std Deviasi:</span>
                    <span id="stdDevValue" class="fw-bold text-primary">0.000</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Main Production Trend Chart (SPC Style) -->
<div class="row g-3 mb-5">
    <div class="col-12 animate-fadeInUp delay-4">
        <div class="card glass-panel overflow-hidden border-0 shadow-lg" style="background: rgba(15, 23, 42, 0.6) !important; backdrop-filter: blur(20px);">
            <div class="card-header border-bottom border-white border-opacity-5 p-4 bg-transparent text-center">
                <h5 class="mb-0 fw-bold fs-5 text-white" style="letter-spacing: -0.5px;">Trend Dimensi: <span id="criteriaTitle" class="text-info">Thickness</span> - <span id="sampleCount" class="text-white-50">0</span></h5>
            </div>
            <div class="card-body p-4 bg-transparent">
                <div class="chart-container" style="position: relative; height:480px; width:100%">
                    <canvas id="spcTrendChart"></canvas>
                </div>
            </div>
            <div class="card-footer border-0 p-4 pt-0 text-center">
                <p class="text-white-50 small mb-0" style="font-size: 0.85rem; font-weight: 300;">
                    Report dimensi per bagian dan parameter mesin secara <span class="neon-text">periodik</span> dengan Cp Cpk & grafik trend
                </p>
            </div>
        </div>
    </div>
</div>

<!-- ── Live Sensor Feed Panel ────────────────────────────────── -->
<div class="row g-3 mb-5">
    <div class="col-12">
        <div class="card glass-panel border-0 shadow" style="background: rgba(15,23,42,0.6) !important; backdrop-filter: blur(20px);">
            <div class="card-header border-bottom border-white border-opacity-5 p-3 bg-transparent d-flex align-items-center gap-3">
                <h6 class="mb-0 fw-bold text-white">
                    <i class="bi bi-broadcast text-success me-2"></i>Live Sensor Feed
                </h6>
                <span class="badge bg-success ms-1" id="sensorLiveBadge" style="font-size:.7rem;">● LIVE</span>
                <a href="/SensorReadings/Monitor" class="btn btn-sm btn-outline-light ms-auto" style="font-size:.75rem;">
                    <i class="bi bi-arrow-up-right-square me-1"></i>Full Monitor
                </a>
            </div>
            <div class="card-body p-3">
                <!-- Device Status Mini -->
                <div class="row g-2 mb-3" id="homeSensorDevices">
                    <div class="col-12"><small class="text-white-50 fst-italic">Memuat status perangkat...</small></div>
                </div>
                <!-- Latest Readings Table -->
                <div style="overflow-x:auto;">
                    <table class="table table-dark table-sm table-hover mb-0" style="font-size:.8rem;">
                        <thead>
                            <tr>
                                <th>Device</th>
                                <th>Machine</th>
                                <th>Metric</th>
                                <th class="text-end">Value</th>
                                <th>Unit</th>
                                <th>Quality</th>
                                <th>Time</th>
                            </tr>
                        </thead>
                        <tbody id="homeSensorTableBody">
                            <tr><td colspan="7" class="text-center text-white-50 fst-italic py-3">Menunggu data sensor...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.12/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        $(document).ready(function() {
            const spcCtx = document.getElementById('spcTrendChart').getContext('2d');
            
            // Populate Products
            $.get('/Home/GetSpcProducts', function(data) {
                const select = $('#productFilter');
                data.forEach(p => {
                    select.append(`<option value="${p.value}">${p.text}</option>`);
                });
            });

            let spcChart = new Chart(spcCtx, {
                type: 'line',
                data: {
                    labels: [],
                    datasets: []
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: {
                        legend: {
                            display: true,
                            position: 'top',
                            labels: { color: 'rgba(255,255,255,0.7)', usePointStyle: true, font: { size: 11 } }
                        }
                    },
                    scales: {
                        y: {
                            grid: { color: 'rgba(255,255,255,0.05)' },
                            ticks: { color: 'rgba(255,255,255,0.5)' }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { color: 'rgba(255,255,255,0.5)', maxRotation: 45, minRotation: 45 }
                        }
                    }
                }
            });


            function loadSpcData() {
                const product = $('#productFilter').val();
                const criteria = $('#criteriaFilter').val();
                const range = $('#rangeFilter').val();

                $('#criteriaTitle').text($('#criteriaFilter option:selected').text());

                // Added timestamp (_t) to prevent AJAX caching
                $.get(`/Home/GetSpcData?productCode=${product}&criteria=${criteria}&timeRange=${range}&_t=${new Date().getTime()}`, function(data) {
                    if (data.success) {
                        const s = data.summary;
                        $('#cpValue').text(s.cp);
                        $('#cpkValue').text(s.cpk);
                        $('#meanValue').text(s.avg + ' mm');
                        $('#stdDevValue').text(s.stdDev);

                        // Badges color logic
                        if (s.cpk > 1.33) {
                            $('#cpkBadge').text('Excellent').removeClass('bg-warning-subtle text-warning').addClass('bg-success-subtle text-success');
                            $('#cpkValue').removeClass('text-warning').addClass('text-success');
                        } else if (s.cpk >= 1.0) {
                            $('#cpkBadge').text('Capable').removeClass('bg-warning-subtle text-warning').addClass('bg-info-subtle text-info');
                            $('#cpkValue').removeClass('text-warning').addClass('text-info');
                        } else {
                            $('#cpkBadge').text('Not Capable').addClass('bg-warning-subtle text-warning');
                            $('#cpkValue').addClass('text-warning');
                        }

                        $('#sampleCount').text(s.totalCount);

                        // Chart update
                        const datasets = [
                            {
                                label: 'Actual Sisi A',
                                data: data.chart.seriesA,
                                borderColor: '#00ccff',
                                backgroundColor: 'transparent',
                                tension: 0.3,
                                pointRadius: 4,
                                pointBackgroundColor: '#00ccff',
                                borderWidth: 2,
                                z: 10
                            }
                        ];

                        if (data.chart.seriesB && data.chart.seriesB.length > 0) {
                            datasets.push({
                                label: 'Actual Sisi B',
                                data: data.chart.seriesB,
                                borderColor: '#ff00ff',
                                backgroundColor: 'transparent',
                                tension: 0.3,
                                pointRadius: 4,
                                pointStyle: 'triangle',
                                pointBackgroundColor: '#ff00ff',
                                borderWidth: 2,
                                z: 9
                            });
                        }

                        // Add limit lines (SPC Style)
                        const uslData = new Array(data.chart.labels.length).fill(data.chart.uslLine);
                        const lslData = new Array(data.chart.labels.length).fill(data.chart.lslLine);
                        const targetData = new Array(data.chart.labels.length).fill(data.chart.targetLine);

                        datasets.push({
                            label: 'Target (Sisi A)',
                            data: targetData,
                            borderColor: '#3b82f6',
                            borderWidth: 1.5,
                            pointRadius: 0,
                            fill: false,
                            borderDash: [0, 0],
                            z: 8
                        });
                        datasets.push({
                            label: 'Spesifikasi Max (Sisi A)',
                            data: uslData,
                            borderColor: '#ef4444',
                            borderWidth: 2,
                            pointRadius: 0,
                            fill: false,
                            borderDash: [5, 5],
                            z: 5
                        });
                        datasets.push({
                            label: 'Spesifikasi Min (Sisi A)',
                            data: lslData,
                            borderColor: '#ef4444',
                            borderWidth: 2,
                            pointRadius: 0,
                            fill: false,
                            borderDash: [5, 5],
                            z: 5
                        });

                        // Reformat labels to "idx (date)"
                        const labels = data.chart.labels.map((l, i) => `${i+1} (${l.split(' ')[0]})`);

                        spcChart.data.labels = labels;
                        spcChart.data.datasets = datasets;
                        spcChart.update();
                    } else {
                        // Show empty or mock if needed
                        console.log(data.message);
                    }
                });
            }

            // Filters change event
            $('#productFilter, #criteriaFilter, #rangeFilter').change(loadSpcData);

            // Initial load
            setTimeout(loadSpcData, 500);

            // SignalR Live Sync
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/hub/dashboard")
                .withAutomaticReconnect()
                .build();

            async function startSignalR() {
                try {
                    await connection.start();
                    console.log("SignalR Connected.");
                    $("#signalrStatus")
                        .removeClass("bg-danger-subtle text-danger border-danger-subtle")
                        .addClass("bg-success-subtle text-success border-success-subtle pulse-badge")
                        .html('<span class="status-dot pulse me-1" style="width: 6px; height: 6px; display: inline-block; background: #10b981; border-radius: 50%;"></span>LIVE SYNC ACTIVE');
                } catch (err) {
                    console.log("SignalR Connection Error: ", err);
                    setTimeout(startSignalR, 5000);
                }
            }

            connection.on("ReceiveUpdate", function () {
                console.log("%c >>> SIGNALR: Real-time Update Received!", "color: #00ccff; font-weight: bold; font-size: 12px;");
                
                // Show Popup Notification
                $("#updateToast").stop(true, true).fadeIn().delay(5000).fadeOut();

                // Add a small toast or visual flash to indicate update
                $(".glass-panel").addClass("blink-border");
                setTimeout(() => $(".glass-panel").removeClass("blink-border"), 800);
                
                // Added 1-second delay before refresh to ensure DB commit is finished
                setTimeout(loadSpcData, 1000);
            });

            connection.on("SensorDataReceived", function (data) {
                refreshHomeSensorFeed();
                refreshHomeSensorDevices();
            });

            connection.onreconnecting(error => {
                $("#signalrStatus")
                    .removeClass("bg-success-subtle text-success border-success-subtle pulse-badge")
                    .addClass("bg-warning-subtle text-warning border-warning-subtle")
                    .html("RECONNECTING...");
            });

            connection.onreconnected(connectionId => {
                $("#signalrStatus")
                    .removeClass("bg-warning-subtle text-warning border-warning-subtle")
                    .addClass("bg-success-subtle text-success border-success-subtle pulse-badge")
                    .html('<span class="status-dot pulse me-1" style="width: 6px; height: 6px; display: inline-block; background: #10b981; border-radius: 50%;"></span>LIVE SYNC ACTIVE');
            });

            startSignalR();

            // ── Sensor Live Feed (home) ──────────────────────────────
            async function refreshHomeSensorFeed() {
                try {
                    const res  = await fetch('/api/sensor-readings/live?last=10');
                    const rows = await res.json();
                    const tbody = document.getElementById('homeSensorTableBody');
                    if (!rows || rows.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="7" class="text-center text-white-50 fst-italic py-3">Belum ada data sensor</td></tr>';
                        return;
                    }
                    const sorted = [...rows].reverse();
                    tbody.innerHTML = sorted.map(r => {
                        const qClass = r.quality === 'OK' ? '#10b981' : r.quality === 'WARN' ? '#ffc107' : '#ef4444';
                        return `<tr>
                            <td><span class="badge bg-secondary" style="font-size:.65rem;">${r.deviceId}</span></td>
                            <td class="text-white-50">${r.machineCode || '—'}</td>
                            <td><span class="badge bg-info text-dark" style="font-size:.65rem;">${r.metricType}</span></td>
                            <td class="text-end text-warning fw-semibold">${(+r.metricValue).toFixed(3)}</td>
                            <td class="text-white-50">${r.unit || '—'}</td>
                            <td><span style="color:${qClass}; font-size:.7rem;">● ${r.quality}</span></td>
                            <td class="text-white-50">${r.timestamp}</td>
                        </tr>`;
                    }).join('');
                } catch (e) { console.warn('Sensor feed error:', e); }
            }

            async function refreshHomeSensorDevices() {
                try {
                    const res     = await fetch('/api/sensor-readings/device-status');
                    const devices = await res.json();
                    const cont    = document.getElementById('homeSensorDevices');
                    if (!devices || devices.length === 0) {
                        cont.innerHTML = '<div class="col-12"><small class="text-white-50 fst-italic">Belum ada device terdaftar</small></div>';
                        return;
                    }
                    cont.innerHTML = devices.map(d => `
                        <div class="col-auto">
                            <span class="badge ${d.isOnline ? 'bg-success' : 'bg-secondary'} px-2 py-1" style="font-size:.72rem;">
                                ${d.isOnline ? '●' : '○'} ${d.deviceId} <span class="opacity-75">${d.machineCode || ''}</span>
                                — ${(+d.lastValue).toFixed(2)} ${d.lastUnit || ''} (${d.lastMetric})
                            </span>
                        </div>`).join('');
                } catch (e) { console.warn('Device status error:', e); }
            }

            refreshHomeSensorFeed();
            refreshHomeSensorDevices();
            setInterval(refreshHomeSensorFeed, 20000);
            setInterval(refreshHomeSensorDevices, 30000);
        });
    </script>
    
    <style>
        .blink-border {
            animation: blink-blue-border 0.8s ease-in-out;
        }
        @@keyframes blink-blue-border {
            0% { border: 1px solid transparent; }
            50% { border: 1px solid #00ccff; box-shadow: 0 0 15px rgba(0, 204, 255, 0.3); }
            100% { border: 1px solid transparent; }
        }
    </style>
}
