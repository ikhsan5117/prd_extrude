@model VelastoProductionSystem.Models.SpsNoDoc

@{
    ViewData["Title"] = "Standard Parameter Setting - " + Model.DocumentNumber;
    Layout = "_Layout";
}

<style>
    /* SPS Document Styles - Scoped to avoid layout override */
    .sps-container {
        width: 100%;
        background: #525252;
        padding: 20px 0;
        min-height: 100vh;
    }

    .sps-document {
        background: white;
        color: black;
        width: 210mm;
        min-height: 297mm;
        margin: 0 auto;
        padding: 10mm 12mm;
        box-shadow: 0 0 15px rgba(0,0,0,0.2);
        font-family: 'Arial', 'Helvetica', sans-serif;
        font-size: 8pt;
        line-height: 1.2;
    }

    .sps-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        border-bottom: 2px solid #000;
        padding-bottom: 8px;
        margin-bottom: 8px;
        position: relative;
    }

    .sps-logo-section {
        width: 110px;
        flex-shrink: 0;
    }

    .sps-logo {
        width: 100px;
        height: auto;
        display: block;
    }

    .sps-title {
        text-align: center;
        flex: 1;
        padding: 0 15px;
    }

    .sps-title h1 {
        font-size: 14pt;
        font-weight: bold;
        margin: 0 0 4px 0;
        text-decoration: underline;
        line-height: 1.1;
        letter-spacing: 0.2px;
    }

    .sps-title p {
        font-size: 8.5pt;
        margin: 0;
        line-height: 1.2;
    }

    .info-section {
        display: flex;
        gap: 10px;
        margin-bottom: 8px;
        font-size: 8pt;
    }

    .info-left {
        flex: 0 0 240px;
        display: grid;
        grid-template-columns: 80px 1fr;
        gap: 2px 8px;
        align-items: center;
    }

    .info-right {
        flex: 1;
        border: 1px solid #000;
        padding: 4px;
    }

    .signature-section {
        width: 165px;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .signature-boxes {
        border: 1px solid #000;
        display: flex;
        flex-direction: row;
    }

    .signature-box {
        flex: 1;
        padding: 6px 3px;
        text-align: center;
        border-right: 1px solid #000;
        min-height: 55px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .signature-box:last-child {
        border-right: none;
    }

    .signature-box strong {
        display: block;
        font-size: 7pt;
        font-weight: bold;
        margin-bottom: 22px;
    }

    .signature-box .sign-line {
        font-size: 6pt;
        margin-top: auto;
    }

    .revision-table {
        width: 100%;
        border-collapse: collapse;
        margin: 0;
        font-size: 7pt;
    }

    .revision-table th,
    .revision-table td {
        border: 1px solid #000;
        padding: 2px 4px;
        text-align: left;
    }

    .revision-table th {
        background-color: #e8e8e8;
        font-weight: bold;
        text-align: center;
    }

    .hose-spec {
        background-color: #f8f8f8;
        border: 1px solid #000;
        padding: 6px 8px;
        margin: 8px 0;
        font-size: 7.5pt;
        line-height: 1.4;
    }

    .hose-spec strong {
        font-weight: bold;
    }

    .param-table {
        width: 100%;
        border-collapse: collapse;
        margin: 6px 0 0 0;
        font-size: 6.5pt;
    }

    .param-table th,
    .param-table td {
        border: 1px solid #000;
        padding: 2px 3px;
        text-align: center;
        vertical-align: middle;
    }

    .param-table th {
        background-color: #e0e0e0;
        font-weight: bold;
        font-size: 6pt;
        line-height: 1.2;
    }

    .param-table td:first-child {
        text-align: center;
        width: 22px;
        font-weight: bold;
    }

    .param-table td:nth-child(2) {
        text-align: left;
        min-width: 70px;
        max-width: 90px;
        font-weight: 600;
        padding-left: 4px;
        font-size: 6.5pt;
    }

    .param-table td:nth-child(3) {
        width: 28px;
    }

    .param-table td:nth-child(4),
    .param-table td:nth-child(5) {
        min-width: 60px;
        max-width: 75px;
        font-size: 6pt;
    }

    .param-table td:nth-child(6),
    .param-table td:nth-child(7),
    .param-table td:nth-child(8) {
        width: 32px;
        font-size: 8pt;
    }

    .param-table td:nth-child(9) {
        min-width: 50px;
        max-width: 65px;
        font-size: 6pt;
    }

    .param-table td:nth-child(10) {
        width: 28px;
    }

    .param-table td:nth-child(11) {
        min-width: 55px;
        max-width: 70px;
        font-size: 6pt;
    }

    .param-table .item-name {
        text-align: left;
        font-weight: bold;
    }

    .field-label {
        font-weight: bold;
        padding: 2px 0;
        font-size: 7.5pt;
    }

    .field-value {
        border-bottom: 1px solid #666;
        min-height: 14px;
        padding: 2px 4px;
        font-size: 7.5pt;
    }

    .footer-note {
        margin-top: 8px;
        padding-top: 6px;
        border-top: 1px solid #000;
        font-size: 6pt;
        line-height: 1.3;
    }

    @@media print {
        .sps-container {
            background: white;
            padding: 0;
        }

        .sps-document {
            width: 100%;
            max-width: none;
            margin: 0;
            padding: 12mm 15mm;
            box-shadow: none;
            page-break-after: always;
        }

        .no-print {
            display: none !important;
        }

        /* Hide navbar and sidebar when printing */
        nav, .sidebar, .navbar, aside, header.main-header {
            display: none !important;
        }

        @@page {
            size: A4 portrait;
            margin: 8mm;
        }
    }

    @@media screen {
        .sps-container {
            background: #525252;
            padding: 20px 0;
        }
    }
</style>

<div class="sps-container">
    <!-- Print Button -->
    <div class="no-print" style="text-align: center; padding: 20px; background: transparent;">
        <button onclick="window.print()" class="btn btn-primary me-2">
            <i class="bi bi-printer me-2"></i>Print / Save as PDF
        </button>
        <a asp-action="Edit" asp-route-documentNumber="@Model.DocumentNumber" class="btn btn-warning me-2">
            <i class="bi bi-pencil me-2"></i>Edit
        </a>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-2"></i>Kembali
        </a>
    </div>

<!-- SPS Document -->
