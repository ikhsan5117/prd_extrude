                                            <div class="row g-2">
                                                <div class="col-md-4">
                                                    <input asp-for="ToleranceSpiralPitch_Min" type="number" step="0.01" class="form-control min-input" placeholder="MIN" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="ToleranceSpiralPitch_Asli" type="number" step="0.01" class="form-control asli-input" placeholder="ASLI" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="ToleranceSpiralPitch_Max" type="number" step="0.01" class="form-control max-input" placeholder="MAX" />
                                                </div>
                                            </div>
                                            <div class="row g-2 mt-1">
                                                <div class="col-md-12">
                                                    <label class="form-label text-white-50 small">Keterangan Spiral Pitch (teks)</label>
                                                    <input asp-for="ToleranceSpiralPitch" class="form-control" placeholder="Contoh: 10±1 mm" />
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Unsmooth Surface -->
                                        <div class="tolerance-group">
                                            <div class="tolerance-label">Unsmooth Surface</div>
                                            <div class="row g-2">
                                                <div class="col-md-12">
                                                    <label class="form-label text-white-50 small">Standar kondisi permukaan (teks/nilai)</label>
                                                    <input asp-for="UnsmoothSurface" class="form-control" placeholder="Contoh: OK / Max 3 titik / ≤ 2 mm" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Form Actions -->
                        <div class="row mt-4">
                            <div class="col-12 d-flex gap-3 justify-content-center">
                                @if (Context.Session.GetString("IsAdmin") == "true" && Context.Session.GetString("UserRole") != "ADMIN_ENG")
                                {
                                    <button type="submit" class="btn btn-success btn-lg px-5">
                                        <i class="bi bi-check-circle me-2"></i>SIMPAN DATA
                                    </button>
                                }
                                else
                                {
                                    <button type="submit" class="btn btn-outline-warning btn-lg px-5" name="saveAsDraft" value="true">
                                        <i class="bi bi-save2 me-2"></i>SIMPAN DRAFT
                                    </button>
                                    <button type="submit" class="btn btn-success btn-lg px-5">
                                        <i class="bi bi-send me-2"></i>APPROVAL REQUEST
                                    </button>
                                }
                                <a asp-action="Index" class="btn btn-secondary btn-lg px-5">
                                    <i class="bi bi-x-circle me-2"></i>BATAL
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/lib/offline-cdn/sweetalert2.all.min.js"></script>
    <script>
        // Form validation
        $('#editForm').on('submit', function(e) {
            const submitter = e.originalEvent?.submitter;
            if (submitter?.name === 'saveAsDraft' && submitter?.value === 'true') {
                return true;
            }

            const machine = $('[name="Machine"]').val();
            
            if (!machine) {
                e.preventDefault();
                Swal.fire({
                    icon: 'error',
                    title: 'Field Wajib Kosong',
                    text: 'Machine harus diisi!',
                    background: '#1a1d21',
                    color: '#fff'
                });
                return false;
            }
        });
    </script>
}

