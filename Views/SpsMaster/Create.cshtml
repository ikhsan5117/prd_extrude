@model VelastoProductionSystem.Models.SpsMaster

@{
    ViewData["Title"] = "Tambah Master SPS";
    var returnUrl = Context.Request.Query["returnUrl"].ToString();
    if (string.IsNullOrWhiteSpace(returnUrl) || !Url.IsLocalUrl(returnUrl))
    {
        returnUrl = Url.Action("Index", "SpsMaster") ?? "/SpsMaster";
    }
}

<style>
    .tolerance-group {
        background: rgba(13, 110, 253, 0.05);
        border: 1px solid rgba(13, 110, 253, 0.2);
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 15px;
    }
    .tolerance-label {
        font-weight: 600;
        color: #60a5fa;
        font-size: 0.9rem;
        margin-bottom: 10px;
    }
    .min-input { border-left: 3px solid #28a745 !important; background-color: rgba(40, 167, 69, 0.05); }
    .asli-input { border-left: 3px solid #0d6efd !important; font-weight: 600; background-color: rgba(13, 110, 253, 0.1); }
    .max-input { border-left: 3px solid #dc3545 !important; background-color: rgba(220, 53, 69, 0.05); }
    .badge-min { background: #28a745; font-size: 0.65rem; padding: 3px 6px; }
    .badge-asli { background: #0d6efd; font-size: 0.65rem; padding: 3px 6px; }
    .badge-max { background: #dc3545; font-size: 0.65rem; padding: 3px 6px; }
    
    .accordion-button:not(.collapsed) {
        background-color: rgba(13, 110, 253, 0.2) !important;
        color: white !important;
    }
    .accordion-button {
        background-color: rgba(0, 0, 0, 0.3) !important;
        color: white !important;
        font-weight: 600;
    }
    .accordion-button::after {
        filter: brightness(0) invert(1);
    }
    .accordion-body {
        background-color: rgba(0, 0, 0, 0.2);
        max-height: 600px;
        overflow-y: auto;
    }
    .section-divider {
        border-top: 2px solid rgba(255, 193, 7, 0.3);
        margin: 20px 0;
        padding-top: 15px;
    }
</style>

<div class="container-fluid mt-4 px-4">
    <div class="row">
        <div class="col-12">
            <div class="card" style="background: rgba(25, 30, 40, 0.9); border: 1px solid rgba(255,255,255,0.1);">
                <div class="card-header bg-primary text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">
                            <i class="bi bi-plus-circle-fill me-2"></i>Tambah Master SPS Baru
                        </h4>
                        <a href="@returnUrl" class="btn btn-sm btn-outline-light">
                            <i class="bi bi-arrow-left me-1"></i>Kembali
                        </a>
                    </div>
                </div>
                <div class="card-body p-4">
                    @if (Context.Session.GetString("IsAdmin") != "true" || Context.Session.GetString("UserRole") == "ADMIN_ENG")
                    {
                        <div class="alert alert-warning" role="alert">
                            <i class="bi bi-shield-lock-fill me-2"></i>
                            <strong>Approval Diperlukan:</strong> User engineering/operator harus request approval admin sebelum bisa menyimpan Create/Edit/Import SPS.
                            <a asp-controller="Approval" asp-action="MyRequests" class="alert-link ms-1">Lihat status request Anda</a>.
                        </div>
                    }

                    <div class="alert alert-info" role="alert">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        <strong>Petunjuk:</strong> Isi field <span class="badge bg-success">MIN</span>, 
                        <span class="badge bg-primary">ASLI</span>, dan <span class="badge bg-danger">MAX</span> 
                        untuk setiap parameter tolerance. Field yang wajib diisi ditandai dengan <span class="text-danger">*</span>
                    </div>

                    <form asp-action="Create" method="post" id="createForm">
                        <input type="hidden" name="sourceRequestId" value="@ViewBag.SourceRequestId" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        
                        <!-- ACCORDION SECTIONS -->
                        <div class="accordion" id="accordionCreate">
                            
                            <!-- SECTION 1: IDENTIFIKASI UTAMA -->
                            <div class="accordion-item bg-dark border-secondary">
                                <h2 class="accordion-header">
                                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#sec1">
                                        <i class="bi bi-bookmark-fill text-primary me-2"></i>
                                        <strong>1. IDENTIFIKASI UTAMA (Wajib)</strong>
                                    </button>
                                </h2>
                                <div id="sec1" class="accordion-collapse collapse show">
                                    <div class="accordion-body">
                                        <div class="row g-3">
                                            <div class="col-md-3">
                                                <label class="form-label text-white">No</label>
                                                <input asp-for="No" class="form-control" type="text" />
                                            </div>
                                            <div class="col-md-3">
                                                <label class="form-label text-white">Machine <span class="text-danger">*</span></label>
                                                <input asp-for="Machine" class="form-control" required />
                                            </div>
                                            <div class="col-md-3">
                                                <label class="form-label text-white">Machine Code</label>
                                                <input asp-for="MachineCode" class="form-control" />
                                            </div>
                                        </div>
                                        <div class="row g-3 mt-2">
                                            <div class="col-md-4">
                                                <label class="form-label text-white">Document Number</label>
                                                <input asp-for="DocumentNumber" class="form-control" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label text-white">Revision Number</label>
                                                <input asp-for="RevisionNumber" class="form-control" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label text-white">Revision Date</label>
                                                <input asp-for="RevisionDate" class="form-control" />
                                            </div>
                                        </div>
                                        <div class="row g-3 mt-2">
                                            <div class="col-md-12">
                                                <label class="form-label text-white">Formulasi</label>
                                                <input asp-for="Formulasi" class="form-control" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- SECTION 2: SPESIFIKASI HOSE & DIES -->
                            <div class="accordion-item bg-dark border-secondary mt-2">
                                <h2 class="accordion-header">
                                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#sec2">
                                        <i class="bi bi-gear-fill text-warning me-2"></i>
                                        <strong>2. SPESIFIKASI HOSE & DIES (34 kolom)</strong>
                                    </button>
                                </h2>
                                <div id="sec2" class="accordion-collapse collapse">
                                    <div class="accordion-body">
                                        <!-- Basic Specs -->
                                        <div class="row g-3 mb-3">
                                            <div class="col-md-3">
                                                <label class="form-label text-white">Customer</label>
                                                <input asp-for="Customer" class="form-control" />
                                            </div>
                                            <div class="col-md-3">
                                                <label class="form-label text-white">Hose Type</label>
                                                <input asp-for="HoseType" class="form-control" />
                                            </div>
                                            <div class="col-md-3">
                                                <label class="form-label text-white">Dimensi</label>
                                                <input asp-for="Dimensi" class="form-control" />
                                            </div>
                                            <div class="col-md-3">
                                                <label class="form-label text-white">Material</label>
                                                <input asp-for="Material" class="form-control" />
                                            </div>
                                        </div>
                                        <div class="row g-3 mb-3">
                                            <div class="col-md-4">
                                                <label class="form-label text-white">Inner Tube</label>
                                                <input asp-for="InnerTube" class="form-control" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label text-white">Middle Tube</label>
                                                <input asp-for="MiddleTube" class="form-control" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label text-white">Outer Cover</label>
                                                <input asp-for="OuterCover" class="form-control" />
                                            </div>
                                        </div>
                                        <div class="row g-3 mb-4">
                                            <div class="col-md-4">
                                                <label class="form-label text-white">Use Limits Inner</label>
                                                <input asp-for="UseLimitsInner" class="form-control" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label text-white">Use Limits Middle</label>
                                                <input asp-for="UseLimitsMiddle" class="form-control" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label text-white">Use Limits Outer</label>
                                                <input asp-for="UseLimitsOuter" class="form-control" />
                                            </div>
                                        </div>
                                        <div class="row g-3 mb-4">
                                            <div class="col-md-4">
                                                <label class="form-label text-white">Yarn</label>
                                                <input asp-for="Yarn" class="form-control" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label text-white">Tension Yarn Inner</label>
                                                <input asp-for="TensionYarnInner" class="form-control" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label text-white">Tension Yarn Outer</label>
                                                <input asp-for="TensionYarnOuter" class="form-control" />
                                            </div>
                                        </div>
                                        <div class="row g-3 mb-4">
                                            <div class="col-md-4">
                                                <label class="form-label text-white">Marking Sort</label>
                                                <input asp-for="MarkingSort" class="form-control" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label text-white">Text Marking Material</label>
                                                <input asp-for="TextMarkingMaterial" class="form-control" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label text-white">Marking Colour</label>
                                                <input asp-for="MarkingColour" class="form-control" />
                                            </div>
                                        </div>

                                        <div class="section-divider">
                                            <h6 class="text-warning"><i class="bi bi-rulers me-2"></i>TOLERANCE PARAMETERS</h6>
                                        </div>

                                        <!-- Pitch Yarn -->
                                        <div class="tolerance-group">
                                            <div class="tolerance-label">Pitch Yarn</div>
                                            <div class="row g-2">
                                                <div class="col-md-4">
                                                    <label><span class="badge badge-min">MIN</span></label>
                                                    <input asp-for="PitchYarn_Min" type="number" step="0.01" class="form-control min-input" />
                                                </div>
                                                <div class="col-md-4">
                                                    <label><span class="badge badge-asli">ASLI</span></label>
                                                    <input asp-for="PitchYarn_Asli" type="number" step="0.01" class="form-control asli-input" />
                                                </div>
                                                <div class="col-md-4">
                                                    <label><span class="badge badge-max">MAX</span></label>
                                                    <input asp-for="PitchYarn_Max" type="number" step="0.01" class="form-control max-input" />
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Nipple -->
                                        <div class="tolerance-group">
                                            <div class="tolerance-label">Nipple</div>
                                            <div class="row g-2">
                                                <div class="col-md-4">
                                                    <label><span class="badge badge-min">MIN</span></label>
                                                    <input asp-for="Nipple_Min" type="number" step="0.0001" class="form-control min-input" />
                                                </div>
                                                <div class="col-md-4">
                                                    <label><span class="badge badge-asli">ASLI</span></label>
                                                    <input asp-for="Nipple_Asli" type="number" step="0.0001" class="form-control asli-input" />
                                                </div>
                                                <div class="col-md-4">
                                                    <label><span class="badge badge-max">MAX</span></label>
                                                    <input asp-for="Nipple_Max" type="number" step="0.0001" class="form-control max-input" />
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Tube Die -->
                                        <div class="tolerance-group">
                                            <div class="tolerance-label">Tube Die</div>
                                            <div class="row g-2">
                                                <div class="col-md-4">
                                                    <input asp-for="TubeDie_Min" type="number" step="0.0001" class="form-control min-input" placeholder="MIN" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="TubeDie_Asli" type="number" step="0.0001" class="form-control asli-input" placeholder="ASLI" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="TubeDie_Max" type="number" step="0.0001" class="form-control max-input" placeholder="MAX" />
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Middle Die -->
                                        <div class="tolerance-group">
                                            <div class="tolerance-label">Middle Die</div>
                                            <div class="row g-2">
                                                <div class="col-md-4">
                                                    <input asp-for="MiddleDie_Min" type="number" step="0.0001" class="form-control min-input" placeholder="MIN" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="MiddleDie_Asli" type="number" step="0.0001" class="form-control asli-input" placeholder="ASLI" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="MiddleDie_Max" type="number" step="0.0001" class="form-control max-input" placeholder="MAX" />
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Cover Die -->
                                        <div class="tolerance-group">
                                            <div class="tolerance-label">Cover Die</div>
                                            <div class="row g-2">
                                                <div class="col-md-4">
                                                    <input asp-for="CoverDie_Min" type="number" step="0.0001" class="form-control min-input" placeholder="MIN" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="CoverDie_Asli" type="number" step="0.0001" class="form-control asli-input" placeholder="ASLI" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="CoverDie_Max" type="number" step="0.0001" class="form-control max-input" placeholder="MAX" />
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Spacer Die -->
                                        <div class="tolerance-group">
                                            <div class="tolerance-label">Spacer Die</div>
                                            <div class="row g-2">
                                                <div class="col-md-4">
                                                    <input asp-for="SpacerDie_Min" type="number" step="0.0001" class="form-control min-input" placeholder="MIN" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="SpacerDie_Asli" type="number" step="0.0001" class="form-control asli-input" placeholder="ASLI" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="SpacerDie_Max" type="number" step="0.0001" class="form-control max-input" placeholder="MAX" />
                                                </div>
                                            </div>
                                        </div>

                                        <!-- A Distance -->
                                        <div class="tolerance-group">
                                            <div class="tolerance-label">A Distance</div>
                                            <div class="row g-2">
                                                <div class="col-md-4">
                                                    <input asp-for="ADistance_Min" type="number" step="0.0001" class="form-control min-input" placeholder="MIN" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="ADistance_Asli" type="number" step="0.0001" class="form-control asli-input" placeholder="ASLI" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="ADistance_Max" type="number" step="0.0001" class="form-control max-input" placeholder="MAX" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- SECTION 3: MESH -->
                            <div class="accordion-item bg-dark border-secondary mt-2">
                                <h2 class="accordion-header">
                                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#sec3">
                                        <i class="bi bi-grid-3x3-gap-fill text-info me-2"></i>
                                        <strong>3. MESH (12 kolom)</strong>
                                    </button>
                                </h2>
                                <div id="sec3" class="accordion-collapse collapse">
                                    <div class="accordion-body">
                                        <div class="row g-3 mb-3">
                                            <div class="col-md-4">
                                                <label class="form-label text-white">Mesh Screen 1</label>
                                                <input asp-for="MeshScreen1" class="form-control" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label text-white">Mesh Screen 2</label>
                                                <input asp-for="MeshScreen2" class="form-control" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label text-white">Mesh Screen 3</label>
                                                <input asp-for="MeshScreen3" class="form-control" />
                                            </div>
                                        </div>

                                        <!-- Mesh Dim 1 -->
                                        <div class="tolerance-group">
                                            <div class="tolerance-label">Mesh Dim 1</div>
                                            <div class="row g-2">
                                                <div class="col-md-4">
                                                    <input asp-for="MeshDim1_Min" type="number" step="0.01" class="form-control min-input" placeholder="MIN" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="MeshDim1_Asli" type="number" step="0.01" class="form-control asli-input" placeholder="ASLI" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="MeshDim1_Max" type="number" step="0.01" class="form-control max-input" placeholder="MAX" />
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Mesh Dim 2 -->
                                        <div class="tolerance-group">
                                            <div class="tolerance-label">Mesh Dim 2</div>
                                            <div class="row g-2">
                                                <div class="col-md-4">
                                                    <input asp-for="MeshDim2_Min" type="number" step="0.01" class="form-control min-input" placeholder="MIN" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="MeshDim2_Asli" type="number" step="0.01" class="form-control asli-input" placeholder="ASLI" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="MeshDim2_Max" type="number" step="0.01" class="form-control max-input" placeholder="MAX" />
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Mesh Dim 3 -->
                                        <div class="tolerance-group">
                                            <div class="tolerance-label">Mesh Dim 3</div>
                                            <div class="row g-2">
                                                <div class="col-md-4">
                                                    <input asp-for="MeshDim3_Min" type="number" step="0.01" class="form-control min-input" placeholder="MIN" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="MeshDim3_Asli" type="number" step="0.01" class="form-control asli-input" placeholder="ASLI" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="MeshDim3_Max" type="number" step="0.01" class="form-control max-input" placeholder="MAX" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- SECTION 4: SUHU PENGERJAAN -->
                            <div class="accordion-item bg-dark border-secondary mt-2">
                                <h2 class="accordion-header">
                                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#sec4">
                                        <i class="bi bi-thermometer-half text-danger me-2"></i>
                                        <strong>4. SUHU PENGERJAAN (45 kolom)</strong>
                                    </button>
                                </h2>
                                <div id="sec4" class="accordion-collapse collapse">
                                    <div class="accordion-body">
                                        <h6 class="text-warning mb-3">Head Temperatures</h6>
                                        
                                        <!-- Head Temp 1 -->
                                        <div class="tolerance-group">
                                            <div class="tolerance-label">Head Temp 1</div>
                                            <div class="row g-2">
                                                <div class="col-md-4">
                                                    <input asp-for="HeadTemp1_Min" type="number" step="0.01" class="form-control min-input" placeholder="MIN" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="HeadTemp1_Asli" type="number" step="0.01" class="form-control asli-input" placeholder="ASLI" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="HeadTemp1_Max" type="number" step="0.01" class="form-control max-input" placeholder="MAX" />
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Head Temp 2 -->
                                        <div class="tolerance-group">
                                            <div class="tolerance-label">Head Temp 2</div>
                                            <div class="row g-2">
                                                <div class="col-md-4">
                                                    <input asp-for="HeadTemp2_Min" type="number" step="0.01" class="form-control min-input" placeholder="MIN" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="HeadTemp2_Asli" type="number" step="0.01" class="form-control asli-input" placeholder="ASLI" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="HeadTemp2_Max" type="number" step="0.01" class="form-control max-input" placeholder="MAX" />
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Head Temp 3 -->
                                        <div class="tolerance-group">
                                            <div class="tolerance-label">Head Temp 3</div>
                                            <div class="row g-2">
                                                <div class="col-md-4">
                                                    <input asp-for="HeadTemp3_Min" type="number" step="0.01" class="form-control min-input" placeholder="MIN" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="HeadTemp3_Asli" type="number" step="0.01" class="form-control asli-input" placeholder="ASLI" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="HeadTemp3_Max" type="number" step="0.01" class="form-control max-input" placeholder="MAX" />
                                                </div>
                                            </div>
                                        </div>

                                        <div class="section-divider">
                                            <h6 class="text-warning">Cylinder Temperatures (3 Extruders × 3 Materials)</h6>
                                        </div>

                                        <!-- Cylinder 1-1 -->
                                        <div class="tolerance-group">
                                            <div class="tolerance-label">Cylinder 1-1 (Extruder 1, Material 1)</div>
                                            <div class="row g-2">
                                                <div class="col-md-4">
                                                    <input asp-for="Cylinder1_1_Min" type="number" step="0.01" class="form-control min-input" placeholder="MIN" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="Cylinder1_1_Asli" type="number" step="0.01" class="form-control asli-input" placeholder="ASLI" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="Cylinder1_1_Max" type="number" step="0.01" class="form-control max-input" placeholder="MAX" />
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Cylinder 1-2 -->
                                        <div class="tolerance-group">
                                            <div class="tolerance-label">Cylinder 1-2 (Extruder 1, Material 2)</div>
                                            <div class="row g-2">
                                                <div class="col-md-4">
                                                    <input asp-for="Cylinder1_2_Min" type="number" step="0.01" class="form-control min-input" placeholder="MIN" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="Cylinder1_2_Asli" type="number" step="0.01" class="form-control asli-input" placeholder="ASLI" />
                                                </div>
                                                <div class="col-md-4">
                                                    <input asp-for="Cylinder1_2_Max" type="number" step="0.01" class="form-control max-input" placeholder="MAX" />
                                                </div>
                                            </div>
