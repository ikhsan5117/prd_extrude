@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function() {
            @if (TempData["ErrorMessage"] != null)
            {
                 var errorMsg = TempData["ErrorMessage"]?.ToString()?.Replace("\n", "<br>")?.Replace("\r", "")?.Replace("'", "\\'");
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Gagal Menyimpan',
                    html: '<div class="text-start" style="font-size: 0.9rem;">@Html.Raw(errorMsg)</div>',
                    confirmButtonText: 'Tutup',
                    background: '#1a1d21',
                    color: '#fff',
                    confirmButtonColor: '#7289da'
                });
                </text>
            }
        });

        // Form validation
        $('#createForm').on('submit', function(e) {
            const submitter = e.originalEvent?.submitter;
            if (submitter?.name === 'saveAsDraft' && submitter?.value === 'true') {
                return true;
            }

            const machine = $('[name="Machine"]').val();
            
            if (!machine) {
                e.preventDefault();
                Swal.fire({
                    icon: 'error',
                    title: 'Field Wajib Kosong',
                    text: 'Machine harus diisi!',
                    background: '#1a1d21',
                    color: '#fff'
                });
                return false;
            }
        });
    </script>
}
