                        <th class="marker-re bg-success bg-opacity-10"><span class="badge bg-success">MIN</span> Cyl 3-1</th>
                        <th class="marker-re bg-primary bg-opacity-10"><span class="badge bg-primary">STN</span> Cyl 3-1</th>
                        <th class="marker-re bg-danger bg-opacity-10"><span class="badge bg-danger">MAX</span> Cyl 3-1</th>
                        <th class="marker-re bg-success bg-opacity-10"><span class="badge bg-success">MIN</span> Screw 1</th>
                        <th class="marker-re bg-primary bg-opacity-10"><span class="badge bg-primary">STN</span> Screw 1</th>
                        <th class="marker-re bg-danger bg-opacity-10"><span class="badge bg-danger">MAX</span> Screw 1</th>

                        <th class="marker-re bg-success bg-opacity-10"><span class="badge bg-success">MIN</span> Head 2</th>
                        <th class="marker-re bg-primary bg-opacity-10"><span class="badge bg-primary">STN</span> Head 2</th>
                        <th class="marker-re bg-danger bg-opacity-10"><span class="badge bg-danger">MAX</span> Head 2</th>
                        <th class="marker-re bg-success bg-opacity-10"><span class="badge bg-success">MIN</span> Cyl 1-2</th>
                        <th class="marker-re bg-primary bg-opacity-10"><span class="badge bg-primary">STN</span> Cyl 1-2</th>
                        <th class="marker-re bg-danger bg-opacity-10"><span class="badge bg-danger">MAX</span> Cyl 1-2</th>
                        <th class="marker-re bg-success bg-opacity-10"><span class="badge bg-success">MIN</span> Cyl 2-2</th>
                        <th class="marker-re bg-primary bg-opacity-10"><span class="badge bg-primary">STN</span> Cyl 2-2</th>
                        <th class="marker-re bg-danger bg-opacity-10"><span class="badge bg-danger">MAX</span> Cyl 2-2</th>
                        <th class="marker-re bg-success bg-opacity-10"><span class="badge bg-success">MIN</span> Cyl 3-2</th>
