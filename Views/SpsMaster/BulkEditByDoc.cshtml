@model VelastoProductionSystem.Models.SpsMaster
@{
    ViewData["Title"] = "Bulk Edit SPS Master";
    var docNo = ViewBag.DocNo as string;
    var itemCount = ViewBag.ItemCount as int? ?? 0;
}

<style>
    .bulk-card {
        background: linear-gradient(145deg, rgba(17, 24, 39, 0.95), rgba(30, 41, 59, 0.9));
        border: 1px solid rgba(249, 115, 22, 0.35);
        border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(249, 115, 22, 0.1);
    }
    .bulk-header {
        background: linear-gradient(135deg, #f97316 0%, #ea580c 60%, #c2410c 100%);
        border-radius: 14px 14px 0 0;
        padding: 24px 28px;
        position: relative;
        overflow: hidden;
    }
    .bulk-header::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 200px;
        height: 200px;
        background: rgba(255,255,255,0.08);
        border-radius: 50%;
    }
    .bulk-header::after {
        content: '';
        position: absolute;
        bottom: -40%;
        right: 15%;
        width: 120px;
        height: 120px;
        background: rgba(255,255,255,0.05);
        border-radius: 50%;
    }
    .badge-doc {
        background: rgba(0,0,0,0.3);
        border: 1px solid rgba(255,255,255,0.3);
        padding: 6px 14px;
        border-radius: 20px;
        font-family: 'Courier New', monospace;
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: 0.5px;
    }
    .impact-banner {
        background: linear-gradient(135deg, rgba(249, 115, 22, 0.12), rgba(234, 88, 12, 0.08));
        border: 1px solid rgba(249, 115, 22, 0.3);
        border-radius: 12px;
        padding: 16px 20px;
    }
    .impact-number {
        font-size: 2.5rem;
        font-weight: 900;
        color: #f97316;
        line-height: 1;
        text-shadow: 0 0 20px rgba(249, 115, 22, 0.4);
    }
    .form-section-title {
        font-size: 0.65rem;
        font-weight: 800;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 12px;
        padding-bottom: 6px;
        border-bottom: 1px solid rgba(148, 163, 184, 0.15);
    }
    .bulk-input {
        background: rgba(15, 23, 42, 0.8);
        border: 1px solid rgba(249, 115, 22, 0.2);
        border-radius: 8px;
        color: #e2e8f0;
        padding: 10px 14px;
        font-size: 0.875rem;
        transition: all 0.25s ease;
        width: 100%;
    }
    .bulk-input:focus {
        background: rgba(249, 115, 22, 0.06);
        border-color: #f97316;
        outline: none;
        box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.15);
        color: #f8fafc;
    }
    .bulk-input::placeholder {
        color: rgba(148, 163, 184, 0.5);
    }
    .bulk-label {
        font-size: 0.72rem;
        font-weight: 700;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 6px;
        display: block;
    }
    .btn-bulk-submit {
        background: linear-gradient(135deg, #f97316, #ea580c);
        border: none;
        border-radius: 10px;
        color: white;
        font-weight: 700;
        font-size: 0.95rem;
        padding: 12px 28px;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(249, 115, 22, 0.35);
        letter-spacing: 0.3px;
    }
    .btn-bulk-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(249, 115, 22, 0.5);
        background: linear-gradient(135deg, #fb923c, #f97316);
        color: white;
    }
    .btn-bulk-cancel {
        background: rgba(51, 65, 85, 0.6);
        border: 1px solid rgba(100, 116, 139, 0.4);
        border-radius: 10px;
        color: #94a3b8;
        font-weight: 600;
        font-size: 0.95rem;
        padding: 12px 24px;
        text-decoration: none;
        transition: all 0.25s ease;
    }
    .btn-bulk-cancel:hover {
        background: rgba(71, 85, 105, 0.8);
        color: #cbd5e1;
        border-color: rgba(148, 163, 184, 0.5);
    }
    .warning-note {
        background: rgba(234, 179, 8, 0.08);
        border: 1px solid rgba(234, 179, 8, 0.25);
        border-radius: 10px;
        padding: 12px 16px;
        font-size: 0.8rem;
        color: #fde68a;
    }
</style>

<div class="container-fluid py-4" style="max-width: 900px;">
    <div class="bulk-card">
        <!-- Header -->
        <div class="bulk-header">
            <div class="d-flex justify-content-between align-items-start">
                <div style="position: relative; z-index: 1;">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-layers-half" style="font-size: 1.4rem; color: rgba(255,255,255,0.9);"></i>
                        <span style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: rgba(255,255,255,0.7);">One-to-Many Edit</span>
                    </div>
                    <h3 class="text-white fw-bold mb-2" style="font-size: 1.5rem;">Bulk Edit SPS Master</h3>
                    <div class="badge-doc text-white">
                        <i class="bi bi-file-earmark-text me-2" style="opacity: 0.7;"></i>@docNo
                    </div>
                </div>
                <div class="text-end" style="position: relative; z-index: 1;">
                    <div class="impact-number">@itemCount</div>
                    <div style="font-size: 0.72rem; color: rgba(255,255,255,0.75); font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">Item Terpengaruh</div>
                </div>
            </div>
        </div>

        <!-- Body -->
        <div class="p-4">
            <!-- Impact Banner -->
            <div class="impact-banner mb-4">
                <div class="d-flex align-items-start gap-3">
                    <i class="bi bi-info-circle-fill text-warning mt-1" style="font-size: 1.1rem; flex-shrink: 0;"></i>
                    <div>
                        <div style="font-weight: 700; color: #fde68a; font-size: 0.875rem; margin-bottom: 4px;">
                            Fitur One-to-Many Edit
                        </div>
                        <div style="color: #cbd5e1; font-size: 0.82rem; line-height: 1.5;">
                            Perubahan di bawah akan diterapkan ke <strong style="color: #f97316;">@itemCount item sekaligus</strong> yang memiliki 
                            No. DOC <strong style="color: #fb923c; font-family: monospace;">@docNo</strong>.
                            Field teknis seperti suhu, kecepatan, dan toleransi tidak akan terpengaruh.
                        </div>
                    </div>
                </div>
            </div>

            <!-- Validation Errors -->
            <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-4"></div>

            <form asp-action="BulkEditByDoc" method="post" id="bulkEditForm">
                <input type="hidden" name="docNo" value="@docNo" />

                <!-- Section: Identifikasi Dokumen -->
                <div class="mb-4">
                    <div class="form-section-title">
                        <i class="bi bi-file-earmark-check me-2"></i>Identifikasi Dokumen
                    </div>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="bulk-label">Machine</label>
                            <input asp-for="Machine" class="bulk-input" placeholder="Contoh: EXT-01" />
                        </div>
                        <div class="col-md-4">
                            <label class="bulk-label">Machine Code (MC)</label>
                            <input asp-for="MachineCode" class="bulk-input" placeholder="Contoh: MC01" />
                        </div>
                        <div class="col-md-2">
                            <label class="bulk-label">No. Revisi</label>
                            <input asp-for="RevisionNumber" class="bulk-input" placeholder="Contoh: 2" />
                        </div>
                        <div class="col-md-2">
                            <label class="bulk-label">Tanggal Revisi</label>
                            <input asp-for="RevisionDate" class="bulk-input" placeholder="dd/mm/yyyy" />
                        </div>
                    </div>
                </div>

                <!-- Section: Identifikasi Produk -->
                <div class="mb-4">
                    <div class="form-section-title">
                        <i class="bi bi-box-seam me-2"></i>Identifikasi Produk
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="bulk-label">Customer</label>
                            <input asp-for="Customer" class="bulk-input" placeholder="Contoh: TOYOTA" />
                        </div>
                        <div class="col-md-6">
                            <label class="bulk-label">Formulasi</label>
                            <input asp-for="Formulasi" class="bulk-input" placeholder="Contoh: NBR-01" />
                        </div>
                        <div class="col-md-4">
                            <label class="bulk-label">Hose Type</label>
                            <input asp-for="HoseType" class="bulk-input" placeholder="Contoh: Fuel Hose 8mm" />
                        </div>
                        <div class="col-md-4">
                            <label class="bulk-label">Dimensi</label>
                            <input asp-for="Dimensi" class="bulk-input" placeholder="Contoh: 8.0 x 12.0" />
                        </div>
                        <div class="col-md-4">
                            <label class="bulk-label">Material</label>
                            <input asp-for="Material" class="bulk-input" placeholder="Contoh: NBR" />
                        </div>
                    </div>
                </div>

                <!-- Warning Note -->
                <div class="warning-note mb-4">
                    <i class="bi bi-shield-check me-2"></i>
                    <strong>Data Aman:</strong> Hanya 9 field identifikasi di atas yang akan diperbarui. 
                    Semua parameter teknis mesin (suhu, kecepatan, pressure, toleransi, dll.) akan tetap tersimpan dan tidak terpengaruh.
                </div>

                <!-- Action Buttons -->
                <hr style="border-color: rgba(249, 115, 22, 0.15); margin: 0 0 20px 0;" />
                <div class="d-flex justify-content-between align-items-center">
                    <a asp-action="Index" class="btn-bulk-cancel">
                        <i class="bi bi-arrow-left me-2"></i>Batal
                    </a>
                    <button type="button" class="btn-bulk-submit" onclick="confirmBulkUpdate()">
                        <i class="bi bi-layers-half me-2"></i>
                        Update @itemCount Item Sekaligus
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function confirmBulkUpdate() {
    const docNo = '@Html.Raw(docNo?.Replace("'", "\\'"))';
    const itemCount = @itemCount;
    
    if (typeof Swal !== 'undefined') {
        // Gunakan SweetAlert jika tersedia
        Swal.fire({
            title: 'Konfirmasi Bulk Update',
            html: `Apakah Anda yakin ingin memperbarui<br>
                   <strong style="color: #f97316; font-size: 1.1rem;">${itemCount} item</strong><br>
                   dengan No. DOC <code style="color: #fb923c;">${docNo}</code>?<br><br>
                   <small style="color: #94a3b8;">Tindakan ini tidak dapat dibatalkan.</small>`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#f97316',
            cancelButtonColor: '#64748b',
            confirmButtonText: '<i class="bi bi-check-lg me-1"></i> Ya, Update Sekarang!',
            cancelButtonText: '<i class="bi bi-x me-1"></i> Batal',
            background: '#1e293b',
            color: '#e2e8f0',
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('bulkEditForm').submit();
            }
        });
    } else {
        // Fallback ke native confirm
        const confirmed = confirm(
            `Konfirmasi Bulk Update\n\n` +
            `Anda akan memperbarui ${itemCount} item dengan No. DOC "${docNo}".\n` +
            `Tindakan ini tidak dapat dibatalkan.\n\n` +
            `Lanjutkan?`
        );
        if (confirmed) {
            document.getElementById('bulkEditForm').submit();
        }
    }
}
</script>
