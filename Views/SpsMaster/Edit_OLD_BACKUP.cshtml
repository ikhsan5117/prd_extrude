@model VelastoProductionSystem.Models.SpsMaster

@{
    ViewData["Title"] = "Edit Master SPS";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card" style="background: rgba(25, 30, 40, 0.8); border: 1px solid rgba(255,255,255,0.1);">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">
                        <i class="bi bi-pencil-square me-2"></i>Edit Master SPS - @Model.ItemList
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        
                        <!-- Basic Info -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <h5 class="text-white border-bottom pb-2 mb-3">
                                    <i class="bi bi-info-circle me-2"></i>Informasi Dasar
                                </h5>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label text-white">Excel ID</label>
                                <input asp-for="ExcelId" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label text-white">No</label>
                                <input asp-for="No" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label text-white">Machine</label>
                                <input asp-for="Machine" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label text-white">Machine Code</label>
                                <input asp-for="MachineCode" class="form-control" />
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label class="form-label text-white">Document Number</label>
                                <input asp-for="DocumentNumber" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label text-white">Revision Number</label>
                                <input asp-for="RevisionNumber" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label text-white">Revision Date</label>
                                <input asp-for="RevisionDate" class="form-control" />
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-4">
                                <label class="form-label text-white">Item List</label>
                                <input asp-for="ItemList" class="form-control bg-info text-dark fw-bold" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-white">Customer</label>
                                <input asp-for="Customer" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-white">Hose Type</label>
                                <input asp-for="HoseType" class="form-control" />
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label class="form-label text-white">Dimensi</label>
                                <input asp-for="Dimensi" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-white">Formulasi</label>
                                <input asp-for="Formulasi" class="form-control" />
                            </div>
                        </div>

                        <!-- Tolerance Section (NEW FORMAT: min|asli|max) -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <h5 class="text-white border-bottom pb-2 mb-3">
                                    <i class="bi bi-rulers me-2"></i>Tolerance (Format: min|asli|max)
                                </h5>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-warning">
                                    <i class="bi bi-arrow-left-right me-1"></i>Tolerance Inner
                                </label>
                                <input asp-for="ToleranceInner" class="form-control bg-dark text-warning" 
                                       placeholder="Contoh: 8.5|9.0|9.5" />
                                <small class="text-muted">Format: min|nilai_asli|max</small>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-warning">
                                    <i class="bi bi-arrow-left-right me-1"></i>Tolerance Outer
                                </label>
                                <input asp-for="ToleranceOuter" class="form-control bg-dark text-warning" 
                                       placeholder="Contoh: 34.0|35.0|36.0" />
                                <small class="text-muted">Format: min|nilai_asli|max</small>
                            </div>
                        </div>

                        <!-- Material Section -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <h5 class="text-white border-bottom pb-2 mb-3">
                                    <i class="bi bi-box-seam me-2"></i>Material
                                </h5>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-white">Material TSM</label>
                                <input asp-for="Material" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-white">Inner Tube</label>
                                <input asp-for="InnerTube" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-white">Middle Tube</label>
                                <input asp-for="MiddleTube" class="form-control" />
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-4">
                                <label class="form-label text-white">Outer Cover</label>
                                <input asp-for="OuterCover" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-white">Use Limits Inner</label>
                                <input asp-for="UseLimitsInner" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-white">Use Limits Outer</label>
                                <input asp-for="UseLimitsOuter" class="form-control" />
                            </div>
                        </div>

                        <!-- Ketebalan -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <h5 class="text-white border-bottom pb-2 mb-3">
                                    <i class="bi bi-thermometer-half me-2"></i>Ketebalan
                                </h5>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label text-white">Tebal Inner</label>
                                <input asp-for="TebalInner" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label text-white">Tebal Inner + Middle</label>
                                <input asp-for="TebalInnerMiddle" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label text-white">Tebal Outer</label>
                                <input asp-for="TebalOuter" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label text-white">Tebal Total</label>
                                <input asp-for="TebalTotal" class="form-control" />
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="row mt-4">
                            <div class="col-12">
                                <button type="submit" class="btn btn-success btn-lg me-2">
                                    <i class="bi bi-check-circle me-2"></i>Simpan Perubahan
                                </button>
                                <a asp-action="Index" class="btn btn-secondary btn-lg">
                                    <i class="bi bi-x-circle me-2"></i>Batal
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
