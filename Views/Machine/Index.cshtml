@model IEnumerable<VelastoProductionSystem.Models.Machine>
@{
    ViewData["Title"] = "Management";
    var shifts = ViewBag.Shifts as IEnumerable<VelastoProductionSystem.Models.ShiftMaster> ?? new List<VelastoProductionSystem.Models.ShiftMaster>();
}

<style>
    /* Tabs Style */
    .nav-tabs-custom { border-bottom: 2px solid rgba(255,255,255,0.05); margin-bottom: 30px; }
    .nav-tabs-custom .nav-link { color: #64748b; border: none; font-weight: 600; padding: 12px 24px; position: relative; transition: all 0.3s; }
    .nav-tabs-custom .nav-link:hover { color: #cbd5e1; }
    .nav-tabs-custom .nav-link.active { color: #3b82f6; background: transparent; }
    .nav-tabs-custom .nav-link.active::after { content: ''; position: absolute; bottom: -2px; left: 0; width: 100%; height: 2px; background: #3b82f6; border-radius: 2px; }

    /* Glassmorphism Cards */
    .mgmt-card { background: rgba(30, 41, 59, 0.4); backdrop-filter: blur(8px); border-radius: 20px; border: 1px solid rgba(255,255,255,0.05); padding: 25px; }

    /* Shift Table Style */
    .shift-row { background: rgba(0,0,0,0.2); border-radius: 12px; margin-bottom: 10px; transition: all 0.2s; }
    .shift-row:hover { background: rgba(255,255,255,0.03); }
    .shift-input { background: #0f172a; border: 1px solid rgba(255,255,255,0.1); color: #fff; padding: 6px 12px; border-radius: 8px; width: 100px; text-align: center; }
    .shift-input:focus { border-color: #3b82f6; outline: none; }

    /* Existing Machine Styles */
    .stat-card { background: rgba(255,255,255,0.04); border-radius: 16px; border: 1px solid rgba(255,255,255,0.06); padding: 20px; }
    .stat-number { font-size: 2rem; font-weight: 800; line-height: 1; }
    .stat-label { font-size: 0.7rem; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px; margin-top: 6px; }
    .machine-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px; }
    .machine-card { background: #1e2229; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05); overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.2); }
    .status-badge { font-size: 0.7rem; padding: 3px 10px; border-radius: 20px; font-weight: 700; }
    .s-aktif { background: rgba(16,185,129,0.15); color: #34d399; }
    .s-maint { background: rgba(245,158,11,0.15); color: #fcd34d; }
    .s-nonaktif { background: rgba(239,68,68,0.15); color: #f87171; }
</style>

<div class="fade-in">
    <!-- Header -->
    <div class="mb-4">
        <h2 class="text-white fw-bold mb-1"><i class="bi bi-gear-wide-connected text-info me-2"></i> Management</h2>
        <p class="text-white-50 small mb-0">Kelola operasional sistem: Mesin & Pengaturan Shift</p>
    </div>

    <!-- Main Navigation Tabs -->
    <ul class="nav nav-tabs nav-tabs-custom" id="mgmtTabs" role="tablist">
        <li class="nav-item">
            <a class="nav-link active" id="machine-tab" data-bs-toggle="tab" href="#machine-content" role="tab">
                <i class="bi bi-display me-2"></i> Machine List
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" id="shift-tab" data-bs-toggle="tab" href="#shift-content" role="tab">
                <i class="bi bi-clock-history me-2"></i> Shift Settings
            </a>
        </li>
    </ul>

    <div class="tab-content" id="mgmtTabsContent">
        <!-- ═══ TAB: MACHINE ═══ -->
        <div class="tab-pane fade show active" id="machine-content" role="tabpanel">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="d-flex gap-3 align-items-center">
                    <input type="text" id="searchInput" class="form-control bg-dark border-secondary text-white" style="width:280px; border-radius:12px;" placeholder="&#xF52A; Cari mesin..." />
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-light rounded-pill filter-btn active" data-filter="ALL">All</button>
                        <button class="btn btn-sm btn-outline-success rounded-pill filter-btn" data-filter="AKTIF">Aktif</button>
                    </div>
                </div>
                <a asp-action="Create" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                    <i class="bi bi-plus-lg me-1"></i> Tambah Mesin
                </a>
            </div>

            <div class="machine-grid" id="machineGrid">
                @foreach (var m in Model)
                {
                    var badgeClass = m.Status == "AKTIF" ? "s-aktif" : m.Status == "MAINTENANCE" ? "s-maint" : "s-nonaktif";
                    <div class="machine-card" data-status="@m.Status" data-search="@(m.MachineCode + " " + m.MachineName)">
                        <div class="p-3">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <div style="font-size:0.65rem; color:#64748b; letter-spacing:1px;">@m.MachineCode</div>
                                    <div class="text-white fw-bold">@m.MachineName</div>
                                </div>
                                <span class="status-badge @badgeClass">@m.Status</span>
                            </div>
                            <div class="mt-2 text-white-50 small">
                                <div><i class="bi bi-pin-map me-1"></i> @(m.Line ?? "-")</div>
                                <div><i class="bi bi-cpu me-1"></i> @(m.MachineType ?? "General")</div>
                            </div>
                        </div>
                        <div class="p-2 bg-dark d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@m.Id" class="btn btn-sm btn-link text-primary"><i class="bi bi-pencil"></i></a>
                            <form asp-action="Delete" method="post" class="ms-auto" onsubmit="return confirm('Hapus @m.MachineName?')">
                                <input type="hidden" name="id" value="@m.Id" />
                                <button type="submit" class="btn btn-sm btn-link text-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- ═══ TAB: SHIFT ═══ -->
        <div class="tab-pane fade" id="shift-content" role="tabpanel">
            <div class="mgmt-card">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h5 class="text-white fw-bold mb-1">Shift Configuration</h5>
                        <p class="text-white-50 small mb-0">Atur jam mulai untuk setiap shift produksi (Planning Master)</p>
                    </div>
                    <button type="button" class="btn btn-outline-info btn-sm rounded-pill" data-bs-toggle="modal" data-bs-target="#addShiftModal">
                        <i class="bi bi-plus-lg me-1"></i> Add Shift
                    </button>
                </div>

                <div class="table-responsive">
                    <table class="table table-dark table-hover border-0">
                        <thead>
                            <tr style="border-bottom: 2px solid rgba(255,255,255,0.05);">
                                <th class="border-0 text-white-50 small">SHIFT NAME</th>
                                <th class="border-0 text-white-50 small text-center">START TIME</th>
                                <th class="border-0 text-white-50 small text-end">ACTIONS</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in shifts)
                            {
                                <tr class="align-middle border-bottom border-white-5">
                                    <td class="border-0 fw-bold text-info">@s.ShiftName</td>
                                    <td class="border-0 text-center">
                                        <input type="time" class="shift-input" value="@s.StartTime" onchange="updateShift(@s.Id, this.value)" />
                                    </td>
                                    <td class="border-0 text-end">
                                        <span id="save-msg-@s.Id" class="text-success small me-2" style="display:none;"><i class="bi bi-check-lg"></i> Saved</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Add Shift -->
<div class="modal fade" id="addShiftModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary text-white" style="border-radius:20px;">
            <div class="modal-header border-0">
                <h5 class="modal-title">Add New Shift</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AddShift" method="post">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label small text-white-50">Shift Name</label>
                        <input name="name" class="form-control bg-dark border-secondary text-white" required placeholder="e.g. SHIFT 4" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-white-50">Start Time</label>
                        <input name="startTime" type="time" class="form-control bg-dark border-secondary text-white" required />
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-link text-white-50" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4 rounded-pill">Save Shift</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Machine Search
    $('#searchInput').on('input', function () {
        const q = $(this).val().toLowerCase();
        $('.machine-card').each(function () {
            const search = $(this).data('search').toLowerCase();
            $(this).toggle(search.includes(q));
        });
    });

    // Shift Update
    function updateShift(id, time) {
        $.post('@Url.Action("UpdateShift")', { id: id, startTime: time }, function (res) {
            if (res.success) {
                const msg = $(`#save-msg-${id}`);
                msg.fadeIn().delay(1500).fadeOut();
            }
        });
    }
</script>
}
