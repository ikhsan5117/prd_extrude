@model IEnumerable<VelastoProductionSystem.Models.Machine>
@{
    ViewData["Title"] = "Machine Management";
    var aktif = Model.Count(x => x.Status == "AKTIF");
    var maintenance = Model.Count(x => x.Status == "MAINTENANCE");
    var nonaktif = Model.Count(x => x.Status == "NON-AKTIF");
}

<style>
    .stat-card {
        background: rgba(255,255,255,0.04);
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.06);
        padding: 20px;
        transition: transform 0.2s;
    }
    .stat-card:hover { transform: translateY(-3px); }
    .stat-number { font-size: 2.5rem; font-weight: 800; line-height: 1; }
    .stat-label { font-size: 0.75rem; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px; margin-top: 6px; }

    .machine-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px; margin-top: 25px; }
    
    .machine-card {
        background: #1e2229;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.05);
        overflow: hidden;
        transition: transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }
    .machine-card:hover { transform: translateY(-4px); box-shadow: 0 12px 30px rgba(0,0,0,0.3); }
    
    .card-stripe-aktif    { height: 5px; background: linear-gradient(90deg, #10b981, #34d399); }
    .card-stripe-maint    { height: 5px; background: linear-gradient(90deg, #f59e0b, #fcd34d); }
    .card-stripe-nonaktif { height: 5px; background: linear-gradient(90deg, #ef4444, #f87171); }
    
    .machine-body { padding: 18px; }
    .machine-code { font-size: 0.75rem; color: #64748b; text-transform: uppercase; letter-spacing: 1px; }
    .machine-name { font-size: 1.1rem; font-weight: 700; color: #f8fafc; margin: 4px 0 10px; }
    
    .info-row { display: flex; justify-content: space-between; align-items: center; font-size: 0.8rem; color: #94a3b8; padding: 4px 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
    .info-row:last-child { border-bottom: none; }
    .info-val { color: #cbd5e1; font-weight: 600; }
    
    .status-badge { font-size: 0.7rem; padding: 3px 10px; border-radius: 20px; font-weight: 700; letter-spacing: 0.5px; }
    .s-aktif    { background: rgba(16,185,129,0.15); color: #34d399; border: 1px solid rgba(16,185,129,0.3); }
    .s-maint    { background: rgba(245,158,11,0.15); color: #fcd34d; border: 1px solid rgba(245,158,11,0.3); }
    .s-nonaktif { background: rgba(239,68,68,0.15); color: #f87171; border: 1px solid rgba(239,68,68,0.3); }

    .card-actions { padding: 12px 18px; background: rgba(0,0,0,0.2); display: flex; gap: 8px; align-items: center; }

    .search-box { background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); color: #fff; border-radius: 10px; padding: 10px 16px; width: 280px; font-size: 0.9rem; }
    .search-box:focus { outline: none; border-color: #3b82f6; }
    .search-box::placeholder { color: #64748b; }

    .empty-state { text-align: center; padding: 60px 20px; color: #64748b; }
    .empty-state i { font-size: 4rem; margin-bottom: 15px; display: block; }
</style>

<div class="fade-in">
    <!-- Header & Aksi -->
    <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3">
        <div>
            <h2 class="text-white fw-bold mb-1"><i class="bi bi-gear-wide-connected text-info me-2"></i> Machine Management</h2>
            <p class="text-white-50 small mb-0">Kelola data mesin, status operasional, dan jadwal maintenance</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Tambah Mesin
        </a>
    </div>

    <!-- Statistik Cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-number text-white">@Model.Count()</div>
                <div class="stat-label">Total Mesin</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-number text-success">@aktif</div>
                <div class="stat-label">Aktif / Running</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-number text-warning">@maintenance</div>
                <div class="stat-label">Maintenance</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-number text-danger">@nonaktif</div>
                <div class="stat-label">Non-Aktif</div>
            </div>
        </div>
    </div>

    <!-- Filter & Search -->
    <div class="d-flex gap-3 align-items-center flex-wrap">
        <input type="text" id="searchInput" class="search-box" placeholder="&#xF52A;  Cari kode / nama mesin..." />
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-light rounded-pill filter-btn active" data-filter="ALL">Semua</button>
            <button class="btn btn-sm btn-outline-success rounded-pill filter-btn" data-filter="AKTIF">Aktif</button>
            <button class="btn btn-sm btn-outline-warning rounded-pill filter-btn" data-filter="MAINTENANCE">Maintenance</button>
            <button class="btn btn-sm btn-outline-danger rounded-pill filter-btn" data-filter="NON-AKTIF">Non-Aktif</button>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="bi bi-gear text-secondary"></i>
            <h5 class="text-white-50">Belum ada data mesin</h5>
            <p class="small">Klik tombol <strong class="text-primary">"Tambah Mesin"</strong> untuk mulai mendaftarkan mesin.</p>
        </div>
    }
    else
    {
        <div class="machine-grid" id="machineGrid">
            @foreach (var m in Model)
            {
                var stripeClass = m.Status == "AKTIF" ? "card-stripe-aktif" : m.Status == "MAINTENANCE" ? "card-stripe-maint" : "card-stripe-nonaktif";
                var badgeClass = m.Status == "AKTIF" ? "s-aktif" : m.Status == "MAINTENANCE" ? "s-maint" : "s-nonaktif";
                var pmWarning = m.NextMaintenanceDate.HasValue && m.NextMaintenanceDate.Value <= DateTime.Now.AddDays(7);
                
                <div class="machine-card" data-status="@m.Status" data-search="@(m.MachineCode + " " + m.MachineName + " " + m.Line)">
                    <div class="@stripeClass"></div>
                    <div class="machine-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <div class="machine-code">@m.MachineCode</div>
                                <div class="machine-name">@m.MachineName</div>
                            </div>
                            <span class="status-badge @badgeClass">@m.Status</span>
                        </div>

                        <div class="mt-3">
                            <div class="info-row"><span>Line / Area</span><span class="info-val">@(m.Line ?? "-")</span></div>
                            <div class="info-row"><span>Tipe Mesin</span><span class="info-val">@(m.MachineType ?? "-")</span></div>
                            <div class="info-row"><span>Brand</span><span class="info-val">@(m.Brand ?? "-") @(m.YearMade != null ? $"({m.YearMade})" : "")</span></div>
                            <div class="info-row"><span>Kapasitas</span><span class="info-val">@(m.CapacityPerHour.HasValue ? $"{m.CapacityPerHour} pcs/jam" : "-")</span></div>
                            <div class="info-row">
                                <span>PM Berikutnya</span>
                                @if (m.NextMaintenanceDate.HasValue)
                                {
                                    <span class="info-val @(pmWarning ? "text-warning" : "")">
                                        @if (pmWarning) { <i class="bi bi-exclamation-triangle-fill me-1"></i> }
                                        @m.NextMaintenanceDate.Value.ToString("dd MMM yyyy")
                                    </span>
                                }
                                else { <span class="text-white-50">-</span> }
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(m.Notes))
                        {
                            <div class="mt-2 p-2 rounded" style="background:rgba(255,255,255,0.03); font-size:0.78rem; color:#94a3b8;">
                                <i class="bi bi-journal-text me-1"></i> @m.Notes
                            </div>
                        }
                    </div>
                    <div class="card-actions">
                        <!-- Quick Status Change -->
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary rounded-pill dropdown-toggle" data-bs-toggle="dropdown">
                                <i class="bi bi-toggle-on me-1"></i> Status
                            </button>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li><a class="dropdown-item status-change" data-id="@m.Id" data-status="AKTIF" href="#"><i class="bi bi-circle-fill text-success me-2"></i>AKTIF</a></li>
                                <li><a class="dropdown-item status-change" data-id="@m.Id" data-status="MAINTENANCE" href="#"><i class="bi bi-circle-fill text-warning me-2"></i>MAINTENANCE</a></li>
                                <li><a class="dropdown-item status-change" data-id="@m.Id" data-status="NON-AKTIF" href="#"><i class="bi bi-circle-fill text-danger me-2"></i>NON-AKTIF</a></li>
                            </ul>
                        </div>
                        <a asp-action="Edit" asp-route-id="@m.Id" class="btn btn-sm btn-outline-primary rounded-pill ms-auto">
                            <i class="bi bi-pencil-fill"></i> Edit
                        </a>
                        <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Yakin hapus mesin @m.MachineName?')">
                            <input type="hidden" name="id" value="@m.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill"><i class="bi bi-trash3"></i></button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
<script>
    // Search filter
    $('#searchInput').on('input', function () {
        filterCards();
    });

    let activeFilter = 'ALL';
    $('.filter-btn').on('click', function () {
        $('.filter-btn').removeClass('active');
        $(this).addClass('active');
        activeFilter = $(this).data('filter');
        filterCards();
    });

    function filterCards() {
        const q = $('#searchInput').val().toLowerCase();
        $('.machine-card').each(function () {
            const status = $(this).data('status');
            const search = $(this).data('search').toLowerCase();
            const matchStatus = activeFilter === 'ALL' || status === activeFilter;
            const matchSearch = search.includes(q);
            $(this).toggle(matchStatus && matchSearch);
        });
    }

    // Quick status change via AJAX
    $('.status-change').on('click', function (e) {
        e.preventDefault();
        const id = $(this).data('id');
        const status = $(this).data('status');
        $.post('@Url.Action("UpdateStatus")', { id: id, status: status }, function (res) {
            if (res.success) {
                location.reload();
            }
        });
    });
</script>
}
