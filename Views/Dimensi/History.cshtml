@model IEnumerable<VelastoProductionSystem.Models.DimensionReport>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Dimension Inspection History";
}

<style>
    :root {
        --hist-bg: rgba(15, 23, 42, 0.9);
        --card-bg: rgba(15, 23, 42, 0.72);
        --accent-glow: #38bdf8;
        --text-dim: #94a3b8;
    }

    .history-page {
        min-height: calc(100vh - 140px);
        padding: 40px 20px 60px;
        display: flex;
        justify-content: center;
        background: linear-gradient(180deg, rgba(6, 15, 34, 0.95) 0%, rgba(9, 16, 29, 1) 100%);
    }

    .history-container {
        width: 100%;
        max-width: 1220px;
        margin: 0 auto;
    }

    .glass-card {
        background: var(--card-bg);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 24px;
        backdrop-filter: blur(24px);
        padding: 32px;
        box-shadow: 0 35px 80px -45px rgba(0,0,0,0.65);
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 18px;
        margin-bottom: 28px;
    }

    .page-header h1 {
        margin: 0;
        font-size: 2.4rem;
        letter-spacing: -1px;
    }

    .page-header p {
        margin: 6px 0 0;
        color: rgba(255,255,255,0.72);
        font-size: 0.95rem;
        max-width: 560px;
    }

    .btn-back {
        background: rgba(255,255,255,0.05);
        color: #fff;
        padding: 12px 24px;
        border-radius: 999px;
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 700;
        transition: all 0.25s ease;
        border: 1px solid rgba(255,255,255,0.12);
        white-space: nowrap;
    }

    .btn-back:hover {
        background: #38bdf8;
        color: #020617;
        text-decoration: none;
        transform: translateY(-1px);
    }

    .table-wrapper {
        overflow-x: auto;
        border-radius: 20px;
        padding-right: 10px;
    }

    .table-custom {
        width: 100%;
        min-width: 860px;
        border-collapse: separate;
        border-spacing: 0 12px;
    }

    .table-custom th {
        padding: 18px 18px 12px;
        text-align: left;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 1.8px;
        color: var(--text-dim);
        font-weight: 800;
        white-space: nowrap;
    }

    .row-item {
        background: rgba(255,255,255,0.04);
        transition: transform 0.22s ease, background 0.22s ease;
        cursor: pointer;
        border-radius: 20px;
        overflow: hidden;
    }

    .row-item:hover {
        background: rgba(56, 189, 248, 0.08);
        transform: translateY(-1px);
    }

    .row-item td {
        padding: 20px 18px;
        font-size: 0.95rem;
        vertical-align: top;
        border: none;
    }

    .row-item td:last-child {
        text-align: right;
        width: 120px;
    }

    .header-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        align-items: center;
    }

    .btn-secondary {
        background: rgba(56, 189, 248, 0.18);
        color: #38bdf8;
        border-color: rgba(56, 189, 248, 0.25);
    }

    .btn-secondary:hover {
        background: rgba(56, 189, 248, 0.28);
    }

    .action-buttons {
        display: inline-flex;
        gap: 8px;
        align-items: center;
        justify-content: flex-end;
        flex-wrap: wrap;
    }

    .action-btn {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #cbd5e1;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
        transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease;
    }

    .action-btn:hover {
        transform: translateY(-1px);
        background: rgba(56, 189, 248, 0.12);
        color: #38bdf8;
    }

    .action-view:hover { color: #38bdf8; }
    .action-edit:hover { color: #fbbf24; }
    .action-delete:hover { color: #f87171; }

    .action-cell {
        min-width: 136px;
    }

    .btn-back { display: inline-flex; align-items: center; justify-content: center; }

    .status-active {
        background: rgba(16, 185, 129, 0.12);
        color: #a3f7c8;
        border: 1px solid rgba(16, 185, 129, 0.22);
    }

    .status-comp {
        background: rgba(56, 189, 248, 0.12);
        color: #a5f3fc;
        border: 1px solid rgba(56, 189, 248, 0.22);
    }

    .lbl-sec {
        color: rgba(255,255,255,0.55);
        font-size: 0.78rem;
        display: block;
        margin-bottom: 6px;
    }

    .val-sec {
        font-weight: 700;
        color: #ffffff;
        display: inline-block;
    }

    .text-action {
        color: rgba(255,255,255,0.65);
        transition: color 0.22s ease;
    }

    .row-item:hover .text-action {
        color: #38bdf8;
    }

    @@media (max-width: 992px) {
        .history-page {
            padding: 30px 16px 50px;
        }

        .page-header {
            align-items: flex-start;
        }

        .page-header h1 {
            font-size: 2rem;
        }

        .table-custom th,
        .row-item td {
            padding: 14px 12px;
        }
    }

    @@media (max-width: 640px) {
        .page-header {
            flex-direction: column;
            align-items: stretch;
        }

        .btn-back {
            width: 100%;
            text-align: center;
        }

        .table-custom {
            min-width: 100%;
        }
    }
</style>

<div class="history-page animate__animated animate__fadeIn">
    <div class="history-container">
        <div class="page-header">
            <div>
                <h1 class="fw-bold mb-1">Dimension History</h1>
                <p>Review and audit all measurement inspections</p>
            </div>
            <div class="header-actions">
                <a href="/Dimensi/Index" class="btn-back btn-secondary">
                    <i class="bi bi-plus-lg me-2"></i> NEW DIMENSION REPORT
                </a>
                <a href="/Dimensi/Index" class="btn-back">
                    <i class="bi bi-arrow-left me-2"></i> BACK TO HUD
                </a>
            </div>
        </div>

        <div class="glass-card">
            <div class="table-wrapper">
                <table class="table-custom">
                    <thead>
                        <tr>
                            <th>INSPECTION INFO</th>
                            <th>PRODUCT DETAILS</th>
                            <th>PRODUCTION TRACE</th>
                            <th>QUALITY</th>
                            <th>STATUS</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="row-item">
                                <td>
                                    <span class="lbl-sec">@item.CreatedDate.ToString("dd MMM yyyy")</span>
                                    <span class="val-sec">@item.DocumentNumber</span>
                                </td>
                                <td>
                                    <span class="lbl-sec">@(item.CustomerName?.ToUpper() ?? "---")</span>
                                    <span class="val-sec" style="color: var(--accent-glow)">@(item.HoseType ?? "---")</span>
                                </td>
                                <td>
                                    <span class="lbl-sec">SHIFT / VIN</span>
                                    <span class="val-sec">@($"{item.Shift ?? "---"} | {item.VinCode ?? "---"}")</span>
                                </td>
                                <td>
                                    <div style="display: flex; gap: 18px; flex-wrap: wrap;">
                                        <div>
                                            <span class="lbl-sec">OK</span>
                                            <span class="val-sec text-success">@item.QtyOk</span>
                                        </div>
                                        <div>
                                            <span class="lbl-sec">NG</span>
                                            <span class="val-sec text-danger">@item.NgDimension</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="status-pill @(item.Status == "COMPLETED" ? "status-comp" : "status-active")">
                                        @item.Status
                                    </span>
                                </td>
                                <td class="text-end action-cell">
                                    <div class="action-buttons">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="action-btn action-view" title="Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn action-edit" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="Delete" method="post" onsubmit="return confirm('Delete this report?');" style="display:inline;">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="action-btn action-delete" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
