@model IEnumerable<VelastoProductionSystem.Models.DimensionReport>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Dimension Inspection History";
    var spsMap = ViewBag.SpsMap as Dictionary<string, VelastoProductionSystem.Models.SpsNoDoc>;
}

<style>
    :root {
        --bg: #010409;
        --tile-bg: rgba(21, 27, 38, 0.7);
        --accent: #0066ff;
        --accent-glow: rgba(0, 102, 255, 0.4);
        --success: #00ff88;
        --danger: #ff4d4d;
        --border: rgba(255,255,255,0.06);
    }

    body { 
        background: var(--bg); color: #e6edf3; font-family: 'Outfit', sans-serif;
        background-image: 
            radial-gradient(circle at 0% 0%, rgba(0, 102, 255, 0.03) 0%, transparent 50%),
            radial-gradient(circle at 100% 100%, rgba(0, 255, 136, 0.03) 0%, transparent 50%);
        min-height: 100vh;
    }

    .fade-in { animation: slideIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; }
    @@keyframes slideIn { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }

    .history-page { padding: 20px 15px 60px; }
    .history-container { max-width: 100%; margin: 0 auto; }

    /* ─── HEADER HUD ─── */
    .page-header {
        display: flex; justify-content: space-between; align-items: flex-end;
        margin-bottom: 40px; border-bottom: 1px solid var(--border); padding-bottom: 30px;
    }
    .page-title { font-size: 3.5rem; font-weight: 1000; letter-spacing: -3px; color: #fff; line-height: 0.9; }
    .page-subtitle { color: #8b949e; font-size: 0.9rem; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; margin-top: 15px; }

    .btn-action {
        display: flex; align-items: center; gap: 10px; padding: 12px 24px; border-radius: 12px;
        font-weight: 800; text-decoration: none; transition: 0.3s; font-size: 0.8rem;
    }
    .btn-action.prm { background: var(--accent); color: #fff; box-shadow: 0 10px 40px var(--accent-glow); }
    .btn-action.sec {
        background: linear-gradient(145deg, rgba(22, 30, 45, 0.75), rgba(10, 15, 26, 0.8));
        border: 1px solid rgba(56, 189, 248, 0.25);
        color: #cbd5e1;
        box-shadow: 0 10px 26px rgba(2, 6, 23, 0.35);
    }
    .btn-action.sec:hover {
        border-color: rgba(56, 189, 248, 0.6);
        color: #e2e8f0;
        box-shadow: 0 12px 28px rgba(37, 99, 235, 0.25);
    }
    .btn-action:hover { transform: translateY(-3px) scale(1.05); color: #fff; }

    /* ─── CONTROL HUB (UNIFIED TACTICAL LOOK) ─── */
    .control-hub {
        display: grid;
        grid-template-columns: minmax(220px, 400px) minmax(170px, 250px);
        justify-content: start;
        gap: 14px;
        margin-bottom: 28px;
        position: relative;
        z-index: 120;
    }

    .control-item {
        position: relative; display: flex; align-items: center;
        background: linear-gradient(140deg, rgba(10, 16, 28, 0.9), rgba(8, 13, 24, 0.85));
        border: 1px solid rgba(56, 189, 248, 0.2);
        border-left: 3px solid var(--accent);
        border-radius: 10px;
        padding: 0 12px;
        height: 50px;
        transition: all 0.3s ease;
        box-shadow: inset 0 0 0 1px rgba(56, 189, 248, 0.04);
    }
    .control-item:focus-within {
        border-color: var(--accent);
        background: linear-gradient(140deg, rgba(15, 26, 44, 0.95), rgba(10, 20, 35, 0.92));
        box-shadow: 0 0 22px rgba(0, 102, 255, 0.18);
    }
    
    .control-item i { 
        color: var(--accent); font-size: 0.95rem;
        margin-right: 10px; flex-shrink: 0;
    }

    .control-item input, .control-item select {
        background: transparent; border: none; color: #fff;
        width: 100%; height: 100%; font-size: 0.74rem;
        font-weight: 600; outline: none;
        text-transform: uppercase; letter-spacing: 0.5px;
    }
    .control-item select { cursor: pointer; color: #8b949e; }
    .control-item select:focus { color: #fff; }
    .control-item select option { background: #0d1117; color: #fff; padding: 10px; }
    
    /* ─── CUSTOM DROPDOWN STYLE ─── */
    .filter-input-dark {
        background: transparent; border: none; color: #fff;
        width: 100%; height: 100%; font-size: 0.8rem;
        font-weight: 600; outline: none;
        text-transform: uppercase; letter-spacing: 0.5px;
        cursor: pointer;
    }
    .filter-input-dark option { background: #010409; color: #fff; }

    /* Custom Date Icon handling */
    input[type="date"]::-webkit-calendar-picker-indicator {
        filter: invert(1) brightness(0.5) sepia(1) saturate(5) hue-rotate(190deg);
        cursor: pointer;
    }

    /* ─── INTELLIGENCE TILES (COMPACT CARDS) ─── */
    .intel-hub {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;
        margin-bottom: 40px;
    }

    .intel-card { 
        display: flex; align-items: center; justify-content: space-between;
        padding: 12px 20px;
        background: linear-gradient(145deg, rgba(21, 27, 38, 0.7), rgba(1, 4, 9, 0.8));
        border: 1px solid rgba(255, 255, 255, 0.05); 
        border-radius: 2px; /* MATCHING SHARP THEME */
        backdrop-filter: blur(20px);
        transition: 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    }
    .intel-card:hover { transform: translateY(-3px); border-color: var(--accent); }
    
    .intel-card.cyan { border-color: rgba(0, 102, 255, 0.2); }
    .intel-card.green { border-color: rgba(0, 255, 136, 0.15); }
    .intel-card.red { border-color: rgba(255, 77, 77, 0.15); }

    .intel-data { display: flex; flex-direction: column; }
    .intel-val { 
        font-size: 1.8rem; font-weight: 1000; line-height: 1; 
        letter-spacing: -1.5px;
    }
    .intel-lbl { font-size: 0.55rem; font-weight: 800; color: #484f58; text-transform: uppercase; margin-top: 3px; letter-spacing: 1.5px; }
    
    .intel-val.cyan { background: linear-gradient(135deg, #0066ff, #00ccff); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .intel-val.green { background: linear-gradient(135deg, #00ff88, #22d3ee); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .intel-val.red { background: linear-gradient(135deg, #ff4d4d, #f43f5e); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

    .intel-ico {
        width: 36px; height: 36px; border-radius: 10px; 
        display: flex; align-items: center; justify-content: center;
        font-size: 1.1rem; background: rgba(0,0,0,0.2);
        border: 1px solid rgba(255,255,255,0.02);
    }
    .intel-ico.cyan { color: #00ccff; }
    .intel-ico.green { color: #00ff88; }
    .intel-ico.red { color: #ff4d4d; }

    /* ─── CONTROL HUB (SEARCH & FILTERS) ─── */
    .control-hub {
        display: grid;
        grid-template-columns: minmax(280px, 420px) minmax(170px, 220px);
        justify-content: start;
        align-items: end;
        gap: 16px;
        margin-bottom: 40px;
    }
    .search-box { position: relative; }
    .search-input {
        background: rgba(21, 27, 38, 0.5); border: 1px solid var(--border);
        border-radius: 16px; padding: 18px 20px 18px 60px; width: 100%;
        color: #fff; font-size: 1rem; font-weight: 600; outline: none; transition: 0.3s;
    }
    .search-input:focus { border-color: var(--accent); box-shadow: 0 0 20px var(--accent-glow); }
    .search-icon { position: absolute; left: 25px; top: 50%; transform: translateY(-50%); color: var(--accent); font-size: 1.2rem; }

    .filter-input {
        background: rgba(21, 27, 38, 0.5); border: 1px solid var(--border);
        border-radius: 16px; padding: 15px 20px; width: 100%;
        color: #fff; font-weight: 700; outline: none; transition: 0.3s;
        font-size: 0.85rem; appearance: none;
    }
    .filter-input:focus { border-color: var(--accent); }

    .control-item .search-mode-select {
        background: transparent;
        border: none;
        border-right: 1px solid rgba(125, 211, 252, 0.25);
        color: #9cc9ff;
        border-radius: 0;
        height: 100%;
        min-width: 146px;
        width: 146px;
        max-width: 146px;
        flex: 0 0 146px;
        font-size: 0.65rem;
        font-weight: 800;
        padding: 0 22px 0 2px;
        margin-right: 10px;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
        cursor: pointer;
        background-image: linear-gradient(45deg, transparent 50%, #7dd3fc 50%), linear-gradient(135deg, #7dd3fc 50%, transparent 50%);
        background-position: calc(100% - 12px) calc(50% - 1px), calc(100% - 8px) calc(50% - 1px);
        background-size: 5px 5px, 5px 5px;
        background-repeat: no-repeat;
        transition: border-color 0.2s ease, color 0.2s ease;
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
    }

    .control-item .search-mode-select:hover,
    .control-item .search-mode-select:focus {
        color: #dbeafe;
    }

    .control-item .search-mode-select option {
        background: #0d1117;
        color: #fff;
    }

    .search-wrap {
        position: relative;
        width: 100%;
        z-index: 130;
    }

    .search-block {
        width: 100%;
    }

    .quick-search-label {
        display: flex;
        align-items: center;
        gap: 6px;
        color: #7dd3fc;
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        margin-bottom: 6px;
    }

    .compact-search {
        height: 40px;
        padding: 0 10px;
        border-left-width: 1px;
        border-radius: 0;
        box-shadow: none;
    }

    .compact-search:focus-within {
        box-shadow: none;
    }

    #globalSearch {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.45px;
        color: #e2e8f0;
        text-transform: none;
    }

    #globalSearch::placeholder {
        color: rgba(148, 163, 184, 0.72);
        letter-spacing: 0.7px;
    }

    #dateFilterLabel {
        font-size: 0.69rem;
        letter-spacing: 0.7px;
        text-transform: uppercase;
    }

    .control-hub > .control-item {
        height: 40px;
        border-left-width: 1px;
        border-radius: 8px;
    }

    .search-autocomplete {
        position: absolute;
        left: 0;
        right: 0;
        top: calc(100% + 6px);
        background: #071225;
        border: 1px solid rgba(56, 189, 248, 0.42);
        border-radius: 10px;
        max-height: 180px;
        overflow-y: auto;
        z-index: 160;
        box-shadow: 0 16px 34px rgba(2, 6, 23, 0.56);
        display: none;
        backdrop-filter: blur(8px);
    }

    .search-autocomplete::-webkit-scrollbar {
        width: 8px;
    }

    .search-autocomplete::-webkit-scrollbar-thumb {
        background: rgba(56, 189, 248, 0.45);
        border-radius: 8px;
    }

    .search-autocomplete-item {
        padding: 8px 12px;
        font-size: 0.78rem;
        color: #dbeafe;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        cursor: pointer;
    }

    .search-autocomplete-item:last-child { border-bottom: none; }
    .search-autocomplete-item:hover { background: rgba(0, 102, 255, 0.2); }

    .date-popup-overlay {
        position: fixed;
        inset: 0;
        background: rgba(1, 4, 9, 0.6);
        backdrop-filter: blur(2px);
        z-index: 1500;
        display: none;
    }

    .date-popup {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: min(420px, 92vw);
        background: linear-gradient(165deg, #f4f6f9, #eceff4);
        border: 1px solid #d7dde7;
        border-radius: 14px;
        box-shadow: 0 24px 50px rgba(15, 23, 42, 0.42);
        z-index: 1501;
        display: none;
        padding: 16px;
    }

    .date-popup.show,
    .date-popup-overlay.show {
        display: block;
    }

    .date-popup-title {
        color: #1e293b;
        font-weight: 800;
        font-size: 1rem;
        margin-bottom: 10px;
    }

    .date-popup-sub {
        color: #334155;
        font-size: 0.82rem;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .date-preset-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 8px;
    }

    .date-preset-btn {
        border: 1px solid #c8d1e0;
        background: #f8fafc;
        color: #64748b;
        border-radius: 8px;
        font-size: 0.72rem;
        font-weight: 700;
        padding: 8px 6px;
    }

    .date-input-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .date-input-label {
        color: #475569;
        font-size: 0.75rem;
        font-weight: 700;
        margin-bottom: 4px;
        display: inline-block;
    }

    .date-input {
        width: 100%;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        padding: 8px 10px;
        color: #0f172a;
        background: #fff;
        font-size: 0.8rem;
    }

    .date-popup-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 16px;
    }

    .date-btn-clear,
    .date-btn-apply {
        border-radius: 8px;
        padding: 8px 20px;
        font-size: 0.78rem;
        font-weight: 800;
        border: 1px solid;
    }

    .date-btn-clear {
        color: #64748b;
        background: #f8fafc;
        border-color: #cbd5e1;
    }

    .date-btn-apply {
        color: #fff;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        border-color: #4338ca;
        box-shadow: 0 8px 18px rgba(67, 56, 202, 0.35);
    }

    /* ─── MODERN DATA TABLE ─── */
    .table-container {
        background: rgba(21, 27, 38, 0.4);
        border: 1px solid var(--border);
        border-radius: 16px;
        backdrop-filter: blur(20px);
        max-height: 650px;
        overflow-x: auto;
        overflow-y: auto;
        position: relative;
    }

    /* Custom Scrollbar Styling */
    .table-container::-webkit-scrollbar {
        width: 10px;
        height: 10px;
    }

    .table-container::-webkit-scrollbar-track {
        background: rgba(0, 0, 0, 0.2);
        border-radius: 10px;
    }

    .table-container::-webkit-scrollbar-thumb {
        background: linear-gradient(180deg, var(--accent), rgba(0, 102, 255, 0.5));
        border-radius: 10px;
        border: 2px solid rgba(0, 0, 0, 0.2);
    }

    .table-container::-webkit-scrollbar-thumb:hover {
        background: linear-gradient(180deg, #0080ff, var(--accent));
    }

    .data-table {
        width: 100%;
        min-width: 1400px;
        border-collapse: collapse;
        font-size: 0.85rem;
    }

    .data-table thead {
        background: linear-gradient(180deg, rgba(0, 102, 255, 0.08), rgba(0, 102, 255, 0.02));
        border-bottom: 2px solid rgba(0, 102, 255, 0.3);
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(10px);
    }

    .data-table th {
        padding: 12px 15px;
        text-align: left;
        font-weight: 900;
        font-size: 0.65rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #8b949e;
        white-space: nowrap;
        cursor: pointer;
        transition: all 0.3s ease;
        user-select: none;
        border-right: 1px solid var(--border);
    }

    .data-table th:last-child {
        border-right: none;
    }

    .data-table th:hover {
        color: var(--accent);
        background: rgba(0, 102, 255, 0.05);
    }

    .data-table th i {
        margin-left: 6px;
        font-size: 0.7rem;
        opacity: 0.4;
        transition: opacity 0.2s;
    }

    .data-table th:hover i {
        opacity: 1;
    }

    .data-table tbody tr {
        border-bottom: 1px solid var(--border);
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .data-table tbody tr:nth-child(even) {
        background: rgba(255, 255, 255, 0.01);
    }

    .data-table tbody tr:hover {
        background: rgba(0, 102, 255, 0.04);
        border-color: rgba(0, 102, 255, 0.2);
        transform: scale(1.005);
        box-shadow: 0 8px 24px rgba(0, 102, 255, 0.08);
    }

    .data-table td {
        padding: 12px 15px;
        color: #e6edf3;
        vertical-align: middle;
        border-right: 1px solid var(--border);
    }

    .data-table td:last-child {
        border-right: none;
    }

    .doc-num {
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
        font-weight: 900;
        color: #38bdf8;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        background: rgba(56, 189, 248, 0.05);
        padding: 4px 10px;
        border: 1px solid rgba(56, 189, 248, 0.2);
        border-radius: 4px;
        display: inline-block;
        transition: all 0.3s ease;
    }
    .doc-num:hover {
        background: rgba(56, 189, 248, 0.15);
        border-color: #38bdf8;
        box-shadow: 0 0 15px rgba(56, 189, 248, 0.3);
        transform: translateX(3px);
        color: #fff;
    }

    .date-stamp {
        font-size: 0.8rem;
        color: #8b949e;
        font-weight: 600;
    }

    .hose-type {
        font-size: 0.85rem;
        font-weight: 900;
        color: #fff;
    }

    .cust-name {
        font-size: 0.8rem;
        color: #8b949e;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .stat-val {
        font-size: 1.25rem;
        font-weight: 900;
        line-height: 1;
    }

    .stat-val.ok {
        color: var(--success);
    }

    .stat-val.ng {
        color: var(--danger);
    }

    .trace-val {
        font-weight: 800;
        color: #fff;
        font-size: 0.9rem;
    }

    .planning-name {
        font-weight: 900;
        color: #00ccff;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .machine-name {
        font-weight: 700;
        color: #fbbf24;
        font-size: 0.85rem;
    }

    .user-name {
        font-weight: 700;
        color: #8b949e;
        font-size: 0.85rem;
    }

    .status-badge {
        display: inline-block;
        padding: 5px 12px;
        font-size: 0.6rem;
        font-weight: 900;
        letter-spacing: 1px;
        border-radius: 8px;
    }

    .st-comp {
        background: rgba(0, 255, 136, 0.15);
        color: var(--success);
        border: 1px solid rgba(0, 255, 136, 0.3);
    }

    .st-active {
        background: rgba(0, 102, 255, 0.15);
        color: var(--accent);
        border: 1px solid rgba(0, 102, 255, 0.3);
    }

    .action-buttons {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
    }

    .btn-action-sm {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--border);
        color: #fff;
        font-size: 1rem;
        transition: all 0.3s ease;
        text-decoration: none;
        cursor: pointer;
    }

    .btn-action-sm:hover {
        background: var(--accent);
        border-color: var(--accent);
        transform: translateY(-2px) scale(1.1);
        box-shadow: 0 8px 20px var(--accent-glow);
        color: #fff;
    }

    .btn-action-sm.del {
        border: none;
        background: rgba(255, 77, 77, 0.1);
    }

    .btn-action-sm.del:hover {
        background: var(--danger);
        border-color: var(--danger);
        box-shadow: 0 8px 20px rgba(255, 77, 77, 0.4);
    }

    .no-results {
        text-align: center;
        padding: 100px 20px;
        color: #484f58;
        font-weight: 900;
        font-size: 1.5rem;
        border: 1px dashed var(--border);
        border-radius: 16px;
        margin-top: 20px;
    }

    @@media (max-width: 900px) {
        .control-hub { grid-template-columns: 1fr; }
        .intel-hub { grid-template-columns: 1fr; }
        .page-header { flex-direction: column; align-items: flex-start; gap: 20px; }
        
        .table-container {
            max-height: 500px;
            border-radius: 12px;
        }
        
        .data-table {
            font-size: 0.75rem;
            min-width: 1200px;
        }
        
        .data-table th,
        .data-table td {
            padding: 12px 10px;
            white-space: nowrap;
        }
        
        .hose-type {
            font-size: 0.85rem;
        }
        
        .stat-val {
            font-size: 1.2rem;
        }

        .table-container::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
    }
</style>

<div class="history-page">
    <div class="history-container">
        <!-- ── HEADER HUD ── -->
        <div class="page-header fade-in">
            <div>
                <div class="page-title">Dimension History</div>
                <div class="page-subtitle">Quality Audit & Traceability Engine</div>
            </div>
            <div class="d-flex gap-3">
                <a href="#" onclick="downloadExcel(); return false;" class="btn-action sec">
                    <i class="bi bi-file-earmark-excel"></i> DOWNLOAD EXCEL
                </a>
                <a href="/Dimensi/Index" class="btn-action prm">
                    <i class="bi bi-plus-circle-fill"></i> NEW_INSPECTION
                </a>
            </div>
        </div>

        <!-- ── CONTROL HUB ── -->
        <div class="control-hub fade-in" style="animation-delay: 0.1s;">
            <div class="search-block">
                <div class="quick-search-label"><i class="bi bi-search"></i> PENCARIAN CEPAT</div>
                <div class="control-item search-wrap compact-search">
                    <select id="searchType" class="search-mode-select" onchange="updateSearchMode()">
                        <option value="" selected>Semua</option>
                        <option value="planning">Planning</option>
                        <option value="operator">Operator</option>
                        <option value="docvin">Vin / Doc</option>
                    </select>
                    <input type="text" id="globalSearch" placeholder="Ketik kata kunci..." oninput="filterHistory()" onfocus="renderSearchAutocomplete()" />
                    <div id="searchAutocomplete" class="search-autocomplete"></div>
                </div>
            </div>
            <div class="control-item" onclick="openDatePopup()" style="cursor:pointer;">
                <i class="bi bi-calendar3"></i>
                <span id="dateFilterLabel" style="font-weight:700;color:#cbd5e1;">PILIH TANGGAL</span>
            </div>
        </div>

        <div id="datePopupOverlay" class="date-popup-overlay" onclick="closeDatePopup()"></div>
        <div id="datePopup" class="date-popup">
            <div class="date-popup-title">Tanggal</div>
            <div class="date-popup-sub">Preset Cepat:</div>
            <div class="date-preset-grid">
                <button type="button" class="date-preset-btn" onclick="setDatePreset('today')">Hari Ini</button>
                <button type="button" class="date-preset-btn" onclick="setDatePreset('week')">Minggu Ini</button>
                <button type="button" class="date-preset-btn" onclick="setDatePreset('month')">Bulan Ini</button>
                <button type="button" class="date-preset-btn" onclick="setDatePreset('year')">Tahun Ini</button>
            </div>
            <div class="date-popup-sub" style="margin-top:12px;">Rentang Tanggal:</div>
            <div class="date-input-grid">
                <div>
                    <label class="date-input-label">Dari:</label>
                    <input id="startDateInput" type="date" class="date-input" />
                </div>
                <div>
                    <label class="date-input-label">Sampai:</label>
                    <input id="endDateInput" type="date" class="date-input" />
                </div>
            </div>
            <div class="date-popup-actions">
                <button type="button" class="date-btn-clear" onclick="clearDateFilter()">Clear</button>
                <button type="button" class="date-btn-apply" onclick="applyDateFilter()">Apply</button>
            </div>
        </div>

        <!-- ── INTELLIGENCE SUMMARY (TOTAL INPUT) ── -->
        <div class="intel-hub fade-in" style="animation-delay: 0.15s;">
            <div class="intel-card cyan">
                <div class="intel-data">
                    <span class="intel-val cyan" id="totalReports">0</span>
                    <span class="intel-lbl">Total Reports</span>
                </div>
                <div class="intel-ico cyan"><i class="bi bi-layers-half"></i></div>
            </div>
            <div class="intel-card green">
                <div class="intel-data">
                    <span class="intel-val green" id="totalOk">0</span>
                    <span class="intel-lbl">Unit Passed</span>
                </div>
                <div class="intel-ico green"><i class="bi bi-check2-all"></i></div>
            </div>
            <div class="intel-card red">
                <div class="intel-data">
                    <span class="intel-val red" id="totalNg">0</span>
                    <span class="intel-lbl">Unit Failed</span>
                </div>
                <div class="intel-ico red"><i class="bi bi-exclamation-triangle"></i></div>
            </div>
        </div>

        <!-- ── MODERN DATA TABLE ── -->
        <div class="table-container fade-in" style="animation-delay: 0.2s;">
            <div class="table-responsive">
            <table class="data-table" id="dimensiTable">
                <thead>
                    <tr>
                        <th onclick="sortTable(0)">Document <i class="bi bi-arrow-down-up"></i></th>
                        <th onclick="sortTable(1)">Date/Time <i class="bi bi-arrow-down-up"></i></th>
                        <th onclick="sortTable(2)">Planning <i class="bi bi-arrow-down-up"></i></th>
                        <th onclick="sortTable(3)">Input By <i class="bi bi-arrow-down-up"></i></th>
                        <th onclick="sortTable(4)">Machine <i class="bi bi-arrow-down-up"></i></th>
                        <th onclick="sortTable(5)">Product Info <i class="bi bi-arrow-down-up"></i></th>
                        <th onclick="sortTable(6)" style="text-align: center;">Passed <i class="bi bi-arrow-down-up"></i></th>
                        <th onclick="sortTable(7)" style="text-align: center;">Failed <i class="bi bi-arrow-down-up"></i></th>
                        <th onclick="sortTable(8)">VIN Code <i class="bi bi-arrow-down-up"></i></th>
                        <th onclick="sortTable(9)" style="text-align: center;">Shift <i class="bi bi-arrow-down-up"></i></th>
                        <th style="text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    @foreach (var item in Model.OrderByDescending(x => x.CreatedDate))
                    {
                        var sps = (!string.IsNullOrEmpty(item.ItemCode) && spsMap != null && spsMap.TryGetValue(item.ItemCode, out var s)) ? s : null;
                        var rawPlanning = (item.ItemCode ?? string.Empty).Trim();
                        var spsItem = sps?.ItemLists?.FirstOrDefault(il => 
                            il.ItemList != null && (
                                il.ItemList.Equals(rawPlanning, StringComparison.OrdinalIgnoreCase) ||
                                il.ItemList.TrimStart('N','A','n','a','B','b').Equals(rawPlanning, StringComparison.OrdinalIgnoreCase)
                            ))?.ItemList ?? sps?.ItemLists?.FirstOrDefault()?.ItemList ?? "";
                        var planningDisplay = (rawPlanning.All(char.IsDigit) && !string.IsNullOrWhiteSpace(spsItem))
                            ? spsItem
                            : rawPlanning;
                            
                        var rawHose = (item.HoseType ?? string.Empty).Trim();
                        var spsHose = sps?.HoseType ?? "";
                        var productInfoDisplay = (!string.IsNullOrWhiteSpace(spsHose) &&
                            (rawHose.Equals(rawPlanning, StringComparison.OrdinalIgnoreCase) || rawHose.All(char.IsDigit)))
                            ? spsHose
                            : rawHose;

                        <tr class="record-item"
                            data-date="@item.CreatedDate.ToString("yyyy-MM-dd")"
                            data-planning="@planningDisplay"
                            data-operator="@(item.CreatedBy ?? "")"
                            data-docvin="@((item.DocumentNumber ?? "") + " " + (item.VinCode ?? ""))"
                            data-ok="@item.QtyOk"
                            data-ng="@item.NgDimension">

                            <td>
                                @{
                                    var spsDoc = ""; // Legacy fallback removed
                                    var displayDoc = !string.IsNullOrEmpty(spsDoc) ? spsDoc : item.DocumentNumber;
                                }
                                <div class="doc-num">#@(displayDoc?.Replace("#", "") ?? "")</div>
                            </td>

                            <td>
                                <div class="date-stamp">@item.CreatedDate.ToString("dd MMM yyyy")</div>
                                <div class="date-stamp" style="color: #484f58; font-size: 0.7rem;">@item.CreatedDate.ToString("HH:mm")</div>
                            </td>

                            <td>
                                <div class="planning-name">@(string.IsNullOrWhiteSpace(planningDisplay) ? "---" : planningDisplay)</div>
                            </td>

                            <td>
                                <div class="user-name">@(item.CreatedBy ?? "SYSTEM")</div>
                            </td>

                            <td>
                                <div class="machine-name">@(item.MachineName ?? "---")</div>
                            </td>

                            <td>
                                <div class="hose-type" style="margin-bottom: 3px;">@(string.IsNullOrWhiteSpace(productInfoDisplay) ? "UNDEFINED_PART" : productInfoDisplay)</div>
                                <div class="cust-name">@(item.CustomerName ?? "UNKNOWN_CLIENT")</div>
                            </td>

                            <td style="text-align: center;">
                                <div class="stat-val ok">@item.QtyOk.ToString("G29")</div>
                            </td>

                            <td style="text-align: center;">
                                <div class="stat-val ng">@item.NgDimension.ToString("G29")</div>
                            </td>

                            <td>
                                <div class="trace-val">@(item.VinCode ?? "---")</div>
                            </td>

                            <td style="text-align: center;">
                                <div class="trace-val">@(item.Shift?.Replace("Shift ", "") ?? "-")</div>
                                <div class="super-small text-white-50" style="font-size: 0.6rem;">SHIFT</div>
                            </td>

                            <td>
                                <div class="action-buttons">
                                    <a asp-action="Details" asp-route-id="@item.Id" asp-route-portal="dimension" class="btn-action-sm" title="View">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action-sm" title="Edit">
                                        <i class="bi bi-sliders"></i>
                                    </a>
                                    <form asp-action="Delete" method="post" onsubmit="return confirm('ERASE DOSSIER?');" style="display:inline;">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn-action-sm del" title="Delete">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
            <div id="noResults" class="no-results" style="display: none;">NO MATCHING RECORDS FOUND</div>
        </div>
    </div>
</div>

<script src="~/lib/offline-cdn/signalr.min.js"></script>
<script src="~/lib/offline-cdn/sweetalert2.all.min.js"></script>
<script>
    let dateStart = '';
    let dateEnd = '';

    function getSearchField() {
        const mode = document.getElementById('searchType')?.value || '';
        if (mode === 'planning') return 'planning';
        if (mode === 'operator') return 'operator';
        if (mode === 'docvin') return 'docvin';
        return '';
    }

    function updateSearchMode() {
        const input = document.getElementById('globalSearch');
        const mode = getSearchField();
        if (!input) return;

        if (mode === 'planning') input.placeholder = 'Ketik planning...';
        else if (mode === 'operator') input.placeholder = 'Ketik operator...';
        else if (mode === 'docvin') input.placeholder = 'Ketik vin / doc...';
        else input.placeholder = 'Ketik kata kunci...';

        filterHistory();
    }

    function hideSearchAutocomplete() {
        const box = document.getElementById('searchAutocomplete');
        if (box) box.style.display = 'none';
    }

    function renderSearchAutocomplete() {
        const box = document.getElementById('searchAutocomplete');
        const input = document.getElementById('globalSearch');
        if (!box || !input) return;

        const mode = getSearchField();
        if (!mode) {
            box.style.display = 'none';
            box.innerHTML = '';
            return;
        }

        const q = (input.value || '').trim().toLowerCase();
        const rows = Array.from(document.querySelectorAll('.record-item'));
        const values = [...new Set(rows
            .map(r => (r.dataset[mode] || '').trim())
            .filter(v => v.length > 0)
        )]
        .filter(v => v.toLowerCase().includes(q))
        .slice(0, 8);

        if (values.length === 0) {
            box.style.display = 'none';
            box.innerHTML = '';
            return;
        }

        box.innerHTML = values.map(v => `<div class="search-autocomplete-item" data-value="${v.replace(/"/g, '&quot;')}">${v}</div>`).join('');
        box.style.display = 'block';

        box.querySelectorAll('.search-autocomplete-item').forEach(el => {
            el.addEventListener('click', () => {
                input.value = el.dataset.value || '';
                filterHistory();
                hideSearchAutocomplete();
            });
        });
    }

    function filterHistory() {
        const query = document.getElementById('globalSearch').value.toUpperCase();
        const searchField = getSearchField();
        
        const items = document.querySelectorAll('.record-item');
        let visibleCount = 0;
        let totalOk = 0;
        let totalNg = 0;

        items.forEach(item => {
            const content = searchField
                ? (item.getAttribute(`data-${searchField}`) || '').toUpperCase()
                : item.innerText.toUpperCase();
            const date = item.getAttribute('data-date');

            const matchesSearch = content.includes(query);
            const matchesDate = (!dateStart || date >= dateStart) && (!dateEnd || date <= dateEnd);

            if (matchesSearch && matchesDate) {
                item.style.display = '';
                visibleCount++;
                totalOk += parseInt(item.getAttribute('data-ok') || 0);
                totalNg += parseInt(item.getAttribute('data-ng') || 0);
            } else {
                item.style.display = 'none';
            }
        });

        document.getElementById('totalReports').innerText = visibleCount;
        document.getElementById('totalOk').innerText = totalOk;
        document.getElementById('totalNg').innerText = totalNg;
        
        const noResults = document.getElementById('noResults');
        const tableBody = document.getElementById('tableBody');
        if (visibleCount === 0) {
            noResults.style.display = 'block';
            tableBody.style.display = 'none';
        } else {
            noResults.style.display = 'none';
            tableBody.style.display = '';
        }

        renderSearchAutocomplete();
    }

    function formatDateValue(d) {
        const m = String(d.getMonth() + 1).padStart(2, '0');
        const day = String(d.getDate()).padStart(2, '0');
        return `${d.getFullYear()}-${m}-${day}`;
    }

    function openDatePopup() {
        document.getElementById('datePopup').classList.add('show');
        document.getElementById('datePopupOverlay').classList.add('show');
    }

    function closeDatePopup() {
        document.getElementById('datePopup').classList.remove('show');
        document.getElementById('datePopupOverlay').classList.remove('show');
    }

    function setDatePreset(type) {
        const now = new Date();
        let from = new Date(now);
        let to = new Date(now);

        if (type === 'week') {
            const day = now.getDay();
            const diffToMonday = day === 0 ? 6 : day - 1;
            from.setDate(now.getDate() - diffToMonday);
        } else if (type === 'month') {
            from = new Date(now.getFullYear(), now.getMonth(), 1);
        } else if (type === 'year') {
            from = new Date(now.getFullYear(), 0, 1);
        }

        document.getElementById('startDateInput').value = formatDateValue(from);
        document.getElementById('endDateInput').value = formatDateValue(to);
    }

    function applyDateFilter() {
        dateStart = document.getElementById('startDateInput').value || '';
        dateEnd = document.getElementById('endDateInput').value || '';

        const label = document.getElementById('dateFilterLabel');
        if (dateStart || dateEnd) {
            label.textContent = `${dateStart || '...'} s/d ${dateEnd || '...'}`;
        } else {
            label.textContent = 'PILIH TANGGAL';
        }

        closeDatePopup();
        filterHistory();
    }

    function clearDateFilter() {
        dateStart = '';
        dateEnd = '';
        document.getElementById('startDateInput').value = '';
        document.getElementById('endDateInput').value = '';
        document.getElementById('dateFilterLabel').textContent = 'PILIH TANGGAL';
        closeDatePopup();
        filterHistory();
    }

    function downloadExcel() {
        const mode = document.getElementById('searchType')?.value || '';
        const query = document.getElementById('globalSearch')?.value || '';
        const params = new URLSearchParams();

        if (mode) params.set('searchType', mode);
        if (query) params.set('query', query);
        if (dateStart) params.set('startDate', dateStart);
        if (dateEnd) params.set('endDate', dateEnd);

        window.location.href = `/Dimensi/ExportHistoryExcel?${params.toString()}`;
    }

    // Table sorting function
    let sortDirections = {}; // Track sort direction for each column

    function sortTable(columnIndex) {
        const table = document.querySelector('.data-table');
        const tbody = table.querySelector('tbody');
        const rows = Array.from(tbody.querySelectorAll('tr.record-item'));
        
        // Toggle sort direction
        if (!sortDirections[columnIndex]) {
            sortDirections[columnIndex] = 'asc';
        } else {
            sortDirections[columnIndex] = sortDirections[columnIndex] === 'asc' ? 'desc' : 'asc';
        }
        
        const direction = sortDirections[columnIndex];
        
        rows.sort((a, b) => {
            let aValue = a.cells[columnIndex].innerText.trim();
            let bValue = b.cells[columnIndex].innerText.trim();
            
            // Handle numeric values
            const aNum = parseFloat(aValue.replace(/[^0-9.-]/g, ''));
            const bNum = parseFloat(bValue.replace(/[^0-9.-]/g, ''));
            
            if (!isNaN(aNum) && !isNaN(bNum)) {
                return direction === 'asc' ? aNum - bNum : bNum - aNum;
            }
            
            // Handle string values
            if (direction === 'asc') {
                return aValue.localeCompare(bValue);
            } else {
                return bValue.localeCompare(aValue);
            }
        });
        
        // Reappend sorted rows
        rows.forEach(row => tbody.appendChild(row));
        
        // Update header indicators
        const headers = table.querySelectorAll('th');
        headers.forEach((header, index) => {
            const icon = header.querySelector('i');
            if (icon) {
                if (index === columnIndex) {
                    icon.className = direction === 'asc' ? 'bi bi-arrow-up' : 'bi bi-arrow-down';
                    icon.style.opacity = '1';
                } else {
                    icon.className = 'bi bi-arrow-down-up';
                    icon.style.opacity = '0.4';
                }
            }
        });
        
        // Setup Pagination
        function setupPagination(tableId, rowsPerPage) {
            const table = document.getElementById(tableId);
            if (!table) return;
            const tbody = table.querySelector('tbody');
            if (!tbody) return;
            const rows = Array.from(tbody.querySelectorAll('tr:not(.no-data)'));
            if(rows.length === 0) return;
            
            let currentPage = 1;
            const totalPages = Math.ceil(rows.length / rowsPerPage);

            function renderPage(page) {
                const start = (page - 1) * rowsPerPage;
                const end = start + rowsPerPage;
                rows.forEach((row, i) => {
                    row.style.display = (i >= start && i < end) ? '' : 'none';
                });
                document.getElementById(tableId + '_pageInfo').textContent = `Halaman ${page} dari ${totalPages}`;
                document.getElementById(tableId + '_btnPrev').disabled = page === 1;
                document.getElementById(tableId + '_btnNext').disabled = page === totalPages;
            }

            const container = document.createElement('div');
            container.className = 'd-flex justify-content-between align-items-center mt-3 p-3';
            container.innerHTML = `
                <span class="text-secondary small" id="${tableId}_pageInfo"></span>
                <div class="btn-group">
                    <button id="${tableId}_btnPrev" class="btn btn-sm btn-outline-info">&laquo; Prev</button>
                    <button id="${tableId}_btnNext" class="btn btn-sm btn-outline-info">Next &raquo;</button>
                </div>
            `;
            table.parentNode.insertBefore(container, table.nextSibling);

            document.getElementById(tableId + '_btnPrev').addEventListener('click', () => {
                if(currentPage > 1) { currentPage--; renderPage(currentPage); }
            });
            document.getElementById(tableId + '_btnNext').addEventListener('click', () => {
                if(currentPage < totalPages) { currentPage++; renderPage(currentPage); }
            });

            renderPage(1);
        }

        setupPagination('dimensiTable', 10);
    }

    // Initial run
    window.addEventListener('load', () => {
        updateSearchMode();
        filterHistory();
    });

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeDatePopup();
    });

    document.addEventListener('click', (e) => {
        const wrap = document.querySelector('.search-wrap');
        if (!wrap || !wrap.contains(e.target)) hideSearchAutocomplete();
    });

    // SignalR Live Sync for Dimension History
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/hub/dashboard")
        .withAutomaticReconnect()
        .build();

    async function startSignalR() {
        try {
            await connection.start();
            console.log("SignalR Connected to Dimensi History Hub.");
        } catch (err) {
            console.log("SignalR Connection Error: ", err);
            setTimeout(startSignalR, 5000);
        }
    }

    connection.on("ReceiveUpdate", function () {
        console.log("Real-time Update Received in Dimensi History!");
        
        // Show notification (SweetAlert2)
        Swal.fire({
            title: 'Cloud Sync',
            text: 'Daftar diperbarui secara otomatis...',
            icon: 'success',
            background: '#010409',
            color: '#fff',
            timer: 1500,
            showConfirmButton: false,
            toast: true,
            position: 'top-end'
        });

        // Refresh list to show new data
        setTimeout(() => {
            window.location.reload();
        }, 1200);
    });

    startSignalR();
</script>

