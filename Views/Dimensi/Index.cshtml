    <script>
        // Simulate scan function
        function simulateScan() {
            // Simulate scanning SPS Masterlist
            const mockData = {
                productCode: 'SPS-001',
                hoseType: 'Double Layer',
                innerDiameter: '11.0 ± 0.2',
                innerThickness: '1.8 ± 0.2',
                totalThickness: '3.3 ± 0.2',
                spiralPitch: '38 ± 5'
            };

            // Show scan result
            document.getElementById('resultProductCode').textContent = mockData.productCode;
            document.getElementById('resultHoseType').textContent = mockData.hoseType;
            document.getElementById('resultInnerDiameter').textContent = mockData.innerDiameter;
            document.getElementById('resultInnerThickness').textContent = mockData.innerThickness;
            document.getElementById('resultTotalThickness').textContent = mockData.totalThickness;
            document.getElementById('resultSpiralPitch').textContent = mockData.spiralPitch;
            
            document.getElementById('scanResult').classList.add('show');

            // Auto-fill form
            document.getElementById('productCode').value = mockData.productCode;
            document.getElementById('hoseType').value = mockData.hoseType;
            document.getElementById('innerDiameter').value = mockData.innerDiameter;
            document.getElementById('innerThickness').value = mockData.innerThickness;
            document.getElementById('totalThickness').value = mockData.totalThickness;
            document.getElementById('spiralPitch').value = mockData.spiralPitch;

            // Update info section
            document.getElementById('infoProductCode').textContent = mockData.productCode;
            document.getElementById('infoHoseType').textContent = mockData.hoseType;
            document.getElementById('infoInnerDiameter').textContent = mockData.innerDiameter;
            document.getElementById('infoInnerThickness').textContent = mockData.innerThickness;
            document.getElementById('infoTotalThickness').textContent = mockData.totalThickness;
        }

        function saveData() {
            const data = {
                productCode: document.getElementById('productCode').value,
                hoseType: document.getElementById('hoseType').value,
                innerDiameter: document.getElementById('innerDiameter').value,
                innerThickness: document.getElementById('innerThickness').value,
                totalThickness: document.getElementById('totalThickness').value,
                spiralPitch: document.getElementById('spiralPitch').value
            };

            // Save to localStorage (simulasi)
            localStorage.setItem('dimensiData', JSON.stringify(data));
            
            alert('Data berhasil disimpan!');
            console.log('Saved data:', data);
        }

        function clearScan() {
            document.getElementById('scanResult').classList.remove('show');
        }

        function clearForm() {
            document.getElementById('productCode').value = '';
            document.getElementById('hoseType').value = '';
            document.getElementById('innerDiameter').value = '';
            document.getElementById('innerThickness').value = '';
            document.getElementById('totalThickness').value = '';
            document.getElementById('spiralPitch').value = '';
            
            document.getElementById('scanResult').classList.remove('show');
            
            // Clear info section
            document.getElementById('infoProductCode').textContent = '-';
            document.getElementById('infoHoseType').textContent = '-';
            document.getElementById('infoInnerDiameter').textContent = '-';
            document.getElementById('infoInnerThickness').textContent = '-';
            document.getElementById('infoTotalThickness').textContent = '-';
        }

        // Load saved data on page load
        window.addEventListener('DOMContentLoaded', function() {
            const savedData = localStorage.getItem('dimensiData');
            if (savedData) {
                const data = JSON.parse(savedData);
                document.getElementById('productCode').value = data.productCode || '';
                document.getElementById('hoseType').value = data.hoseType || '';
                document.getElementById('innerDiameter').value = data.innerDiameter || '';
                document.getElementById('innerThickness').value = data.innerThickness || '';
                document.getElementById('totalThickness').value = data.totalThickness || '';
                document.getElementById('spiralPitch').value = data.spiralPitch || '';
                
                // Update info section
                document.getElementById('infoProductCode').textContent = data.productCode || '-';
                document.getElementById('infoHoseType').textContent = data.hoseType || '-';
                document.getElementById('infoInnerDiameter').textContent = data.innerDiameter || '-';
                document.getElementById('infoInnerThickness').textContent = data.innerThickness || '-';
                document.getElementById('infoTotalThickness').textContent = data.totalThickness || '-';
            }
        });
    </script>
</body>
