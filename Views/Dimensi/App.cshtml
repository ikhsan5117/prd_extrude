@model VelastoProductionSystem.Models.DimensionReport

@{
    Layout = "_Layout";
    ViewData["Title"] = "Extruder Production Hub";
}

@Html.AntiForgeryToken()

@section Styles {
    <style>
        :root {
            --bg-deep: #0f172a;
            --glass-bg: rgba(30, 41, 59, 0.7);
            --glass-border: rgba(255, 255, 255, 0.1);
            --accent-glow: #38bdf8;
            --accent-success: #4ade80;
            --accent-warning: #fbbf24;
            --accent-danger: #f87171;
            --text-main: #f8fafc;
            --text-dim: #94a3b8;
        }

        body {
            background: radial-gradient(circle at top right, #1e293b, #0f172a);
            color: var(--text-main);
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            min-height: 100vh;
        }

        .hub-container {
            max-width: 1500px;
            margin: 0 auto;
            padding: 16px;
            animation: fadeIn 0.6s ease-out;
        }

        /* Glass Panel */
        .glass-panel {
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border);
            border-radius: 12px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
            margin-bottom: 16px;
        }

        /* Action Bar */
        .action-bar {
            display: flex;
            align-items: center;
            padding: 8px 20px;
            gap: 20px;
        }
        .scanner-input-group {
            display: flex;
            background: rgba(0,0,0,0.3);
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid var(--glass-border);
            width: 400px;
        }
        .scanner-input-group input {
            background: transparent; border: none; color: #fff; padding: 10px 15px; width: 100%; outline: none; font-size: 13px;
        }
        .scanner-input-group button {
            background: var(--accent-glow); border: none; color: #000; padding: 0 20px; font-weight: 800; cursor: pointer;
        }

        /* Header Card */
        .header-grid {
            display: grid;
            grid-template-columns: 240px 1fr 200px;
            padding: 15px 24px;
            align-items: center;
        }
        .brand-box img { height: 35px; filter: brightness(0) invert(1); }
        .title-box { text-align: center; }
        .title-box h1 { margin: 0; font-size: 18px; font-weight: 800; background: linear-gradient(to right, #fff, var(--accent-glow)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        
        .meta-strip {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 10px;
            padding: 12px 24px;
            background: rgba(0,0,0,0.2);
            border-bottom-left-radius: 12px;
            border-bottom-right-radius: 12px;
        }
        .meta-cell { border-left: 1px solid rgba(255,255,255,0.1); padding-left: 10px; }
        .meta-label { font-size: 9px; color: var(--text-dim); text-transform: uppercase; font-weight: 700; }
        .meta-val { font-size: 13px; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

        /* Workspace Grid */
        .workspace {
            display: grid;
            grid-template-columns: 1.4fr 1.6fr;
            gap: 16px;
        }

        /* Measurement Card Modernized */
        .mc-card { margin-bottom: 12px; overflow: hidden; border: 1px solid rgba(255,255,255,0.05); }
        .mc-header {
            background: rgba(255,255,255,0.03);
            padding: 8px 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .mc-title { font-size: 12px; font-weight: 800; color: var(--accent-glow); }
        .mc-standard { font-size: 11px; background: rgba(56, 189, 248, 0.1); padding: 2px 10px; border-radius: 4px; border: 1px solid rgba(56, 189, 248, 0.2); }

        .mc-grid {
            display: grid;
            grid-template-columns: 60px 40px repeat(5, 1fr);
            gap: 1px;
            background: rgba(255,255,255,0.05);
        }
        .mc-h { background: rgba(0,0,0,0.2); font-size: 8px; color: var(--text-dim); padding: 4px; text-align: center; }
        .mc-cell { background: rgba(15,23,42,0.4); display: flex; align-items: center; justify-content: center; }
        .mc-scale { font-size: 10px; font-weight: 700; color: #60a5fa; }
        .mc-initial { font-size: 9px; color: #94a3b8; }
        .mc-input {
            width: 100%; border: none; background: transparent; color: #fff; text-align: center; font-size: 13px; font-weight: 700; padding: 10px 0; outline: none;
        }
        .mc-input:focus { background: rgba(56, 189, 248, 0.1); }

        /* Production Stream (Right) */
        .stream-table { width: 100%; border-collapse: collapse; font-size: 11px; }
        .stream-table th { 
            background: rgba(0,0,0,0.2); color: var(--text-dim); padding: 10px 4px; font-size: 9px; 
            text-transform: uppercase; border-bottom: 1px solid var(--glass-border); 
        }
        .stream-row { border-bottom: 1px solid rgba(255,255,255,0.03); transition: 0.2s; }
        .stream-row:hover { background: rgba(255,255,255,0.02); }
        .stream-row td { padding: 4px; }
        .stream-input {
            width: 100%; background: transparent; border: none; color: #fff; font-size: 12px; outline: none; padding: 4px 0;
            text-align: center;
        }
        .stream-input::placeholder { color: rgba(255,255,255,0.1); }

        .btn-sync {
            background: linear-gradient(135deg, #0ea5e9, #2563eb);
            color: #fff; border: none; padding: 12px; border-radius: 8px; width: 100%; margin-top: 15px;
            font-weight: 800; font-size: 14px; cursor: pointer; transition: 0.3s;
            box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);
        }
        .btn-sync:hover { transform: scale(1.02); filter: brightness(1.1); }

        @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    </style>
}

<div class="hub-container">
    <!-- Top Action Bar -->
    <div class="glass-panel action-bar no-print">
        <div style="display:flex; align-items:center; gap:10px">
            <i class="bi bi-radar text-info fs-5"></i>
            <span style="font-size: 10px; font-weight: 800; letter-spacing: 1px; color: var(--accent-glow)">SYSTEM ACTIVE</span>
        </div>
        <div class="scanner-input-group">
            <input type="text" id="spsLookup" placeholder="Scan Barcode / QR Extruder..." autofocus />
            <button onclick="lookupSps()">LOAD</button>
        </div>
        <div style="flex:1; text-align:right" id="scanStatus" class="d-none">
            <span class="badge rounded-pill bg-info text-dark">SYNCING DATA...</span>
        </div>
    </div>

    <!-- Hub Header Card -->
    <div class="glass-panel">
        <div class="header-grid">
            <div class="brand-box"><img src="/images/velasto-logo-e1700056160273.png" alt="Velasto" /></div>
            <div class="title-box">
                <h1>HUB PRODUCTION REPORT</h1>
                <div style="font-size: 9px; color: var(--text-dim); text-transform: uppercase">Operational Tracking Station - Extruder</div>
            </div>
            <div style="text-align: right">
                <div style="font-size: 12px; font-weight: 800; color: var(--accent-glow)" id="docNo">@Model.DocumentNumber</div>
                <div style="font-size: 9px; color: var(--text-dim)" id="printedAt">TIME: @DateTime.Now.ToString("HH:mm")</div>
            </div>
        </div>
        <div class="meta-strip">
            <div class="meta-cell"><div class="meta-label">Customer</div><div class="meta-val" id="customer">@Model.CustomerName</div></div>
            <div class="meta-cell"><div class="meta-label">Revision No</div><div class="meta-val" id="revNo">6</div></div>
            <div class="meta-cell"><div class="meta-label">Production Date</div><div class="meta-val">@Model.ProductionDate.ToString("dd MMM yyyy")</div></div>
            <div class="meta-cell"><div class="meta-label">Active Shift</div><div class="meta-val">@Model.Shift</div></div>
            <div class="meta-cell"><div class="meta-label">Hose Type</div><div class="meta-val" id="hoseTypeDisp">@Model.HoseType</div></div>
            <div class="meta-cell"><div class="meta-label">Operator</div><div class="meta-val">@User.Identity?.Name</div></div>
        </div>
    </div>

    <!-- Workspace -->
    <div class="workspace">
        <!-- Measurement Hub -->
        <div id="measurementHub">
            <div class="glass-panel" style="padding: 40px; text-align: center; color: rgba(255,255,255,0.2); border: 1px dashed rgba(255,255,255,0.1)">
                <i class="bi bi-shield-lock-fill fs-1 d-block mb-2"></i>
                <span style="font-size: 11px; text-transform: uppercase; font-weight: 800">AWAITING UNIT SCAN...</span>
            </div>
        </div>

        <!-- Production Stream -->
        <div class="glass-panel" style="padding: 0; overflow: hidden;">
            <div style="background: rgba(255,255,255,0.03); padding: 12px 20px; border-bottom: 1px solid var(--glass-border); display:flex; justify-content:space-between; align-items:center">
                <span style="font-weight: 800; font-size: 13px">PRODUCTION STREAM</span>
                <span id="bypassDisp" style="font-size:10px; color:var(--accent-glow)">ByPass: -</span>
            </div>
            <div style="max-height: 700px; overflow-y: auto;">
                <table class="stream-table">
                    <thead>
                        <tr>
                            <th style="width:110px">Part Number</th>
                            <th style="width:50px">Vin</th>
                            <th style="width:40px">Std P</th>
                            <th style="width:40px">Act P</th>
                            <th style="width:40px">Tgt</th>
                            <th style="width:30px">OK</th>
                            <th style="width:30px">NG D</th>
                            <th style="width:30px">NG V</th>
                            <th>Remark</th>
                        </tr>
                    </thead>
                    <tbody id="prodTBody">
                        @for(int i=0; i<24; i++) {
                            <tr class="stream-row">
                                <td><input type="text" id="partNum_@i" class="stream-input" placeholder="Part#" /></td>
                                <td><input type="text" id="vin_@i" class="stream-input" placeholder="..." /></td>
                                <td><input type="text" id="stdP_@i" class="stream-input" /></td>
                                <td><input type="text" id="actP_@i" class="stream-input" /></td>
                                <td><input type="text" id="tgt_@i" class="stream-input" /></td>
                                <td><input type="text" id="ok_@i" class="stream-input" style="color:var(--accent-success)" /></td>
                                <td><input type="text" id="ngD_@i" class="stream-input" style="color:var(--accent-danger)" /></td>
                                <td><input type="text" id="ngV_@i" class="stream-input" style="color:var(--accent-danger)" /></td>
                                <td><input type="text" id="rem_@i" class="stream-input" style="text-align:left; padding-left:5px" /></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div style="padding: 15px;">
                <button class="btn-sync" onclick="saveReport()">SYNC & FINALIZE PRODUCTION</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const measurementHub = document.getElementById('measurementHub');
        const spsLookup = document.getElementById('spsLookup');

        async function lookupSps() {
            const val = spsLookup.value;
            if(!val) return;
            document.getElementById('scanStatus').classList.remove('d-none');
            try {
                const res = await fetch(`/Dimensi/GetSpsStandard?hoseType=${encodeURIComponent(val)}`);
                const result = await res.json();
                document.getElementById('scanStatus').classList.add('d-none');
                if(result.success) {
                    populate(result.data);
                    spsLookup.value = "";
                } else alert(result.message);
            } catch(e) { console.error(e); }
        }

        function populate(data) {
            document.getElementById('hoseTypeDisp').innerText = data.hoseType;
            document.getElementById('customer').innerText = data.customer || "-";
            document.getElementById('docNo').innerText = data.docNo || "SOP/DIM/VLT";
            document.getElementById('revNo').innerText = data.revNo || "R01";
            document.getElementById('bypassDisp').innerText = `ByPass: ${data.bypass || "-"}`;

            const pSet = [
                { n: "Inner Diameter", s: data.dimensi, t: data.toleranceInner },
                { n: "Inner Thickness (x/y)", s: data.tebalInner, t: "0.2" },
                { n: "Total Thickness (x/y)", s: data.tebalTotal, t: data.toleranceOuter },
                { n: "Spiral Pitch", s: "32 ± 5", t: "-" },
                { n: "Visual Appearance", s: "No Burry/Bubble", t: "-" }
            ];

            let html = "";
            pSet.forEach(p => {
                const sv = parseFloat(p.s) || 0;
                const tv = parseFloat(p.t) || 0;
                const rowCount = tv > 0 ? 5 : 1;

                html += `<div class="glass-panel mc-card">
                    <div class="mc-header">
                        <span class="mc-title">${p.n}</span>
                        <div class="mc-standard">${p.s}</div>
                    </div>
                    <div class="mc-grid">
                        <div class="mc-h">SCALE</div><div class="mc-h">INIT</div>
                        <div class="mc-h">SEQ 1</div><div class="mc-h">SEQ 2</div><div class="mc-h">SEQ 3</div><div class="mc-h">SEQ 4</div><div class="mc-h">SEQ 5</div>`;

                for(let r=0; r < rowCount; r++) {
                    const scale = tv > 0 ? (sv + (tv - (tv * 0.5 * r))).toFixed(2) : "-";
                    html += `<div class="mc-cell mc-scale">${scale}</div><div class="mc-cell mc-initial">ok</div>`;
                    for(let t=0; t<5; t++) {
                        html += `<div class="mc-cell"><input type="text" class="mc-input" placeholder="-" /></div>`;
                    }
                }
                html += `</div></div>`;
            });
            measurementHub.innerHTML = html;

            const pnValue = data.itemList || data.excelId || data.hoseType;
            for(let i=0; i<24; i++) {
                const pn = document.getElementById(`partNum_${i}`);
                if(pn) pn.value = pnValue;
            }
        }

        function saveReport() { alert("Production Data Synchronized!"); window.location.href = "/Dimensi/Index"; }
        spsLookup.addEventListener('keypress', (e) => { if(e.key === 'Enter') lookupSps(); });
        window.onload = () => { setTimeout(() => spsLookup.focus(), 500); };
    </script>
}
