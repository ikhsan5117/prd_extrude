            <div class="card-header-flex">
                <div class="card-point">SPIRAL PITCH</div>
                <i class="bi bi-hr card-icon"></i>
            </div>
            <div class="std-container">
                 <div class="std-label">STANDARD</div>
                 <div class="std-value" id="std-spiral">---</div>
            </div>
            <div class="limit-row">
                <div class="limit-pill">
                    <span class="limit-label">MIN</span>
                    <span class="limit-val min" id="limit-spiral-min">---</span>
                </div>
                <div class="limit-pill">
                    <span class="limit-label">MAX</span>
                    <span class="limit-val max" id="limit-spiral-max">---</span>
                </div>
            </div>
            <div class="input-group-custom">
                <label>ACTUAL PITCH VALUE</label>
                <div class="c-input-wrap" id="wrap-spiral">
                    <input type="text" inputmode="decimal" class="c-input" id="val-spiral" oninput="validateCard('spiral'); toggleClearBtn('spiral')" placeholder="0" />
                    <button type="button" class="c-clear-btn" onclick="clearCard('spiral')" tabindex="-1" title="Clear">✕</button>
                </div>
            </div>
            <span class="status-badge"></span>
        </div>

        <!-- VISUAL CHECK CARD -->
        <div class="dimensi-card" id="card-visual">
            <div class="card-header-flex">
                <div class="card-point">VISUAL CHECK</div>
                <i class="bi bi-eye-fill card-icon"></i>
            </div>
            <div class="visual-grid">
                <div class="visual-item">
                    <i class="bi bi-eraser-fill text-primary mb-1"></i>
                    <span class="visual-label">BURRY</span>
                    <div class="segmented-control">
                        <button class="seg-btn" id="v-burry-ok" onclick="toggleVisual('burry', 'ok')">OK</button>
                        <button class="seg-btn" id="v-burry-ng" onclick="toggleVisual('burry', 'ng')">NG</button>
                    </div>
                </div>
                <div class="visual-item">
                    <i class="bi bi-border-width text-primary mb-1"></i>
                    <span class="visual-label">LINE</span>
                    <div class="segmented-control">
                        <button class="seg-btn" id="v-line-ok" onclick="toggleVisual('line', 'ok')">OK</button>
                        <button class="seg-btn" id="v-line-ng" onclick="toggleVisual('line', 'ng')">NG</button>
                    </div>
                </div>
                <div class="visual-item">
                    <i class="bi bi-droplet-fill text-primary mb-1"></i>
                    <span class="visual-label">BUBBLE</span>
                    <div class="segmented-control">
                        <button class="seg-btn" id="v-bubble-ok" onclick="toggleVisual('bubble', 'ok')">OK</button>
                        <button class="seg-btn" id="v-bubble-ng" onclick="toggleVisual('bubble', 'ng')">NG</button>
                    </div>
                </div>
                <div class="visual-item">
                    <i class="bi bi-scissors text-primary mb-1"></i>
                    <span class="visual-label">SCRATCH</span>
                    <div class="segmented-control">
                        <button class="seg-btn" id="v-scratch-ok" onclick="toggleVisual('scratch', 'ok')">OK</button>
                        <button class="seg-btn" id="v-scratch-ng" onclick="toggleVisual('scratch', 'ng')">NG</button>
                    </div>
                </div>
            </div>
            <span class="status-badge"></span>
        </div>
    </div> <!-- END CARD GRID -->

    <!-- PRODUCTION DATA SECTION -->
    <div class="section-title">
        <i class="bi bi-clipboard2-data-fill"></i> PRODUCTION DATA Summary
        <button type="button" class="btn-add-summary ms-auto" onclick="addProductionRecord()">
            <i class="bi bi-plus-lg"></i> ADD TO LIST
        </button>
    </div>
    <div class="prod-data-container">
        <div class="prod-grid">
            <div class="field-column">
                <div class="field-box">
                    <span class="field-label">PART NUMBER</span>
                    <div class="field-input-wrap"><div class="f-input" id="disp-part-no">-</div></div>
                </div>
                <div class="field-box">
                    <span class="field-label">STD PNJG</span>
                    <div class="field-input-wrap"><input type="text" class="f-input" id="disp-std-pnjg" value="-"></div>
                </div>
                <div class="field-box">
                    <span class="field-label">QTY TARGET</span>
                    <div class="field-input-wrap"><input type="number" class="f-input" id="disp-qty-target" value="0"></div>
                </div>
            </div>
            <div class="field-column">
                <div class="field-box" style="position: relative;">
                    <span class="field-label">VIN KODE (KODE ITEM)</span>
                    <div class="field-input-wrap">
                        <input type="text" class="f-input" id="val-vin-kode"
                               placeholder="Ketik atau pilih Kode Item..."
                               oninput="filterVinKode(this.value)"
                               onfocus="showVinDropdown(this.value)"
                               onblur="setTimeout(hideVinDropdown, 250)"
                               autocomplete="off" />
                    </div>
                    <div id="vin-dropdown" style="
                        display: none; position: absolute; top: 100%; left: 0; right: 0;
                        background: rgba(10,20,40,0.98); border: 1px solid #00e5ff66;
                        border-radius: 8px; max-height: 205px; overflow-y: auto;
                        z-index: 99999; box-shadow: 0 12px 40px rgba(0,229,255,0.25);
                        margin-top: 4px;
                    "></div>
                </div>
                <div class="field-box">
                    <span class="field-label">ACT PNJG</span>
                    <div class="field-input-wrap"><input type="number" class="f-input" id="val-act-pnjg" placeholder="Enter length"></div>
                </div>
                <div class="field-box">
                    <span class="field-label">QTY ACTUAL STATUS</span>
                    <div class="qty-row">
                        <button type="button" class="qty-btn" id="qty-ok" onclick="setQtyStatus('ok')"><i class="bi bi-check-circle-fill"></i> ALL OK</button>
                        <button type="button" class="qty-btn" id="qty-ng" onclick="setQtyStatus('ng')"><i class="bi bi-x-circle-fill"></i> CONTAINS NG</button>
                    </div>
                    
                    <div id="qtyContentArea" style="margin-top: 15px; min-height: 50px;">
                        <!-- OK PANEL: Muncul 1 Input di Tengah -->
                        <div id="okPanel" style="display: none; text-align: center;">
                            <span style="font-size: 8px; color: #10b981; font-weight: 800; display: block; margin-bottom: 5px;">TOTAL QTY OK</span>
                            <div class="field-input-wrap" style="max-width: 250px; margin: 0 auto; border-color: rgba(16, 185, 129, 0.4);">
                                <input type="number" class="f-input" id="val-qty-ok" value="0">
                            </div>
                        </div>

                        <!-- NG PANEL: Muncul 2 Input Berjejer -->
                        <div id="ngPanel" style="display: none; grid-template-columns: 1fr 1fr; gap: 10px;">
                            <div>
                                <span style="font-size: 8px; color: #ef4444; font-weight: 800; display: block; text-align: center; margin-bottom: 5px;">NG DIMENSI</span>
                                <div class="field-input-wrap" style="border-color: #ef4444;">
                                    <input type="number" class="f-input" id="val-ng-dimensi" value="0">
                                </div>
                            </div>
                            <div>
                                <span style="font-size: 8px; color: #ef4444; font-weight: 800; display: block; text-align: center; margin-bottom: 5px;">NG VISUAL</span>
                                <div class="field-input-wrap" style="border-color: #ef4444;">
                                    <input type="number" class="f-input" id="val-ng-visual" value="0">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Full Width Remark -->
            <div style="grid-column: span 2; margin-top: 10px;">
                <span class="field-label">REMARK / NOTES</span>
                <textarea class="f-textarea" id="val-remark" placeholder="Enter any specific observations or production notes..."></textarea>
            </div>
        </div>

        <!-- Dynamic List Container -->
        <div class="summary-list-container">
            <table class="summary-table">
                <thead>
                    <tr>
                        <th style="width: 25%;">VIN KODE</th>
                        <th style="width: 15%;">LENGTH</th>
                        <th style="width: 15%;">QTY OK</th>
                        <th style="width: 15%;">NG DIM</th>
                        <th style="width: 15%;">NG VIS</th>
                        <th style="width: 10%; text-align: center;">ACT</th>
                    </tr>
                </thead>
                <tbody id="summary-list-body">
                    <!-- Rows injected via JS -->
                </tbody>
            </table>
            <div id="summary-empty" class="empty-summary-state">
                <i class="bi bi-inbox mb-2" style="font-size: 24px; display: block;"></i>
                No production records added yet for this slot.
            </div>
        </div>
    </div>
</div> <!-- END INPUT WORKSPACE -->

    <!-- STATIC ACTION BAR AT THE BOTTOM -->
    <div class="bottom-action-bar-container" style="
        margin-top: 50px; 
        padding: 30px 0 60px; 
        display: flex; 
        justify-content: center;
        border-top: 1px solid rgba(255,255,255,0.05);
        position: relative;
    ">
        <button type="button" onclick="submitEntry()" class="submit-btn" id="submit-entry-btn" disabled style="
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            color: white; 
            padding: 20px 100px; 
            border: none; 
            border-radius: 15px;
            font-weight: 800; 
            font-size: 20px; 
            cursor: pointer;
            box-shadow: 0 15px 40px rgba(37, 99, 235, 0.3);
            display: flex; 
            align-items: center; 
            gap: 15px;
            transition: all 0.3s;
            text-transform: uppercase; 
            letter-spacing: 2px;
            opacity: 0.5;
            cursor: not-allowed;
        " onmouseover="this.style.transform='scale(1.05) translateY(-5px)';" 
          onmouseout="this.style.transform='scale(1) translateY(0)';">
            <i class="bi bi-cloud-arrow-up-fill" style="font-size: 28px;"></i>
            SUBMIT ENTRY
        </button>
        
        <div id="save-status" style="
            position: absolute; 
            right: 0; 
            top: 40px;
            color: #10b981; 
            font-size: 14px; 
            opacity: 0; 
            transition: 0.5s; 
            font-weight: 800; 
            background: rgba(16, 185, 129, 0.1); 
            padding: 10px 20px; 
            border-radius: 10px; 
            border: 1px solid rgba(16, 185, 129, 0.2);
            pointer-events: none;
        ">
            <i class="bi bi-check2-circle"></i> DATA SAVED!
        </div>
    </div>

</div> <!-- END SMART DIMENSION HUB --></div>

@section Scripts {
    <script src="~/lib/offline-cdn/sweetalert2.all.min.js"></script>
    <script src="~/lib/offline-cdn/html5-qrcode.min.js"></script>
    <script>
        let measurements = @Html.Raw(Json.Serialize(Model.Measurements.GroupBy(m => m.TimeSection).Select(g => new {
            time = g.Key,
            data = new {
                vin = Model.VinCode,
                actPnjg = Model.ActualLength,
                remark = Model.Remark,
                qtySt = Model.Status == "COMPLETED" ? "ok" : "ng",
                qtyOk = Model.QtyOk,
                ngDim = Model.NgDimension,
                ngVis = Model.NgVisual,
                innerDia = g.FirstOrDefault(x => x.PointName == "Inner Diameter")?.R1,
                innerTx = g.FirstOrDefault(x => x.PointName == "Inner Thick X")?.R1,
                innerTy = g.FirstOrDefault(x => x.PointName == "Inner Thick Y")?.R1,
                totalTx = g.FirstOrDefault(x => x.PointName == "Total Thick X")?.R1,
                totalTy = g.FirstOrDefault(x => x.PointName == "Total Thick Y")?.R1,
                spiral = g.FirstOrDefault(x => x.PointName == "Spiral Pitch")?.R1,
                visual = new { 
                    burry = (string?)null, line = (string?)null, bubble = (string?)null, scratch = (string?)null 
                },
                summaries = new List<object>()
            }
        })));

        if (!measurements || measurements.length === 0) {
            measurements = [ { time: null, data: { 
                vin: "@Model.VinCode", actPnjg: "@Model.ActualLength", remark: "@Model.Remark", qtyOk: "@Model.QtyOk", ngDim: "@Model.NgDimension", ngVis: "@Model.NgVisual",
                summaries: [] 
            } } ];
        }

        let currentIndex = 0;
        let activeStandards = {}; // Will be populated by loadMaster()

        // ── VIN KODE Autocomplete ──────────────────────────────────────────────
        const vinItemCodes = @Html.Raw(
            System.Text.Json.JsonSerializer.Serialize(
                (ViewBag.ItemCodes as IEnumerable<object> ?? new List<object>())
                .Select(x => x == null ? "" : x.ToString())
                .Where(x => !string.IsNullOrEmpty(x))
                .ToList()
            )
        );
        console.log('[VIN KODE] Items loaded:', vinItemCodes.length, vinItemCodes);

        function renderVinItems(list) {
            const dd = document.getElementById('vin-dropdown');
            if (!dd) return;
            if (list.length === 0) { dd.style.display = 'none'; return; }
            dd.innerHTML = list.map(c => `
                <div onclick="selectVinCode('${c}')" style="
                    padding: 10px 16px; cursor: pointer; font-size: 12px; font-family: 'Roboto Mono', monospace;
                    color: #e0f7ff; letter-spacing: 1px; border-bottom: 1px solid #ffffff10;
                    transition: background .15s;
                " onmouseover="this.style.background='#00e5ff18'" onmouseout="this.style.background='transparent'">
                    ${c}
                </div>`).join('');
            dd.style.display = 'block';
        }

        function showVinDropdown(val) {
            const q = (val || '').trim().toUpperCase();
            const filtered = q.length === 0 ? vinItemCodes : vinItemCodes.filter(c => c.toUpperCase().includes(q));
            renderVinItems(filtered);
        }

        function filterVinKode(val) { showVinDropdown(val); }

        function hideVinDropdown() {
            const dd = document.getElementById('vin-dropdown');
            if (dd) dd.style.display = 'none';
        }

        function selectVinCode(code) {
            const inp = document.getElementById('val-vin-kode');
            if (inp) inp.value = code;
            hideVinDropdown();
        }
        // ──────────────────────────────────────────────────────────────────────

        let html5QrCode;

        window.onload = () => {
            loadMaster();
            renderTimeline();
            loadDataToUI();
            initSmartNext();
        };

        async function openScanner() {
            const res = await Swal.fire({
                title: 'SCAN ITEM LIST CODE',
                html: '<div id="qr-reader" style="width: 100%; border-radius: 12px; overflow: hidden; background: #000;"></div>',
                showCancelButton: true,
                confirmButtonText: 'CANCEL',
                showConfirmButton: false,
                didOpen: () => {
                    html5QrCode = new Html5Qrcode("qr-reader");
                    const qrCodeSuccessCallback = (decodedText, decodedResult) => {
                        document.getElementById('main-item-search').value = decodedText;
                        Swal.close();
                        loadMaster();
                    };
                    const config = { fps: 15, qrbox: { width: 250, height: 250 } };
                    html5QrCode.start({ facingMode: "environment" }, config, qrCodeSuccessCallback)
                        .catch(err => {
                            Swal.showValidationMessage(`Camera failed: ${err}`);
                        });
                },
                willClose: () => {
                    if (html5QrCode) {
                        html5QrCode.stop().catch(e => console.error(e));
                    }
                }
            });
        }

        let isToolConnected = false;
        let toolPrefix = "";
        let linkedDeviceName = "NONE / MANUAL";

        function normalizePlanningShift(shiftValue) {
            if (!shiftValue) return '';
            const raw = shiftValue.toString().trim().toUpperCase();
            const num = raw.replace(/SHIFT/gi, '').trim();
            if (num === '1' || num === 'I' || raw.includes('SIANG') || raw.includes('ONE')) return 'Shift 1';
            if (num === '2' || num === 'II' || raw.includes('SORE') || raw.includes('TWO')) return 'Shift 2';
            if (num === '3' || num === 'III' || raw.includes('MALAM') || raw.includes('THREE')) return 'Shift 3';
            return shiftValue.toString().trim();
        }

        function toggleShift() {
            const el = document.getElementById('h-shift');
            const current = normalizePlanningShift(el.innerText) || 'Shift 1';
            const next = current === 'Shift 1' ? 'Shift 2' : 'Shift 1';
            el.innerText = next;
            
            // Pulse effect
            el.classList.remove('animate__animated', 'animate__pulse');
            setTimeout(() => el.classList.add('animate__animated', 'animate__pulse'), 10);
            
            Swal.fire({ 
                icon: 'info', 
                title: 'SHIFT UPDATED', 
                text: `Toggled to ${next}`, 
                timer: 1000, 
                showConfirmButton: false, 
                toast: true, 
                position: 'top-end' 
            });

            refreshPlanningItems();
        }

        let planningItemsCache = [];
        let planningResultItems = [];
        let planningResultIndex = -1;

        async function refreshPlanningItems() {
            const dateText = document.getElementById('h-date')?.innerText || '';
            const shiftText = document.getElementById('h-shift')?.innerText || '';
            const date = parseDisplayDate(dateText);
            const planningInput = document.getElementById('planningSearch');
            if (!date || !shiftText || !planningInput) return;

            planningInput.placeholder = 'LOADING PLANNING...';
            planningInput.disabled = true;
            document.getElementById('planningResults')?.classList.add('d-none');

            try {
                const res = await fetch(`/ProductionReport/GetPlanningItems?date=${date}&shift=${encodeURIComponent(shiftText)}`);
                planningItemsCache = await res.json();
                planningResultItems = planningItemsCache;
                planningResultIndex = -1;

                // Cek apakah filter mesin aktif
                const isFiltered = planningItemsCache.length > 0 && planningItemsCache[0].isFiltered;
                const machineCtx = isFiltered && planningItemsCache[0].machineName
                    ? ` [${planningItemsCache[0].machineName}]`
                    : '';

                planningInput.disabled = false;
                if (planningItemsCache.length > 0) {
                    planningInput.placeholder = `KETIK ITEM CODE (${planningItemsCache.length} TERSEDIA${machineCtx})`;
                } else {
                    planningInput.placeholder = 'NO ITEMS IN PLAN FOR THIS MACHINE/DAY';
                }
                planningInput.value = '';
            } catch (error) {
                console.error('Failed to refresh planning items:', error);
                planningInput.disabled = false;
                planningInput.placeholder = 'ERROR LOADING PLANNING';
            }
        }

        function filterPlanningResults(query) {
            const sanitizedQuery = query.trim().toUpperCase();
            const results = sanitizedQuery.length === 0
                ? planningItemsCache
                : planningItemsCache.filter(item =>
                    (item.itemCode && item.itemCode.toUpperCase().includes(sanitizedQuery)) ||
                    (item.itemName && item.itemName.toUpperCase().includes(sanitizedQuery))
                );

            planningResultItems = results;
            planningResultIndex = -1;
            renderPlanningResults(results, sanitizedQuery.length === 0);
        }

        function renderPlanningResults(items, showAll = false) {
            const container = document.getElementById('planningResults');
            if (!container) return;
            container.innerHTML = '';

            if (items.length === 0) {
                container.innerHTML = `<div class="planning-result-item" style="text-align:center; opacity:0.5; pointer-events:none;">
                    <div class="planning-result-code">--- NO MATCHES FOUND ---</div>
                </div>`;
                container.classList.remove('d-none');
                return;
            }

            // Header with count
            const header = document.createElement('div');
            header.style.cssText = 'padding:10px 20px;font-size:9px;font-weight:900;color:var(--accent-glow);letter-spacing:2px;text-transform:uppercase;border-bottom:1px solid rgba(255,255,255,0.05);margin-bottom:8px;opacity:0.7;display:flex;align-items:center;justify-content:space-between;';
            header.innerHTML = `<span>PLANNING RESULTS (${items.length})</span> <i class="bi bi-funnel-fill"></i>`;
            container.appendChild(header);

            items.forEach((item, index) => {
                const hasSps = item.hasSps === true;
                const spsBadge = hasSps
                    ? `<span style="font-size:9px;font-weight:900;color:#10b981;background:rgba(16,185,129,0.15);padding:2px 8px;border-radius:20px;border:1px solid rgba(16,185,129,0.4);white-space:nowrap;"><i class="bi bi-check-circle-fill me-1"></i>SPS ✓</span>`
                    : `<span style="font-size:9px;font-weight:900;color:#ef4444;background:rgba(239,68,68,0.12);padding:2px 8px;border-radius:20px;border:1px solid rgba(239,68,68,0.35);white-space:nowrap;"><i class="bi bi-x-circle-fill me-1"></i>NO SPS</span>`;
                const borderColor = hasSps ? 'rgba(16,185,129,0.5)' : 'rgba(239,68,68,0.35)';

                const div = document.createElement('div');
                div.className = 'planning-result-item';
                div.dataset.index = index;
                div.style.borderLeft = `3px solid ${borderColor}`;
                div.innerHTML = `
                    <div style="display:flex;justify-content:space-between;align-items:center;width:100%;gap:8px;flex-wrap:wrap;">
                        <div class="planning-result-code">${item.itemCode}</div>
                        <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
                            ${item.machineName ? `<div class="machine-badge-mini"><i class="bi bi-cpu-fill"></i>${item.machineName}</div>` : ''}
                            ${spsBadge}
                        </div>
                    </div>
                    <div class="planning-result-name">${item.itemName || 'NO DESCRIPTION'}</div>
                    <div class="planning-result-meta"><i class="bi bi-calendar3"></i> ${item.dateShift || '---'}</div>
                `;
                div.onclick = () => selectPlanningItem(item);
                div.onmouseenter = () => highlightPlanningResult(index);
                container.appendChild(div);
            });

            container.classList.remove('d-none');
            planningResultIndex = showAll ? 0 : -1;
            if (showAll && items.length > 0) highlightPlanningResult(0);
        }

        function highlightPlanningResult(index) {
            const container = document.getElementById('planningResults');
            if (!container) return;
            const options = Array.from(container.querySelectorAll('.planning-result-item'));
            options.forEach(opt => opt.classList.remove('planning-result-highlight'));
            const target = options[index];
            if (!target) return;
            target.classList.add('planning-result-highlight');
            planningResultIndex = index;
            target.scrollIntoView({ block: 'nearest' });
        }

        function movePlanningSelection(direction) {
            if (!planningResultItems.length) return;
            planningResultIndex = Math.max(0, Math.min(planningResultItems.length - 1, planningResultIndex + direction));
            highlightPlanningResult(planningResultIndex);
        }

        function selectHighlightedPlanningItem() {
            if (planningResultIndex < 0 || planningResultIndex >= planningResultItems.length) return;
            selectPlanningItem(planningResultItems[planningResultIndex]);
        }

        function selectPlanningItem(item) {
            const planningInput = document.getElementById('planningSearch');
            const displayText = item.machineName ? `[${item.itemCode}] ${item.machineName}` : `[${item.itemCode}]`;
            if (planningInput) {
                planningInput.value = displayText;
                planningInput.readOnly = true;
                planningInput.style.cursor = 'pointer';
            }
            window._dimSelectedLabel = displayText;
            window._dimSelectedItemCode = item.itemCode;
            window._dimSelectedItemName = item.itemName; // Tambahkan ini untuk menyimpan itemName
            const itemCodeInput = document.getElementById('itemCode');
            if (itemCodeInput) itemCodeInput.value = item.itemCode;
            document.getElementById('planningResults')?.classList.add('d-none');

            // Save draft for previous item before switching
            if (_dimCurrentItem && _dimCurrentItem !== (item.itemCode || '').toUpperCase().trim()) {
                saveCurrentData();          // flush DOM → measurements[] first
                dimCaptureDraft(_dimCurrentItem);  // then snapshot to localStorage
            }

            const lineEl = document.getElementById('h-line');
            if (lineEl && item.machineName) {
                lineEl.innerText = item.machineName;
                lineEl.classList.add('animate__animated', 'animate__flash');
                setTimeout(() => lineEl.classList.remove('animate__flash'), 1000);
            }
            if (item.date || item.shift) setPlanningDateAndShift(item.date, item.shift);
            document.getElementById('main-item-search').value = item.itemCode;
            loadMaster();
        }

        function openPlanningDropdown() {
            const planningInput = document.getElementById('planningSearch');
            if (!planningInput) return;
            planningInput.value = '';
            planningInput.readOnly = false;
            
            const isFiltered = planningItemsCache.length > 0 && planningItemsCache[0].isFiltered;
            const machineCtx = isFiltered && planningItemsCache[0].machineName ? ` [${planningItemsCache[0].machineName}]` : '';
            
            planningInput.placeholder = planningItemsCache.length > 0
