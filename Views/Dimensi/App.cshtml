@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/html5-qrcode"></script>
    <script>
        let measurements = @Html.Raw(Json.Serialize(Model.Measurements.GroupBy(m => m.TimeSection).Select(g => new {
            time = g.Key,
            data = new {
                vin = Model.VinCode,
                actPnjg = Model.ActualLength,
                remark = Model.Remark,
                qtySt = Model.Status == "COMPLETED" ? "ok" : "ng",
                qtyOk = Model.QtyOk,
                ngDim = Model.NgDimension,
                ngVis = Model.NgVisual,
                innerDia = g.FirstOrDefault(x => x.PointName == "Inner Diameter")?.R1,
                innerTx = g.FirstOrDefault(x => x.PointName == "Inner Thick X")?.R1,
                innerTy = g.FirstOrDefault(x => x.PointName == "Inner Thick Y")?.R1,
                totalTx = g.FirstOrDefault(x => x.PointName == "Total Thick X")?.R1,
                totalTy = g.FirstOrDefault(x => x.PointName == "Total Thick Y")?.R1,
                spiral = g.FirstOrDefault(x => x.PointName == "Spiral Pitch")?.R1,
                visual = new { 
                    burry = (string?)null, line = (string?)null, bubble = (string?)null, scratch = (string?)null 
                } // Visual labels can be expanded as needed
            }
        })));

        if (!measurements || measurements.length === 0) {
            measurements = [ { time: null, data: { vin: "@Model.VinCode", actPnjg: "@Model.ActualLength", remark: "@Model.Remark", qtyOk: "@Model.QtyOk", ngDim: "@Model.NgDimension", ngVis: "@Model.NgVisual" } } ];
        }

        let currentIndex = 0;
        let activeStandards = {}; // Will be populated by loadMaster()

        let html5QrCode;

        window.onload = () => {
            loadMaster();
            renderTimeline();
            loadDataToUI();
            initSmartNext();
        };

        async function openScanner() {
            const res = await Swal.fire({
                title: 'SCAN ITEM LIST CODE',
                html: '<div id="qr-reader" style="width: 100%; border-radius: 12px; overflow: hidden; background: #000;"></div>',
                showCancelButton: true,
                confirmButtonText: 'CANCEL',
                showConfirmButton: false,
                didOpen: () => {
                    html5QrCode = new Html5Qrcode("qr-reader");
                    const qrCodeSuccessCallback = (decodedText, decodedResult) => {
                        document.getElementById('main-item-search').value = decodedText;
                        Swal.close();
                        loadMaster();
                    };
                    const config = { fps: 15, qrbox: { width: 250, height: 250 } };
                    html5QrCode.start({ facingMode: "environment" }, config, qrCodeSuccessCallback)
                        .catch(err => {
                            Swal.showValidationMessage(`Camera failed: ${err}`);
                        });
                },
                willClose: () => {
                    if (html5QrCode) {
                        html5QrCode.stop().catch(e => console.error(e));
                    }
                }
            });
        }

        let isToolConnected = false;
        let toolPrefix = "";
        let linkedDeviceName = "NONE / MANUAL";

        function toggleShift() {
            const el = document.getElementById('h-shift');
            const current = el.innerText;
            let next = "Shift 1";
            if (current === "Shift 1") next = "Shift 2";
            else if (current === "Shift 2") next = "Shift 3";
            el.innerText = next;
            
            // Pulse effect
            el.classList.remove('animate__animated', 'animate__pulse');
            setTimeout(() => el.classList.add('animate__animated', 'animate__pulse'), 10);
            
            Swal.fire({ 
                icon: 'info', 
                title: 'SHIFT UPDATED', 
                text: `Toggled to ${next}`, 
                timer: 1000, 
                showConfirmButton: false, 
                toast: true, 
                position: 'top-end' 
            });

            refreshPlanningItems();
        }

        let planningItemsCache = [];
        let planningResultItems = [];
        let planningResultIndex = -1;

        async function refreshPlanningItems() {
            const dateText = document.getElementById('h-date')?.innerText || '';
            const shiftText = document.getElementById('h-shift')?.innerText || '';
            const date = parseDisplayDate(dateText);
            const planningInput = document.getElementById('planningSearch');
            if (!date || !shiftText || !planningInput) return;

            planningInput.placeholder = 'LOADING PLANNING...';
            planningInput.disabled = true;
            document.getElementById('planningResults')?.classList.add('d-none');

            try {
                const res = await fetch(`/ProductionReport/GetPlanningItems?date=${date}&shift=${encodeURIComponent(shiftText)}`);
                planningItemsCache = await res.json();
                planningResultItems = planningItemsCache;
                planningResultIndex = -1;

                // Cek apakah filter mesin aktif
                const isFiltered = planningItemsCache.length > 0 && planningItemsCache[0].isFiltered;
                const machineCtx = isFiltered && planningItemsCache[0].machineName
                    ? ` [${planningItemsCache[0].machineName}]`
                    : '';

                planningInput.disabled = false;
                if (planningItemsCache.length > 0) {
                    planningInput.placeholder = `SEARCH PLANNING (${planningItemsCache.length} ITEM${planningItemsCache.length > 1 ? 'S' : ''}${machineCtx})`;
                } else {
                    planningInput.placeholder = 'NO ITEMS IN PLAN FOR THIS MACHINE/DAY';
                }
                planningInput.value = '';
            } catch (error) {
                console.error('Failed to refresh planning items:', error);
                planningInput.disabled = false;
                planningInput.placeholder = 'ERROR LOADING PLANNING';
            }
        }

        function filterPlanningResults(query) {
            const sanitizedQuery = query.trim().toUpperCase();
            const results = sanitizedQuery.length === 0
                ? planningItemsCache
                : planningItemsCache.filter(item =>
                    (item.itemCode && item.itemCode.toUpperCase().includes(sanitizedQuery)) ||
                    (item.itemName && item.itemName.toUpperCase().includes(sanitizedQuery))
                );

            planningResultItems = results;
            planningResultIndex = -1;
            renderPlanningResults(results, sanitizedQuery.length === 0);
        }

        function renderPlanningResults(items, showAll = false) {
            const container = document.getElementById('planningResults');
            if (!container) return;
            container.innerHTML = '';

            if (items.length === 0) {
                container.innerHTML = `<div class="planning-result-item" style="text-align:center; opacity:0.5; pointer-events:none;">
                    <div class="planning-result-code">--- NO MATCHES FOUND ---</div>
                </div>`;
                container.classList.remove('d-none');
                return;
            }

            // Add Header with count
            const header = document.createElement('div');
            header.style = "padding: 10px 20px; font-size: 9px; font-weight: 900; color: var(--accent-glow); letter-spacing: 2px; text-transform: uppercase; border-bottom: 1px solid rgba(255,255,255,0.05); margin-bottom: 8px; opacity: 0.7; display: flex; align-items: center; justify-content: space-between;";
            header.innerHTML = `<span>PLANNING RESULTS (${items.length})</span> <i class="bi bi-funnel-fill"></i>`;
            container.appendChild(header);

            items.forEach((item, index) => {
                const div = document.createElement('div');
                div.className = 'planning-result-item';
                div.dataset.index = index;
                div.innerHTML = `
                    <div style="display:flex; justify-content:space-between; align-items:center; width: 100%;">
                        <div class="planning-result-code">${item.itemCode}</div>
                        ${item.machineName ? `
                            <div class="machine-badge-mini">
                                <i class="bi bi-cpu-fill"></i>
                                ${item.machineName}
                            </div>` : ''}
                    </div>
                    <div class="planning-result-name">${item.itemName || 'NO DESCRIPTION'}</div>
                    <div class="planning-result-meta">
                        <i class="bi bi-calendar3"></i> ${item.dateShift || '---'}
                    </div>
                `;
                div.onclick = () => selectPlanningItem(item);
                div.onmouseenter = () => highlightPlanningResult(index);
                container.appendChild(div);
            });

            container.classList.remove('d-none');
            planningResultIndex = showAll ? 0 : -1;
            if (showAll && items.length > 0) {
                highlightPlanningResult(0);
            }
        }

        function highlightPlanningResult(index) {
            const container = document.getElementById('planningResults');
            if (!container) return;
            const options = Array.from(container.querySelectorAll('.planning-result-item'));
            options.forEach(opt => opt.classList.remove('planning-result-highlight'));
            const target = options[index];
            if (!target) return;
            target.classList.add('planning-result-highlight');
            planningResultIndex = index;
            target.scrollIntoView({ block: 'nearest' });
        }

        function movePlanningSelection(direction) {
            if (!planningResultItems.length) return;
            planningResultIndex = Math.max(0, Math.min(planningResultItems.length - 1, planningResultIndex + direction));
            highlightPlanningResult(planningResultIndex);
        }

        function selectHighlightedPlanningItem() {
            if (planningResultIndex < 0 || planningResultIndex >= planningResultItems.length) return;
            selectPlanningItem(planningResultItems[planningResultIndex]);
        }

        function selectPlanningItem(item) {
            const planningInput = document.getElementById('planningSearch');
            // Tampilkan hanya kode item + nama mesin (ringkas)
            const displayText = item.machineName
                ? `[${item.itemCode}] ${item.machineName}`
                : `[${item.itemCode}]`;
            if (planningInput) planningInput.value = displayText;
            document.getElementById('planningResults')?.classList.add('d-none');
            
            // Update Machine / Line dynamically from Planning
            const lineEl = document.getElementById('h-line');
            if (lineEl && item.machineName) {
                lineEl.innerText = item.machineName;
                lineEl.classList.add('animate__animated', 'animate__flash');
                setTimeout(() => lineEl.classList.remove('animate__flash'), 1000);
            }

            if (item.date) {
                setPlanningDateAndShift(item.date, item.shift);
            }
            document.getElementById('main-item-search').value = item.itemCode;
            loadMaster();
        }

        function showPlanningResults() {
            const val = document.getElementById('planningSearch')?.value || '';
            if (planningItemsCache.length > 0) {
                filterPlanningResults(val.replace(/^\[.*?\]\s*/, ''));
            }
        }

        function parseDisplayDate(displayText) {
            const monthMap = {
                JAN: '01', FEB: '02', MAR: '03', APR: '04', MAY: '05', JUN: '06',
                JUL: '07', AUG: '08', SEP: '09', OCT: '10', NOV: '11', DEC: '12'
            };
            const parts = (displayText || '').trim().split(' ');
            if (parts.length !== 3) return null;
            const [day, month, year] = parts;
            const monthNum = monthMap[month.toUpperCase()];
            if (!monthNum) return null;
            return `${year}-${monthNum}-${day.padStart(2, '0')}`;
        }

        function formatDisplayDate(dateValue) {
            const date = new Date(dateValue);
            if (isNaN(date.getTime())) return '';
            const monthNames = ['JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN', 'JUL', 'AUG', 'SEP', 'OCT', 'NOV', 'DEC'];
            const day = String(date.getDate()).padStart(2, '0');
            const month = monthNames[date.getMonth()];
            const year = date.getFullYear();
            return `${day} ${month} ${year}`;
        }

        async function selectHUDDate() {
            const { value: date } = await Swal.fire({
                title: 'SELECT PRODUCTION DATE',
                input: 'date',
                inputValue: parseDisplayDate(document.getElementById('h-date').innerText),
                confirmButtonColor: '#38bdf8'
            });
            if (date) {
                const formatted = formatDisplayDate(date);
                document.getElementById('h-date').innerText = formatted;
                refreshPlanningItems();
            }
        }

        function setPlanningDateAndShift(dateValue, shiftValue) {
            const dateEl = document.getElementById('h-date');
            const shiftEl = document.getElementById('h-shift');
            if (dateEl) {
                const formatted = formatDisplayDate(dateValue);
                if (formatted) dateEl.innerText = formatted;
            }
            if (shiftEl && shiftValue) {
                const normalized = shiftValue.toUpperCase();
                if (normalized === 'I') shiftEl.innerText = 'Shift 1';
                else if (normalized === 'II') shiftEl.innerText = 'Shift 2';
                else if (normalized === 'III') shiftEl.innerText = 'Shift 3';
                else shiftEl.innerText = shiftValue;
            }
        }

        async function scanForTool() {
            try {
                if (!navigator.bluetooth) {
                    Swal.fire({ icon: 'error', title: 'NOT SUPPORTED', text: 'Browser Anda tidak mendukung Web Bluetooth API.' });
                    return;
                }
                
                const filterVal = document.getElementById('bt-filter-name')?.value.trim();
                const options = filterVal 
                    ? { filters: [{ namePrefix: filterVal }] } 
                    : { acceptAllDevices: true };

                const device = await navigator.bluetooth.requestDevice(options);
                linkedDeviceName = device.name || "UNNAMED DEVICE";
                
                // Update UI in popup if still open
                const nameEl = document.getElementById('val-device-name');
                if(nameEl) nameEl.innerText = linkedDeviceName;
                
                Swal.fire({ icon: 'success', title: 'TOOL ASSIGNED', text: `${linkedDeviceName} Linked`, timer: 1500, showConfirmButton: false, position: 'top-end', toast: true });
            } catch (e) {
                console.error("Discovery Cancelled", e);
            }
        }

