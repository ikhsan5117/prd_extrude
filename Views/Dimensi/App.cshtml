                + '<div style="color:#6ee7b7;font-size:0.7rem;">[' + itemCode + '] — ' + (age < 1 ? 'baru saja' : age + ' mnt lalu') + '</div></div>'
                + '<button onclick="this.parentElement.remove()" style="background:none;border:none;color:#6ee7b7;font-size:1.1rem;cursor:pointer;margin-left:8px;">✕</button>';
            document.body.appendChild(banner);
            setTimeout(() => { const b = document.getElementById('dimDraftBanner'); if (b) b.remove(); }, 7000);
