        // ─── DRAFT SYSTEM (Dimensi) ──────────────────────────────────────────
        const DIM_DRAFT_PREFIX = 'velasto_dim_draft_v1_';
        let _dimCurrentItem = null;
        let _dimAutoSaveTimer = null;

        function _dimDraftKey(itemCode) { return DIM_DRAFT_PREFIX + (itemCode || '').toUpperCase().trim(); }

        function dimCaptureDraft(itemCode) {
            if (!itemCode) return;
            const draft = { ts: Date.now(), measurements: JSON.parse(JSON.stringify(measurements)), currentIndex };
            try { localStorage.setItem(_dimDraftKey(itemCode), JSON.stringify(draft)); } catch(e) {}
        }

        function dimRestoreDraft(itemCode) {
            const raw = localStorage.getItem(_dimDraftKey(itemCode));
            if (!raw) return false;
            let draft; try { draft = JSON.parse(raw); } catch { return false; }
            if (!draft || !draft.measurements) return false;
            measurements = draft.measurements;
            currentIndex = draft.currentIndex || 0;
            renderTimeline();
            loadDataToUI();
            return true;
        }

        function dimClearDraft(itemCode) {
            try { if (itemCode) localStorage.removeItem(_dimDraftKey(itemCode)); } catch {}
        }

