        function cleanValue(raw) {
            if(!raw || raw === "0" || raw === "0.00") return "0.00";
            let cleaned = raw.toString().replace(/[+]/g, '').trim();
            let n = parseFloat(cleaned);
            return isNaN(n) ? cleaned : n.toFixed(2);
        }

        function initSmartNext() {
            // Global Enter key listener — auto-advance for caliper & Bluetooth tools
            document.addEventListener('keydown', (e) => {
                if (e.key !== 'Enter') return;

                const active = document.activeElement;
                const isCInput = active && active.classList.contains('c-input');
                const isFInput = active && active.classList.contains('f-input');

                // For f-input: only auto-next if tool connected (Bluetooth mode)
                if (isFInput && !isToolConnected) return;

                // For c-input: ALWAYS auto-next (caliper mode — Enter = send value)
                if (!isCInput && !isFInput) return;

                e.preventDefault();

                // Clean value: strip + prefix and leading zeros (caliper output format)
                setTimeout(() => {
                    let val = active.value.trim();
                    if (toolPrefix && val.startsWith(toolPrefix)) {
                        val = val.replace(toolPrefix, '').replace(':', '').trim();
                    }
                    active.value = cleanValue(active.value);

                    const id = active.id.replace('val-', '');
                    if (isCInput) {
                        validateCard(id);
                        toggleClearBtn(id);
                    }

                    // Sequence: all c-input then f-input (non-readonly)
                    const sequence = Array.from(document.querySelectorAll('.c-input:not([disabled]), .f-input:not([readonly])'));
                    const currentIdx = sequence.indexOf(active);

                    if (currentIdx > -1 && currentIdx < sequence.length - 1) {
                        const next = sequence[currentIdx + 1];
                        next.focus();
                        if (next.tagName === 'INPUT') next.select();
                        const card = next.closest('.dimensi-card');
                        if (card) card.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    } else if (currentIdx === sequence.length - 1) {
                        Swal.fire({ icon: 'success', title: 'SEQUENCE COMPLETED', timer: 1000, showConfirmButton: false, position: 'top-end', toast: true });
                    }
                }, 20);
            });
        }

        function renderTimeline() {
            const container = document.getElementById('timelineContainer');
            const btns = container.querySelectorAll('.jam-btn:not(.add-btn)');
            btns.forEach(b => b.remove());

            measurements.forEach((slot, idx) => {
                const btn = document.createElement('button');
                btn.className = `jam-btn ${idx === currentIndex ? 'active' : ''}`;
                btn.innerText = slot.time || `P-${idx + 1}`;
                btn.onclick = () => switchSlot(idx);
                
                if (idx > 0) {
                    const del = document.createElement('div');
                    del.className = 'slot-delete-btn';
                    del.innerHTML = '<i class="bi bi-x-lg"></i>';
                    del.onclick = (e) => { e.stopPropagation(); removeSlot(idx); };
                    btn.appendChild(del);
                }
                container.insertBefore(btn, container.querySelector('.add-btn'));
            });
        }

        async function removeSlot(idx) {
            const result = await Swal.fire({
                title: 'Hapus Sesi?', text: "Data pada sesi ini akan hilang!", icon: 'warning',
                showCancelButton: true, confirmButtonColor: '#ef4444', confirmButtonText: 'Ya, Hapus'
            });
            if (result.isConfirmed) {
                measurements.splice(idx, 1);
                if (currentIndex >= measurements.length) currentIndex = measurements.length - 1;
                loadDataToUI();
                renderTimeline();
            }
        }

        function addNewSlot() {
            saveCurrentData();
            measurements.push({ time: null, data: {} });
            switchSlot(measurements.length - 1);
        }

        function switchSlot(idx) {
            saveCurrentData();
            currentIndex = idx;
            loadDataToUI();
            renderTimeline();
        }

        function setQtyStatus(state) {
            const okBtn = document.getElementById('qty-ok');
            const ngBtn = document.getElementById('qty-ng');
            const okPanel = document.getElementById('okPanel');
            const ngPanel = document.getElementById('ngPanel');

            if(!okBtn || !ngBtn || !okPanel || !ngPanel) return;

            // Reset UI
            okBtn.classList.remove('active-ok');
            ngBtn.classList.remove('active-ng');
            okPanel.style.display = 'none';
            ngPanel.style.display = 'none';

            if(state === 'ok') {
                okBtn.classList.add('active-ok');
                okPanel.style.display = 'block';
            } else if(state === 'ng') {
                ngBtn.classList.add('active-ng');
                ngPanel.style.display = 'grid';
            }
            saveCurrentData();
        }

        function toggleVisual(item, state) {
            const okBtn = document.getElementById(`v-${item}-ok`);
            const ngBtn = document.getElementById(`v-${item}-ng`);
            okBtn.classList.remove('active-ok');
            ngBtn.classList.remove('active-ng');
            if (state === 'ok') okBtn.classList.add('active-ok');
            else ngBtn.classList.add('active-ng');
            renderVisualStatus();
            saveCurrentData();
        }

        function renderVisualStatus() {
            const card = document.getElementById('card-visual');
            const items = ['burry', 'line', 'bubble', 'scratch'];
            let allOK = true, anyNG = false, anySelected = false;

            items.forEach(it => {
                const isOK = document.getElementById(`v-${it}-ok`).classList.contains('active-ok');
                const isNG = document.getElementById(`v-${it}-ng`).classList.contains('active-ng');
                if (isOK || isNG) anySelected = true;
                if (isNG) anyNG = true;
                if (!isOK) allOK = false;
            });

            card.classList.remove('status-ok', 'status-ng');
            if (anySelected) {
                if (anyNG) card.classList.add('status-ng');
                else if (allOK) card.classList.add('status-ok');
            }
        }

        function saveCurrentData() {
            const current = measurements[currentIndex];
            if(!current) return;

            const vStates = {};
            ['burry', 'line', 'bubble', 'scratch'].forEach(it => {
                const ok = document.getElementById(`v-${it}-ok`).classList.contains('active-ok');
                const ng = document.getElementById(`v-${it}-ng`).classList.contains('active-ng');
                vStates[it] = ok ? 'ok' : (ng ? 'ng' : null);
            });

            // Capture QTY Status
            const qtyOkActive = document.getElementById('qty-ok')?.classList.contains('active-ok');
            const qtyNgActive = document.getElementById('qty-ng')?.classList.contains('active-ng');
            const qtySt = qtyOkActive ? 'ok' : (qtyNgActive ? 'ng' : null);

            current.data = {
                innerDia: document.getElementById('val-inner-dia').value,
                innerTx: document.getElementById('val-inner-tx').value,
                innerTy: document.getElementById('val-inner-ty').value,
                innermidTx: document.getElementById('val-innermid-tx').value,
                innermidTy: document.getElementById('val-innermid-ty').value,
                totalTx: document.getElementById('val-total-tx').value,
                totalTy: document.getElementById('val-total-ty').value,
                spiral: document.getElementById('val-spiral').value,
                visual: vStates,
                // === PER-SLOT PRODUCTION SUMMARY ===
                vin:     document.getElementById('val-vin-kode')?.value || '',
                actPnjg: document.getElementById('val-act-pnjg')?.value || '',
                qtySt:   qtySt,
                qtyOk:   document.getElementById('val-qty-ok')?.value || '',
                ngDim:   document.getElementById('val-ng-dimensi')?.value || '',
                ngVis:   document.getElementById('val-ng-visual')?.value || '',
                remark:  document.getElementById('val-remark')?.value || '',
                summaries: measurements[currentIndex].data?.summaries || []
            };

            const hasVal = ['innerDia','innerTx','innerTy','innermidTx','innermidTy','totalTx','totalTy','spiral'].some(k => current.data[k] !== '') ||
                           Object.values(vStates).some(v => v !== null);

            if (hasVal && !current.time) {
                const now = new Date();
                current.time = now.getHours().toString().padStart(2,'0') + ':' + now.getMinutes().toString().padStart(2,'0');
            }
        }

        function loadDataToUI() {
            const data = measurements[currentIndex].data || {};
            
            // 1. Per-slot measurements (always override, including empty to clear)
            document.getElementById('val-inner-dia').value = data.innerDia || '';
            document.getElementById('val-inner-tx').value = data.innerTx || '';
            document.getElementById('val-inner-ty').value = data.innerTy || '';
            document.getElementById('val-innermid-tx').value = data.innermidTx || '';
            document.getElementById('val-innermid-ty').value = data.innermidTy || '';
            document.getElementById('val-total-tx').value = data.totalTx || '';
            document.getElementById('val-total-ty').value = data.totalTy || '';
            document.getElementById('val-spiral').value = data.spiral || '';

            // 2. Per-slot Visual Check UI refresh
            const v = data.visual || {};
            ['burry', 'line', 'bubble', 'scratch'].forEach(it => {
                const okBtn = document.getElementById(`v-${it}-ok`);
                const ngBtn = document.getElementById(`v-${it}-ng`);
                okBtn.classList.remove('active-ok');
                ngBtn.classList.remove('active-ng');
                if (v[it] === 'ok') okBtn.classList.add('active-ok');
                else if (v[it] === 'ng') ngBtn.classList.add('active-ng');
            });
            renderVisualStatus();

            // 3. PER-SLOT PRODUCTION SUMMARY (always set — clears old values when switching)
            document.getElementById('val-vin-kode').value    = data.vin     || '';
            document.getElementById('val-act-pnjg').value   = data.actPnjg || '';
            document.getElementById('val-qty-ok').value     = data.qtyOk   || '';
            document.getElementById('val-ng-dimensi').value = data.ngDim   || '';
            document.getElementById('val-ng-visual').value  = data.ngVis   || '';
            document.getElementById('val-remark').value     = data.remark  || '';

            // Restore QTY Status toggle
            if (data.qtySt) setQtyStatus(data.qtySt);
            else {
                // Clear toggle if no status yet
                document.getElementById('qty-ok')?.classList.remove('active-ok');
                document.getElementById('qty-ng')?.classList.remove('active-ng');
                document.getElementById('okPanel').style.display = 'none';
                document.getElementById('ngPanel').style.display = 'none';
            }
            
            // 4. Header / Fixed Inputs (not cleared on slot switch)
            const stdPnjgInput = document.getElementById('disp-std-pnjg');
            if (stdPnjgInput && (stdPnjgInput.value === '-' || stdPnjgInput.value === '')) {
                stdPnjgInput.value = `@Html.Raw(Model?.StandardLength ?? "-")`;
            }
            const targetInput = document.getElementById('disp-qty-target');
            if (targetInput && (targetInput.value === '0' || targetInput.value === '')) {
                targetInput.value = '@(Model?.QtyTarget)' || '0';
            }

            // 5. Render Production Summaries
            renderSummaryList();
            
            // 6. Run validation for all cards
            ['inner-dia', 'inner-tx', 'inner-ty', 'innermid-tx', 'innermid-ty', 'total-tx', 'total-ty', 'spiral'].forEach(id => {
                validateCard(id);
                if (typeof toggleClearBtn === 'function') toggleClearBtn(id);
            });
        }

        function addProductionRecord() {
            const vin = document.getElementById('val-vin-kode').value.trim();
            const act = document.getElementById('val-act-pnjg').value.trim();
            const ok = document.getElementById('val-qty-ok').value.trim() || "0";
            const ngD = document.getElementById('val-ng-dimensi').value.trim() || "0";
            const ngV = document.getElementById('val-ng-visual').value.trim() || "0";

            if (!vin) {
                Swal.fire('MISSING DATA', 'Please enter at least a VIN Code.', 'warning');
                return;
            }

            const record = { vin, act, ok, ngD, ngV };
            
            if (!measurements[currentIndex].data.summaries) measurements[currentIndex].data.summaries = [];
            measurements[currentIndex].data.summaries.push(record);

            // Clear inputs for next record
            document.getElementById('val-vin-kode').value = "";
            document.getElementById('val-act-pnjg').value = "";
            document.getElementById('val-qty-ok').value = "0";
            document.getElementById('val-ng-dimensi').value = "0";
            document.getElementById('val-ng-visual').value = "0";
            
            renderSummaryList();
            
            Swal.fire({
                icon: 'success',
                title: 'RECORD ADDED',
                text: 'Production data added to list.',
                timer: 1000,
                showConfirmButton: false,
                toast: true,
                position: 'top-end'
            });
        }

        function removeProductionRecord(idx) {
            measurements[currentIndex].data.summaries.splice(idx, 1);
            renderSummaryList();
        }

        function renderSummaryList() {
            const body = document.getElementById('summary-list-body');
            const empty = document.getElementById('summary-empty');
            const list = (measurements[currentIndex] && measurements[currentIndex].data) ? (measurements[currentIndex].data.summaries || []) : [];

            body.innerHTML = '';
            if (list.length === 0) {
                if (empty) empty.style.display = 'block';
                return;
            }

            if (empty) empty.style.display = 'none';
            list.forEach((item, idx) => {
                const tr = document.createElement('tr');
                tr.className = 'summary-row-new';
                tr.innerHTML = `
                    <td><span class="text-primary">${item.vin}</span></td>
                    <td>${item.act || '-'}</td>
                    <td class="text-success">${item.ok}</td>
                    <td class="text-danger">${item.ngD}</td>
                    <td class="text-danger">${item.ngV}</td>
                    <td style="text-align: center;">
                        <button type="button" class="btn-del-summary" onclick="removeProductionRecord(${idx})">
                            <i class="bi bi-trash3-fill"></i>
                        </button>
                    </td>
                `;
                body.appendChild(tr);
            });
        }

        function toggleClearBtn(id) {
            const wrap = document.getElementById('wrap-' + id);
            const inp  = document.getElementById('val-' + id);
            if (!wrap || !inp) return;
            if (inp.value && inp.value.trim() !== '') {
                wrap.classList.add('has-value');
            } else {
                wrap.classList.remove('has-value');
            }
        }

        function clearCard(id) {
            const inp = document.getElementById('val-' + id);
            if (!inp) return;
            inp.value = '';
            validateCard(id);
            toggleClearBtn(id);
            inp.focus();
            saveCurrentData();
            if (window._dimCurrentItem) dimCaptureDraft(window._dimCurrentItem);
        }

        function isCardVisible(id) {
            const el = document.getElementById(`card-${id}`);
            if (!el) return false;
            return el.style.display !== 'none' && getComputedStyle(el).display !== 'none';
        }

        function getRequiredDimensionInputs() {
            const required = ['inner-dia', 'inner-tx', 'inner-ty', 'total-tx', 'total-ty'];
            if (isCardVisible('innermid-tx')) required.push('innermid-tx');
            if (isCardVisible('innermid-ty')) required.push('innermid-ty');
            if (isCardVisible('spiral')) required.push('spiral');
            return required;
        }

        function getMissingRequiredFields() {
            return getRequiredDimensionInputs().filter(id => {
                const input = document.getElementById(`val-${id}`);
                return !input || !input.value || input.value.toString().trim() === '';
            });
        }

        function refreshSubmitButtonState() {
            const btn = document.getElementById('submit-entry-btn');
            if (!btn) return;

            const hoseType = (document.getElementById('h-hose')?.innerText || '').trim();
            const hasMaster = hoseType && hoseType !== '---' && hoseType !== 'NOT FOUND';
            const hasMissing = getMissingRequiredFields().length > 0;
            const canSubmit = hasMaster && !hasMissing;

            btn.disabled = !canSubmit;
            btn.style.opacity = canSubmit ? '1' : '0.5';
            btn.style.cursor = canSubmit ? 'pointer' : 'not-allowed';
        }

        function isChs2LayerContext(spsData) {
            const machineText = (document.getElementById('h-line')?.innerText || '').toLowerCase();
            const hoseText = ((spsData?.hoseType || document.getElementById('h-hose')?.innerText || '') + '').toLowerCase();
            const layerText = ((spsData?.layerType || '') + '').toLowerCase();

            const hasChs = machineText.includes('chs') || hoseText.includes('chs');
            const has3Layer = layerText.includes('3') || layerText.includes('triple') || hoseText.includes('3 layer') || hoseText.includes('3layer');
            const has2Layer = layerText.includes('2') || hoseText.includes('2 layer') || hoseText.includes('2layer') || machineText.includes('2 layer') || machineText.includes('chs2');

            return hasChs && !has3Layer && has2Layer;
        }

        function validateCard(id) {
            const cleanId = id.toLowerCase().replace(/-/g, '');
            const card = document.getElementById(`card-${id}`), std = activeStandards[cleanId], inp = document.getElementById(`val-${id}`);
            if(!card || !inp) return;
            
            // Clean local value for parsing
            const raw = inp.value.toString().replace(/[+]/g, '').trim();
            const val = parseFloat(raw);
            card.classList.remove('status-ok', 'status-ng');
            
            if (!isNaN(val) && std && std.val !== 0) {
                const min = std.val - std.tol;
                const max = std.val + std.tol;
                const isOK = (val >= (min - 0.001) && val <= (max + 0.001)); // Tolerance buffer
                card.classList.add(isOK ? 'status-ok' : 'status-ng');
            }
            refreshSubmitButtonState();
        }

        async function loadMaster() {
            const code = document.getElementById('main-item-search').value;
            const machine = document.getElementById('h-line')?.innerText || '';
            if(!code) return;
            Swal.fire({ title: 'FETCHING MASTER...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            try {
                const res = await fetch(`/Dimensi/GetSpsStandard?hoseType=${encodeURIComponent(code)}&machineCode=${encodeURIComponent(machine)}`);
                const data = await res.json();
                Swal.close();
                
                if(!data.success) {
                    lockDimensiForm(code);
                    return;
                }

                if(data.success) {
                    const m = data.data;
                    const shouldShowSpiral = isChs2LayerContext(m);
                    
                    // Update Refined Technical HUD Ribbon (v3 IDs)
                    const custEl = document.getElementById('h-customer');
                    const hoseEl = document.getElementById('h-hose');
                    const docEl = document.getElementById('h-doc');
                    const revEl = document.getElementById('h-rev');

                    if(custEl) custEl.innerText = m.customer || "GENERAL";
                    if(hoseEl) hoseEl.innerText = m.hoseType || "---";
                    if(docEl) docEl.innerText = m.docNo || "---";
                    if(revEl) revEl.innerText = "REV." + (m.revNo || "0");

                    // Update SPS Masterlist input with Item List (instead of Document Number)
                    const searchInput = document.getElementById('main-item-search');
                    if(searchInput) searchInput.value = m.itemList || code || m.docNo || m.hoseType;

                    // Capture specific SpsId to bind the report exactly to this specification row
                    window._dimSpsId = data.id || m.id || m.spsId || null;

                    // FALLBACK: If no planning was selected, treat the scanned SPS as the ItemCode
                    if (!window._dimSelectedItemCode || window._dimSelectedItemCode === "") {
                        window._dimSelectedItemCode = code;
                        const itemCodeInput = document.getElementById('itemCode');
                        if (itemCodeInput) itemCodeInput.value = code;
                    }

                    // Populate Data Summary
                    const partEl = document.getElementById('disp-part-no');
                    if(partEl) partEl.innerText = window._dimSelectedItemCode || m.itemList || m.hoseType || "---";
                    
                    const stdPnjgEl = document.getElementById('disp-std-pnjg');
                    if(stdPnjgEl) stdPnjgEl.value = m.cuttingLength && m.cuttingLength !== '-' ? m.cuttingLength : (m.dimensi || "-"); 
                    
                    const qtyTargetInput = document.getElementById('disp-qty-target');
                    if(qtyTargetInput && qtyTargetInput.value == "0") qtyTargetInput.value = ""; // Let user type easily

                    document.getElementById('h-row-hose')?.classList.add('animate__animated', 'animate__pulse');
                    
                    // Update Status Indicator
                    const dot = document.getElementById('scan-status-dot');
                    const text = document.getElementById('scan-status-text');
                    if (dot) { dot.style.background = '#10b981'; dot.style.boxShadow = '0 0 10px #10b981'; }
                    if (text) { text.innerText = 'READY TO MEASURE'; text.style.color = '#10b981'; }

                    const getF = (v) => { 
                        if(!v) return 0;
                        const match = v.toString().replace(/,/g, '.').match(/\d+(\.\d+)?/);
                        return match ? parseFloat(match[0]) : 0;
                    };

                    const parseV = (str, def = null) => {
                        if(!str || str === '---') return def;
                        // Replace comma with dot and extract first number
                        const m = str.toString().replace(/,/g, '.').match(/[-+]?\d+(\.\d+)?/);
                        return m ? parseFloat(m[0]) : def;
                    };
                    const parseT = (str, def = 0.1) => {
                        if(!str || str === '---') return def;
                        // For tolerance, we usually want the last number (e.g. ± 0.1)
                        const m = str.toString().replace(/,/g, '.').match(/[-+]?\d+(\.\d+)?/g);
                        if (!m) return def;
                        let val = Math.abs(parseFloat(m[m.length - 1]));
                        return val > 5.0 ? def : val; // Sanity check for crazy tolerances
                    };

                    console.log("SPS Data Found:", m);

                    // Show workspace and hide placeholder
                    const placeholder = document.getElementById('selection-placeholder');
                    const workspace = document.getElementById('input-workspace');
                    if (placeholder) placeholder.style.display = 'none';
                    if (workspace) {
                        workspace.style.display = 'block';
                        setTimeout(() => workspace.style.opacity = '1', 10);
                    }

                    try {
                        const configs = [
                            // Inner Diameter: prioritize exact innerTarget, fallback to dimensi
                            { id: 'innerdia', v: m.innerTarget || m.dimensi, t: m.innerTol || m.toleranceInner, el: 'inner-dia', dt: 0.1 },
                            // Inner Thickness: use thickTol ONLY — never fall back to toleranceOuter (which is an outer-dia string)
                            { id: 'innertx', v: m.thickTarget || m.tebalInner, t: m.thickTol, el: 'inner-tx', dt: 0.1 },
                            { id: 'innerty', v: m.thickTarget || m.tebalInner, t: m.thickTol, el: 'inner-ty', dt: 0.1 },
                            { id: 'innermidtx', v: m.innerMidTarget || m.tebalInnerMiddle, t: m.innerMidTol || m.thickTol, el: 'innermid-tx', dt: 0.1 },
                            { id: 'innermidty', v: m.innerMidTarget || m.tebalInnerMiddle, t: m.innerMidTol || m.thickTol, el: 'innermid-ty', dt: 0.1 },
                            // Total Thickness: use totalTol ONLY — never fall back to toleranceOuter
                            { id: 'totaltx', v: m.totalTarget || m.tebalTotal, t: m.totalTol, el: 'total-tx', dt: 0.1 },
                            { id: 'totalty', v: m.totalTarget || m.tebalTotal, t: m.totalTol, el: 'total-ty', dt: 0.1 },
                            { id: 'spiral', v: m.spiralPitchSetting || m.spiralPitchDisplay, t: m.toleranceSpiralPitch, el: 'spiral', dt: 5 }
                        ];

                        configs.forEach(p => {
                            let target = parseV(p.v);
                            let tol = parseT(p.t, p.dt);
                            
                            // Smart fallback: If the primary value string explicitly contains ± (e.g. "2.2±0.1")
                            // We MUST use its tolerance to avoid cross-column pollution.
                            if (p.v && p.v.toString().includes('±')) {
                                const mPlusMinus = p.v.toString().replace(/,/g, '.').match(/±\s*([0-9.]+)/);
                                if (mPlusMinus) {
                                    tol = parseFloat(mPlusMinus[1]);
                                }
                            }

                            activeStandards[p.id] = { val: target, tol: tol };
                            
                            const targetEl = document.getElementById(`std-${p.el}`);
                            const minEl = document.getElementById(`limit-${p.el}-min`);
                            const maxEl = document.getElementById(`limit-${p.el}-max`);
                            const inputEl = document.getElementById(`val-${p.el}`);
                            const cardEl = document.getElementById(`card-${p.el}`);

                            if (targetEl) targetEl.innerText = target === null ? "NO DATA" : `${target.toFixed(2)}`;
                            if (minEl) minEl.innerText = target === null ? "---" : (target - tol).toFixed(2);
                            if (maxEl) maxEl.innerText = target === null ? "---" : (target + tol).toFixed(2);

                            if (cardEl) {
                                if (target === null) {
                                    if (p.id.startsWith('innermid')) {
                                        cardEl.style.display = 'none';
                                    } else if (p.id === 'spiral') {
                                        cardEl.style.display = shouldShowSpiral ? 'block' : 'none';
                                    } else {
                                        cardEl.style.display = 'block';
                                    }
                                    if (inputEl) {
                                        inputEl.placeholder = "NO STD";
                                        // Removed inputEl.disabled = true to allow manual input even if std is missing
                                    }
                                    cardEl.style.opacity = (p.id.startsWith('innermid')) ? "1" : "0.7";
                                } else {
                                    cardEl.style.display = 'block';
                                    if (inputEl) {
                                        inputEl.disabled = false;
                                        inputEl.placeholder = "0.00";
                                    }
                                    cardEl.style.opacity = "1";
                                    cardEl.style.pointerEvents = "auto";
                                }
                            }
                        });
                        refreshSubmitButtonState();
                    } catch (err) {
                        console.error("Error populating cards:", err);
                    }

                    // REMOVED AUTO-SET VISUAL CHECKS TO OK (Per User Request)
                    
                    Swal.fire({ 
                        icon: 'success', 
                        title: 'MASTER LOADED', 
                        text: 'Standard and Visuals have been synced.',
                        timer: 1500, 
                        showConfirmButton: false,
                        toast: true,
                        position: 'top-end'
                    });

                    unlockDimensiForm();

                    // Draft restore: check if this item has saved draft
                    const normalCode = (code || '').toUpperCase().trim();
                    const hasDraft = localStorage.getItem(_dimDraftKey(normalCode));
                    if (hasDraft) {
                        setTimeout(() => {
                            let d; try { d = JSON.parse(hasDraft); } catch {}
                            if (dimRestoreDraft(normalCode) && d) dimShowDraftBanner(normalCode, d.ts);
                        }, 200);
                    } else {
                        // Auto-focus starting point only if no draft
                        const firstInput = document.getElementById('val-inner-dia');
                        if (firstInput) { firstInput.focus(); firstInput.select(); }
                        loadDataToUI();
                    }

                    dimSetupAutoSave(normalCode);  // begin tracking changes
                }
            } catch (e) { 
                console.error("LoadMaster Error:", e);
                Swal.fire('Error', 'Failed to load master data structure.', 'error');
            }
        }

        function clearTechnicalStandards() {
            // Reset active standards object
            activeStandards = {};

            // 1. Reset HUD Ribbon fallback text
            const hudMappings = {
                'h-customer': 'NO SPS DATA',
                'h-hose': 'NOT FOUND',
                'h-doc': '---',
                'h-rev': '---',
                'disp-part-no': '---'
