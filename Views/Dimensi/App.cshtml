@model VelastoProductionSystem.Models.DimensionReport

@{
    Layout = "_Layout";
    ViewData["Title"] = "Dimension Input Hub";
}

@section Styles {
    <style>
        .swal2-container {
            z-index: 15000 !important;
        }

        :root {
            --bg-deep: #020617;
            --glass-bg: rgba(15, 23, 42, 0.8);
            --glass-border: rgba(56, 189, 248, 0.2);
            --accent-glow: #38bdf8;
            --accent-success: #10b981;
            --accent-warning: #f59e0b;
            --accent-danger: #ef4444;
            --text-white: #f1f5f9;
            --text-dim: #94a3b8;
            --hud-glow: 0 0 15px rgba(56, 189, 248, 0.2);
        }

        body {
            background: radial-gradient(circle at 50% 0%, #1e293b, #0b1120);
            color: var(--text-white);
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            min-height: 100vh;
            padding: 0; margin: 0;
            letter-spacing: -0.01em;
        }

        /* --- Header & Layout --- */
        .search-action-bar {
            display: flex; align-items: center; justify-content: center; gap: 15px;
            flex-wrap: wrap; margin-bottom: 30px; position: relative; z-index: 50;
        }
        .header-title-main {
            font-size: 26px; font-weight: 800; color: #fff; text-align: center;
            letter-spacing: 6px; text-transform: uppercase; margin-bottom: 8px;
            text-shadow: 0 0 10px rgba(255, 255, 255, 0.1);
        }
        .header-subtitle {
            font-size: 11px; font-weight: 700; color: var(--text-dim); text-align: center;
            letter-spacing: 5px; text-transform: uppercase; margin-bottom: 40px;
        }

        /* --- Search Console --- */
        .search-container {
            max-width: 1200px; margin: 0 auto 25px auto; width: 100%; padding: 0 15px;
        }
        
        .planning-search-panel {
            flex: 1; min-width: 320px; position: relative;
        }

        .hud-console-pill {
            background: rgba(15, 23, 42, 0.8);
            border: 1px solid var(--glass-border);
            border-radius: 8px;
            overflow: visible;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            transition: all 0.3s;
            position: relative;
        }

        .hud-console-pill:focus-within {
            border-color: var(--accent-glow);
            box-shadow: 0 0 20px rgba(56, 189, 248, 0.2);
        }

        .hud-label-mini {
            font-size: 8px;
            font-weight: 900;
            color: var(--accent-glow);
            letter-spacing: 1.5px;
            text-transform: uppercase;
            padding: 4px 12px;
            background: rgba(56, 189, 248, 0.1);
            border-bottom: 1px solid rgba(56, 189, 248, 0.15);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .hud-input-flat {
            background: transparent;
            border: none;
            color: #fff;
            padding: 10px 15px;
            font-size: 14px;
            font-weight: 700;
            outline: none;
            width: 100%;
            height: 44px;
            letter-spacing: 0.5px;
        }

        .hud-btn-side {
            width: 50px;
            background: rgba(56, 189, 248, 0.05);
            color: var(--accent-glow);
            border: none;
            border-left: 1px solid rgba(255,255,255,0.05);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            cursor: pointer;
            transition: 0.3s;
        }

        .hud-btn-side:hover {
            background: var(--accent-glow);
            color: #000;
        }

        .planning-results {
            position: absolute; top: calc(100% + 5px); left: 0; right: 0; 
            background: rgba(15, 23, 42, 0.95);
            backdrop-filter: blur(20px);
            border: 1px solid var(--accent-glow); 
            border-radius: 12px; 
            z-index: 1000;
            max-height: 450px; overflow-y: auto; 
            box-shadow: 0 25px 60px rgba(0,0,0,0.9), 0 0 30px rgba(56, 189, 248, 0.1);
            animation: dropdownFade 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            padding: 8px;
        }

        @@keyframes dropdownFade {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* --- Custom Scrollbar --- */
        .custom-tactical-scroll::-webkit-scrollbar { width: 6px; }
        .custom-tactical-scroll::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); border-radius: 10px; }
        .custom-tactical-scroll::-webkit-scrollbar-thumb { 
            background: rgba(56, 189, 248, 0.3); border-radius: 10px; 
            border: 1px solid rgba(255,255,255,0.05);
        }
        .custom-tactical-scroll::-webkit-scrollbar-thumb:hover { background: var(--accent-glow); }

        .planning-result-item {
            padding: 15px 20px;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            border: 1px solid transparent;
            margin-bottom: 4px;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .planning-result-item:last-child { margin-bottom: 0; }

        .planning-result-item:hover, .planning-result-highlight {
            background: rgba(56, 189, 248, 0.1);
            border-color: rgba(56, 189, 248, 0.3);
            transform: translateX(5px);
        }

        .planning-result-highlight {
            background: rgba(56, 189, 248, 0.15) !important;
            border-color: var(--accent-glow) !important;
            box-shadow: inset 4px 0 0 var(--accent-glow);
        }

        .planning-result-code {
            font-family: 'JetBrains Mono', 'Fira Code', monospace;
            font-size: 14px;
            font-weight: 800;
            color: var(--accent-glow);
            letter-spacing: 0.5px;
        }

        .planning-result-name {
            font-size: 12px;
            font-weight: 600;
            color: #f1f5f9;
            opacity: 0.9;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .planning-result-meta {
            font-size: 10px;
            font-weight: 700;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            gap: 8px;
            margin-top: 2px;
        }

        .planning-result-meta i { font-size: 12px; opacity: 0.5; }

        .machine-badge-mini {
            font-size: 10px; 
            font-weight: 900; 
            color: #000;
            background: var(--accent-warning); 
            padding: 3px 10px; 
            border-radius: 50px; 
            white-space: nowrap;
            display: flex;
            align-items: center;
            gap: 5px;
            box-shadow: 0 4px 10px rgba(245, 158, 11, 0.3);
        }

        @@media (max-width: 1200px) {
            .tech-header-ribbon { grid-template-columns: repeat(2, 1fr); gap: 12px; }
            .header-cluster { min-height: 80px; padding: 15px; }
            .planning-search-panel { width: 100%; min-width: 0; }
        }
        
        .cam-btn {
            width: 55px; background: rgba(255,255,255,0.03); color: var(--accent-glow); border: none;
            display: flex; align-items: center; justify-content: center; font-size: 18px; cursor: pointer;
            transition: 0.3s; border-right: 1px solid rgba(255,255,255,0.05);
        }
        .cam-btn:hover { background: rgba(56, 189, 248, 0.1); color: #fff; }

        .search-input-group input {
            flex: 1; background: transparent; border: none; outline: none; padding: 0 20px;
            color: #fff; font-size: 14px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
        }
        
        .search-trigger-btn {
            width: 55px; background: var(--accent-glow); color: #000; border: none;
            display: flex; align-items: center; justify-content: center; font-size: 18px; cursor: pointer;
            transition: 0.3s;
        }
        .search-trigger-btn:hover { background: #fff; box-shadow: 0 0 15px var(--accent-glow); }
        
        .bt-icon-btn {
            width: 48px; height: 48px; border-radius: 50%;
        }
        .info-card {
            background: linear-gradient(135deg, rgba(56, 189, 248, 0.1) 0%, rgba(15, 23, 42, 0.8) 30%, #020617 100%);
            border: 1px solid rgba(255, 255, 255, 0.1); border-top: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 8px; padding: 18px 25px; transition: all 0.4s;
            display: flex; flex-direction: column; gap: 8px; position: relative;
            box-shadow: 0 10px 30px rgba(0,0,0,0.6); backdrop-filter: blur(15px);
        }
        .info-card:hover { border-color: var(--accent-glow); transform: translateY(-2px); }
        .bt-icon-btn.active {
            color: var(--accent-success); border-color: var(--accent-success);
            box-shadow: 0 0 20px rgba(16, 185, 129, 0.2);
        }
        .bt-icon-btn.active::after {
            content: ''; position: absolute; top: -2px; right: -2px; width: 10px; height: 10px;
            background: var(--accent-success); border-radius: 50%; border: 2px solid var(--bg-deep);
            box-shadow: 0 0 10px var(--accent-success); animation: pulse 1s infinite;
        }
        .tool-link-btn.active {
            border-color: var(--accent-success);
            box-shadow: 0 0 20px rgba(16, 185, 129, 0.1);
        }
        .tool-link-btn.active .t-dot { background: var(--accent-success); box-shadow: 0 0 10px var(--accent-success); animation: pulse 1s infinite; }
        .tool-link-btn.active .t-text { color: var(--accent-success); }

        .t-dot { width: 8px; height: 8px; border-radius: 50%; background: #94a3b8; transition: 0.3s; }
        .t-text { font-size: 10px; color: #94a3b8; font-weight: 900; letter-spacing: 1.5px; text-transform: uppercase; transition: 0.3s; }
        .t-icon { font-size: 14px; color: #94a3b8; }
        .tool-link-btn.active .t-icon { color: var(--accent-success); }

        /* --- New Modular Dashboard Widgets (Non-Table) --- */
        .tech-header-ribbon {
            display: grid; grid-template-columns: repeat(4, 1fr);
            gap: 15px; max-width: 1400px; margin: 0 auto 30px auto; width: 100%;
            padding: 0 15px;
        }
        .header-cluster {
            background: rgba(30, 41, 59, 0.4); border: 1px solid var(--glass-border);
            border-left: 4px solid var(--accent-glow); border-radius: 8px;
            padding: 15px 20px; display: flex; flex-direction: column; justify-content: center;
            box-shadow: 0 10px 25px rgba(0,0,0,0.3); backdrop-filter: blur(10px);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .header-cluster:hover {
            transform: translateY(-3px); border-color: rgba(56, 189, 248, 0.4);
            box-shadow: 0 15px 35px rgba(56, 189, 248, 0.15);
            background: rgba(30, 41, 59, 0.6);
        }
        
        /* --- Responsive Cockpit (Tablet Mode) --- */
        @@media (max-width: 1200px) {
            .tech-header-ribbon { grid-template-columns: repeat(2, 1fr); gap: 12px; }
            .header-cluster { min-height: 80px; padding: 15px; }
        }
        
        @@media (max-width: 900px) {
            .search-input-group { width: 100%; max-width: none; }
        }

        @@media (max-width: 600px) {
            .tech-header-ribbon { grid-template-columns: 1fr; }
        }
        .header-cluster:last-child { border-right: none; }
        .m-lbl { font-size: 8px; color: var(--text-dim); font-weight: 800; letter-spacing: 1px; text-transform: uppercase; display: flex; align-items: center; gap: 6px; opacity: 0.6; white-space: nowrap; }
        .m-row { display: flex; align-items: center; gap: 6px; white-space: nowrap; margin-top: 4px; overflow: hidden; }
        .m-val { font-size: 11px; color: #fff; font-weight: 900; letter-spacing: 0.2px; line-height: 1; }
        .m-accent { color: var(--accent-glow); text-shadow: 0 0 10px rgba(56, 189, 248, 0.1); }
        .m-sub { font-size: 9px; color: rgba(255,255,255,0.25); font-weight: 800; text-transform: uppercase; margin-left: 4px; }
        .m-icon { font-size: 10px; color: var(--accent-glow); opacity: 0.5; }
        .m-divider { width: 1px; height: 10px; background: rgba(255,255,255,0.08); margin: 0 2px; }

        .jam-nav { display: flex; gap: 15px; margin-bottom: 30px; justify-content: center; }
        .jam-btn {
            background: rgba(30, 41, 59, 0.4); border: 1px solid rgba(56, 189, 248, 0.15);
            color: var(--text-dim); padding: 12px 28px; border-radius: 4px;
            font-size: 13px; font-weight: 800; cursor: pointer; transition: all 0.3s;
            position: relative; overflow: visible;
        }
        .jam-btn.active {
            background: var(--accent-glow); color: #000; border-color: transparent;
            box-shadow: var(--hud-glow), 0 0 30px rgba(0, 242, 254, 0.3); transform: scale(1.05);
        }
        .add-btn { background: rgba(0, 242, 254, 0.05); border-style: dashed; }
        .slot-delete-btn {
            position: absolute; 
            top: -12px; 
            right: -12px; 
            width: 28px; 
            height: 28px;
            border-radius: 50%; 
            background: #ef4444; 
            border: 2px solid #020617;
            display: flex; 
            align-items: center; 
            justify-content: center; 
            font-size: 12px;
            color: #fff; 
            opacity: 1; 
            transition: all 0.2s ease; 
            z-index: 50;
            box-shadow: 0 0 15px rgba(239, 68, 68, 0.4);
        }
        .jam-btn:active .slot-delete-btn { transform: scale(0.8); }

        /* --- Card Styles --- */
        .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 25px; }
        .dimensi-card {
            background: linear-gradient(135deg, rgba(56, 189, 248, 0.5) 0%, rgba(30, 64, 175, 0.4) 30%, rgba(15, 23, 42, 0.95) 100%);
            border: 1px solid var(--glass-border);
            border-top: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 8px; padding: 25px; transition: all 0.4s;
            backdrop-filter: blur(20px); position: relative; overflow: hidden;
            box-shadow: 0 10px 40px rgba(0,0,0,0.7);
        }
        .dimensi-card::before {
            content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 1px;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
        }
        .dimensi-card:hover { 
            border-color: var(--accent-glow); 
            box-shadow: 0 15px 40px rgba(0,0,0,0.6);
            transform: translateY(-4px);
        }
        .card-header-flex { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
        .card-point { font-weight: 800; font-size: 14px; color: #fff; letter-spacing: 2px; text-shadow: 0 0 10px rgba(255,255,255,0.3); }
        .card-icon { font-size: 20px; color: var(--accent-glow); opacity: 0.8; filter: drop-shadow(0 0 5px var(--accent-glow)); }

        .std-container { display: flex; flex-direction: column; align-items: center; margin-bottom: 20px; }
        .std-label { font-size: 10px; color: #64748b; font-weight: 900; letter-spacing: 2px; opacity: 0.8; margin-bottom: 4px; }
        .std-value { 
            font-size: 18px; color: var(--accent-glow); font-weight: 950; 
            text-shadow: 0 0 15px rgba(0, 242, 254, 0.5); 
            letter-spacing: 1px;
        }
        .std-container::after {
            content: ''; width: 40px; height: 2px; background: var(--accent-glow);
            margin-top: 8px; border-radius: 2px; box-shadow: 0 0 10px var(--accent-glow);
        }

        .limit-row { display: flex; gap: 12px; margin-bottom: 20px; }
        .limit-pill { 
            flex: 1; background: rgba(0,0,0,0.5); border: 1px solid rgba(255,255,255,0.08);
            padding: 10px 15px; border-radius: 50px; display: flex; align-items: center; justify-content: space-between;
            box-shadow: inset 0 2px 10px rgba(0,0,0,0.4);
        }
        .limit-label { font-size: 10px; color: #94a3b8; font-weight: 900; letter-spacing: 1px; }
        .limit-val { font-size: 15px; font-weight: 950; }
        .limit-val.min { color: var(--accent-success); text-shadow: 0 0 12px rgba(0, 255, 157, 0.5); }
        .limit-val.max { color: var(--accent-warning); text-shadow: 0 0 12px rgba(255, 234, 0, 0.5); }

        .input-group-custom { display: flex; flex-direction: column; gap: 10px; }
        .input-group-custom label { font-size: 11px; color: #64748b; font-weight: 900; text-align: center; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 5px; }
        .c-input {
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 10px;
            color: #fff; padding: 18px; font-size: 32px; font-weight: 800; text-align: center; outline: none;
            box-shadow: inset 0 2px 10px rgba(0,0,0,0.5); width: 100%; transition: all 0.3s;
            text-shadow: 0 0 10px rgba(255,255,255,0.1);
            font-family: 'Inter', sans-serif;
            letter-spacing: 0px;
        }
        .c-input:focus { border-color: var(--accent-glow); box-shadow: 0 0 15px rgba(56, 189, 248, 0.3); }
        .c-input::placeholder { color: rgba(248,250,252,0.3); }
        .status-badge { position: absolute; bottom: 0; left: 0; width: 100%; height: 4px; background: transparent; transition: 0.4s; }
        .status-ok .status-badge { background: var(--accent-success); box-shadow: 0 0 25px var(--accent-success); }
        .status-ok .c-input { 
            color: var(--accent-success) !important; 
            border-color: var(--accent-success) !important;
            text-shadow: 0 0 15px rgba(0, 255, 157, 0.6); 
            box-shadow: inset 0 0 20px rgba(0, 255, 157, 0.1), var(--hud-glow);
        }
        .status-ng .status-badge { background: var(--accent-danger); box-shadow: 0 0 30px var(--accent-danger); }
        .status-ng .c-input { 
            color: var(--accent-danger) !important; 
            background: rgba(255, 0, 85, 0.1) !important;
            border-color: var(--accent-danger) !important;
            text-shadow: 0 0 20px rgba(255, 0, 85, 0.7); 
            box-shadow: inset 0 0 30px rgba(255, 0, 85, 0.2), 0 0 20px rgba(255, 0, 85, 0.3);
            animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both;
        }
        
        @@keyframes shake {
          10%, 90% { transform: translate3d(-1px, 0, 0); }
          20%, 80% { transform: translate3d(2px, 0, 0); }
          30%, 50%, 70% { transform: translate3d(-4px, 0, 0); }
          40%, 60% { transform: translate3d(4px, 0, 0); }
        }

        /* --- Visual Check & Summary --- */
        .visual-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .visual-item { 
            background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);
            padding: 12px; border-radius: 12px; text-align: center; display: flex; flex-direction: column; gap: 8px;
        }
        .visual-label { font-size: 9px; color: var(--text-dim); font-weight: 900; letter-spacing: 1px; }
        .segmented-control { display: flex; background: rgba(0,0,0,0.3); padding: 4px; border-radius: 8px; gap: 4px; }
        .seg-btn {
            flex: 1; border: none; background: transparent; color: var(--text-dim);
            font-size: 10px; font-weight: 900; padding: 8px 0; border-radius: 6px; cursor: pointer; transition: 0.2s;
        }
        .seg-btn.active-ok { background: var(--accent-success); color: #000; box-shadow: 0 0 15px rgba(0, 255, 157, 0.3); }
        .seg-btn.active-ng { background: var(--accent-danger); color: #fff; box-shadow: 0 0 15px rgba(255, 0, 85, 0.3); }

        .section-title {
            font-size: 12px; font-weight: 800; color: var(--text-dim);
            letter-spacing: 3px; display: flex; align-items: center; gap: 12px;
            margin: 50px 0 25px 0; padding-left: 15px; border-left: 4px solid var(--text-dim);
            text-transform: uppercase;
        }
        .prod-data-container {
            background: linear-gradient(135deg, rgba(56, 189, 248, 0.1) 0%, rgba(15, 23, 42, 0.95) 100%);
            border: 1px solid var(--glass-border);
            border-radius: 12px; padding: 35px; backdrop-filter: blur(20px);
            box-shadow: 0 15px 50px rgba(0,0,0,0.7);
        }
        .prod-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; }
        .field-column { display: flex; flex-direction: column; gap: 20px; }
        .field-box { display: flex; flex-direction: column; gap: 8px; }
        .field-label { font-size: 9px; color: var(--text-dim); font-weight: 900; letter-spacing: 1px; text-transform: uppercase; }
        .field-input-wrap {
            background: rgba(0, 0, 0, 0.4); border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 8px; padding: 16px 20px; transition: 0.3s;
            box-shadow: inset 0 2px 10px rgba(0,0,0,0.5);
        }
        .field-input-wrap:focus-within { border-color: var(--accent-glow); box-shadow: 0 0 15px rgba(0, 242, 254, 0.2); background: #000; }
        .f-input { background: transparent; border: none; color: #fff; width: 100%; font-size: 15px; font-weight: 700; outline: none; }
        .qty-row { display: flex; gap: 10px; }
        .qty-btn {
            flex: 1; padding: 12px; border: 1px solid rgba(255,255,255,0.1);
            background: rgba(255,255,255,0.03); color: var(--text-dim);
            font-size: 11px; font-weight: 900; cursor: pointer; transition: 0.3s;
            border-radius: 8px; display: flex; align-items: center; justify-content: center; gap: 8px;
        }
        .qty-btn:hover { border-color: var(--accent-glow); color: #fff; }
        .qty-btn.active-ok { border-color: var(--accent-success); color: var(--accent-success); background: rgba(16,185,129,0.05); }
        .qty-btn.active-ng { border-color: var(--accent-danger); color: var(--accent-danger); background: rgba(239,68,68,0.05); }

        .f-textarea {
            background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.16); border-radius: 10px;
            color: #f8fafc; padding: 15px; width: 100%; font-size: 13px; outline: none; height: 80px; resize: none;
        }

        @@keyframes pulse { 0%, 100% { opacity: 0.5; } 50% { opacity: 1; } }
        .tracking-widest { letter-spacing: 0.2em; }
    </style>
}



<!-- NEW REPORT HEADER (AS PER IMAGE) -->
<div class="app-container pt-3">
    <!-- Main Header -->
    <div class="text-center mb-3 animate__animated animate__fadeInDown">
        <h2 class="display-6 fw-bold tracking-widest text-uppercase" style="letter-spacing: 6px;">EXTRUDER PRODUCTION REPORT</h2>
        <div class="text-primary fw-bold" style="font-size: 13px; letter-spacing: 4px;">( DIMENSION )</div>
    </div>

    <!-- Item List Scanner Action Bar -->
    <div class="search-container no-print">
        <div class="row g-3 animate__animated animate__fadeInUp">
            <!-- Left Console: Planning Master -->
            <div class="col-md-7">
                <div class="hud-console-pill">
                    <div class="hud-label-mini">
                        @{
                            var dimMachine = Context.Session.GetString("MachineName");
                            var dimIsAdmin = Context.Session.GetString("IsAdmin") == "true";
                        }
                        <i class="bi bi-list-check"></i>
                        <span>PLANNING MASTER</span>
                        @if (!dimIsAdmin && !string.IsNullOrEmpty(dimMachine))
                        {
                            <span class="ms-auto" style="font-size:9px; font-weight:900; color:#f59e0b; background:rgba(245,158,11,0.1); padding:1px 8px; border-radius:20px; border:1px solid rgba(245,158,11,0.2);">
                                <i class="bi bi-cpu-fill me-1"></i>@dimMachine
                            </span>
                        }
                        else if (dimIsAdmin)
                        {
                            <span class="ms-auto" style="font-size:9px; font-weight:900; color:#10b981; background:rgba(16,185,129,0.1); padding:1px 8px; border-radius:20px; border:1px solid rgba(16,185,129,0.2);">
                                <i class="bi bi-shield-fill me-1"></i>ALL MACHINES
                            </span>
                        }
                    </div>
                    <div class="d-flex align-items-center">
                        <input id="planningSearch" type="text" class="hud-input-flat" 
                               placeholder="SEARCH PLANNING MASTER..." 
                               oninput="filterPlanningResults(this.value)" 
                               onfocus="showPlanningResults()" autocomplete="off" />
                        <button type="button" class="hud-btn-side" onclick="refreshPlanningItems()" title="Refresh Planning">
                            <i class="bi bi-arrow-clockwise"></i>
                        </button>
                    </div>
                    <div id="planningResults" class="planning-results d-none custom-tactical-scroll"></div>
                </div>
            </div>

            <!-- Right Console: Masterlist SPS -->
            <div class="col-md-5">
                <div class="hud-console-pill">
                    <div class="hud-label-mini">
                        <i class="bi bi-search"></i>
                        <span>SPS MASTERLIST</span>
                    </div>
                    <div class="d-flex align-items-center">
                        <input type="text" id="main-item-search" class="hud-input-flat" 
                               placeholder="SEARCH SPS MASTERLIST..." 
                               autocomplete="off" 
                               onkeypress="if(event.key === 'Enter') loadMaster()" />
                        <button class="hud-btn-side" id="btn-master-search" onclick="loadMaster()" title="Trigger Master Search">
                            <i class="bi bi-lightning-fill"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Unified Technical HUD Dashboard -->
    <div class="tech-header-ribbon animate__animated animate__fadeIn">
        <!-- CLUSTER 1: MACHINE -->
        <div class="header-cluster" style="border-left-color: #fca311;">
            <span class="m-lbl"><i class="bi bi-gear-wide-connected m-icon" style="color: #fca311;"></i> PRODUCTION MACHINE</span>
            <div class="m-row">
                <span class="m-val" id="h-line" style="color: #fca311;">@(Model.MachineName ?? "---")</span>
            </div>
        </div>
        <!-- CLUSTER 2: DOC -->
