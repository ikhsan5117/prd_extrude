            if (text) { text.innerText = 'LOCKED: NO SPS'; text.style.color = '#ef4444'; }
            refreshSubmitButtonState();
        }

        async function submitEntry() {
            const hoseType = document.getElementById('h-hose')?.innerText || '';
            if (!hoseType || hoseType.trim() === '' || hoseType.trim() === '---') {
                Swal.fire({
                    title: 'DATA KOSONG!',
                    text: 'Anda belum memilih atau scan Planning / Mesin. Harap pilih terlebih dahulu.',
                    icon: 'warning',
                    confirmButtonColor: '#10b981',
                    background: '#020617',
                    color: '#fff'
                });
                return;
            }

            const missingRequired = getMissingRequiredFields();
            if (missingRequired.length > 0) {
                Swal.fire({
                    title: 'INPUT BELUM LENGKAP',
                    text: 'Lengkapi seluruh card pengukuran yang wajib sebelum submit.',
                    icon: 'warning',
                    confirmButtonColor: '#10b981',
                    background: '#020617',
                    color: '#fff'
                });
                refreshSubmitButtonState();
                return;
            }

            saveCurrentData();
            const btn = document.querySelector('.submit-btn');
            if(btn) btn.disabled = true;

            try {
                const aggregateReadings = [];
                const pointMap = [
                    { name: 'Inner Diameter',       key: 'innerDia', stdKey: 'innerdia'       },
                    { name: 'Inner Thickness (x)',  key: 'innerTx',  stdKey: 'innertx'        },
                    { name: 'Inner Thickness (y)',  key: 'innerTy',  stdKey: 'innerty'        },
                    { name: 'Inn+Mid Thickness (x)', key: 'innermidTx', stdKey: 'innermidtx'   },
                    { name: 'Inn+Mid Thickness (y)', key: 'innermidTy', stdKey: 'innermidty'   },
                    { name: 'Total Thickness (x)',  key: 'totalTx',  stdKey: 'totaltx'        },
                    { name: 'Total Thickness (y)',  key: 'totalTy',  stdKey: 'totalty'        },
                    { name: 'Spiral Pitch',         key: 'spiral',   stdKey: 'spiral'         }
                ];

                for (const point of pointMap) {
                    const std = activeStandards[point.stdKey];
                    const stdText = (std && std.val > 0)
                        ? (std.val.toFixed(2) + ' ± ' + std.tol.toFixed(2))
                        : '-';

                    const allTimes = measurements.map(m => m.time || '').join(',');
                    const row = {
                        PointName: point.name,
                        TimeSection: allTimes,
                        Frequency: '30m Sekali',
                        StandardDimension: stdText,
                        Initial: '',
                        Reading1: '', Reading2: '', Reading3: '', Reading4: '', Reading5: '',
                        Status: 'OK'
                    };

                    for (let idx = 0; idx < Math.min(measurements.length, 5); idx++) {
                        const val = measurements[idx].data[point.key];
                        row[`Reading${idx + 1}`] = (val !== null && val !== undefined && val !== '') ? val : '';
                        if (std && std.val > 0 && val !== '' && val !== null && val !== undefined) {
                            const v = parseFloat(val);
                            if (!isNaN(v) && (v < (std.val - std.tol - 0.001) || v > (std.val + std.tol + 0.001))) {
                                row.Status = 'NG';
                            }
                        }
                    }
                    aggregateReadings.push(row);
                }

                // Visual Check per item
                const visualItems = [
                    { name: 'Visual Check - Burry',   key: 'burry'   },
                    { name: 'Visual Check - Line',    key: 'line'    },
                    { name: 'Visual Check - Bubble',  key: 'bubble'  },
                    { name: 'Visual Check - Scratch', key: 'scratch' }
                ];
                for (const vIt of visualItems) {
                    const allTimes = measurements.map(m => m.time || '').join(',');
                    const vRow = {
                        PointName: vIt.name,
                        TimeSection: allTimes,
                        Frequency: '30m Sekali',
                        StandardDimension: 'NORMAL',
                        Initial: 'OK',
                        Reading1: '', Reading2: '', Reading3: '', Reading4: '', Reading5: '',
                        Status: 'OK'
                    };
                    for (let idx = 0; idx < Math.min(measurements.length, 5); idx++) {
                        const state = measurements[idx].data.visual?.[vIt.key];
                        vRow[`Reading${idx + 1}`] = state === 'ok' ? '1' : (state === 'ng' ? '0' : '');
                        if (state === 'ng') vRow.Status = 'NG';
                    }
                    aggregateReadings.push(vRow);
                }

                // === PER-SLOT PRODUCTION SUMMARY ROWS ===
                const summaryFields = [
                    { name: 'Summary - QTY OK',     key: 'qtyOk'   },
                    { name: 'Summary - NG Dimensi',  key: 'ngDim'   },
                    { name: 'Summary - NG Visual',   key: 'ngVis'   },
                    { name: 'Summary - VIN Kode',    key: 'vin'     },
                    { name: 'Summary - ACT Panjang', key: 'actPnjg' },
                    { name: 'Summary - QTY Status',  key: 'qtySt'  }
                ];
                for (const sf of summaryFields) {
                    const allTimes = measurements.map(m => m.time || '').join(',');
                    const sRow = {
                        PointName: sf.name, TimeSection: allTimes,
                        Frequency: '30m Sekali', StandardDimension: '-',
                        Initial: '', Reading1: '', Reading2: '', Reading3: '', Reading4: '', Reading5: '',
                        Status: 'OK'
                    };
                    for (let idx = 0; idx < Math.min(measurements.length, 5); idx++) {
                        const val = measurements[idx].data[sf.key];
                        sRow[`Reading${idx + 1}`] = (val !== null && val !== undefined) ? String(val) : '';
                    }
                    aggregateReadings.push(sRow);
                }

                // Aggregate totals across all slots
                const totalQtyOk  = measurements.reduce((s, m) => {
                    const slotTotal = (m.data.summaries || []).reduce((ss, item) => ss + (parseInt(item.ok) || 0), 0);
                    return s + (parseInt(m.data.qtyOk) || 0) + slotTotal;
                }, 0);
                
                const totalNgDim  = measurements.reduce((s, m) => {
                    const slotTotal = (m.data.summaries || []).reduce((ss, item) => ss + (parseInt(item.ngD) || 0), 0);
                    return s + (parseInt(m.data.ngDim) || 0) + slotTotal;
                }, 0);

                const totalNgVis  = measurements.reduce((s, m) => {
                    const slotTotal = (m.data.summaries || []).reduce((ss, item) => ss + (parseInt(item.ngV) || 0), 0);
                    return s + (parseInt(m.data.ngVis) || 0) + slotTotal;
                }, 0);

                const lastVin     = [...measurements].reverse().find(m => (m.data.summaries && m.data.summaries.length > 0) || m.data.vin)?.data.summaries?.map(s => s.vin).join(', ') || document.getElementById('val-vin-kode')?.value  || '';
                const lastActPnjg = [...measurements].reverse().find(m => m.data.actPnjg)?.data.actPnjg || document.getElementById('val-act-pnjg')?.value || '';
                const lastRemark  = [...measurements].reverse().find(m => m.data.remark)?.data.remark   || document.getElementById('val-remark')?.value   || '';

                const allSummaries = [];
                measurements.forEach((m, slotIdx) => {
                    if (m.data.summaries && m.data.summaries.length > 0) {
                        m.data.summaries.forEach(s => {
                            allSummaries.push({
                                PartNumber: (document.getElementById('disp-part-no')?.innerText || '') + '#' + slotIdx,
                                VinCode: s.vin,
                                StandardLength: document.getElementById('disp-std-pnjg')?.value || '',
                                ActualLength: s.act,
                                QtyTarget: parseInt(document.getElementById('disp-qty-target')?.value || '0'),
                                QtyOk: parseInt(s.ok) || 0,
                                NgDimension: parseInt(s.ngD) || 0,
                                NgVisual: parseInt(s.ngV) || 0
                            });
                        });
                    } else {
                        // Auto-capture loose inputs if user forgot to click "Add to List"
                        const looseVin = (m.data.vin || '').trim();
                        const looseAct = (m.data.actPnjg || '').trim();
                        const looseOk = parseInt(m.data.qtyOk) || 0;
                        const looseNgD = parseInt(m.data.ngDim) || 0;
                        const looseNgV = parseInt(m.data.ngVis) || 0;

                        if (looseVin !== '' || looseAct !== '' || looseOk > 0 || looseNgD > 0 || looseNgV > 0) {
                            allSummaries.push({
                                PartNumber: (document.getElementById('disp-part-no')?.innerText || '') + '#' + slotIdx,
                                VinCode: looseVin || '-',
                                StandardLength: document.getElementById('disp-std-pnjg')?.value || '',
                                ActualLength: looseAct,
                                QtyTarget: parseInt(document.getElementById('disp-qty-target')?.value || '0'),
                                QtyOk: looseOk,
                                NgDimension: looseNgD,
                                NgVisual: looseNgV
                            });
                        }
                    }
                });

                const payload = {
                    ReportId: @(Model?.Id ?? 0),
                    SpsId: window._dimSpsId || null,
                    DocumentNumber: document.getElementById('h-doc')?.innerText || '---',
                    ItemCode: document.getElementById('itemCode')?.value || window._dimSelectedItemCode || '',
                    HoseType: document.getElementById('h-hose')?.innerText || '',
                    CustomerName: document.getElementById('h-customer')?.innerText || '',
                    DimensionDisplay: document.getElementById('disp-part-no')?.innerText || '',
                    VinCode: lastVin,
                    StandardLength: document.getElementById('disp-std-pnjg')?.value || '',
                    ActualLength: lastActPnjg,
                    QtyTarget: parseInt(document.getElementById('disp-qty-target')?.value || '0'),
                    QtyOk: totalQtyOk,
                    NgDimension: totalNgDim,
                    NgVisual: totalNgVis,
                    Remark: lastRemark,
                    ByPass: '',
                    Shift: normalizePlanningShift(document.getElementById('h-shift')?.innerText || ''),
                    DimensionReadings: aggregateReadings,
                    ProductionDataSummaries: allSummaries
                };


                const response = await fetch('/Dimensi/SaveData', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const result = await response.json();
                if(result.success) {
                    dimClearDraft(_dimCurrentItem);  // draft selesai — hapus dari storage

                    // Flash success message
                    const status = document.getElementById('save-status');
                    status.style.opacity = '1';
                    
                    // Reset HUD
                    resetHUD();

                    // Reset UI to 'before selecting planning' state
                    resetPlanningSelection();
                    
                    setTimeout(() => { status.style.opacity = '0'; }, 3000);

                } else {
                    Swal.fire('Error', result.message || 'Failed to save', 'error');
                }
            } catch (err) {
                console.error(err);
                Swal.fire('Error', 'Sistem Gagal Menyimpan', 'error');
            } finally {
                refreshSubmitButtonState();
            }
        }

        function resetHUD() {
            // 1. Reset Global Data
            measurements = [{ time: null, data: {} }];
            currentIndex = 0;

            // 2. Clear All Card Inputs
            document.querySelectorAll('.c-input').forEach(inp => {
                inp.value = "";
                const id = inp.id.replace('val-', '');
                validateCard(id);
            });

            // 3. Clear Summary Inputs
            ['val-vin-kode', 'val-act-pnjg', 'val-qty-ok', 'val-ng-dimensi', 'val-ng-visual', 'val-remark'].forEach(id => {
                const el = document.getElementById(id);
                if(el) el.value = "";
            });

            // 4. Clear Static Labels
            ['disp-part-no', 'disp-std-pnjg'].forEach(id => {
                const el = document.getElementById(id);
                if(el) el.innerText = "-";
            });
            const qtyTargetEl = document.getElementById('disp-qty-target');
            if(qtyTargetEl) qtyTargetEl.value = "0";

            // 5. Reset Visual Buttons & Status
            document.querySelectorAll('.seg-btn').forEach(btn => btn.classList.remove('active-ok', 'active-ng'));
            document.querySelectorAll('.qty-btn').forEach(btn => btn.classList.remove('active-ok', 'active-ng'));
            document.getElementById('okPanel').style.display = 'none';
            document.getElementById('ngPanel').style.display = 'none';

            // 6. UI Update
            renderTimeline();
            loadDataToUI();
            refreshSubmitButtonState();

            // 7. Notification (Toast)
            Swal.fire({
                icon: 'success',
                title: 'DASHBOARD RESET',
                text: 'Data tersimpan & Layar dikosongkan.',
                timer: 1500,
                showConfirmButton: false,
                position: 'top-end',
                toast: true
            });
        }

        function resetPlanningSelection() {
            // Restore default placeholder
            const placeholder = document.getElementById('selection-placeholder');
            const workspace = document.getElementById('input-workspace');
            if (placeholder) {
                placeholder.style.display = 'block';
                placeholder.style.borderColor = 'rgba(255,255,255,0.1)';
                placeholder.innerHTML = `
                    <div class="mb-4">
                        <i class="bi bi-cursor-fill text-info" style="font-size: 60px; opacity: 0.5; display: block;"></i>
                    </div>
                    <h3 style="color: #fff; font-weight: 800; letter-spacing: 1px;">PLEASE SELECT PLANNING</h3>
                    <p style="color: #94a3b8; font-size: 14px;">Select an item from the <b>Planning Master</b> above to start dimension inspection.</p>
                `;
            }
            if (workspace) {
                workspace.style.display = 'none';
                workspace.style.opacity = '0';
            }

            // Clear search input
            const pi = document.getElementById('planningSearch');
            if (pi) {
                pi.value = '';
                pi.readOnly = false;
                pi.placeholder = 'PILIH PLANNING MASTER...';
            }
            window._dimSelectedLabel = null;
            window._dimSelectedItemCode = null;
            
            const itemCodeInput = document.getElementById('itemCode');
            if (itemCodeInput) itemCodeInput.value = '';
            
            const mainSearchInput = document.getElementById('main-item-search');
            if (mainSearchInput) mainSearchInput.value = '';
            
            // Clear headers
            const docEl = document.getElementById('h-doc'); if (docEl) docEl.innerText = '---';
            const hoseEl = document.getElementById('h-hose'); if (hoseEl) hoseEl.innerText = '---';
            const custEl = document.getElementById('h-customer'); if (custEl) custEl.innerText = '---';
            const specEl = document.getElementById('h-spec'); if (specEl) specEl.innerText = '---';
            
            // Re-fetch planning items (in case of updates)
            refreshPlanningItems();
        }

        function finalize() {
            saveCurrentData();
            Swal.fire({
                icon: 'question',
                title: 'SUBMIT REPORT?',
                text: 'Pastikan semua jam sudah terisi dengan benar.',
                showCancelButton: true,
                confirmButtonText: 'YA, SUBMIT',
                confirmButtonColor: '#10b981'
            }).then(r => {
                 if(r.isConfirmed) {
                     Swal.fire({ icon: 'success', title: 'SYNC SUCCESS!', timer: 2000, showConfirmButton: false });
                     setTimeout(() => window.location.href = '/Dimensi/Index', 2000);
                 }
            });
        }
    </script>
}

