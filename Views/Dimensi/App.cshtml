@model VelastoProductionSystem.Models.DimensionReport

@{
    Layout = "_Layout";
    ViewData["Title"] = "Dimension Input Hub";
}

@section Styles {
    <style>
        :root {
            --bg-deep: #0b1120;
            --glass-bg: rgba(15, 23, 42, 0.7);
            --glass-border: rgba(56, 189, 248, 0.15);
            --accent-glow: #38bdf8;
            --accent-success: #10b981;
            --accent-warning: #fbbf24;
            --accent-danger: #ef4444;
            --text-white: #f8fafc;
            --text-dim: #94a3b8;
        }

        body {
            background: radial-gradient(circle at top right, #1e293b, #0b1120);
            color: var(--text-white);
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            min-height: 100vh;
            padding: 0; margin: 0;
            letter-spacing: -0.01em;
        }

        /* --- Search & Control Bar --- */
        .search-action-bar {
            display: flex; align-items: center; justify-content: center; gap: 15px;
            max-width: 1200px; margin: 0 auto 25px auto; width: 100%; padding: 0 15px;
        }
        .search-input-group {
            flex: 1; max-width: 800px; display: flex; align-items: stretch; background: rgba(30, 41, 59, 0.4);
            border: 1px solid var(--glass-border); border-left: 5px solid var(--accent-glow);
            border-radius: 4px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            transition: all 0.3s; height: 48px;
        }
        .search-input-group:focus-within { border-color: var(--accent-glow); box-shadow: 0 0 20px rgba(56, 189, 248, 0.2); }
        
        .cam-btn {
            width: 55px; background: rgba(255,255,255,0.03); color: var(--accent-glow); border: none;
            display: flex; align-items: center; justify-content: center; font-size: 18px; cursor: pointer;
            transition: 0.3s; border-right: 1px solid rgba(255,255,255,0.05);
        }
        .cam-btn:hover { background: rgba(56, 189, 248, 0.1); color: #fff; }

        .search-input-group input {
            flex: 1; background: transparent; border: none; outline: none; padding: 0 20px;
            color: #fff; font-size: 14px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
        }
        
        .search-trigger-btn {
            width: 55px; background: var(--accent-glow); color: #000; border: none;
            display: flex; align-items: center; justify-content: center; font-size: 18px; cursor: pointer;
            transition: 0.3s;
        }
        .search-trigger-btn:hover { background: #fff; box-shadow: 0 0 15px var(--accent-glow); }
        
        .bt-icon-btn {
            width: 48px; height: 48px; border-radius: 50%; background: rgba(15, 23, 42, 0.8);
            border: 1px solid rgba(255, 255, 255, 0.05); display: flex; align-items: center; justify-content: center;
            font-size: 20px; color: #94a3b8; cursor: pointer; transition: all 0.4s; position: relative;
        }
        .bt-icon-btn.active {
            color: var(--accent-success); border-color: var(--accent-success);
            box-shadow: 0 0 20px rgba(16, 185, 129, 0.2);
        }
        .bt-icon-btn.active::after {
            content: ''; position: absolute; top: -2px; right: -2px; width: 10px; height: 10px;
            background: var(--accent-success); border-radius: 50%; border: 2px solid var(--bg-deep);
            box-shadow: 0 0 10px var(--accent-success); animation: pulse 1s infinite;
        }
        .tool-link-btn.active {
            border-color: var(--accent-success);
            box-shadow: 0 0 20px rgba(16, 185, 129, 0.1);
        }
        .tool-link-btn.active .t-dot { background: var(--accent-success); box-shadow: 0 0 10px var(--accent-success); animation: pulse 1s infinite; }
        .tool-link-btn.active .t-text { color: var(--accent-success); }

        .t-dot { width: 8px; height: 8px; border-radius: 50%; background: #94a3b8; transition: 0.3s; }
        .t-text { font-size: 10px; color: #94a3b8; font-weight: 900; letter-spacing: 1.5px; text-transform: uppercase; transition: 0.3s; }
        .t-icon { font-size: 14px; color: #94a3b8; }
        .tool-link-btn.active .t-icon { color: var(--accent-success); }

        /* --- New Modular Dashboard Widgets (Non-Table) --- */
        .tech-header-ribbon {
            display: grid; grid-template-columns: repeat(4, 1fr);
            gap: 15px; max-width: 1400px; margin: 0 auto 30px auto; width: 100%;
            padding: 0 15px;
        }
        .header-cluster {
            background: rgba(30, 41, 59, 0.4); border: 1px solid var(--glass-border);
            border-left: 4px solid var(--accent-glow); border-radius: 8px;
            padding: 15px 20px; display: flex; flex-direction: column; justify-content: center;
            box-shadow: 0 10px 25px rgba(0,0,0,0.3); backdrop-filter: blur(10px);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .header-cluster:hover {
            transform: translateY(-3px); border-color: rgba(56, 189, 248, 0.4);
            box-shadow: 0 15px 35px rgba(56, 189, 248, 0.15);
            background: rgba(30, 41, 59, 0.6);
        }
        
        /* --- Responsive Cockpit (Tablet Mode) --- */
        @@media (max-width: 1200px) {
            .tech-header-ribbon { grid-template-columns: repeat(2, 1fr); gap: 12px; }
            .header-cluster { min-height: 80px; padding: 15px; }
        }
        
        @@media (max-width: 900px) {
            .search-input-group { width: 100%; max-width: none; }
        }

        @@media (max-width: 600px) {
            .tech-header-ribbon { grid-template-columns: 1fr; }
        }
        .header-cluster:last-child { border-right: none; }
        .m-lbl { font-size: 8px; color: var(--text-dim); font-weight: 800; letter-spacing: 1px; text-transform: uppercase; display: flex; align-items: center; gap: 6px; opacity: 0.6; white-space: nowrap; }
        .m-row { display: flex; align-items: center; gap: 6px; white-space: nowrap; margin-top: 4px; overflow: hidden; }
        .m-val { font-size: 11px; color: #fff; font-weight: 900; letter-spacing: 0.2px; line-height: 1; }
        .m-accent { color: var(--accent-glow); text-shadow: 0 0 10px rgba(56, 189, 248, 0.1); }
        .m-sub { font-size: 9px; color: rgba(255,255,255,0.25); font-weight: 800; text-transform: uppercase; margin-left: 4px; }
        .m-icon { font-size: 10px; color: var(--accent-glow); opacity: 0.5; }
        .m-divider { width: 1px; height: 10px; background: rgba(255,255,255,0.08); margin: 0 2px; }

        .jam-nav { display: flex; gap: 15px; margin-bottom: 30px; justify-content: center; }
        .jam-btn {
            background: rgba(30, 41, 59, 0.4); border: 1px solid rgba(56, 189, 248, 0.15);
            color: var(--text-dim); padding: 12px 28px; border-radius: 4px;
            font-size: 13px; font-weight: 800; cursor: pointer; transition: all 0.3s;
            position: relative; overflow: visible;
        }
        .jam-btn.active {
            background: var(--accent-glow); color: #000; border-color: transparent;
            box-shadow: 0 0 20px rgba(56, 189, 248, 0.2); transform: scale(1.05);
        }
        .add-btn { background: rgba(56, 189, 248, 0.05); border-style: dashed; }
        .slot-delete-btn {
            position: absolute; top: -10px; right: -10px; width: 20px; height: 20px;
            border-radius: 50%; background: var(--accent-danger); border: 2px solid var(--bg-deep);
            display: flex; align-items: center; justify-content: center; font-size: 10px;
            color: #fff; opacity: 0; transition: 0.3s; z-index: 5;
        }
        .jam-btn:hover .slot-delete-btn { opacity: 1; }

        /* --- Card Styles --- */
        .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 25px; }
        .dimensi-card {
            background: rgba(15, 23, 42, 0.4); border: 1px solid rgba(56, 189, 248, 0.1);
            border-radius: 12px; padding: 25px; transition: all 0.4s;
            backdrop-filter: blur(15px); position: relative; overflow: hidden;
        }
        .card-header-flex { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
        .card-point { font-weight: 800; font-size: 14px; color: #fff; letter-spacing: 2px; }
        .card-icon { font-size: 20px; color: var(--accent-glow); opacity: 0.5; }
        
        .std-container { display: flex; flex-direction: column; align-items: center; margin-bottom: 20px; }
        .std-label { font-size: 9px; color: var(--text-dim); font-weight: 900; letter-spacing: 1.5px; opacity: 0.6; }
        .std-value { font-size: 16px; color: var(--accent-glow); font-weight: 900; }

        .limit-row { display: flex; gap: 12px; margin-bottom: 20px; }
        .limit-pill { 
            flex: 1; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05);
            padding: 8px 15px; border-radius: 50px; display: flex; align-items: center; justify-content: space-between;
        }
        .limit-label { font-size: 9px; color: var(--text-dim); font-weight: 900; }
        .limit-val { font-size: 14px; font-weight: 900; }
        .limit-val.min { color: var(--accent-success); }
        .limit-val.max { color: var(--accent-warning); }

        .input-group-custom { display: flex; flex-direction: column; gap: 10px; }
        .input-group-custom label { font-size: 10px; color: var(--text-dim); font-weight: 900; text-align: center; }
        .c-input {
            background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px;
            color: #fff; padding: 15px; font-size: 28px; font-weight: 900; text-align: center; outline: none;
            box-shadow: inset 0 2px 10px rgba(0,0,0,0.5); width: 100%; transition: all 0.3s;
        }
        .status-badge { position: absolute; bottom: 0; left: 0; width: 100%; height: 4px; background: transparent; transition: 0.4s; }
        .status-ok .status-badge { background: var(--accent-success); box-shadow: 0 0 20px var(--accent-success); }
        .status-ok .c-input { 
            color: #10b981 !important; 
            border-color: rgba(16, 185, 129, 0.5) !important;
            text-shadow: 0 0 10px rgba(16, 185, 129, 0.4); 
            box-shadow: inset 0 0 15px rgba(16, 185, 129, 0.1);
        }
        .status-ng .status-badge { background: #ff4d4d; box-shadow: 0 0 25px #ff4d4d; }
        .status-ng .c-input { 
            color: #ff4d4d !important; 
            background: rgba(255, 77, 77, 0.15) !important;
            border-color: rgba(255, 77, 77, 0.6) !important;
            text-shadow: 0 0 15px rgba(255, 77, 77, 0.5); 
            box-shadow: inset 0 0 25px rgba(255, 77, 77, 0.2), 0 0 15px rgba(255, 77, 77, 0.2);
            animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both;
        }
        
        @@keyframes shake {
          10%, 90% { transform: translate3d(-1px, 0, 0); }
          20%, 80% { transform: translate3d(2px, 0, 0); }
          30%, 50%, 70% { transform: translate3d(-4px, 0, 0); }
          40%, 60% { transform: translate3d(4px, 0, 0); }
        }

        /* --- Visual Check & Summary --- */
        .visual-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .visual-item { 
            background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);
            padding: 12px; border-radius: 12px; text-align: center; display: flex; flex-direction: column; gap: 8px;
        }
        .visual-label { font-size: 9px; color: var(--text-dim); font-weight: 900; letter-spacing: 1px; }
        .segmented-control { display: flex; background: rgba(0,0,0,0.3); padding: 4px; border-radius: 8px; gap: 4px; }
        .seg-btn {
            flex: 1; border: none; background: transparent; color: var(--text-dim);
            font-size: 10px; font-weight: 900; padding: 8px 0; border-radius: 6px; cursor: pointer; transition: 0.2s;
        }
        .seg-btn.active-ok { background: var(--accent-success); color: #000; }
        .seg-btn.active-ng { background: var(--accent-danger); color: #fff; }

        .section-title {
            font-size: 11px; font-weight: 900; color: var(--accent-glow);
            letter-spacing: 2px; display: flex; align-items: center; gap: 10px;
            margin: 40px 0 20px 0; padding-left: 15px; border-left: 4px solid var(--accent-glow);
            text-transform: uppercase;
        }
        .prod-data-container {
            background: rgba(15, 23, 42, 0.4); border: 1px solid rgba(56, 189, 248, 0.1);
            border-radius: 12px; padding: 25px; backdrop-filter: blur(15px);
        }
        .prod-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; }
        .field-column { display: flex; flex-direction: column; gap: 20px; }
        .field-box { display: flex; flex-direction: column; gap: 8px; }
        .field-label { font-size: 9px; color: var(--text-dim); font-weight: 900; letter-spacing: 1px; text-transform: uppercase; }
        .field-input-wrap {
            background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08);
            border-radius: 8px; padding: 12px 15px;
        }
        .f-input { background: transparent; border: none; color: #fff; width: 100%; font-size: 14px; font-weight: 700; outline: none; }
        .qty-row { display: flex; gap: 10px; }
        .qty-btn {
            flex: 1; padding: 12px; border: 1px solid rgba(255,255,255,0.1);
            background: rgba(255,255,255,0.03); color: var(--text-dim);
            font-size: 11px; font-weight: 900; cursor: pointer; transition: 0.3s;
            border-radius: 8px; display: flex; align-items: center; justify-content: center; gap: 8px;
        }
        .qty-btn:hover { border-color: var(--accent-glow); color: #fff; }
        .qty-btn.active-ok { border-color: var(--accent-success); color: var(--accent-success); background: rgba(16,185,129,0.05); }
        .qty-btn.active-ng { border-color: var(--accent-danger); color: var(--accent-danger); background: rgba(239,68,68,0.05); }

        .f-textarea {
            background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px;
            color: #fff; padding: 15px; width: 100%; font-size: 13px; outline: none; height: 80px; resize: none;
        }

        @@keyframes pulse { 0%, 100% { opacity: 0.5; } 50% { opacity: 1; } }
        .tracking-widest { letter-spacing: 0.2em; }
    </style>
}



<!-- NEW REPORT HEADER (AS PER IMAGE) -->
<div class="app-container pt-3">
    <!-- Main Header -->
    <div class="text-center mb-3 animate__animated animate__fadeInDown">
        <h2 class="display-6 fw-bold tracking-widest text-uppercase" style="letter-spacing: 6px;">EXTRUDER PRODUCTION REPORT</h2>
        <div class="text-primary fw-bold" style="font-size: 13px; letter-spacing: 4px;">( DIMENSION )</div>
    </div>

    <!-- Item List Scanner Action Bar -->
    <div class="search-action-bar animate__animated animate__fadeInDown">
        <!-- 3-Part Smart Search Bar -->
        <div class="search-input-group">
            <button class="cam-btn" title="Open Camera Scanner" onclick="openScanner()">
                <i class="bi bi-qr-code-scan"></i>
            </button>
            <input type="text" id="main-item-search" placeholder="MANUAL INPUT / SCAN ITEM LIST..." autocomplete="off" onkeypress="if(event.key === 'Enter') loadMaster()">
            <button class="search-trigger-btn" id="btn-master-search" onclick="loadMaster()" title="Trigger Master Search">
                <i class="bi bi-search"></i>
            </button>
        </div>
        
        <!-- History Shortcut -->
        <a href="/Dimensi/History" class="bt-icon-btn" style="text-decoration: none;" title="View Inspection History">
            <i class="bi bi-clock-history"></i>
        </a>
        
        <!-- Compact Bluetooth Tool Control -->
        <div class="bt-icon-btn" id="toolLinkBtn" onclick="showBluetoothSettings()" title="Bluetooth Tool Settings">
            <i class="bi bi-bluetooth"></i>
        </div>
    </div>

    <!-- Unified Technical HUD Dashboard -->
    <div class="tech-header-ribbon animate__animated animate__fadeIn">
        <!-- CLUSTER 1: LINE -->
        <div class="header-cluster">
            <span class="m-lbl"><i class="bi bi-gear-fill m-icon"></i> PRODUCTION LINE</span>
            <div class="m-row">
                <span class="m-val m-accent" id="h-line">DL01 ENGINE</span>
            </div>
        </div>
        <!-- CLUSTER 2: DOC -->
        <div class="header-cluster">
            <span class="m-lbl"><i class="bi bi-tag-fill m-icon"></i> DOC NO.</span>
            <div class="m-row">
                <span class="m-val" id="h-doc">@(string.IsNullOrEmpty(Model.DocumentNumber) ? "---" : Model.DocumentNumber)</span>
                <span class="m-sub" id="h-rev">REV.0</span>
            </div>
        </div>
        <!-- CLUSTER 3: TIMING -->
        <div class="header-cluster">
            <span class="m-lbl"><i class="bi bi-clock-fill m-icon"></i> TIME / SHIFT</span>
            <div class="m-row">
                <span class="m-val" style="font-size: 11px;">@DateTime.Now.ToString("dd MMM yyyy").ToUpper()</span>
                <span class="m-divider"></span>
                <span class="m-val m-accent" id="h-shift" onclick="toggleShift()" style="cursor: pointer;" title="CLICK TO TOGGLE SHIFT">@(Model.Shift ?? "Shift 1")</span>
            </div>
        </div>
        <!-- CLUSTER 4: PRODUCT -->
        <div class="header-cluster">
            <span class="m-lbl"><i class="bi bi-cpu-fill m-icon"></i> CUSTOMER / SPEC</span>
            <div class="m-row">
                <div id="h-row-hose" style="display: flex; align-items: center; gap: 8px;">
                    <span class="m-val" id="h-customer">---</span>
                    <span class="m-divider"></span>
                    <span class="m-val m-accent" id="h-hose" style="font-size: 11px;">---</span>
                </div>
            </div>
        </div>
        </div>
    </div>
</div>

<!-- SMART DIMENSION HUB -->
<div class="p-3">
    <!-- DIMENSION SECTION -->
    <div class="section-title">
        <i class="bi bi-rulers"></i>
        DIMENSION INSPECTION
    </div>

    <!-- Dynamic Timeline Navigator -->
    <div class="jam-nav" id="timelineContainer">
        <!-- Buttons will be generated here -->
        <button class="jam-btn add-btn" onclick="addNewSlot()">
            <i class="bi bi-plus-lg"></i>
        </button>
    </div>

    <!-- Cards Grid -->
    <div class="card-grid" id="cardContainer">
        <!-- Inner Diameter Card -->
        <div class="dimensi-card" id="card-inner-dia">
            <div class="card-header-flex">
                <div class="card-point">INNER DIAMETER</div>
                <i class="bi bi-circle card-icon"></i>
            </div>
            <div class="std-container">
                 <div class="std-label">STANDARD</div>
                 <div class="std-value" id="std-inner-dia">---</div>
            </div>
            <div class="limit-row">
                <div class="limit-pill">
                    <span class="limit-label">MIN</span>
                    <span class="limit-val min" id="limit-inner-dia-min">---</span>
                </div>
                <div class="limit-pill">
                    <span class="limit-label">MAX</span>
                    <span class="limit-val max" id="limit-inner-dia-max">---</span>
                </div>
            </div>
            <div class="input-group-custom">
                <label>ACTUAL MEASUREMENT</label>
                <input type="text" inputmode="decimal" class="c-input" id="val-inner-dia" oninput="validateCard('inner-dia')" placeholder="0.00" />
            </div>
            <span class="status-badge"></span>
        </div>

        <!-- Inner Thick X Card -->
        <div class="dimensi-card" id="card-inner-tx">
            <div class="card-header-flex">
                <div class="card-point">INNER THICK (X)</div>
                <i class="bi bi-arrows-expand card-icon"></i>
            </div>
            <div class="std-container">
                 <div class="std-label">STANDARD</div>
                 <div class="std-value" id="std-inner-tx">---</div>
            </div>
            <div class="limit-row">
                <div class="limit-pill">
                    <span class="limit-label">MIN</span>
                    <span class="limit-val min" id="limit-inner-tx-min">---</span>
                </div>
                <div class="limit-pill">
                    <span class="limit-label">MAX</span>
                    <span class="limit-val max" id="limit-inner-tx-max">---</span>
                </div>
            </div>
            <div class="input-group-custom">
                <label>ACTUAL MEASUREMENT</label>
                <input type="text" inputmode="decimal" class="c-input" id="val-inner-tx" oninput="validateCard('inner-tx')" placeholder="0.00" />
            </div>
            <span class="status-badge"></span>
        </div>

        <!-- Inner Thick Y Card -->
        <div class="dimensi-card" id="card-inner-ty">
            <div class="card-header-flex">
                <div class="card-point">INNER THICK (Y)</div>
                <i class="bi bi-arrows-vertical card-icon"></i>
            </div>
            <div class="std-container">
                 <div class="std-label">STANDARD</div>
                 <div class="std-value" id="std-inner-ty">---</div>
            </div>
            <div class="limit-row">
                <div class="limit-pill">
                    <span class="limit-label">MIN</span>
                    <span class="limit-val min" id="limit-inner-ty-min">---</span>
                </div>
                <div class="limit-pill">
                    <span class="limit-label">MAX</span>
                    <span class="limit-val max" id="limit-inner-ty-max">---</span>
                </div>
            </div>
            <div class="input-group-custom">
                <label>ACTUAL MEASUREMENT</label>
                <input type="text" inputmode="decimal" class="c-input" id="val-inner-ty" oninput="validateCard('inner-ty')" placeholder="0.00" />
            </div>
            <span class="status-badge"></span>
        </div>

        <!-- Total Thick X Card -->
        <div class="dimensi-card" id="card-total-tx">
            <div class="card-header-flex">
                <div class="card-point">TOTAL THICK (X)</div>
                <i class="bi bi-arrows-expand card-icon"></i>
            </div>
            <div class="std-container">
                 <div class="std-label">STANDARD</div>
                 <div class="std-value" id="std-total-tx">---</div>
            </div>
            <div class="limit-row">
                <div class="limit-pill">
                    <span class="limit-label">MIN</span>
                    <span class="limit-val min" id="limit-total-tx-min">---</span>
                </div>
                <div class="limit-pill">
                    <span class="limit-label">MAX</span>
                    <span class="limit-val max" id="limit-total-tx-max">---</span>
                </div>
            </div>
            <div class="input-group-custom">
                <label>ACTUAL MEASUREMENT</label>
                <input type="text" inputmode="decimal" class="c-input" id="val-total-tx" oninput="validateCard('total-tx')" placeholder="0.00" />
            </div>
            <span class="status-badge"></span>
        </div>

        <!-- Total Thick Y Card -->
        <div class="dimensi-card" id="card-total-ty">
            <div class="card-header-flex">
                <div class="card-point">TOTAL THICK (Y)</div>
                <i class="bi bi-arrows-vertical card-icon"></i>
            </div>
            <div class="std-container">
                 <div class="std-label">STANDARD</div>
                 <div class="std-value" id="std-total-ty">---</div>
            </div>
            <div class="limit-row">
                <div class="limit-pill">
                    <span class="limit-label">MIN</span>
                    <span class="limit-val min" id="limit-total-ty-min">---</span>
                </div>
                <div class="limit-pill">
                    <span class="limit-label">MAX</span>
                    <span class="limit-val max" id="limit-total-ty-max">---</span>
                </div>
            </div>
            <div class="input-group-custom">
                <label>ACTUAL MEASUREMENT</label>
                <input type="text" inputmode="decimal" class="c-input" id="val-total-ty" oninput="validateCard('total-ty')" placeholder="0.00" />
            </div>
            <span class="status-badge"></span>
        </div>

        <!-- Spiral Pitch Card -->
        <div class="dimensi-card" id="card-spiral">
            <div class="card-header-flex">
                <div class="card-point">SPIRAL PITCH</div>
                <i class="bi bi-hr card-icon"></i>
            </div>
            <div class="std-container">
                 <div class="std-label">STANDARD</div>
                 <div class="std-value" id="std-spiral">---</div>
            </div>
            <div class="limit-row">
                <div class="limit-pill">
                    <span class="limit-label">MIN</span>
                    <span class="limit-val min" id="limit-spiral-min">---</span>
                </div>
                <div class="limit-pill">
                    <span class="limit-label">MAX</span>
                    <span class="limit-val max" id="limit-spiral-max">---</span>
                </div>
            </div>
            <div class="input-group-custom">
                <label>ACTUAL PITCH VALUE</label>
                <input type="text" inputmode="decimal" class="c-input" id="val-spiral" oninput="validateCard('spiral')" placeholder="0" />
            </div>
            <span class="status-badge"></span>
        </div>

        <!-- VISUAL CHECK CARD -->
        <div class="dimensi-card" id="card-visual">
            <div class="card-header-flex">
                <div class="card-point">VISUAL CHECK</div>
                <i class="bi bi-eye-fill card-icon"></i>
            </div>
            <div class="visual-grid">
                <div class="visual-item">
                    <i class="bi bi-eraser-fill text-primary mb-1"></i>
                    <span class="visual-label">BURRY</span>
                    <div class="segmented-control">
                        <button class="seg-btn" id="v-burry-ok" onclick="toggleVisual('burry', 'ok')">OK</button>
                        <button class="seg-btn" id="v-burry-ng" onclick="toggleVisual('burry', 'ng')">NG</button>
                    </div>
                </div>
                <div class="visual-item">
                    <i class="bi bi-border-width text-primary mb-1"></i>
                    <span class="visual-label">LINE</span>
                    <div class="segmented-control">
                        <button class="seg-btn" id="v-line-ok" onclick="toggleVisual('line', 'ok')">OK</button>
                        <button class="seg-btn" id="v-line-ng" onclick="toggleVisual('line', 'ng')">NG</button>
                    </div>
                </div>
                <div class="visual-item">
                    <i class="bi bi-droplet-fill text-primary mb-1"></i>
                    <span class="visual-label">BUBBLE</span>
                    <div class="segmented-control">
                        <button class="seg-btn" id="v-bubble-ok" onclick="toggleVisual('bubble', 'ok')">OK</button>
                        <button class="seg-btn" id="v-bubble-ng" onclick="toggleVisual('bubble', 'ng')">NG</button>
                    </div>
                </div>
                <div class="visual-item">
                    <i class="bi bi-scissors text-primary mb-1"></i>
                    <span class="visual-label">SCRATCH</span>
                    <div class="segmented-control">
                        <button class="seg-btn" id="v-scratch-ok" onclick="toggleVisual('scratch', 'ok')">OK</button>
                        <button class="seg-btn" id="v-scratch-ng" onclick="toggleVisual('scratch', 'ng')">NG</button>
                    </div>
                </div>
            </div>
            <span class="status-badge"></span>
        </div>
    </div> <!-- END CARD GRID -->

    <!-- FLOATING ACTION BUTTON -->
    <div style="position: fixed; bottom: 30px; right: 30px; z-index: 1000; display: flex; gap: 15px; align-items: center;">
        <div id="save-status" style="color: #10b981; font-size: 11px; opacity: 0; transition: 0.5s; font-weight: 800;">
            <i class="bi bi-check2-circle"></i> DATA SAVED TO HISTORY
        </div>
        <button type="button" onclick="submitEntry()" class="submit-btn" style="
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            color: white; padding: 18px 35px; border: none; border-radius: 50px;
            font-weight: 800; font-size: 16px; cursor: pointer;
            box-shadow: 0 10px 40px rgba(37, 99, 235, 0.4);
            display: flex; align-items: center; gap: 12px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            text-transform: uppercase; letter-spacing: 1px;
            border: 2px solid rgba(255,255,255,0.1);
        " onmouseover="this.style.transform='scale(1.05) translateY(-5px)'; this.style.boxShadow='0 15px 50px rgba(37, 99, 235, 0.6)';" 
          onmouseout="this.style.transform='scale(1) translateY(0)'; this.style.boxShadow='0 10px 40px rgba(37, 99, 235, 0.4)';">
            <i class="bi bi-cloud-arrow-up-fill" style="font-size: 24px;"></i>
            SUBMIT ENTRY
        </button>
    </div>

    <!-- PRODUCTION DATA SECTION -->
    <div class="section-title">
        <i class="bi bi-clipboard2-data-fill"></i> PRODUCTION DATA Summary
    </div>
    <div class="prod-data-container">
        <div class="prod-grid">
            <div class="field-column">
                <div class="field-box">
                    <span class="field-label">PART NUMBER</span>
                    <div class="field-input-wrap"><div class="f-input" id="disp-part-no">-</div></div>
                </div>
                <div class="field-box">
                    <span class="field-label">STD PNJG</span>
                    <div class="field-input-wrap"><input type="text" class="f-input" id="disp-std-pnjg" value="-"></div>
                </div>
                <div class="field-box">
                    <span class="field-label">QTY TARGET</span>
                    <div class="field-input-wrap"><input type="number" class="f-input" id="disp-qty-target" value="0"></div>
                </div>
            </div>
            <div class="field-column">
                <div class="field-box">
                    <span class="field-label">VIN KODE</span>
                    <div class="field-input-wrap"><input type="text" class="f-input" id="val-vin-kode" placeholder="Enter VIN Code"></div>
                </div>
                <div class="field-box">
                    <span class="field-label">ACT PNJG</span>
                    <div class="field-input-wrap"><input type="number" class="f-input" id="val-act-pnjg" placeholder="Enter length"></div>
                </div>
                <div class="field-box">
                    <span class="field-label">QTY ACTUAL STATUS</span>
                    <div class="qty-row">
                        <button type="button" class="qty-btn" id="qty-ok" onclick="setQtyStatus('ok')"><i class="bi bi-check-circle-fill"></i> ALL OK</button>
                        <button type="button" class="qty-btn" id="qty-ng" onclick="setQtyStatus('ng')"><i class="bi bi-x-circle-fill"></i> CONTAINS NG</button>
                    </div>
                    
                    <div id="qtyContentArea" style="margin-top: 15px; min-height: 50px;">
                        <!-- OK PANEL: Muncul 1 Input di Tengah -->
                        <div id="okPanel" style="display: none; text-align: center;">
                            <span style="font-size: 8px; color: #10b981; font-weight: 800; display: block; margin-bottom: 5px;">TOTAL QTY OK</span>
                            <div class="field-input-wrap" style="max-width: 250px; margin: 0 auto; border-color: rgba(16, 185, 129, 0.4);">
                                <input type="number" class="f-input" id="val-qty-ok" value="0">
                            </div>
                        </div>

                        <!-- NG PANEL: Muncul 2 Input Berjejer -->
                        <div id="ngPanel" style="display: none; grid-template-columns: 1fr 1fr; gap: 10px;">
                            <div>
                                <span style="font-size: 8px; color: #ef4444; font-weight: 800; display: block; text-align: center; margin-bottom: 5px;">NG DIMENSI</span>
                                <div class="field-input-wrap" style="border-color: #ef4444;">
                                    <input type="number" class="f-input" id="val-ng-dimensi" value="0">
                                </div>
                            </div>
                            <div>
                                <span style="font-size: 8px; color: #ef4444; font-weight: 800; display: block; text-align: center; margin-bottom: 5px;">NG VISUAL</span>
                                <div class="field-input-wrap" style="border-color: #ef4444;">
                                    <input type="number" class="f-input" id="val-ng-visual" value="0">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Full Width Remark -->
            <div style="grid-column: span 2; margin-top: 10px;">
                <span class="field-label">REMARK / NOTES</span>
                <textarea class="f-textarea" id="val-remark" placeholder="Enter any specific observations or production notes..."></textarea>
            </div>
        </div>
    </div>
</div> <!-- END SMART DIMENSION HUB --></div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/html5-qrcode"></script>
    <script>
        let measurements = @Html.Raw(Json.Serialize(Model.Measurements.GroupBy(m => m.TimeSection).Select(g => new {
            time = g.Key,
            data = new {
                vin = Model.VinCode,
                actPnjg = Model.ActualLength,
                remark = Model.Remark,
                qtySt = Model.Status == "COMPLETED" ? "ok" : "ng",
                qtyOk = Model.QtyOk,
                ngDim = Model.NgDimension,
                ngVis = Model.NgVisual,
                innerDia = g.FirstOrDefault(x => x.PointName == "Inner Diameter")?.R1,
                innerTx = g.FirstOrDefault(x => x.PointName == "Inner Thick X")?.R1,
                innerTy = g.FirstOrDefault(x => x.PointName == "Inner Thick Y")?.R1,
                totalTx = g.FirstOrDefault(x => x.PointName == "Total Thick X")?.R1,
                totalTy = g.FirstOrDefault(x => x.PointName == "Total Thick Y")?.R1,
                spiral = g.FirstOrDefault(x => x.PointName == "Spiral Pitch")?.R1,
                visual = new { 
                    burry = "ok", line = "ok", bubble = "ok", scratch = "ok" 
                } // Visual labels can be expanded as needed
            }
        })));

        if (!measurements || measurements.length === 0) {
            measurements = [ { time: null, data: { vin: "@Model.VinCode", actPnjg: "@Model.ActualLength", remark: "@Model.Remark", qtyOk: "@Model.QtyOk", ngDim: "@Model.NgDimension", ngVis: "@Model.NgVisual" } } ];
        }

        let currentIndex = 0;
        let activeStandards = {}; // Will be populated by loadMaster()

        let html5QrCode;

        window.onload = () => {
            loadMaster();
            renderTimeline();
            loadDataToUI();
            initSmartNext();
        };

        async function openScanner() {
            const res = await Swal.fire({
                title: 'SCAN ITEM LIST CODE',
                html: '<div id="qr-reader" style="width: 100%; border-radius: 12px; overflow: hidden; background: #000;"></div>',
                showCancelButton: true,
                confirmButtonText: 'CANCEL',
                showConfirmButton: false,
                didOpen: () => {
                    html5QrCode = new Html5Qrcode("qr-reader");
                    const qrCodeSuccessCallback = (decodedText, decodedResult) => {
                        document.getElementById('main-item-search').value = decodedText;
                        Swal.close();
                        loadMaster();
                    };
                    const config = { fps: 15, qrbox: { width: 250, height: 250 } };
                    html5QrCode.start({ facingMode: "environment" }, config, qrCodeSuccessCallback)
                        .catch(err => {
                            Swal.showValidationMessage(`Camera failed: ${err}`);
                        });
                },
                willClose: () => {
                    if (html5QrCode) {
                        html5QrCode.stop().catch(e => console.error(e));
                    }
                }
            });
        }

        let isToolConnected = false;
        let toolPrefix = "";
        let linkedDeviceName = "NONE / MANUAL";

        function toggleShift() {
            const el = document.getElementById('h-shift');
            const current = el.innerText;
            let next = "Shift 1";
            if (current === "Shift 1") next = "Shift 2";
            else if (current === "Shift 2") next = "Shift 3";
            el.innerText = next;
            
            // Pulse effect
            el.classList.remove('animate__animated', 'animate__pulse');
            setTimeout(() => el.classList.add('animate__animated', 'animate__pulse'), 10);
            
            Swal.fire({ 
                icon: 'info', 
                title: 'SHIFT UPDATED', 
                text: `Toggled to ${next}`, 
                timer: 1000, 
                showConfirmButton: false, 
                toast: true, 
                position: 'top-end' 
            });
        }

        async function scanForTool() {
            try {
                if (!navigator.bluetooth) {
                    Swal.fire({ icon: 'error', title: 'NOT SUPPORTED', text: 'Browser Anda tidak mendukung Web Bluetooth API.' });
                    return;
                }
                
                const filterVal = document.getElementById('bt-filter-name')?.value.trim();
                const options = filterVal 
                    ? { filters: [{ namePrefix: filterVal }] } 
                    : { acceptAllDevices: true };

                const device = await navigator.bluetooth.requestDevice(options);
                linkedDeviceName = device.name || "UNNAMED DEVICE";
                
                // Update UI in popup if still open
                const nameEl = document.getElementById('val-device-name');
                if(nameEl) nameEl.innerText = linkedDeviceName;
                
                Swal.fire({ icon: 'success', title: 'TOOL ASSIGNED', text: `${linkedDeviceName} Linked`, timer: 1500, showConfirmButton: false, position: 'top-end', toast: true });
            } catch (e) {
                console.error("Discovery Cancelled", e);
            }
        }

        async function showBluetoothSettings() {
            const res = await Swal.fire({
                title: 'BLUETOOTH TOOL CONTROL',
                html: `
                    <div style="text-align: left; background: rgba(15, 23, 42, 0.5); padding: 20px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05);">
                        
                        <!-- NEW SEARCH / FILTER AREA -->
                        <div style="margin-bottom: 20px; background: rgba(30, 41, 59, 0.6); padding: 15px; border-radius: 10px; border-bottom: 3px solid var(--accent-glow);">
                            <label style="color: #64748b; font-size: 9px; font-weight: 900; display: block; margin-bottom: 8px; letter-spacing: 1px;">SEARCH BY NAME PREFIX</label>
                            <div style="display: flex; gap: 10px;">
                                <input type="text" id="bt-filter-name" placeholder="Contoh: SYLVAC / MIT..." 
                                    style="flex: 1; height: 38px; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); border-radius: 4px; color: #fff; padding: 0 12px; font-size: 11px; font-weight: 700;">
                                <button onclick="scanForTool()" style="background: var(--accent-glow); border: none; color: #000; padding: 0 15px; border-radius: 4px; font-size: 10px; font-weight: 800; cursor: pointer; transition: 0.3s;">
                                    <i class="bi bi-search"></i> SCAN
                                </button>
                            </div>
                        </div>

                        <div style="margin-bottom: 25px; padding: 0 10px;">
                            <h6 style="color: #64748b; margin: 0 0 5px 0; font-size: 10px; font-weight: 900;">CURRENT ASSIGNED DEVICE</h6>
                            <div id="device-badge" style="color: #fff; font-size: 15px; font-weight: 800; letter-spacing: 1px;">
                                <i class="bi bi-cpu" style="color: var(--accent-glow);"></i> <span id="val-device-name">${linkedDeviceName}</span>
                            </div>
                        </div>

                        <div style="margin-bottom: 20px; display: flex; align-items: start; gap: 15px; padding-top: 15px; border-top: 1px solid rgba(255,255,255,0.05);">
                            <i class="bi bi-fingerprint" style="color: #38bdf8; font-size: 20px;"></i>
                            <div>
                                <h6 style="color: #fff; margin: 0 0 5px 0;">TOOL FINGERPRINT (ID)</h6>
                                <p style="color: #94a3b8; font-size: 11px; margin: 0;">Sinkronisasi ID prefix dari sinyal alat.</p>
                            </div>
                        </div>
                        
                        <div style="background: rgba(0,0,0,0.2); padding: 15px; border-radius: 8px; margin-bottom: 20px;">
                            <input type="text" id="bt-test-field" placeholder="Tekan DATA pada alat untuk deteksi ID..." 
                                style="width: 100%; height: 45px; background: rgba(30, 41, 59, 0.4); border: 1px dashed rgba(56, 189, 248, 0.3); border-radius: 6px; color: #38bdf8; text-align: center; font-weight: 700; font-size: 16px;">
                            <div id="prefix-badge" style="margin-top:10px; font-size: 10px; color: #10b981; font-weight: 800; ${toolPrefix ? '' : 'display: none;'}">
                                <i class="bi bi-check-circle-fill"></i> DETECTED PREFIX: <span id="val-tool-prefix">${toolPrefix || 'NONE'}</span>
                            </div>
                        </div>

                        <div style="display: flex; align-items: center; justify-content: space-between; padding: 10px 0;">
                            <div>
                                <h6 style="color: #fff; margin: 0;">ACTIVATE SMART LINK</h6>
                                <p style="color: #64748b; font-size: 10px; margin: 0;">Hanya terima data jika ID Cocok.</p>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="bt-active-toggle" ${isToolConnected ? 'checked' : ''} style="width: 50px; height: 25px; cursor: pointer;">
                            </div>
                        </div>
                    </div>
                `,
                showCancelButton: true,
                confirmButtonText: 'SAVE & LOCK TOOL',
                confirmButtonColor: '#10b981',
                cancelButtonText: 'DISCONNECT',
                didOpen: () => {
                    const testInput = document.getElementById('bt-test-field');
                    testInput.onkeyup = (e) => {
                        if (e.key === 'Enter') {
                            const raw = testInput.value.trim();
                            const match = raw.match(/^([A-Za-z0-9]+)[:]/);
                            if (match) {
                                toolPrefix = match[1];
                                document.getElementById('prefix-badge').style.display = 'block';
                                document.getElementById('val-tool-prefix').innerText = toolPrefix;
                            }
                        }
                    }
                },
                preConfirm: () => {
                    return document.getElementById('bt-active-toggle').checked;
                }
            });

            if (res.isConfirmed) {
                isToolConnected = res.value;
                updateBtUI();
            } else if (res.dismiss === Swal.DismissReason.cancel) {
                isToolConnected = false;
                toolPrefix = "";
                linkedDeviceName = "NONE / MANUAL";
                updateBtUI();
            }
        }

        function updateBtUI() {
            const btn = document.getElementById('toolLinkBtn');
            if (isToolConnected) {
                btn.classList.add('active');
                Swal.fire({ icon: 'success', title: 'TOOL SYNCED', text: 'Smart-Link is now ACTIVE', timer: 1200, showConfirmButton: false, position: 'top-end', toast: true });
            } else {
                btn.classList.remove('active');
                Swal.fire({ icon: 'info', title: 'DISCONNECTED', text: 'Switched to Manual Mode', timer: 1200, showConfirmButton: false, position: 'top-end', toast: true });
            }
        }

        // TURBO BACKGROUND SCRUBBER: For stubborn bluetooth tools 
        setInterval(() => {
            document.querySelectorAll('.c-input').forEach(input => {
                const raw = input.value;
                if (!raw || raw === "0" || raw === "0.00") return;
                
                // If it contains raw tool symbols (+ or leading 000)
                if (raw.includes('+') || (raw.startsWith('0') && raw.length > 4)) {
                    // FORCE CLEAN: No matter if focused or not
                    let n = parseFloat(raw.toString().replace(/[+]/g, ''));
                    if (!isNaN(n)) {
                        input.value = n.toFixed(2);
                        const id = input.id.replace('val-', '');
                        validateCard(id);
                    }
                }
            });
        }, 200);

        // DEEP CLEAN ON BLUR: When operator moves to next field
        document.addEventListener('blur', (e) => {
            if (e.target.classList.contains('c-input')) {
                const input = e.target;
                let n = parseFloat(input.value.toString().replace(/[+]/g, ''));
                if (!isNaN(n)) {
                    input.value = n.toFixed(2);
                    validateCard(input.id.replace('val-', ''));
                }
            }
        }, true);

        // IMMEDIATE DELEGATE: For live updates        // --- THE ATOMIC INSTANT SCRUBBER ---
        // Handles text fields and cleans tool output (+006.10 -> 6.10) instantly
        document.addEventListener('input', (e) => {
            if (e.target.classList.contains('c-input')) {
                const input = e.target;
                let val = input.value;
                
                // Nuclear Regex: Strip PLUS and stripping leading zeros before any digits
                let cleaned = val.replace(/[+]/g, '').replace(/^0+(?=\d)/, '');
                
                if (input.value !== cleaned) {
                    input.value = cleaned;
                }
                
                validateCard(input.id.replace('val-', ''));
            }
        });

        // Ensure initialization
        document.addEventListener('DOMContentLoaded', () => {
            initSmartNext();
            loadMaster();
            renderTimeline();
        });

        function cleanValue(raw) {
            if(!raw || raw === "0" || raw === "0.00") return "0.00";
            let cleaned = raw.toString().replace(/[+]/g, '').trim();
            let n = parseFloat(cleaned);
            return isNaN(n) ? cleaned : n.toFixed(2);
        }

        function initSmartNext() {
            // Global Enter key listener for Bluetooth tools and manual input
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') {
                    // ONLY AUTO-NEXT IF TOOL LINK IS ACTIVE
                    if (!isToolConnected) return;

                    const active = document.activeElement;
                    if (active && (active.classList.contains('c-input') || active.classList.contains('f-input'))) {
                        e.preventDefault();
                        
                        // Handle Signal Prefixes (ID Filter)
                        let val = active.value.trim();
                        if (toolPrefix && val.startsWith(toolPrefix)) {
                            // Strip prefix if detected (e.g. "CAL01:12.05" becomes "12.05")
                            val = val.replace(toolPrefix, '').replace(':', '').trim();
                        }
                        
                        // CLEAN VALUE: Remove + and leading zeros
                        // Add a tiny delay to wait for tool to finish typing final digits
                        setTimeout(() => {
                            active.value = cleanValue(active.value);
                            const id = active.id.replace('val-', '');
                            validateCard(id);

                            // List all relevant fields in sequence
                            const sequence = Array.from(document.querySelectorAll('.c-input, .f-input:not([readonly])'));
                            const currentIdx = sequence.indexOf(active);
                            
                            if (currentIdx > -1 && currentIdx < sequence.length - 1) {
                                const next = sequence[currentIdx + 1];
                                next.focus();
                                if (next.tagName === 'INPUT') next.select();
                                const card = next.closest('.dimensi-card');
                                if (card) card.scrollIntoView({ behavior: 'smooth', block: 'center' });
                            } else if (currentIdx === sequence.length - 1) {
                                Swal.fire({ icon: 'success', title: 'SEQUENCE COMPLETED', timer: 1000, showConfirmButton: false, position: 'top-end', toast: true });
                            }
                        }, 20);
                    }
                }
            });
        }

        function renderTimeline() {
            const container = document.getElementById('timelineContainer');
            const btns = container.querySelectorAll('.jam-btn:not(.add-btn)');
            btns.forEach(b => b.remove());

            measurements.forEach((slot, idx) => {
                const btn = document.createElement('button');
                btn.className = `jam-btn ${idx === currentIndex ? 'active' : ''}`;
                btn.innerText = slot.time || `P-${idx + 1}`;
                btn.onclick = () => switchSlot(idx);
                
                if (measurements.length > 1) {
                    const del = document.createElement('div');
                    del.className = 'slot-delete-btn';
                    del.innerHTML = '<i class="bi bi-x-lg"></i>';
                    del.onclick = (e) => { e.stopPropagation(); removeSlot(idx); };
                    btn.appendChild(del);
                }
                container.insertBefore(btn, container.querySelector('.add-btn'));
            });
        }

        async function removeSlot(idx) {
            const result = await Swal.fire({
                title: 'Hapus Sesi?', text: "Data pada sesi ini akan hilang!", icon: 'warning',
                showCancelButton: true, confirmButtonColor: '#ef4444', confirmButtonText: 'Ya, Hapus'
            });
            if (result.isConfirmed) {
                measurements.splice(idx, 1);
                if (currentIndex >= measurements.length) currentIndex = measurements.length - 1;
                loadDataToUI();
                renderTimeline();
            }
        }

        function addNewSlot() {
            saveCurrentData();
            measurements.push({ time: null, data: {} });
            switchSlot(measurements.length - 1);
        }

        function switchSlot(idx) {
            saveCurrentData();
            currentIndex = idx;
            loadDataToUI();
            renderTimeline();
        }

        function setQtyStatus(state) {
            const okBtn = document.getElementById('qty-ok');
            const ngBtn = document.getElementById('qty-ng');
            const okPanel = document.getElementById('okPanel');
            const ngPanel = document.getElementById('ngPanel');

            if(!okBtn || !ngBtn || !okPanel || !ngPanel) return;

            // Reset UI
            okBtn.classList.remove('active-ok');
            ngBtn.classList.remove('active-ng');
            okPanel.style.display = 'none';
            ngPanel.style.display = 'none';

            if(state === 'ok') {
                okBtn.classList.add('active-ok');
                okPanel.style.display = 'block';
            } else if(state === 'ng') {
                ngBtn.classList.add('active-ng');
                ngPanel.style.display = 'grid';
            }
            saveCurrentData();
        }

        function toggleVisual(item, state) {
            const okBtn = document.getElementById(`v-${item}-ok`);
            const ngBtn = document.getElementById(`v-${item}-ng`);
            okBtn.classList.remove('active-ok');
            ngBtn.classList.remove('active-ng');
            if (state === 'ok') okBtn.classList.add('active-ok');
            else ngBtn.classList.add('active-ng');
            renderVisualStatus();
            saveCurrentData();
        }

        function renderVisualStatus() {
            const card = document.getElementById('card-visual');
            const items = ['burry', 'line', 'bubble', 'scratch'];
            let allOK = true, anyNG = false, anySelected = false;

            items.forEach(it => {
                const isOK = document.getElementById(`v-${it}-ok`).classList.contains('active-ok');
                const isNG = document.getElementById(`v-${it}-ng`).classList.contains('active-ng');
                if (isOK || isNG) anySelected = true;
                if (isNG) anyNG = true;
                if (!isOK) allOK = false;
            });

            card.classList.remove('status-ok', 'status-ng');
            if (anySelected) {
                if (anyNG) card.classList.add('status-ng');
                else if (allOK) card.classList.add('status-ok');
            }
        }

        function saveCurrentData() {
            const current = measurements[currentIndex];
            if(!current) return;

            const vStates = {};
            ['burry', 'line', 'bubble', 'scratch'].forEach(it => {
                const ok = document.getElementById(`v-${it}-ok`).classList.contains('active-ok');
                const ng = document.getElementById(`v-${it}-ng`).classList.contains('active-ng');
                vStates[it] = ok ? 'ok' : (ng ? 'ng' : null);
            });

            // Capture QTY Status
            const qtyOkActive = document.getElementById('qty-ok')?.classList.contains('active-ok');
            const qtyNgActive = document.getElementById('qty-ng')?.classList.contains('active-ng');
            const qtySt = qtyOkActive ? 'ok' : (qtyNgActive ? 'ng' : null);

            current.data = {
                innerDia: document.getElementById('val-inner-dia').value,
                innerTx: document.getElementById('val-inner-tx').value,
                innerTy: document.getElementById('val-inner-ty').value,
                totalTx: document.getElementById('val-total-tx').value,
                totalTy: document.getElementById('val-total-ty').value,
                spiral: document.getElementById('val-spiral').value,
                visual: vStates,
                // === PER-SLOT PRODUCTION SUMMARY ===
                vin:     document.getElementById('val-vin-kode')?.value || '',
                actPnjg: document.getElementById('val-act-pnjg')?.value || '',
                qtySt:   qtySt,
                qtyOk:   document.getElementById('val-qty-ok')?.value || '',
                ngDim:   document.getElementById('val-ng-dimensi')?.value || '',
                ngVis:   document.getElementById('val-ng-visual')?.value || '',
                remark:  document.getElementById('val-remark')?.value || ''
            };

            const hasVal = ['innerDia','innerTx','innerTy','totalTx','totalTy','spiral'].some(k => current.data[k] !== '') ||
                           Object.values(vStates).some(v => v !== null);

            if (hasVal && !current.time) {
                const now = new Date();
                current.time = now.getHours().toString().padStart(2,'0') + ':' + now.getMinutes().toString().padStart(2,'0');
            }
        }

        function loadDataToUI() {
            const data = measurements[currentIndex].data || {};
            
            // 1. Per-slot measurements (always override, including empty to clear)
            document.getElementById('val-inner-dia').value = data.innerDia || '';
            document.getElementById('val-inner-tx').value = data.innerTx || '';
            document.getElementById('val-inner-ty').value = data.innerTy || '';
            document.getElementById('val-total-tx').value = data.totalTx || '';
            document.getElementById('val-total-ty').value = data.totalTy || '';
            document.getElementById('val-spiral').value = data.spiral || '';

            // 2. Per-slot Visual Check UI refresh
            const v = data.visual || {};
            ['burry', 'line', 'bubble', 'scratch'].forEach(it => {
                const okBtn = document.getElementById(`v-${it}-ok`);
                const ngBtn = document.getElementById(`v-${it}-ng`);
                okBtn.classList.remove('active-ok');
                ngBtn.classList.remove('active-ng');
                if (v[it] === 'ok') okBtn.classList.add('active-ok');
                else if (v[it] === 'ng') ngBtn.classList.add('active-ng');
            });
            renderVisualStatus();

            // 3. PER-SLOT PRODUCTION SUMMARY (always set — clears old values when switching)
            document.getElementById('val-vin-kode').value    = data.vin     || '';
            document.getElementById('val-act-pnjg').value   = data.actPnjg || '';
            document.getElementById('val-qty-ok').value     = data.qtyOk   || '';
            document.getElementById('val-ng-dimensi').value = data.ngDim   || '';
            document.getElementById('val-ng-visual').value  = data.ngVis   || '';
            document.getElementById('val-remark').value     = data.remark  || '';

            // Restore QTY Status toggle
            if (data.qtySt) setQtyStatus(data.qtySt);
            else {
                // Clear toggle if no status yet
                document.getElementById('qty-ok')?.classList.remove('active-ok');
                document.getElementById('qty-ng')?.classList.remove('active-ng');
                document.getElementById('okPanel').style.display = 'none';
                document.getElementById('ngPanel').style.display = 'none';
            }
            
            // 4. Header / Fixed Inputs (not cleared on slot switch)
            const stdPnjgInput = document.getElementById('disp-std-pnjg');
            if (stdPnjgInput && (stdPnjgInput.value === '-' || stdPnjgInput.value === '')) {
                stdPnjgInput.value = '@Model.StandardLength' || '-';
            }
            const targetInput = document.getElementById('disp-qty-target');
            if (targetInput && (targetInput.value === '0' || targetInput.value === '')) {
                targetInput.value = '@Model.QtyTarget' || '0';
            }

            // 5. Run validation for all cards
            ['inner-dia', 'inner-tx', 'inner-ty', 'total-tx', 'total-ty', 'spiral'].forEach(id => validateCard(id));
        }

        function validateCard(id) {
            const cleanId = id.toLowerCase().replace(/-/g, '');
            const card = document.getElementById(`card-${id}`), std = activeStandards[cleanId], inp = document.getElementById(`val-${id}`);
            if(!card || !inp) return;
            
            // Clean local value for parsing
            const raw = inp.value.toString().replace(/[+]/g, '').trim();
            const val = parseFloat(raw);
            card.classList.remove('status-ok', 'status-ng');
            
            if (!isNaN(val) && std && std.val !== 0) {
                const min = std.val - std.tol;
                const max = std.val + std.tol;
                const isOK = (val >= (min - 0.001) && val <= (max + 0.001)); // Tolerance buffer
                card.classList.add(isOK ? 'status-ok' : 'status-ng');
            }
        }

        async function loadMaster() {
            const code = document.getElementById('main-item-search').value;
            if(!code) return;
            Swal.fire({ title: 'FETCHING MASTER...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            try {
                const res = await fetch(`/Dimensi/GetSpsStandard?hoseType=${encodeURIComponent(code)}`);
                const data = await res.json();
                Swal.close();
                if(data.success) {
                    const m = data.data;
                    
                    // Update Refined Technical HUD Ribbon (v3 IDs)
                    const lineEl = document.getElementById('h-line');
                    const custEl = document.getElementById('h-customer');
                    const hoseEl = document.getElementById('h-hose');
                    const docEl = document.getElementById('h-doc');

                    if(lineEl) lineEl.innerText = "DL01 ENGINE LINE"; 
                    if(custEl) custEl.innerText = m.customer || "GENERAL";
                    if(hoseEl) hoseEl.innerText = m.hoseType || "---";
                    if(docEl) docEl.innerText = m.docNo || "---";

                    // Populate Data Summary
                    const partEl = document.getElementById('disp-part-no');
                    if(partEl) partEl.innerText = m.itemList || "---";
                    
                    const stdPnjgEl = document.getElementById('disp-std-pnjg');
                    if(stdPnjgEl) stdPnjgEl.value = m.dimensi || "-"; 
                    
                    const qtyTargetInput = document.getElementById('disp-qty-target');
                    if(qtyTargetInput && qtyTargetInput.value == "0") qtyTargetInput.value = ""; // Let user type easily

                    document.getElementById('h-row-hose')?.classList.add('animate__animated', 'animate__pulse');
                    
                    // Update Status Indicator
                    const dot = document.getElementById('scan-status-dot');
                    const text = document.getElementById('scan-status-text');
                    if (dot) { dot.style.background = '#10b981'; dot.style.boxShadow = '0 0 10px #10b981'; }
                    if (text) { text.innerText = 'READY TO MEASURE'; text.style.color = '#10b981'; }

                    const getF = (v) => { 
                        if(!v) return 0;
                        const match = v.toString().replace(/,/g, '.').match(/\d+(\.\d+)?/);
                        return match ? parseFloat(match[0]) : 0;
                    };

                    const parseV = (str, def = 0) => {
                        if(!str || str === '---') return def;
                        const m = str.toString().replace(/,/g, '.').match(/\d+(\.\d+)?/g);
                        return m ? parseFloat(m[0]) : def;
                    };
                    const parseT = (str, def = 0.1) => {
                        if(!str || str === '---') return def;
                        const m = str.toString().replace(/,/g, '.').match(/\d+(\.\d+)?/g);
                        if (!m) return def;
                        let val = parseFloat(m[m.length - 1]);
                        return val > 2.0 ? def : val;
                    };

                    const configs = [
                        { id: 'innerdia', v: m.dimensi, t: m.toleranceInner, el: 'inner-dia', dt: 0.1 },
                        { id: 'innertx', v: m.tebalInner, t: m.toleranceOuter, el: 'inner-tx', dt: 0.2 },
                        { id: 'innerty', v: m.tebalInner, t: m.toleranceOuter, el: 'inner-ty', dt: 0.2 },
                        { id: 'totaltx', v: m.tebalTotal, t: m.toleranceOuter, el: 'total-tx', dt: 0.2 },
                        { id: 'totalty', v: m.tebalTotal, t: m.toleranceOuter, el: 'total-ty', dt: 0.2 },
                        { id: 'spiral', v: m.toleranceSpiralPitch, t: m.toleranceSpiralPitch, el: 'spiral', dt: 5 }
                    ];

                    configs.forEach(p => {
                        const target = parseV(p.v);
                        const tol = parseT(p.t, p.dt);
                        activeStandards[p.id] = { val: target, tol: tol };
                        
                        document.getElementById(`std-${p.el}`).innerText = target === 0 ? "NO DATA" : `${target.toFixed(2)} ± ${tol.toFixed(2)}`;
                        document.getElementById(`limit-${p.el}-min`).innerText = target === 0 ? "---" : (target - tol).toFixed(2);
                        document.getElementById(`limit-${p.el}-max`).innerText = target === 0 ? "---" : (target + tol).toFixed(2);
                    });
                    
                    Swal.fire({ icon: 'success', title: 'MASTER LOADED', timer: 800, showConfirmButton: false });
                    
                    // Auto-focus starting point
                    document.getElementById('val-inner-dia')?.focus();
                    loadDataToUI();
                }
            } catch (e) { }
        }

        async function submitEntry() {
            saveCurrentData();
            const btn = document.querySelector('.submit-btn');
            if(btn) btn.disabled = true;

            try {
                const aggregateReadings = [];
                const pointMap = [
                    { name: 'Inner Diameter',       key: 'innerDia', stdKey: 'innerdia'       },
                    { name: 'Inner Thickness (x)',  key: 'innerTx',  stdKey: 'innertx'        },
                    { name: 'Inner Thickness (y)',  key: 'innerTy',  stdKey: 'innerty'        },
                    { name: 'Total Thickness (x)',  key: 'totalTx',  stdKey: 'totaltx'        },
                    { name: 'Total Thickness (y)',  key: 'totalTy',  stdKey: 'totalty'        },
                    { name: 'Spiral Pitch',         key: 'spiral',   stdKey: 'spiral'         }
                ];

                for (const point of pointMap) {
                    const std = activeStandards[point.stdKey];
                    const stdText = (std && std.val > 0)
                        ? (std.val.toFixed(2) + ' ± ' + std.tol.toFixed(2))
                        : '-';

                    const row = {
                        PointName: point.name,
                        TimeSection: measurements[0]?.time || new Date().toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }),
                        Frequency: '30m Sekali',
                        StandardDimension: stdText,
                        Initial: '',
                        Reading1: '', Reading2: '', Reading3: '', Reading4: '', Reading5: '',
                        Status: 'OK'
                    };

                    for (let idx = 0; idx < Math.min(measurements.length, 5); idx++) {
                        const val = measurements[idx].data[point.key];
                        row[`Reading${idx + 1}`] = (val !== null && val !== undefined && val !== '') ? val : '';
                        if (std && std.val > 0 && val !== '' && val !== null && val !== undefined) {
                            const v = parseFloat(val);
                            if (!isNaN(v) && (v < (std.val - std.tol - 0.001) || v > (std.val + std.tol + 0.001))) {
                                row.Status = 'NG';
                            }
                        }
                    }
                    aggregateReadings.push(row);
                }

                // Visual Check per item
                const visualItems = [
                    { name: 'Visual Check - Burry',   key: 'burry'   },
                    { name: 'Visual Check - Line',    key: 'line'    },
                    { name: 'Visual Check - Bubble',  key: 'bubble'  },
                    { name: 'Visual Check - Scratch', key: 'scratch' }
                ];
                for (const vIt of visualItems) {
                    const vRow = {
                        PointName: vIt.name,
                        TimeSection: measurements[0]?.time || '',
                        Frequency: '30m Sekali',
                        StandardDimension: 'NORMAL',
                        Initial: 'OK',
                        Reading1: '', Reading2: '', Reading3: '', Reading4: '', Reading5: '',
                        Status: 'OK'
                    };
                    for (let idx = 0; idx < Math.min(measurements.length, 5); idx++) {
                        const state = measurements[idx].data.visual?.[vIt.key];
                        vRow[`Reading${idx + 1}`] = state === 'ok' ? '1' : (state === 'ng' ? '0' : '');
                        if (state === 'ng') vRow.Status = 'NG';
                    }
                    aggregateReadings.push(vRow);
                }

                // === PER-SLOT PRODUCTION SUMMARY ROWS ===
                const summaryFields = [
                    { name: 'Summary - QTY OK',     key: 'qtyOk'   },
                    { name: 'Summary - NG Dimensi',  key: 'ngDim'   },
                    { name: 'Summary - NG Visual',   key: 'ngVis'   },
                    { name: 'Summary - VIN Kode',    key: 'vin'     },
                    { name: 'Summary - ACT Panjang', key: 'actPnjg' },
                    { name: 'Summary - QTY Status',  key: 'qtySt'  }
                ];
                for (const sf of summaryFields) {
                    const sRow = {
                        PointName: sf.name, TimeSection: measurements[0]?.time || '',
                        Frequency: '30m Sekali', StandardDimension: '-',
                        Initial: '', Reading1: '', Reading2: '', Reading3: '', Reading4: '', Reading5: '',
                        Status: 'OK'
                    };
                    for (let idx = 0; idx < Math.min(measurements.length, 5); idx++) {
                        const val = measurements[idx].data[sf.key];
                        sRow[`Reading${idx + 1}`] = (val !== null && val !== undefined) ? String(val) : '';
                    }
                    aggregateReadings.push(sRow);
                }

                // Aggregate totals across all slots
                const totalQtyOk  = measurements.reduce((s, m) => s + (parseInt(m.data.qtyOk)  || 0), 0);
                const totalNgDim  = measurements.reduce((s, m) => s + (parseInt(m.data.ngDim)  || 0), 0);
                const totalNgVis  = measurements.reduce((s, m) => s + (parseInt(m.data.ngVis)  || 0), 0);
                const lastVin     = [...measurements].reverse().find(m => m.data.vin)?.data.vin     || document.getElementById('val-vin-kode')?.value  || '';
                const lastActPnjg = [...measurements].reverse().find(m => m.data.actPnjg)?.data.actPnjg || document.getElementById('val-act-pnjg')?.value || '';
                const lastRemark  = [...measurements].reverse().find(m => m.data.remark)?.data.remark   || document.getElementById('val-remark')?.value   || '';

                const payload = {
                    ReportId: @Model.Id,
                    DocumentNumber: document.getElementById('h-doc')?.innerText || '---',
                    HoseType: document.getElementById('h-hose')?.innerText || '',
                    CustomerName: document.getElementById('h-customer')?.innerText || '',
                    DimensionDisplay: document.getElementById('disp-part-no')?.innerText || '',
                    VinCode: lastVin,
                    StandardLength: document.getElementById('disp-std-pnjg')?.value || '',
                    ActualLength: lastActPnjg,
                    QtyTarget: parseInt(document.getElementById('disp-qty-target')?.value || '0'),
                    QtyOk: totalQtyOk,
                    NgDimension: totalNgDim,
                    NgVisual: totalNgVis,
                    Remark: lastRemark,
                    ByPass: '',
                    Shift: document.getElementById('h-shift')?.innerText || '',
                    DimensionReadings: aggregateReadings
                };

                const response = await fetch('/Dimensi/SaveData', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const result = await response.json();
                if(result.success) {
                    // Flash success message
                    const status = document.getElementById('save-status');
                    status.style.opacity = '1';
                    
                    // Reset HUD
                    resetHUD();
                    
                    setTimeout(() => { status.style.opacity = '0'; }, 3000);
                } else {
                    Swal.fire('Error', result.message || 'Failed to save', 'error');
                }
            } catch (err) {
                console.error(err);
                Swal.fire('Error', 'Sistem Gagal Menyimpan', 'error');
            } finally {
                if(btn) btn.disabled = false;
            }
        }

        function resetHUD() {
            // 1. Reset Global Data
            measurements = [{ time: null, data: {} }];
            currentIndex = 0;

            // 2. Clear All Card Inputs
            document.querySelectorAll('.c-input').forEach(inp => {
                inp.value = "";
                const id = inp.id.replace('val-', '');
                validateCard(id);
            });

            // 3. Clear Summary Inputs
            ['val-vin-kode', 'val-act-pnjg', 'val-qty-ok', 'val-ng-dimensi', 'val-ng-visual', 'val-remark'].forEach(id => {
                const el = document.getElementById(id);
                if(el) el.value = "";
            });

            // 4. Clear Static Labels
            ['disp-part-no', 'disp-std-pnjg'].forEach(id => {
                const el = document.getElementById(id);
                if(el) el.innerText = "-";
            });
            const qtyTargetEl = document.getElementById('disp-qty-target');
            if(qtyTargetEl) qtyTargetEl.value = "0";

            // 5. Reset Visual Buttons & Status
            document.querySelectorAll('.seg-btn').forEach(btn => btn.classList.remove('active-ok', 'active-ng'));
            document.querySelectorAll('.qty-btn').forEach(btn => btn.classList.remove('active-ok', 'active-ng'));
            document.getElementById('okPanel').style.display = 'none';
            document.getElementById('ngPanel').style.display = 'none';

            // 6. UI Update
            renderTimeline();
            loadDataToUI();

            // 7. Notification (Toast)
            Swal.fire({
                icon: 'success',
                title: 'DASHBOARD RESET',
                text: 'Data tersimpan & Layar dikosongkan.',
                timer: 1500,
                showConfirmButton: false,
                position: 'top-end',
                toast: true
            });
        }

        function finalize() {
            saveCurrentData();
            Swal.fire({
                icon: 'question',
                title: 'SUBMIT REPORT?',
                text: 'Pastikan semua jam sudah terisi dengan benar.',
                showCancelButton: true,
                confirmButtonText: 'YA, SUBMIT',
                confirmButtonColor: '#10b981'
            }).then(r => {
                 if(r.isConfirmed) {
                     Swal.fire({ icon: 'success', title: 'SYNC SUCCESS!', timer: 2000, showConfirmButton: false });
                     setTimeout(() => window.location.href = '/Dimensi/Index', 2000);
                 }
            });
        }
    </script>
}
