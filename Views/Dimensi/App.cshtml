@model VelastoProductionSystem.Models.DimensionReport

@{
    Layout = "_Layout";
    ViewData["Title"] = "Extruder Production Report";
}

@Html.AntiForgeryToken()

@section Styles {
    <style>
        :root {
            --paper-bg: #ffffff;
            --table-border: #2d3748;
            --text-dark: #1a202c;
            --header-gray: #f7fafc;
            --accent-blue: #3182ce;
        }

        body {
            background-color: #e2e8f0;
            color: var(--text-dark);
            font-family: 'Times New Roman', Times, serif; /* Traditional report feel */
            padding: 20px;
        }

        .report-paper {
            background: var(--paper-bg);
            max-width: 1300px;
            margin: 0 auto;
            padding: 20px;
            box-shadow: 0 5px 25px rgba(0,0,0,0.1);
            border: 1px solid #cbd5e0;
        }

        /* Top Section */
        .report-header {
            display: grid;
            grid-template-columns: 200px 1fr 280px;
            align-items: flex-start;
            margin-bottom: 5px;
        }

        .logo-box img { height: 50px; }

        .title-box { text-align: center; }
        .title-box h1 { font-size: 24px; font-weight: bold; margin: 0; text-transform: uppercase; }
        .title-box p { font-size: 16px; font-weight: bold; margin: 0; }

        .sign-table { width: 100%; border-collapse: collapse; font-size: 11px; text-align: center; }
        .sign-table th, .sign-table td { border: 1px solid var(--table-border); }
        .sign-table th { background: var(--header-gray); height: 20px; padding: 2px; }
        .sign-table td { height: 60px; }

        /* Meta Info Section */
        .meta-info {
            display: grid;
            grid-template-columns: 350px 1fr;
            margin-bottom: 10px;
            font-size: 12px;
        }
        .meta-left div { display: grid; grid-template-columns: 80px 1fr; margin-bottom: 2px; }
        .meta-left span, .meta-left input { 
            font-weight: bold; 
            border-bottom: 1px solid #ddd; 
            width: 100%;
            display: inline-block;
        }

        .sub-header-row {
            border: 1px solid var(--table-border);
            background: var(--header-gray);
            padding: 5px 10px;
            font-size: 12px;
            font-weight: bold;
            margin-bottom: 10px;
            display: flex;
            gap: 20px;
        }
        .sub-header-row span { color: var(--accent-blue); }

        /* Main Split Table */
        .main-content-grid {
            display: grid;
            grid-template-columns: 1.5fr 1fr;
            gap: 0;
            border: 1.5px solid var(--table-border);
        }

        .table-section { border-right: 1.5px solid var(--table-border); }
        .qc-table { width: 100%; border-collapse: collapse; font-size: 11px; }
        .qc-table th, .qc-table td { border: 1px solid var(--table-border); padding: 5px 2px; text-align: center; }
        .qc-table th { background: var(--header-gray); }

        .point-name { text-align: left; padding-left: 5px; font-weight: bold; width: 100px; }
        
        .input-cell { 
            width: 100%; border: none; background: transparent; 
            text-align: center; font-size: 11px; font-weight: bold;
            outline: none;
        }
        .input-cell:focus { background: #ebf8ff; }

        /* Right Side: Production Data */
        .data-section { padding: 0; }
        .data-table { width: 100%; border-collapse: collapse; font-size: 11px; }
        .data-table th, .data-table td { border: 1px solid var(--table-border); padding: 8px 5px; text-align: center; }
        .data-table th { background: var(--header-gray); font-size: 10px; }
        
        .data-input { 
            width: 100%; border: none; background: #fff; 
            text-align: center; font-weight: bold; outline: none; 
        }

        /* Footer Notes */
        .report-footer {
            display: grid; grid-template-columns: 1fr 1fr; gap: 0;
            border: 1.5px solid var(--table-border); border-top: none;
            font-size: 10px;
        }
        .note-box { padding: 5px; border-right: 1px solid var(--table-border); }
        .attention-box { padding: 5px; }
        .footer-title { font-weight: bold; text-decoration: underline; margin-bottom: 3px; }

        /* Controls */
        .scanner-pill {
            display: flex; gap: 10px; align-items: center; margin-bottom: 15px;
            background: #fff; padding: 10px; border-radius: 8px; border: 1px solid #cbd5e0;
        }
        .scanner-pill input {
            padding: 8px; border: 1px solid #cbd5e0; border-radius: 4px; width: 250px;
        }
        .btn-blue { background: #3182ce; color: white; border: none; padding: 8px 20px; border-radius: 4px; cursor: pointer; font-weight: bold; }
        .btn-green { background: #38a169; color: white; border: none; padding: 12px 30px; border-radius: 4px; cursor: pointer; font-weight: bold; font-size: 14px; }

        .action-container { margin-top: 20px; text-align: right; }

        @@media print {
            body { background: white; padding: 0; }
            .report-paper { box-shadow: none; border: none; }
            .scanner-pill, .action-container { display: none; }
        }
    </style>
}

<div class="report-paper">
    <!-- Scanner (Digital Only) -->
    <div class="scanner-pill">
        <strong style="color: #3182ce;"><i class="bi bi-qr-code-scan"></i> SCAN BARCODE/QR EXTRUDER:</strong>
        <input type="text" id="spsLookup" placeholder="Contoh: VHFUNC-TA1080-EH" autofocus oninput="checkAutoScan(this)" />
        <button class="btn-blue" onclick="lookupSps()">CARI DATA</button>
        <span id="scanStatus" style="font-size: 11px; margin-left: 10px; color: #a0aec0; display:none;">Searching...</span>
    </div>

    <!-- Paper Header -->
    <header class="report-header">
        <div class="logo-box"><img src="/images/velasto-logo-e1700056160273.png" alt="Logo" /></div>
        <div class="title-box">
            <h1>EXTRUDER PRODUCTION REPORT</h1>
            <p>(DIMENSION)</p>
        </div>
        <div>
            <table class="sign-table">
                <thead><tr><th>PREPARED</th><th>CHECKED</th><th>APPROVED</th></tr></thead>
                <tbody><tr><td></td><td></td><td></td></tr></tbody>
                <tfoot><tr><td style="height:15px">OPR EXTRUDER</td><td style="height:15px">LDR EXTRUDER</td><td style="height:15px">SPV EXTRUDER</td></tr></tfoot>
            </table>
        </div>
    </header>

    <!-- Meta Fields -->
    <div class="meta-info">
        <div class="meta-left">
            <div><strong>No Doc. :</strong> <span id="docNo" class="input-cell" style="text-align:left;">@(Model.DocumentNumber ?? "-")</span></div>
            <div><strong>Revisi :</strong> <span id="revNo" class="input-cell" style="text-align:left;">-</span></div>
            <div><strong>Date :</strong> <span class="input-cell" style="text-align:left;">@Model.ProductionDate.ToString("dd MMMM yyyy")</span></div>
            <div><strong>Shift :</strong> <span class="input-cell" style="text-align:left;">@Model.Shift</span></div>
            <div><strong>Customer:</strong> <span id="customer" class="input-cell" style="text-align:left;">@(Model.CustomerName ?? "-")</span></div>
        </div>
        <div style="text-align:right; font-size: 11px;">
            <p style="margin:0;">Printed: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
        </div>
    </div>

    <div class="sub-header-row">
        Tipe: <span id="hoseTypeDisp">@Model.HoseType</span>
        &nbsp;|&nbsp;
        By Pass: <span id="bypassDisp">@Model.ByPass</span>
    </div>

    <div class="main-content-grid">
        <!-- Measurement Left Section -->
        <div class="table-section">
            <table class="qc-table" id="measurementTable">
                <thead>
                    <tr>
                        <th colspan="4" style="text-align:right; padding-right:10px;">PUKUL / JAM</th>
                        @for(int i=0; i<6; i++) {
                            <th><input type="text" class="input-cell time-header" data-col="@i" placeholder="00:00" /></th>
                        }
                    </tr>
                    <tr>
                        <th style="width:100px">POINT</th>
                        <th style="width:80px">FREKUENSI</th>
                        <th style="width:100px">STD DIMENSI</th>
                        <th style="width:50px">INITIAL</th>
                        @for(int i=1; i<=5; i++) { <th>@i</th> }
                    </tr>
                </thead>
                <tbody id="measurementTableBody">
                    <!-- Dynamic Rows -->
                </tbody>
            </table>
        </div>

        <!-- Production Right Section -->
        <div class="data-section">
            <table class="data-table">
                <thead>
                    <tr>
                        <th rowspan="2">PART NUMBER</th>
                        <th rowspan="2">VIN KODE</th>
                        <th rowspan="2">STD PANJANG</th>
                        <th rowspan="2">ACT PANJANG</th>
                        <th rowspan="2">QTY TARGET</th>
                        <th colspan="3">QTY ACTUAL</th>
                        <th rowspan="2">REMARK</th>
                    </tr>
                    <tr>
                        <th style="font-size:8px">OK</th>
                        <th colspan="2" style="font-size:8px">NG<br/>(Dim/Vis)</th>
                    </tr>
                </thead>
                <tbody>
                    @for(int r=0; r<20; r++) {
                        <tr>
                            <td><input type="text" class="input-cell" id="partNum_@r" /></td>
                            <td><input type="text" class="input-cell" id="vin_@r" /></td>
                            <td><input type="text" class="input-cell" id="stdPanjang_@r" /></td>
                            <td><input type="text" class="input-cell" id="actPanjang_@r" /></td>
                            <td><input type="text" class="input-cell" id="qtyTarget_@r" /></td>
                            <td><input type="text" class="input-cell" id="qtyOk_@r" /></td>
                            <td><input type="text" class="input-cell" id="ngDim_@r" /></td>
                            <td><input type="text" class="input-cell" id="ngVis_@r" /></td>
                            <td><input type="text" class="input-cell" id="remark_@r" /></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="report-footer">
        <div class="note-box">
            <div class="footer-title">Note :</div>
            <textarea id="remarkOverall" style="width:100%; height:40px; border:none; outline:none; font-family:serif; font-size:10px;">@Model.Remark</textarea>
        </div>
        <div class="attention-box">
            <div class="footer-title">Attention :</div>
            <p style="margin:0;">1. Setiap operator wajib menggunakan APD (Safety shoes & Sarung tangan)</p>
            <p style="margin:0;">2. Periksa Dies Sebelum dan sesudah proses</p>
            <p style="margin:0;">3. Pastikan semua parameter sesuai dengan SPS</p>
        </div>
    </div>

    <div class="action-container">
        <button class="btn-green" onclick="saveReport()">SIMPAN & SELESAI</button>
    </div>
</div>

@section Scripts {
    <script>
        let reportId = @Model.Id;
        const mTBody = document.getElementById('measurementTableBody');

        document.addEventListener('DOMContentLoaded', () => {
            initBlank();
            const existingHose = "@Model.HoseType";
            if (existingHose && reportId > 0) lookupSps(existingHose, true);

            // Force focus with delay for better tablet support
            setTimeout(() => {
                const searchInput = document.getElementById('spsLookup');
                if (searchInput) {
                    searchInput.focus();
                    searchInput.select();
                }
            }, 500);

            document.getElementById('spsLookup').addEventListener('keypress', (e) => {
                if(e.key === 'Enter') lookupSps();
            });
        });

        function checkAutoScan(input) {
            // Some physical scanners append a delay or specific length. 
            // For now, we'll let Enter trigger it, but if barcode is long, we can detect it.
        }

        function initBlank() {
            mTBody.innerHTML = `<tr><td colspan="10" style="padding: 40px; text-align:center; color:#a0aec0;">SILAKAN SCAN BARCODE ATAU TIPE UNTUK MEMULAI...</td></tr>`;
        }

        async function lookupSps(typeOverride = null, silent = false) {
            const val = typeOverride || document.getElementById('spsLookup').value;
            if(!val) return;

            document.getElementById('scanStatus').style.display = 'inline';
            try {
                const res = await fetch(`/Dimensi/GetSpsStandard?hoseType=${encodeURIComponent(val)}`);
                const result = await res.json();
                document.getElementById('scanStatus').style.display = 'none';
                if(result.success) {
                    populate(result.data);
                    // Clear search box for next scan
                    if(!typeOverride) document.getElementById('spsLookup').value = "";
                } else if(!silent) alert(result.message);
            } catch(e) { console.error(e); document.getElementById('scanStatus').style.display = 'none'; }
        }

        function populate(data) {
            document.getElementById('hoseTypeDisp').innerText = data.hoseType;
            document.getElementById('bypassDisp').innerText = data.bypass || "-";
            document.getElementById('docNo').innerText = data.docNo || "VI-SOP-PROD";
            document.getElementById('revNo').innerText = data.revNo || "6";
            document.getElementById('customer').innerText = data.customer || "-";

            // Pre-fill part number in all 20 rows of the data table
            for (let i = 0; i < 20; i++) {
                const pn = document.getElementById(`partNum_${i}`);
                if (pn) pn.value = data.excelId || data.hoseType;
            }
            
            const pSet = [
                { n: "Inner Diameter", s: data.dimensi, t: data.toleranceInner, m: true },
                { n: "Inner Thickness (x)", s: data.tebalInner, t: "0.2", m: true },
                { n: "Inner Thickness (y)", s: data.tebalInner, t: "0.2", m: true },
                { n: "Total Thickness (x)", s: data.tebalTotal, t: data.toleranceOuter, m: true },
                { n: "Total Thickness (y)", s: data.tebalTotal, t: data.toleranceOuter, m: true },
                { n: "Spiral Pitch", s: "32 ± 5", t: "-", m: false },
                { n: "Visual Check", s: "No Burry, No line, No Bubble", t: "-", m: false }
            ];

            let html = "";
            pSet.forEach(p => {
                if(p.m) {
                    const sv = parseFloat(p.s) || 0;
                    const tv = parseFloat(p.t) || 0;
                    for(let r=0; r<5; r++) {
                        const sc = sv + (tv - (tv * 0.5 * r));
                        const scs = isNaN(sc) ? p.s : sc.toFixed(2);
                        html += `<tr class="data-row" data-point="${p.n}" data-scale="${scs}">`;
                        if(r === 0) {
                            html += `<td rowspan="5" class="point-name">${p.n}</td>`;
                            html += `<td rowspan="5">30 Menit Sekali</td>`;
                            html += `<td rowspan="5"><strong>${p.s} ± ${p.t}</strong></td>`;
                        }
                        html += `<td>${scs}</td>`;
                        for(let c=0; c<6; c++) html += `<td><input type="text" class="input-cell v-input" data-col="${c}" /></td>`;
                        html += `</tr>`;
                    }
                } else {
                    html += `<tr class="data-row" data-point="${p.n}" data-scale="-">`;
                    html += `<td class="point-name">${p.n}</td><td>30 Menit Sekali</td><td><strong>${p.s}</strong></td><td>-</td>`;
                    for(let c=0; c<6; c++) html += `<td><input type="text" class="input-cell v-input" data-col="${c}" /></td>`;
                    html += `</tr>`;
                }
            });
            mTBody.innerHTML = html;
        }

        async function saveReport() {
            const times = Array.from(document.querySelectorAll('.time-header')).map(i => i.value || "00:00");
            const rs = [];
            document.querySelectorAll('.data-row').forEach(row => {
                row.querySelectorAll('.v-input').forEach(input => {
                    if(input.value) {
                        rs.push({
                            PointName: row.dataset.point,
                            TimeSection: times[input.dataset.col],
                            Initial: row.dataset.scale,
                            Reading1: input.value
                        });
                    }
                });
            });

            // Simplified: we'll just send the first row of Production Data for now 
            // since our model is single-row oriented. To support multiple rows properly
            // we'd need another mapping or child records.
            const payload = {
                ReportId: reportId,
                HoseType: document.getElementById('hoseTypeDisp').innerText,
                DimensionDisplay: document.getElementById('hoseTypeDisp').innerText,
                CustomerName: document.getElementById('customer').innerText,
                ByPass: document.getElementById('bypassDisp').innerText,
                VinCode: document.getElementById('vin_0').value,
                ActualLength: document.getElementById('act_0').value,
                QtyOk: parseInt(document.getElementById('ok_0').value) || 0,
                NgDimension: parseInt(document.getElementById('ngD_0').value) || 0,
                NgVisual: parseInt(document.getElementById('ngV_0').value) || 0,
                Remark: document.getElementById('remarkOverall').value,
                DimensionReadings: rs
            };

            try {
                const res = await fetch('/Dimensi/SubmitReport', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value },
                    body: JSON.stringify(payload)
                });
                const result = await res.json();
                if(result.success) { alert("Berhasil Disimpan!"); window.location.href = "/Dimensi/Index"; }
                else alert("Error: " + result.message);
            } catch(e) { alert("Error koneksi!"); }
        }
    </script>
}
