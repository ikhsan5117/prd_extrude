            <span class="status-badge"></span>
        </div>
    </div> <!-- END CARD GRID -->

    <!-- FLOATING ACTION HUB -->
    <div class="finalize-action-hub">
        <div id="save-status" style="color: #10b981; font-size: 11px; opacity: 0; transition: 0.5s; font-weight: 800; background: rgba(0,0,0,0.4); padding: 5px 15px; border-radius: 50px;">
            <i class="bi bi-check2-circle"></i> AUTO_SAVING_ENABLED
        </div>
        <button type="button" onclick="submitEntry()" class="submit-btn" title="Finalize and Sync Inspection">
            <div class="d-flex flex-column align-items-start">
                <span style="font-size: 8px; opacity: 0.7; letter-spacing: 1px;">PRODUCTION QUALITY HUB</span>
                <span>UPDATE INSPECTION</span>
