                </div>
                <div class="field-box">
                    <span class="field-label">STD PNJG</span>
                    <div class="field-input-wrap"><input type="text" class="f-input" id="disp-std-pnjg" value="@Model.StandardLength"></div>
                </div>
                <div class="field-box">
                    <span class="field-label">QTY TARGET</span>
                    <div class="field-input-wrap"><input type="number" class="f-input" id="disp-qty-target" value="@Model.QtyTarget"></div>
                </div>
