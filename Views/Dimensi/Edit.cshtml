                    <div class="qty-row">
                        <button type="button" class="qty-btn" id="qty-ok" onclick="setQtyStatus('ok')"><i class="bi bi-check-circle-fill"></i> ALL OK</button>
                        <button type="button" class="qty-btn" id="qty-ng" onclick="setQtyStatus('ng')"><i class="bi bi-x-circle-fill"></i> CONTAINS NG</button>
                    </div>
                    
                    <div id="qtyContentArea" style="margin-top: 15px; min-height: 50px;">
                        <!-- OK PANEL: Muncul 1 Input di Tengah -->
                        <div id="okPanel" style="display: none; text-align: center;">
                            <span style="font-size: 8px; color: #10b981; font-weight: 800; display: block; margin-bottom: 5px;">TOTAL QTY OK</span>
                            <div class="field-input-wrap" style="max-width: 250px; margin: 0 auto; border-color: rgba(16, 185, 129, 0.4);">
                                <input type="number" class="f-input" id="val-qty-ok" value="0">
                            </div>
                        </div>

                        <!-- NG PANEL: Muncul 2 Input Berjejer -->
                        <div id="ngPanel" style="display: none; grid-template-columns: 1fr 1fr; gap: 10px;">
                            <div>
                                <span style="font-size: 8px; color: #ef4444; font-weight: 800; display: block; text-align: center; margin-bottom: 5px;">NG DIMENSI</span>
                                <div class="field-input-wrap" style="border-color: #ef4444;">
                                    <input type="number" class="f-input" id="val-ng-dimensi" value="0">
                                </div>
                            </div>
                            <div>
                                <span style="font-size: 8px; color: #ef4444; font-weight: 800; display: block; text-align: center; margin-bottom: 5px;">NG VISUAL</span>
                                <div class="field-input-wrap" style="border-color: #ef4444;">
                                    <input type="number" class="f-input" id="val-ng-visual" value="0">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Full Width Remark -->
            <div style="grid-column: span 2; margin-top: 10px;">
                <span class="field-label">REMARK / NOTES</span>
                <textarea class="f-textarea" id="val-remark" placeholder="Enter any specific observations or production notes..."></textarea>
            </div>
        </div>
    </div>
</div> <!-- END SMART DIMENSION HUB --></div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/html5-qrcode"></script>
    <script>
        // RENDER DATABASE DATAsafely by selecting only needed properties (BREAKS CYCLE)
        const rawMeasurements = @Html.Raw(Json.Serialize(Model.Measurements.Select(m => new {
            pointName = m.PointName,
            r1 = m.R1,
            r2 = m.R2,
            r3 = m.R3,
            r4 = m.R4,
            r5 = m.R5,
            timeSection = m.TimeSection,
            status = m.Status
        })));
        let measurements = [];

        // Build slots with independent times
        const timeHeader = "@(Model.Measurements.FirstOrDefault()?.TimeSection ?? "")";
        const timeParts = timeHeader.split(',').map(s => s.trim());

        for (let i = 1; i <= 5; i++) {
            const hasData = rawMeasurements.some(m => m[`r${i}`] !== null && m[`r${i}`] !== "");
            if (hasData || i === 1) {
                const getVal = (exactName) => {
                    const search = exactName.toLowerCase().trim();
                    const isInner = search.includes('inner');
                    const isTotal = search.includes('total');
                    const isThick = search.includes('thick');
                    
                    let row = rawMeasurements.find(m => (m.pointName || "").trim().toLowerCase() === search);
                    if (!row && isThick) {
                        row = rawMeasurements.find(m => {
                            const dbName = (m.pointName || "").trim().toLowerCase();
                            const dbIsInner = dbName.includes('inner');
                            const dbIsTotal = dbName.includes('total');
                            const hasX = search.includes('(x)');
                            const hasY = search.includes('(y)');
                            if (isInner && !dbIsInner) return false;
                            if (isTotal && !dbIsTotal) return false;
                            if (hasX && !dbName.includes('(x)')) return false;
                            if (hasY && !dbName.includes('(y)')) return false;
                            return dbName.includes('thick');
                        });
                    }
                    if (!row && !isThick) {
                        row = rawMeasurements.find(m => (m.pointName || "").trim().toLowerCase().includes(search.split(' ')[0]));
                    }
                    return row ? row[`r${i}`] : "";
                };
                
                const getVState = (itemName) => {
                    let row = rawMeasurements.find(m => (m.pointName || "").includes(itemName));
                    if (!row) row = rawMeasurements.find(m => (m.pointName || "").trim() === "Visual Check");
                    const val = row ? row[`r${i}`] : null;
                    return (val == 1) ? "ok" : (val == 0 && val !== null ? "ng" : null);
                };

                measurements.push({
                    time: timeParts[i-1] || "",
                    data: {
                        innerDia: getVal("Inner Diameter"),
                        innerTx: getVal("Inner Thickness (x)"),
                        innerTy: getVal("Inner Thickness (y)"),
                        totalTx: getVal("Total Thickness (x)"),
                        totalTy: getVal("Total Thickness (y)"),
                        spiral: getVal("Spiral Pitch"),
                        visual: { 
                            burry: getVState("Burry"), 
                            line: getVState("Line"), 
                            bubble: getVState("Bubble"), 
                            scratch: getVState("Scratch") 
                        }
                    }
                });
            }
        }

        let currentIndex = 0;
        let activeStandards = {};

        window.onload = () => {
            // Priority 1: Render existing data from measurements array
            renderTimeline();
            loadDataToUI();

            // Priority 2: Load standards (Tolerances) from master, 
            // but DO NOT overwrite current Summary values (Header info)
            loadMaster(true); // 'true' means STANDARDS ONLY MODE
            
            initSmartNext();
        };

        async function openScanner() {
            const res = await Swal.fire({
                title: 'SCAN ITEM LIST CODE',
                html: '<div id="qr-reader" style="width: 100%; border-radius: 12px; overflow: hidden; background: #000;"></div>',
                showCancelButton: true,
                confirmButtonText: 'CANCEL',
                showConfirmButton: false,
                didOpen: () => {
                    html5QrCode = new Html5Qrcode("qr-reader");
                    const qrCodeSuccessCallback = (decodedText, decodedResult) => {
                        document.getElementById('main-item-search').value = decodedText;
                        Swal.close();
                        loadMaster();
                    };
                    const config = { fps: 15, qrbox: { width: 250, height: 250 } };
                    html5QrCode.start({ facingMode: "environment" }, config, qrCodeSuccessCallback)
                        .catch(err => {
                            Swal.showValidationMessage(`Camera failed: ${err}`);
                        });
                },
                willClose: () => {
                    if (html5QrCode) {
                        html5QrCode.stop().catch(e => console.error(e));
                    }
                }
            });
        }

        let isToolConnected = false;
        let toolPrefix = "";
        let linkedDeviceName = "NONE / MANUAL";

        function toggleShift() {
            const el = document.getElementById('h-shift');
            const current = el.innerText;
            let next = "Shift 1";
            if (current === "Shift 1") next = "Shift 2";
            else if (current === "Shift 2") next = "Shift 3";
            el.innerText = next;
            
            // Pulse effect
            el.classList.remove('animate__animated', 'animate__pulse');
            setTimeout(() => el.classList.add('animate__animated', 'animate__pulse'), 10);
            
            Swal.fire({ 
                icon: 'info', 
                title: 'SHIFT UPDATED', 
                text: `Toggled to ${next}`, 
                timer: 1000, 
                showConfirmButton: false, 
                toast: true, 
                position: 'top-end' 
            });
        }

        async function scanForTool() {
            try {
                if (!navigator.bluetooth) {
                    Swal.fire({ icon: 'error', title: 'NOT SUPPORTED', text: 'Browser Anda tidak mendukung Web Bluetooth API.' });
                    return;
                }
                
                const filterVal = document.getElementById('bt-filter-name')?.value.trim();
                const options = filterVal 
                    ? { filters: [{ namePrefix: filterVal }] } 
                    : { acceptAllDevices: true };

                const device = await navigator.bluetooth.requestDevice(options);
                linkedDeviceName = device.name || "UNNAMED DEVICE";
                
                // Update UI in popup if still open
                const nameEl = document.getElementById('val-device-name');
                if(nameEl) nameEl.innerText = linkedDeviceName;
                
                Swal.fire({ icon: 'success', title: 'TOOL ASSIGNED', text: `${linkedDeviceName} Linked`, timer: 1500, showConfirmButton: false, position: 'top-end', toast: true });
            } catch (e) {
                console.error("Discovery Cancelled", e);
            }
        }

        async function showBluetoothSettings() {
            const res = await Swal.fire({
                title: 'BLUETOOTH TOOL CONTROL',
                html: `
                    <div style="text-align: left; background: rgba(15, 23, 42, 0.5); padding: 20px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05);">
                        
                        <!-- NEW SEARCH / FILTER AREA -->
                        <div style="margin-bottom: 20px; background: rgba(30, 41, 59, 0.6); padding: 15px; border-radius: 10px; border-bottom: 3px solid var(--accent-glow);">
                            <label style="color: #64748b; font-size: 9px; font-weight: 900; display: block; margin-bottom: 8px; letter-spacing: 1px;">SEARCH BY NAME PREFIX</label>
                            <div style="display: flex; gap: 10px;">
                                <input type="text" id="bt-filter-name" placeholder="Contoh: SYLVAC / MIT..." 
                                    style="flex: 1; height: 38px; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); border-radius: 4px; color: #fff; padding: 0 12px; font-size: 11px; font-weight: 700;">
                                <button onclick="scanForTool()" style="background: var(--accent-glow); border: none; color: #000; padding: 0 15px; border-radius: 4px; font-size: 10px; font-weight: 800; cursor: pointer; transition: 0.3s;">
                                    <i class="bi bi-search"></i> SCAN
                                </button>
                            </div>
                        </div>

                        <div style="margin-bottom: 25px; padding: 0 10px;">
                            <h6 style="color: #64748b; margin: 0 0 5px 0; font-size: 10px; font-weight: 900;">CURRENT ASSIGNED DEVICE</h6>
                            <div id="device-badge" style="color: #fff; font-size: 15px; font-weight: 800; letter-spacing: 1px;">
                                <i class="bi bi-cpu" style="color: var(--accent-glow);"></i> <span id="val-device-name">${linkedDeviceName}</span>
                            </div>
                        </div>

                        <div style="margin-bottom: 20px; display: flex; align-items: start; gap: 15px; padding-top: 15px; border-top: 1px solid rgba(255,255,255,0.05);">
                            <i class="bi bi-fingerprint" style="color: #38bdf8; font-size: 20px;"></i>
                            <div>
                                <h6 style="color: #fff; margin: 0 0 5px 0;">TOOL FINGERPRINT (ID)</h6>
                                <p style="color: #94a3b8; font-size: 11px; margin: 0;">Sinkronisasi ID prefix dari sinyal alat.</p>
                            </div>
                        </div>
                        
                        <div style="background: rgba(0,0,0,0.2); padding: 15px; border-radius: 8px; margin-bottom: 20px;">
                            <input type="text" id="bt-test-field" placeholder="Tekan DATA pada alat untuk deteksi ID..." 
                                style="width: 100%; height: 45px; background: rgba(30, 41, 59, 0.4); border: 1px dashed rgba(56, 189, 248, 0.3); border-radius: 6px; color: #38bdf8; text-align: center; font-weight: 700; font-size: 16px;">
                            <div id="prefix-badge" style="margin-top:10px; font-size: 10px; color: #10b981; font-weight: 800; ${toolPrefix ? '' : 'display: none;'}">
                                <i class="bi bi-check-circle-fill"></i> DETECTED PREFIX: <span id="val-tool-prefix">${toolPrefix || 'NONE'}</span>
                            </div>
                        </div>

                        <div style="display: flex; align-items: center; justify-content: space-between; padding: 10px 0;">
                            <div>
                                <h6 style="color: #fff; margin: 0;">ACTIVATE SMART LINK</h6>
                                <p style="color: #64748b; font-size: 10px; margin: 0;">Hanya terima data jika ID Cocok.</p>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="bt-active-toggle" ${isToolConnected ? 'checked' : ''} style="width: 50px; height: 25px; cursor: pointer;">
                            </div>
                        </div>
                    </div>
                `,
                showCancelButton: true,
                confirmButtonText: 'SAVE & LOCK TOOL',
                confirmButtonColor: '#10b981',
                cancelButtonText: 'DISCONNECT',
                didOpen: () => {
                    const testInput = document.getElementById('bt-test-field');
                    testInput.onkeyup = (e) => {
                        if (e.key === 'Enter') {
                            const raw = testInput.value.trim();
                            const match = raw.match(/^([A-Za-z0-9]+)[:]/);
                            if (match) {
                                toolPrefix = match[1];
                                document.getElementById('prefix-badge').style.display = 'block';
                                document.getElementById('val-tool-prefix').innerText = toolPrefix;
                            }
                        }
                    }
                },
                preConfirm: () => {
                    return document.getElementById('bt-active-toggle').checked;
                }
            });

            if (res.isConfirmed) {
                isToolConnected = res.value;
                updateBtUI();
            } else if (res.dismiss === Swal.DismissReason.cancel) {
                isToolConnected = false;
                toolPrefix = "";
                linkedDeviceName = "NONE / MANUAL";
                updateBtUI();
            }
        }

        function updateBtUI() {
            const btn = document.getElementById('toolLinkBtn');
            if (isToolConnected) {
                btn.classList.add('active');
                Swal.fire({ icon: 'success', title: 'TOOL SYNCED', text: 'Smart-Link is now ACTIVE', timer: 1200, showConfirmButton: false, position: 'top-end', toast: true });
            } else {
                btn.classList.remove('active');
                Swal.fire({ icon: 'info', title: 'DISCONNECTED', text: 'Switched to Manual Mode', timer: 1200, showConfirmButton: false, position: 'top-end', toast: true });
            }
        }

        // TURBO BACKGROUND SCRUBBER: For stubborn bluetooth tools 
        setInterval(() => {
            document.querySelectorAll('.c-input').forEach(input => {
                const raw = input.value;
                if (!raw || raw === "0" || raw === "0.00") return;
                
                // If it contains raw tool symbols (+ or leading 000)
                if (raw.includes('+') || (raw.startsWith('0') && raw.length > 4)) {
                    // FORCE CLEAN: No matter if focused or not
                    let n = parseFloat(raw.toString().replace(/[+]/g, ''));
                    if (!isNaN(n)) {
                        input.value = n.toFixed(2);
                        const id = input.id.replace('val-', '');
                        validateCard(id);
                    }
                }
            });
        }, 200);

        // DEEP CLEAN ON BLUR: When operator moves to next field
        document.addEventListener('blur', (e) => {
            if (e.target.classList.contains('c-input')) {
                const input = e.target;
                let n = parseFloat(input.value.toString().replace(/[+]/g, ''));
                if (!isNaN(n)) {
                    input.value = n.toFixed(2);
                    validateCard(input.id.replace('val-', ''));
                }
            }
        }, true);

        // IMMEDIATE DELEGATE: For live updates        // --- THE ATOMIC INSTANT SCRUBBER ---
        // Handles text fields and cleans tool output (+006.10 -> 6.10) instantly
        document.addEventListener('input', (e) => {
            if (e.target.classList.contains('c-input')) {
                const input = e.target;
                let val = input.value;
                
                // Nuclear Regex: Strip PLUS and stripping leading zeros before any digits
                let cleaned = val.replace(/[+]/g, '').replace(/^0+(?=\d)/, '');
                
                if (input.value !== cleaned) {
                    input.value = cleaned;
                }
                
                validateCard(input.id.replace('val-', ''));
            }
        });

        // Ensure initialization
        document.addEventListener('DOMContentLoaded', () => {
            initSmartNext();
            loadMaster();
            renderTimeline();
        });

        function cleanValue(raw) {
            if(!raw || raw === "0" || raw === "0.00") return "0.00";
            let cleaned = raw.toString().replace(/[+]/g, '').trim();
            let n = parseFloat(cleaned);
            return isNaN(n) ? cleaned : n.toFixed(2);
        }

        function initSmartNext() {
            // Global Enter key listener for Bluetooth tools and manual input
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') {
                    // ONLY AUTO-NEXT IF TOOL LINK IS ACTIVE
                    if (!isToolConnected) return;

                    const active = document.activeElement;
                    if (active && (active.classList.contains('c-input') || active.classList.contains('f-input'))) {
                        e.preventDefault();
                        
                        // Handle Signal Prefixes (ID Filter)
                        let val = active.value.trim();
                        if (toolPrefix && val.startsWith(toolPrefix)) {
                            // Strip prefix if detected (e.g. "CAL01:12.05" becomes "12.05")
                            val = val.replace(toolPrefix, '').replace(':', '').trim();
                        }
                        
                        // CLEAN VALUE: Remove + and leading zeros
                        // Add a tiny delay to wait for tool to finish typing final digits
                        setTimeout(() => {
                            active.value = cleanValue(active.value);
                            const id = active.id.replace('val-', '');
                            validateCard(id);

                            // List all relevant fields in sequence
                            const sequence = Array.from(document.querySelectorAll('.c-input, .f-input:not([readonly])'));
                            const currentIdx = sequence.indexOf(active);
                            
                            if (currentIdx > -1 && currentIdx < sequence.length - 1) {
                                const next = sequence[currentIdx + 1];
                                next.focus();
                                if (next.tagName === 'INPUT') next.select();
                                const card = next.closest('.dimensi-card');
                                if (card) card.scrollIntoView({ behavior: 'smooth', block: 'center' });
                            } else if (currentIdx === sequence.length - 1) {
                                Swal.fire({ icon: 'success', title: 'SEQUENCE COMPLETED', timer: 1000, showConfirmButton: false, position: 'top-end', toast: true });
                            }
                        }, 20);
                    }
                }
            });
        }

        function renderTimeline() {
            const container = document.getElementById('timelineContainer');
            const btns = container.querySelectorAll('.jam-btn:not(.add-btn)');
            btns.forEach(b => b.remove());

            measurements.forEach((slot, idx) => {
                const btn = document.createElement('button');
                btn.className = `jam-btn ${idx === currentIndex ? 'active' : ''}`;
                btn.innerText = slot.time || `P-${idx + 1}`;
                btn.onclick = () => switchSlot(idx);
                
                if (measurements.length > 1) {
                    const del = document.createElement('div');
                    del.className = 'slot-delete-btn';
                    del.innerHTML = '<i class="bi bi-x-lg"></i>';
                    del.onclick = (e) => { e.stopPropagation(); removeSlot(idx); };
                    btn.appendChild(del);
                }
                container.insertBefore(btn, container.querySelector('.add-btn'));
            });
        }

        async function removeSlot(idx) {
            const result = await Swal.fire({
                title: 'Hapus Sesi?', text: "Data pada sesi ini akan hilang!", icon: 'warning',
                showCancelButton: true, confirmButtonColor: '#ef4444', confirmButtonText: 'Ya, Hapus'
            });
            if (result.isConfirmed) {
                measurements.splice(idx, 1);
                if (currentIndex >= measurements.length) currentIndex = measurements.length - 1;
                loadDataToUI();
                renderTimeline();
            }
        }

        function addNewSlot() {
            saveCurrentData();
            // Default new slot to "OK" for visual check as it's the most common case
            measurements.push({ 
                time: null, 
                data: { 
                    visual: { burry: 'ok', line: 'ok', bubble: 'ok', scratch: 'ok' } 
                } 
            });
            switchSlot(measurements.length - 1);
        }

        function switchSlot(idx) {
            saveCurrentData();
            currentIndex = idx;
            loadDataToUI();
            renderTimeline();
        }

        function setQtyStatus(state) {
            const okBtn = document.getElementById('qty-ok');
            const ngBtn = document.getElementById('qty-ng');
            const okPanel = document.getElementById('okPanel');
            const ngPanel = document.getElementById('ngPanel');

            if(!okBtn || !ngBtn || !okPanel || !ngPanel) return;

            // Reset UI
            okBtn.classList.remove('active-ok');
            ngBtn.classList.remove('active-ng');
            okPanel.style.display = 'none';
            ngPanel.style.display = 'none';

            if(state === 'ok') {
                okBtn.classList.add('active-ok');
                okPanel.style.display = 'block';
            } else if(state === 'ng') {
                ngBtn.classList.add('active-ng');
                ngPanel.style.display = 'grid';
            }
            saveCurrentData();
        }

        function toggleVisual(item, state) {
            const okBtn = document.getElementById(`v-${item}-ok`);
            const ngBtn = document.getElementById(`v-${item}-ng`);
            okBtn.classList.remove('active-ok');
            ngBtn.classList.remove('active-ng');
            if (state === 'ok') okBtn.classList.add('active-ok');
            else ngBtn.classList.add('active-ng');
            renderVisualStatus();
            saveCurrentData();
        }

        function renderVisualStatus() {
            const card = document.getElementById('card-visual');
            const items = ['burry', 'line', 'bubble', 'scratch'];
            let allOK = true, anyNG = false, anySelected = false;

            items.forEach(it => {
                const okBtn = document.getElementById(`v-${it}-ok`);
                const ngBtn = document.getElementById(`v-${it}-ng`);
                if(!okBtn || !ngBtn) return;
                
                const isOK = okBtn.classList.contains('active-ok');
                const isNG = ngBtn.classList.contains('active-ng');
                
                if (isOK || isNG) anySelected = true;
                if (isNG) anyNG = true;
                if (!isOK) allOK = false;
                
                // Update icon color and glow
                const icon = okBtn.closest('.visual-item').querySelector('i');
                if(icon) {
                    if (isNG) {
                        icon.style.color = "#ff4d4d";
                        icon.style.filter = "drop-shadow(0 0 8px rgba(255, 77, 77, 0.6))";
                        icon.style.opacity = "1";
                    } else if (isOK) {
                        icon.style.color = "#10b981";
                        icon.style.filter = "drop-shadow(0 0 8px rgba(16, 185, 129, 0.6))";
                        icon.style.opacity = "1";
                    } else {
                        icon.style.color = "var(--accent-glow)";
                        icon.style.filter = "none";
                        icon.style.opacity = "0.5";
                    }
                }
            });

            card.classList.remove('status-ok', 'status-ng');
            if (anySelected) {
                if (anyNG) card.classList.add('status-ng');
                else if (allOK) card.classList.add('status-ok');
            }
        }
        
        function setAllVisualOK() {
            ['burry', 'line', 'bubble', 'scratch'].forEach(it => toggleVisual(it, 'ok'));
        }

        function saveCurrentData() {
            const current = measurements[currentIndex];
            if(!current) return;

            const vStates = {};
            ['burry', 'line', 'bubble', 'scratch'].forEach(it => {
                const ok = document.getElementById(`v-${it}-ok`).classList.contains('active-ok');
                const ng = document.getElementById(`v-${it}-ng`).classList.contains('active-ng');
                vStates[it] = ok ? 'ok' : (ng ? 'ng' : null);
            });

            current.data = {
                innerDia: document.getElementById('val-inner-dia').value,
                innerTx: document.getElementById('val-inner-tx').value,
                innerTy: document.getElementById('val-inner-ty').value,
                totalTx: document.getElementById('val-total-tx').value,
                totalTy: document.getElementById('val-total-ty').value,
                spiral: document.getElementById('val-spiral').value,
                visual: vStates
            };

            const hasVal = Object.values(current.data).some(v => v !== "" && v !== "0" && v !== null && typeof v !== 'object') || 
                           Object.values(vStates).some(v => v !== null);

            if (hasVal && !current.time) {
                const now = new Date();
                current.time = now.getHours().toString().padStart(2, '0') + ':' + now.getMinutes().toString().padStart(2, '0');
            }
        }

        function loadDataToUI() {
            const data = measurements[currentIndex].data || {};
            
            // 1. Per-slot measurements
            const fmt = (v) => (v !== null && v !== "" && !isNaN(v)) ? parseFloat(v).toFixed(2) : (v || '');
            document.getElementById('val-inner-dia').value = fmt(data.innerDia);
            document.getElementById('val-inner-tx').value = fmt(data.innerTx);
            document.getElementById('val-inner-ty').value = fmt(data.innerTy);
            document.getElementById('val-total-tx').value = fmt(data.totalTx);
            document.getElementById('val-total-ty').value = fmt(data.totalTy);
            document.getElementById('val-spiral').value = fmt(data.spiral);

            // 2. Per-slot Visual Check UI refresh
            const v = data.visual || {};
            ['burry', 'line', 'bubble', 'scratch'].forEach(it => {
                const okBtn = document.getElementById(`v-${it}-ok`);
                const ngBtn = document.getElementById(`v-${it}-ng`);
                okBtn.classList.remove('active-ok');
                ngBtn.classList.remove('active-ng');
                if (v[it] === 'ok') okBtn.classList.add('active-ok');
                else if (v[it] === 'ng') ngBtn.classList.add('active-ng');
            });
            renderVisualStatus();

            // 3. GLOBAL PRODUCTION DATA
            document.getElementById('val-vin-kode').value = "@Model.VinCode" || "";
            document.getElementById('val-act-pnjg').value = "@Model.ActualLength" || "";
            document.getElementById('val-qty-ok').value = "@Model.QtyOk" || "0";
            document.getElementById('val-ng-dimensi').value = "@Model.NgDimension" || "0";
            document.getElementById('val-ng-visual').value = "@Model.NgVisual" || "0";
            document.getElementById('val-remark').value = `@Html.Raw(Model.Remark)` || "";
            
            // Auto Set Qty Status Panel
            const hasNG = parseInt("@Model.NgDimension" || "0") > 0 || parseInt("@Model.NgVisual" || "0") > 0;
            setQtyStatus(hasNG ? 'ng' : 'ok');
            
            // 4. Header / Fixed Inputs
            const stdPnjgInput = document.getElementById('disp-std-pnjg');
            if (stdPnjgInput) stdPnjgInput.value = "@Model.StandardLength" || "-";
            
            const targetInput = document.getElementById('disp-qty-target');
            if (targetInput) targetInput.value = "@Model.QtyTarget" || "0";

            // Run validation for all cards
            ['inner-dia', 'inner-tx', 'inner-ty', 'total-tx', 'total-ty', 'spiral'].forEach(id => validateCard(id));
        }

        function validateCard(id) {
            // Map shorthand element IDs to activeStandards keys
            const map = {
                'inner-dia': 'innerdiameter',
                'inner-tx': 'innerthicknessx',
                'inner-ty': 'innerthicknessy',
                'total-tx': 'totalthicknessx',
                'total-ty': 'totalthicknessy',
                'spiral': 'spiralpitch'
            };
            const cleanId = map[id] || id.toLowerCase().replace(/-/g, '');
            const card = document.getElementById(`card-${id}`);
            const std = activeStandards[cleanId];
            const inp = document.getElementById(`val-${id}`);
            
            if(!card || !inp) return;
            
            card.classList.remove('status-ok', 'status-ng');
            
            // Clean local value for parsing
            const rawValue = inp.value.toString().replace(/[+]/g, '').trim();
            if(!rawValue) return; // Silent if empty

            const val = parseFloat(rawValue);
            if (isNaN(val)) return;

            // If we have a valid standard (val > 0), validate against it. 
            // If std.val is 0 (No Data), we leave the card neutral (White).
            if (std && std.val > 0) {
                const min = std.val - std.tol;
                const max = std.val + std.tol;
                // Use a tiny buffer for precision
                const isOK = (val >= (min - 0.005) && val <= (max + 0.005)); 
                card.classList.add(isOK ? 'status-ok' : 'status-ng');
            } else {
                // No standard found or target is 0: remain neutral
                card.classList.remove('status-ok', 'status-ng');
            }
        }

        async function loadMaster(standardsOnly = false) {
            const code = document.getElementById('main-item-search').value;
            if(!code) return;
            
            // Show loading overlay only if NOT in standards-only mode (prevent flicker on load)
            if(!standardsOnly) {
                Swal.fire({ title: 'FETCHING MASTER...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            }

            try {
                const res = await fetch(`/Dimensi/GetSpsStandard?hoseType=${encodeURIComponent(code)}`);
                const data = await res.json();
                
                if(!standardsOnly) Swal.close();

                if(data.success) {
                    const m = data.data;
                    
                    // ONLY UPDATE HEADER IF NOT IN STANDARDS-ONLY MODE
                    if (!standardsOnly) {
                        const lineEl = document.getElementById('h-line');
                        const custEl = document.getElementById('h-customer');
                        const hoseEl = document.getElementById('h-hose');
                        const docEl = document.getElementById('h-doc');

                        if(lineEl) lineEl.innerText = "DL01 ENGINE LINE"; 
                        if(custEl) custEl.innerText = m.customer || "GENERAL";
                        if(hoseEl) hoseEl.innerText = m.hoseType || "---";
                        if(docEl) docEl.innerText = m.docNo || "---";

                        const partEl = document.getElementById('disp-part-no');
                        if(partEl) partEl.innerText = m.itemList || "---";
                        
                        const stdPnjgEl = document.getElementById('disp-std-pnjg');
                        if(stdPnjgEl) stdPnjgEl.value = m.dimensi || "-"; 
                        
                        const qtyTargetInput = document.getElementById('disp-qty-target');
                        if(qtyTargetInput && qtyTargetInput.value == "0") qtyTargetInput.value = "";
                        
                        document.getElementById('h-row-hose')?.classList.add('animate__animated', 'animate__pulse');
                    }
                    
                    // ALWAYS UPDATE STANDARDS (Min/Max Tresholds) - DOES NOT TOUCH ACTUAL INPUTS
                    const parseV = (str, def = 0) => {
                        if(!str || str === '---') return def;
                        const m = str.toString().replace(/,/g, '.').match(/\d+(\.\d+)?/g);
                        return m ? parseFloat(m[0]) : def;
                    };
                    const parseT = (str, def = 0.1) => {
                        if(!str || str === '---') return def;
                        const m = str.toString().replace(/,/g, '.').match(/\d+(\.\d+)?/g);
                        if (!m) return def;
                        let val = parseFloat(m[m.length - 1]);
                        return val > 2.0 ? def : val;
                    };

                    const configs = [
                        { id: 'innerdiameter', v: m.dimensi, t: m.toleranceInner, el: 'inner-dia', dt: 0.1 },
                        { id: 'innerthicknessx', v: m.tebalInner, t: m.toleranceOuter, el: 'inner-tx', dt: 0.2 },
                        { id: 'innerthicknessy', v: m.tebalInner, t: m.toleranceOuter, el: 'inner-ty', dt: 0.2 },
                        { id: 'totalthicknessx', v: m.tebalTotal, t: m.toleranceOuter, el: 'total-tx', dt: 0.2 },
                        { id: 'totalthicknessy', v: m.tebalTotal, t: m.toleranceOuter, el: 'total-ty', dt: 0.2 },
                        { id: 'spiralpitch', v: m.toleranceSpiralPitch, t: m.toleranceSpiralPitch, el: 'spiral', dt: 5 }
                    ];

                    configs.forEach(p => {
                        const target = parseV(p.v);
                        const tol = parseT(p.t, p.dt);
                        activeStandards[p.id] = { id: p.id, val: target, tol: tol };
                        
                        const stdEl = document.getElementById(`std-${p.el}`);
                        if (stdEl) {
                            stdEl.innerText = target === 0 ? "NO DATA" : `${target.toFixed(2)} ± ${tol.toFixed(2)}`;
                        }
                        
                        const minEl = document.getElementById(`limit-${p.el}-min`);
                        const maxEl = document.getElementById(`limit-${p.el}-max`);
                        if (minEl) minEl.innerText = target === 0 ? "---" : (target - tol).toFixed(2);
                        if (maxEl) maxEl.innerText = target === 0 ? "---" : (target + tol).toFixed(2);
                    });
                    
                    if(!standardsOnly) Swal.fire({ icon: 'success', title: 'MASTER LOADED', timer: 800, showConfirmButton: false });
                    
                    // RE-VALIDATE COLORS ONLY (NOT VALUES)
                    ['inner-dia', 'inner-tx', 'inner-ty', 'total-tx', 'total-ty', 'spiral'].forEach(id => validateCard(id));
                }
            } catch (e) { }
        }
        async function submitEntry() {
            saveCurrentData();
            const btn = document.querySelector('.submit-btn');
            if(btn) btn.disabled = true;

            try {
                const aggregateReadings = [];

                // === MEASUREMENT POINTS ===
                const pointMap = [
                    { name: 'Inner Diameter',       key: 'innerDia', stdKey: 'innerdiameter'  },
                    { name: 'Inner Thickness (x)',  key: 'innerTx',  stdKey: 'innerthicknessx'},
                    { name: 'Inner Thickness (y)',  key: 'innerTy',  stdKey: 'innerthicknessy'},
                    { name: 'Total Thickness (x)',  key: 'totalTx',  stdKey: 'totalthicknessx'},
                    { name: 'Total Thickness (y)',  key: 'totalTy',  stdKey: 'totalthicknessy'},
                    { name: 'Spiral Pitch',         key: 'spiral',   stdKey: 'spiralpitch'    }
                ];

                for (const point of pointMap) {
                    const std = activeStandards[point.stdKey];
                    const stdText = (std && std.val > 0)
                        ? (std.val.toFixed(2) + ' \u00b1 ' + std.tol.toFixed(2))
                        : '-';

                    const allTimes = measurements.map(m => m.time || '').join(',');
                    const row = {
                        PointName: point.name,
                        TimeSection: allTimes,
                        Frequency: '30m Sekali',
                        StandardDimension: stdText,
                        Initial: '',
                        Reading1: '', Reading2: '', Reading3: '', Reading4: '', Reading5: '',
                        Status: 'OK'
                    };

                    for (let idx = 0; idx < Math.min(measurements.length, 5); idx++) {
                        const val = measurements[idx].data[point.key];
                        row[`Reading${idx + 1}`] = (val !== null && val !== undefined && val !== '') ? val : '';
                        if (std && std.val > 0 && val !== '' && val !== null && val !== undefined) {
                            const v = parseFloat(val);
                            if (!isNaN(v) && (v < (std.val - std.tol - 0.001) || v > (std.val + std.tol + 0.001))) {
                                row.Status = 'NG';
                            }
                        }
                    }
                    aggregateReadings.push(row);
                }

                // === VISUAL CHECK POINTS (per item) ===
                const visualItems = [
                    { name: 'Visual Check - Burry',   key: 'burry'   },
                    { name: 'Visual Check - Line',    key: 'line'    },
                    { name: 'Visual Check - Bubble',  key: 'bubble'  },
                    { name: 'Visual Check - Scratch', key: 'scratch' }
                ];

                for (const vIt of visualItems) {
                    const allTimes = measurements.map(m => m.time || '').join(',');
                    const vRow = {
                        PointName: vIt.name,
                        TimeSection: allTimes,
                        Frequency: '30m Sekali',
                        StandardDimension: 'NORMAL',
                        Initial: 'OK',
                        Reading1: '', Reading2: '', Reading3: '', Reading4: '', Reading5: '',
                        Status: 'OK'
                    };
                    for (let idx = 0; idx < Math.min(measurements.length, 5); idx++) {
                        const state = measurements[idx].data.visual?.[vIt.key];
                        vRow[`Reading${idx + 1}`] = state === 'ok' ? '1' : (state === 'ng' ? '0' : '');
                        if (state === 'ng') vRow.Status = 'NG';
                    }
                    aggregateReadings.push(vRow);
                }

                // === PAYLOAD ===
                const safeInt = (id) => {
                    const v = parseInt(document.getElementById(id)?.value || '0');
                    return isNaN(v) ? 0 : v;
                };

                const payload = {
                    reportId: parseInt("@Model.Id") || 0,
                    documentNumber: document.getElementById('h-doc')?.innerText || '---',
                    hoseType: document.getElementById('h-hose')?.innerText || '',
                    customerName: document.getElementById('h-customer')?.innerText || '',
                    dimensionDisplay: document.getElementById('disp-part-no')?.innerText || '',
                    vinCode: document.getElementById('val-vin-kode')?.value || '',
                    standardLength: document.getElementById('disp-std-pnjg')?.value || '',
                    actualLength: document.getElementById('val-act-pnjg')?.value || '',
                    qtyTarget: safeInt('disp-qty-target'),
                    qtyOk: safeInt('val-qty-ok'),
                    ngDimension: safeInt('val-ng-dimensi'),
                    ngVisual: safeInt('val-ng-visual'),
                    remark: document.getElementById('val-remark')?.value || '',
                    byPass: '',
                    shift: document.getElementById('h-shift')?.innerText || '',
                    dimensionReadings: aggregateReadings.map(r => ({
                        pointName: String(r.PointName || ''),
                        timeSection: String(r.TimeSection || ''),
                        frequency: String(r.Frequency || ''),
                        standardDimension: String(r.StandardDimension || ''),
                        initial: String(r.Initial || ''),
                        reading1: String(r.Reading1 ?? ''),
                        reading2: String(r.Reading2 ?? ''),
                        reading3: String(r.Reading3 ?? ''),
                        reading4: String(r.Reading4 ?? ''),
                        reading5: String(r.Reading5 ?? ''),
                        status: String(r.Status || 'OK')
                    }))
                };

                const response = await fetch('/Dimensi/SaveData', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const result = await response.json();
                if (result.success) {
                    Swal.fire({ icon: 'success', title: 'UPDATE SUCCESSFUL', text: 'Data berhasil diperbarui.', timer: 1500, showConfirmButton: false });
                    setTimeout(() => window.location.href = '/Dimensi/History', 1500);
                } else {
                    Swal.fire('Error', result.message || 'Gagal menyimpan', 'error');
                }
            } catch (err) {
                console.error(err);
                Swal.fire('Error', 'Sistem Gagal Menyimpan: ' + err.message, 'error');
            } finally {
                if(btn) btn.disabled = false;
            }
        }

        function finalize() {
            saveCurrentData();
            Swal.fire({
                icon: 'question',
                title: 'SUBMIT CHANGES?',
                text: 'Setelah disubmit, perubahan akan muncul di laporan.',
                showCancelButton: true,
                confirmButtonText: 'YA, UPDATE',
                confirmButtonColor: '#10b981'
            }).then(r => {
                 if(r.isConfirmed) {
                     submitEntry();
                 }
            });
        }
    </script>
}
