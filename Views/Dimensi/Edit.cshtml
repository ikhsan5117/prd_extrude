@model VelastoProductionSystem.Models.DimensionReport

@{
    Layout = "_Layout";
    ViewData["Title"] = "Dimension Input Hub";
}

@section Styles {
    <style>
        :root {
            --bg-deep: #0b1120;
            --glass-bg: rgba(15, 23, 42, 0.7);
            --glass-border: rgba(56, 189, 248, 0.15);
            --accent-glow: #38bdf8;
            --accent-success: #10b981;
            --accent-warning: #fbbf24;
            --accent-danger: #ef4444;
            --text-white: #f8fafc;
            --text-dim: #94a3b8;
        }

        body {
            background: radial-gradient(circle at top right, #1e293b, #0b1120);
            color: var(--text-white);
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            min-height: 100vh;
            padding: 0; margin: 0;
            letter-spacing: -0.01em;
        }

        /* --- Search & Control Bar --- */
        .search-action-bar {
            display: flex; align-items: center; justify-content: center; gap: 15px;
            max-width: 1200px; margin: 0 auto 25px auto; width: 100%; padding: 0 15px;
        }
        .search-input-group {
            flex: 1; max-width: 800px; display: flex; align-items: stretch; background: rgba(30, 41, 59, 0.4);
            border: 1px solid var(--glass-border); border-left: 5px solid var(--accent-glow);
            border-radius: 4px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            transition: all 0.3s; height: 48px;
        }
        .search-input-group:focus-within { border-color: var(--accent-glow); box-shadow: 0 0 20px rgba(56, 189, 248, 0.2); }
        
        .cam-btn {
            width: 55px; background: rgba(255,255,255,0.03); color: var(--accent-glow); border: none;
            display: flex; align-items: center; justify-content: center; font-size: 18px; cursor: pointer;
            transition: 0.3s; border-right: 1px solid rgba(255,255,255,0.05);
        }
        .cam-btn:hover { background: rgba(56, 189, 248, 0.1); color: #fff; }

        .search-input-group input {
            flex: 1; background: transparent; border: none; outline: none; padding: 0 20px;
            color: #fff; font-size: 14px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
        }
        
        .search-trigger-btn {
            width: 55px; background: var(--accent-glow); color: #000; border: none;
            display: flex; align-items: center; justify-content: center; font-size: 18px; cursor: pointer;
            transition: 0.3s;
        }
        .search-trigger-btn:hover { background: #fff; box-shadow: 0 0 15px var(--accent-glow); }
        
        .bt-icon-btn {
            width: 48px; height: 48px; border-radius: 50%; background: rgba(15, 23, 42, 0.8);
            border: 1px solid rgba(255, 255, 255, 0.05); display: flex; align-items: center; justify-content: center;
            font-size: 20px; color: #94a3b8; cursor: pointer; transition: all 0.4s; position: relative;
        }
        .bt-icon-btn.active {
            color: var(--accent-success); border-color: var(--accent-success);
            box-shadow: 0 0 20px rgba(16, 185, 129, 0.2);
        }
        .bt-icon-btn.active::after {
            content: ''; position: absolute; top: -2px; right: -2px; width: 10px; height: 10px;
            background: var(--accent-success); border-radius: 50%; border: 2px solid var(--bg-deep);
            box-shadow: 0 0 10px var(--accent-success); animation: pulse 1s infinite;
        }
        .tool-link-btn.active {
            border-color: var(--accent-success);
            box-shadow: 0 0 20px rgba(16, 185, 129, 0.1);
        }
        .tool-link-btn.active .t-dot { background: var(--accent-success); box-shadow: 0 0 10px var(--accent-success); animation: pulse 1s infinite; }
        .tool-link-btn.active .t-text { color: var(--accent-success); }

        .t-dot { width: 8px; height: 8px; border-radius: 50%; background: #94a3b8; transition: 0.3s; }
        .t-text { font-size: 10px; color: #94a3b8; font-weight: 900; letter-spacing: 1.5px; text-transform: uppercase; transition: 0.3s; }
        .t-icon { font-size: 14px; color: #94a3b8; }
        .tool-link-btn.active .t-icon { color: var(--accent-success); }

        /* --- New Modular Dashboard Widgets (Non-Table) --- */
        .tech-header-ribbon {
            display: grid; grid-template-columns: repeat(4, 1fr);
            gap: 15px; max-width: 1400px; margin: 0 auto 30px auto; width: 100%;
            padding: 0 15px;
        }
        .header-cluster {
            background: rgba(30, 41, 59, 0.4); border: 1px solid var(--glass-border);
            border-left: 4px solid var(--accent-glow); border-radius: 8px;
            padding: 15px 20px; display: flex; flex-direction: column; justify-content: center;
            box-shadow: 0 10px 25px rgba(0,0,0,0.3); backdrop-filter: blur(10px);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .header-cluster:hover {
            transform: translateY(-3px); border-color: rgba(56, 189, 248, 0.4);
            box-shadow: 0 15px 35px rgba(56, 189, 248, 0.15);
            background: rgba(30, 41, 59, 0.6);
        }
        
        /* --- Responsive Cockpit (Tablet Mode) --- */
        @@media (max-width: 1200px) {
            .tech-header-ribbon { grid-template-columns: repeat(2, 1fr); gap: 12px; }
            .header-cluster { min-height: 80px; padding: 15px; }
        }
        
        @@media (max-width: 900px) {
            .search-input-group { width: 100%; max-width: none; }
        }

        @@media (max-width: 600px) {
            .tech-header-ribbon { grid-template-columns: 1fr; }
        }
        .header-cluster:last-child { border-right: none; }
        .m-lbl { font-size: 8px; color: var(--text-dim); font-weight: 800; letter-spacing: 1px; text-transform: uppercase; display: flex; align-items: center; gap: 6px; opacity: 0.6; white-space: nowrap; }
        .m-row { display: flex; align-items: center; gap: 6px; white-space: nowrap; margin-top: 4px; overflow: hidden; }
        .m-val { font-size: 11px; color: #fff; font-weight: 900; letter-spacing: 0.2px; line-height: 1; }
        .m-accent { color: var(--accent-glow); text-shadow: 0 0 10px rgba(56, 189, 248, 0.1); }
        .m-sub { font-size: 9px; color: rgba(255,255,255,0.25); font-weight: 800; text-transform: uppercase; margin-left: 4px; }
        .m-icon { font-size: 10px; color: var(--accent-glow); opacity: 0.5; }
        .m-divider { width: 1px; height: 10px; background: rgba(255,255,255,0.08); margin: 0 2px; }

        .jam-nav { display: flex; gap: 15px; margin-bottom: 30px; justify-content: center; }
        .jam-btn {
            background: rgba(30, 41, 59, 0.4); border: 1px solid rgba(56, 189, 248, 0.15);
            color: var(--text-dim); padding: 12px 28px; border-radius: 4px;
            font-size: 13px; font-weight: 800; cursor: pointer; transition: all 0.3s;
            position: relative; overflow: visible;
        }
        .jam-btn.active {
            background: var(--accent-glow); color: #000; border-color: transparent;
            box-shadow: 0 0 20px rgba(56, 189, 248, 0.2); transform: scale(1.05);
        }
        .add-btn { background: rgba(56, 189, 248, 0.05); border-style: dashed; }
        .slot-delete-btn {
            position: absolute; top: -10px; right: -10px; width: 20px; height: 20px;
            border-radius: 50%; background: var(--accent-danger); border: 2px solid var(--bg-deep);
            display: flex; align-items: center; justify-content: center; font-size: 10px;
            color: #fff; opacity: 0; transition: 0.3s; z-index: 5;
        }
        .jam-btn:hover .slot-delete-btn { opacity: 1; }

        /* --- Card Styles --- */
        .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 25px; }
        .dimensi-card {
            background: rgba(15, 23, 42, 0.4); border: 1px solid rgba(56, 189, 248, 0.1);
            border-radius: 12px; padding: 25px; transition: all 0.4s;
            backdrop-filter: blur(15px); position: relative; overflow: hidden;
        }
        .card-header-flex { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
        .card-point { font-weight: 800; font-size: 14px; color: #fff; letter-spacing: 2px; }
        .card-icon { font-size: 20px; color: var(--accent-glow); opacity: 0.5; }
        
        .std-container { display: flex; flex-direction: column; align-items: center; margin-bottom: 20px; }
        .std-label { font-size: 9px; color: var(--text-dim); font-weight: 900; letter-spacing: 1.5px; opacity: 0.6; }
        .std-value { font-size: 16px; color: var(--accent-glow); font-weight: 900; }

        .limit-row { display: flex; gap: 12px; margin-bottom: 20px; }
        .limit-pill { 
            flex: 1; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05);
            padding: 8px 15px; border-radius: 50px; display: flex; align-items: center; justify-content: space-between;
        }
        .limit-label { font-size: 9px; color: var(--text-dim); font-weight: 900; }
        .limit-val { font-size: 14px; font-weight: 900; }
        .limit-val.min { color: var(--accent-success); }
        .limit-val.max { color: var(--accent-warning); }

        .input-group-custom { display: flex; flex-direction: column; gap: 10px; }
        .input-group-custom label { font-size: 10px; color: var(--text-dim); font-weight: 900; text-align: center; }
        .c-input {
            background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px;
            color: #fff; padding: 15px; font-size: 28px; font-weight: 900; text-align: center; outline: none;
            box-shadow: inset 0 2px 10px rgba(0,0,0,0.5); width: 100%; transition: all 0.3s;
        }
        .status-badge { position: absolute; bottom: 0; left: 0; width: 100%; height: 4px; background: transparent; transition: 0.4s; }
        .status-ok .status-badge { background: var(--accent-success); box-shadow: 0 0 20px var(--accent-success); }
        .status-ok .c-input { 
            color: #10b981 !important; 
            border-color: rgba(16, 185, 129, 0.5) !important;
            text-shadow: 0 0 10px rgba(16, 185, 129, 0.4); 
            box-shadow: inset 0 0 15px rgba(16, 185, 129, 0.1);
        }
        .status-ng .status-badge { background: #ff4d4d; box-shadow: 0 0 25px #ff4d4d; }
        .status-ng .c-input { 
            color: #ff4d4d !important; 
            background: rgba(255, 77, 77, 0.15) !important;
            border-color: rgba(255, 77, 77, 0.6) !important;
            text-shadow: 0 0 15px rgba(255, 77, 77, 0.5); 
            box-shadow: inset 0 0 25px rgba(255, 77, 77, 0.2), 0 0 15px rgba(255, 77, 77, 0.2);
            animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both;
        }
        
        @@keyframes shake {
          10%, 90% { transform: translate3d(-1px, 0, 0); }
          20%, 80% { transform: translate3d(2px, 0, 0); }
          30%, 50%, 70% { transform: translate3d(-4px, 0, 0); }
          40%, 60% { transform: translate3d(4px, 0, 0); }
        }

        /* --- Visual Check & Summary --- */
        .visual-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .visual-item { 
            background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);
            padding: 12px; border-radius: 12px; text-align: center; display: flex; flex-direction: column; gap: 8px;
        }
        .visual-label { font-size: 9px; color: var(--text-dim); font-weight: 900; letter-spacing: 1px; }
        .segmented-control { display: flex; background: rgba(0,0,0,0.3); padding: 4px; border-radius: 8px; gap: 4px; }
        .seg-btn {
            flex: 1; border: none; background: transparent; color: var(--text-dim);
            font-size: 10px; font-weight: 900; padding: 8px 0; border-radius: 6px; cursor: pointer; transition: 0.2s;
        }
        .seg-btn.active-ok { background: var(--accent-success); color: #000; box-shadow: 0 0 15px rgba(16, 185, 129, 0.3); }
        .seg-btn.active-ng { background: var(--accent-danger); color: #fff; box-shadow: 0 0 15px rgba(239, 68, 68, 0.3); }
        .visual-item i { font-size: 20px; transition: 0.3s; }
        .visual-item:hover i { transform: scale(1.2); filter: drop-shadow(0 0 10px var(--accent-glow)); }
        .v-quick-ok {
            background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.3);
            color: var(--accent-success); padding: 4px 12px; border-radius: 50px; font-size: 9px;
            font-weight: 900; cursor: pointer; transition: 0.3s;
        }
        .v-quick-ok:hover { background: var(--accent-success); color: #000; }

        .section-title {
            font-size: 11px; font-weight: 900; color: var(--accent-glow);
            letter-spacing: 2px; display: flex; align-items: center; gap: 10px;
            margin: 40px 0 20px 0; padding-left: 15px; border-left: 4px solid var(--accent-glow);
            text-transform: uppercase;
        }
        .prod-data-container {
            background: rgba(15, 23, 42, 0.4); border: 1px solid rgba(56, 189, 248, 0.1);
            border-radius: 12px; padding: 25px; backdrop-filter: blur(15px);
        }
        .prod-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; }
        .field-column { display: flex; flex-direction: column; gap: 20px; }
        .field-box { display: flex; flex-direction: column; gap: 8px; }
        .field-label { font-size: 9px; color: var(--text-dim); font-weight: 900; letter-spacing: 1px; text-transform: uppercase; }
        .field-input-wrap {
            background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08);
            border-radius: 8px; padding: 12px 15px;
        }
        .f-input { background: transparent; border: none; color: #fff; width: 100%; font-size: 14px; font-weight: 700; outline: none; }
        .qty-row { display: flex; gap: 10px; }
        .jam-nav { 
            display: flex; gap: 10px; margin-bottom: 25px; 
            overflow-x: auto; padding: 10px 5px; 
            scrollbar-width: thin; scrollbar-color: var(--accent-glow) transparent;
        }
        .jam-nav::-webkit-scrollbar { height: 4px; }
        .jam-nav::-webkit-scrollbar-thumb { background: var(--accent-glow); border-radius: 10px; }
        .jam-btn { 
            flex: 0 0 auto; 
            min-width: 80px; height: 50px; 
            background: rgba(30, 41, 59, 0.4); 
            border: 1px solid var(--glass-border); 
            border-radius: 8px; color: var(--text-dim); 
            font-weight: 800; font-size: 14px; 
            cursor: pointer; transition: all 0.3s;
            display: flex; align-items: center; justify-content: center; position: relative;
        }

        .qty-btn {
            flex: 1; height: 50px; border-radius: 12px; border: 1px solid var(--glass-border);
            background: rgba(30, 41, 59, 0.3); color: var(--text-dim);
            font-size: 11px; font-weight: 900; letter-spacing: 1px; transition: 0.3s;
            display: flex; align-items: center; justify-content: center; gap: 10px; cursor: pointer;
        }
        .qty-btn:hover { background: rgba(255,255,255,0.05); color: #fff; }
        .qty-btn.active-ok { 
            background: rgba(16, 185, 129, 0.15); border-color: var(--accent-success); 
            color: var(--accent-success); box-shadow: 0 0 20px rgba(16, 185, 129, 0.2); 
        }
        .qty-btn.active-ng { 
            background: rgba(239, 68, 68, 0.15); border-color: var(--accent-danger); 
            color: var(--accent-danger); box-shadow: 0 0 20px rgba(239, 68, 68, 0.2); 
        }

        .finalize-action-hub {
            position: fixed; bottom: 30px; right: 30px; z-index: 1000;
            display: flex; flex-direction: column; align-items: flex-end; gap: 10px;
        }
        .submit-btn {
            background: linear-gradient(135deg, #10b981, #059669);
            color: #000; padding: 20px 40px; border: none; border-radius: 50px;
            font-weight: 1000; font-size: 14px; cursor: pointer;
            box-shadow: 0 0 50px rgba(16, 185, 129, 0.3);
            display: flex; align-items: center; gap: 15px;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            text-transform: uppercase; letter-spacing: 2px;
            border-top: 2px solid rgba(255,255,255,0.3);
        }
        .submit-btn:hover {
            transform: translateY(-8px) scale(1.05);
            box-shadow: 0 20px 60px rgba(16, 185, 129, 0.5);
            background: #fff; color: #10b981;
        }
        .submit-btn i { font-size: 24px; }
        .submit-btn:active { transform: scale(0.95); }

        .f-textarea {
            background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px;
            color: #fff; padding: 15px; width: 100%; font-size: 13px; outline: none; height: 80px; resize: none;
        }

        @@keyframes pulse { 0%, 100% { opacity: 0.5; } 50% { opacity: 1; } }
        .tracking-widest { letter-spacing: 0.2em; }
    </style>
}



<!-- NEW REPORT HEADER (AS PER IMAGE) -->
<div class="app-container pt-3">
    <!-- Main Header -->
    <div class="text-center mb-3 animate__animated animate__fadeInDown">
        <h2 class="display-6 fw-bold tracking-widest text-uppercase" style="letter-spacing: 6px;">EXTRUDER PRODUCTION REPORT</h2>
        <div class="text-primary fw-bold" style="font-size: 13px; letter-spacing: 4px;">( DIMENSION )</div>
    </div>

    <!-- Item List Scanner Action Bar -->
    <div class="search-action-bar animate__animated animate__fadeInDown">
        <!-- 3-Part Smart Search Bar -->
        <div class="search-input-group">
            <button class="cam-btn" title="Open Camera Scanner" onclick="openScanner()">
                <i class="bi bi-qr-code-scan"></i>
            </button>
            <input type="text" id="main-item-search" placeholder="MANUAL INPUT / SCAN ITEM LIST..." autocomplete="off" onkeypress="if(event.key === 'Enter') loadMaster()" value="@(Model.DimensionDisplay ?? Model.HoseType)">
            <button class="search-trigger-btn" id="btn-master-search" onclick="loadMaster()" title="Trigger Master Search">
                <i class="bi bi-search"></i>
            </button>
        </div>
        
        <!-- History Shortcut -->
        <a href="/Dimensi/History" class="bt-icon-btn" style="text-decoration: none;" title="View Inspection History">
            <i class="bi bi-clock-history"></i>
        </a>
        
        <!-- Compact Bluetooth Tool Control -->
        <div class="bt-icon-btn" id="toolLinkBtn" onclick="showBluetoothSettings()" title="Bluetooth Tool Settings">
            <i class="bi bi-bluetooth"></i>
        </div>
    </div>

    <!-- Unified Technical HUD Dashboard -->
    <div class="tech-header-ribbon animate__animated animate__fadeIn">
        <!-- CLUSTER 1: LINE -->
        <div class="header-cluster">
            <span class="m-lbl"><i class="bi bi-gear-fill m-icon"></i> PRODUCTION LINE</span>
            <div class="m-row">
                <span class="m-val m-accent" id="h-line">DL01 ENGINE</span>
            </div>
        </div>
        <!-- CLUSTER 2: DOC -->
        <div class="header-cluster">
            <span class="m-lbl"><i class="bi bi-tag-fill m-icon"></i> DOC NO.</span>
            <div class="m-row">
                <span class="m-val" id="h-doc">@(string.IsNullOrEmpty(Model.DocumentNumber) ? "---" : Model.DocumentNumber)</span>
                <span class="m-sub" id="h-rev">REV.0</span>
            </div>
        </div>
        <!-- CLUSTER 3: TIMING -->
        <div class="header-cluster">
            <span class="m-lbl"><i class="bi bi-clock-fill m-icon"></i> TIME / SHIFT</span>
            <div class="m-row">
                <span class="m-val" style="font-size: 11px;">@DateTime.Now.ToString("dd MMM yyyy").ToUpper()</span>
                <span class="m-divider"></span>
                <span class="m-val m-accent" id="h-shift" onclick="toggleShift()" style="cursor: pointer;" title="CLICK TO TOGGLE SHIFT">@(Model.Shift ?? "Shift 1")</span>
            </div>
        </div>
        <!-- CLUSTER 4: PRODUCT -->
        <div class="header-cluster">
            <span class="m-lbl"><i class="bi bi-cpu-fill m-icon"></i> CUSTOMER / SPEC</span>
            <div class="m-row">
                <div id="h-row-hose" style="display: flex; align-items: center; gap: 8px;">
                    <span class="m-val" id="h-customer">@(Model.CustomerName ?? "---")</span>
                    <span class="m-divider"></span>
                    <span class="m-val m-accent" id="h-hose" style="font-size: 11px;">@(Model.HoseType ?? "---")</span>
                </div>
            </div>
        </div>
        </div>
    </div>
</div>

<!-- SMART DIMENSION HUB -->
<div class="p-3">
    <!-- DIMENSION SECTION -->
    <div class="section-title">
        <i class="bi bi-rulers"></i>
        DIMENSION INSPECTION
    </div>

    <!-- Dynamic Timeline Navigator -->
    <div class="jam-nav" id="timelineContainer">
        <!-- Buttons will be generated here -->
        <button class="jam-btn add-btn" onclick="addNewSlot()">
            <i class="bi bi-plus-lg"></i>
        </button>
    </div>

    <!-- Cards Grid -->
    <div class="card-grid" id="cardContainer">
        <!-- Inner Diameter Card -->
        <div class="dimensi-card" id="card-inner-dia">
            <div class="card-header-flex">
                <div class="card-point">INNER DIAMETER</div>
                <i class="bi bi-circle card-icon"></i>
            </div>
            <div class="std-container">
                 <div class="std-label">STANDARD</div>
                 <div class="std-value" id="std-inner-dia">---</div>
            </div>
            <div class="limit-row">
                <div class="limit-pill">
                    <span class="limit-label">MIN</span>
                    <span class="limit-val min" id="limit-inner-dia-min">---</span>
                </div>
                <div class="limit-pill">
                    <span class="limit-label">MAX</span>
                    <span class="limit-val max" id="limit-inner-dia-max">---</span>
                </div>
            </div>
            <div class="input-group-custom">
                <label>ACTUAL MEASUREMENT</label>
                <input type="text" inputmode="decimal" class="c-input" id="val-inner-dia" oninput="validateCard('inner-dia')" placeholder="0.00" />
            </div>
            <span class="status-badge"></span>
        </div>

        <!-- Inner Thick X Card -->
        <div class="dimensi-card" id="card-inner-tx">
            <div class="card-header-flex">
                <div class="card-point">INNER THICK (X)</div>
                <i class="bi bi-arrows-expand card-icon"></i>
            </div>
            <div class="std-container">
                 <div class="std-label">STANDARD</div>
                 <div class="std-value" id="std-inner-tx">---</div>
            </div>
            <div class="limit-row">
                <div class="limit-pill">
                    <span class="limit-label">MIN</span>
                    <span class="limit-val min" id="limit-inner-tx-min">---</span>
                </div>
                <div class="limit-pill">
                    <span class="limit-label">MAX</span>
                    <span class="limit-val max" id="limit-inner-tx-max">---</span>
                </div>
            </div>
            <div class="input-group-custom">
                <label>ACTUAL MEASUREMENT</label>
                <input type="text" inputmode="decimal" class="c-input" id="val-inner-tx" oninput="validateCard('inner-tx')" placeholder="0.00" />
            </div>
            <span class="status-badge"></span>
