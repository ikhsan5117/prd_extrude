                    <div class="field-input-wrap"><input type="number" class="f-input" id="val-act-pnjg" value="@(Model?.ActualLength ?? "")" placeholder="Enter length"></div>
                </div>
                <div class="field-box">
                    <span class="field-label">QTY ACTUAL STATUS</span>
                    <div class="qty-row">
                        <button type="button" class="qty-btn" id="qty-ok" onclick="setQtyStatus('ok')"><i class="bi bi-check-circle-fill"></i> ALL OK</button>
                        <button type="button" class="qty-btn" id="qty-ng" onclick="setQtyStatus('ng')"><i class="bi bi-x-circle-fill"></i> CONTAINS NG</button>
                    </div>
                    
                    <div id="qtyContentArea" style="margin-top: 15px; min-height: 50px;">
                        <!-- OK PANEL: Muncul 1 Input di Tengah -->
                        <div id="okPanel" style="display: none; text-align: center;">
                            <span style="font-size: 8px; color: #10b981; font-weight: 800; display: block; margin-bottom: 5px;">TOTAL QTY OK</span>
                            <div class="field-input-wrap" style="max-width: 250px; margin: 0 auto; border-color: rgba(16, 185, 129, 0.4);">
                                <input type="number" class="f-input" id="val-qty-ok" value="@(Model?.QtyOk ?? 0)">
                            </div>
                        </div>

                        <!-- NG PANEL: Muncul 2 Input Berjejer -->
                        <div id="ngPanel" style="display: none; grid-template-columns: 1fr 1fr; gap: 10px;">
                            <div>
                                <span style="font-size: 8px; color: #ef4444; font-weight: 800; display: block; text-align: center; margin-bottom: 5px;">NG DIMENSI</span>
                                <div class="field-input-wrap" style="border-color: #ef4444;">
                                    <input type="number" class="f-input" id="val-ng-dimensi" value="@(Model?.NgDimension ?? 0)">
                                </div>
                            </div>
                            <div>
                                <span style="font-size: 8px; color: #ef4444; font-weight: 800; display: block; text-align: center; margin-bottom: 5px;">NG VISUAL</span>
                                <div class="field-input-wrap" style="border-color: #ef4444;">
                                    <input type="number" class="f-input" id="val-ng-visual" value="@(Model?.NgVisual ?? 0)">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Full Width Remark -->
            <div style="grid-column: span 2; margin-top: 10px;">
                <span class="field-label">REMARK / NOTES</span>
                <textarea class="f-textarea" id="val-remark" placeholder="Enter any specific observations or production notes...">@(Model?.Remark ?? "")</textarea>
            </div>
        </div>

        <!-- Dynamic List Container -->
        <div class="summary-list-container" style="margin-top: 20px;">
            <table class="summary-table">
                <thead>
                    <tr>
                        <th style="width: 25%;">VIN KODE</th>
                        <th style="width: 15%;">LENGTH</th>
                        <th style="width: 15%;">QTY OK</th>
                        <th style="width: 15%;">NG DIM</th>
                        <th style="width: 15%;">NG VIS</th>
                        <th style="width: 10%; text-align: center;">ACT</th>
                    </tr>
                </thead>
                <tbody id="summary-list-body">
                    <!-- Rows injected via JS -->
                </tbody>
            </table>
            <div id="summary-empty" class="empty-summary-state">
                <i class="bi bi-inbox mb-2" style="font-size: 24px; display: block;"></i>
                No production records added yet.
            </div>
        </div>
    </div>

    <!-- ACTION BUTTONS -->
    <div class="finalize-action-hub">
        <button type="button" onclick="cancelEdit()" class="cancel-btn" title="Cancel and Return">
            <i class="bi bi-x-circle"></i>
            <div class="d-flex flex-column align-items-start">
                <span style="font-size: 8px; opacity: 0.7; letter-spacing: 1px;">ABORT OPERATION</span>
                <span>CANCEL</span>
            </div>
        </button>
        <button type="button" onclick="finalize()" class="submit-btn" title="Finalize and Sync Inspection">
            <div class="d-flex flex-column align-items-start">
                <span style="font-size: 8px; opacity: 0.7; letter-spacing: 1px;">PRODUCTION QUALITY HUB</span>
                <span>UPDATE INSPECTION</span>
            </div>
            <i class="bi bi-shield-check"></i>
        </button>
    </div>

</div> <!-- END SMART DIMENSION HUB --></div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/html5-qrcode"></script>
    <script>
        // === GLOBAL STATE ===
        let currentIndex = 0;
        let activeStandards = {};
        let isToolConnected = false;
        let toolPrefix = "";
        let linkedDeviceName = "NONE / MANUAL";
        let productionRecords = []; // Store multiple production data records
        let userHasSelectedData = false; // Flag to prevent auto-fetch override

        // Load existing summaries from server
        @if (Model?.Summaries != null && Model.Summaries.Any())
        {
            <text>
        productionRecords = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            Model.Summaries.Select(s => new {
                vin = s.VinCode ?? "",
                act = s.ActualLength ?? "",
                ok = s.QtyOk.ToString(),
                ngD = s.NgDimension.ToString(),
                ngV = s.NgVisual.ToString()
            })
        ));
            </text>
        }

        // === PLANNING SEARCH VARIABLES ===
        let planningItemsCache = [];
        let planningResultItems = [];
        let planningResultIndex = -1;

        // === PLANNING SEARCH FUNCTIONS ===
        async function refreshPlanningItems() {
            const dateText = document.getElementById('h-date')?.innerText || '';
            const shiftText = document.getElementById('h-shift')?.innerText || '';
            const date = parseDisplayDate(dateText);
            const planningInput = document.getElementById('planningSearch');
            if (!date || !shiftText || !planningInput) return;

            planningInput.placeholder = 'LOADING PLANNING...';
            planningInput.disabled = true;

            try {
                const res = await fetch(`/ProductionReport/GetPlanningItems?date=${date}&shift=${encodeURIComponent(shiftText)}`);
                planningItemsCache = await res.json();
                planningResultItems = planningItemsCache;
                planningResultIndex = -1;

                const isFiltered = planningItemsCache.length > 0 && planningItemsCache[0].isFiltered;
                const machineCtx = isFiltered && planningItemsCache[0].machineName
                    ? ` [${planningItemsCache[0].machineName}]`
                    : '';

                planningInput.disabled = false;
                if (planningItemsCache.length > 0) {
                    planningInput.placeholder = `SEARCH PLANNING (${planningItemsCache.length} ITEM${planningItemsCache.length > 1 ? 'S' : ''}${machineCtx})`;
                    // FIX: Hanya tampilkan jika user sedang aktif di kolom ini (mencegah muncul sendiri saat load)
                    if (document.activeElement === planningInput) {
                        document.getElementById('planningResults')?.classList.remove('d-none');
                        renderPlanningResults(planningResultItems, true);
                    }
                } else {
                    planningInput.placeholder = 'NO ITEMS IN PLAN FOR THIS MACHINE/DAY';
                }
                // FIX: JANGAN hapus value di sini agar input user tetap ada
                // planningInput.value = ''; 
            } catch (error) {
                console.error('Failed to refresh planning items:', error);
                planningInput.disabled = false;
                planningInput.placeholder = 'ERROR LOADING PLANNING';
            }
        }

        function filterPlanningResults(query) {
            const sanitizedQuery = query.trim().toUpperCase();
            const results = sanitizedQuery.length === 0
                ? planningItemsCache
                : planningItemsCache.filter(item =>
                    (item.itemCode && item.itemCode.toUpperCase().includes(sanitizedQuery)) ||
                    (item.itemName && item.itemName.toUpperCase().includes(sanitizedQuery))
                );

            planningResultItems = results;
            planningResultIndex = -1;
            renderPlanningResults(results, sanitizedQuery.length === 0);
        }

        function renderPlanningResults(items, showAll = false) {
            const container = document.getElementById('planningResults');
            if (!container) return;
            container.innerHTML = '';

            if (items.length === 0) {
                container.innerHTML = `<div class="planning-result-item" style="text-align:center; opacity:0.5; pointer-events:none;">
                    <div class="planning-result-code">--- NO MATCHES FOUND ---</div>
                </div>`;
                container.classList.remove('d-none');
                return;
            }

            const header = document.createElement('div');
            header.style.cssText = 'padding:10px 20px;font-size:9px;font-weight:900;color:var(--accent-glow);letter-spacing:2px;text-transform:uppercase;border-bottom:1px solid rgba(255,255,255,0.05);margin-bottom:8px;opacity:0.7;display:flex;align-items:center;justify-content:space-between;';
            header.innerHTML = `<span>PLANNING RESULTS (${items.length})</span> <i class="bi bi-funnel-fill"></i>`;
            container.appendChild(header);

            items.forEach((item, index) => {
                const hasSps = item.hasSps === true;
                const spsBadge = hasSps
                    ? `<span style="font-size:9px;font-weight:900;color:#10b981;background:rgba(16,185,129,0.15);padding:2px 8px;border-radius:20px;border:1px solid rgba(16,185,129,0.4);white-space:nowrap;"><i class="bi bi-check-circle-fill me-1"></i>SPS ✓</span>`
                    : `<span style="font-size:9px;font-weight:900;color:#ef4444;background:rgba(239,68,68,0.12);padding:2px 8px;border-radius:20px;border:1px solid rgba(239,68,68,0.35);white-space:nowrap;"><i class="bi bi-x-circle-fill me-1"></i>NO SPS</span>`;
                const borderColor = hasSps ? 'rgba(16,185,129,0.5)' : 'rgba(239,68,68,0.35)';

                const div = document.createElement('div');
                div.className = 'planning-result-item';
                div.dataset.index = index;
                div.style.borderLeft = `3px solid ${borderColor}`;
                div.innerHTML = `
                    <div style="display:flex;justify-content:space-between;align-items:center;width:100%;gap:8px;flex-wrap:wrap;">
                        <div class="planning-result-code">${item.itemCode}</div>
                        <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
                            ${item.machineName ? `<div class="machine-badge-mini"><i class="bi bi-cpu-fill"></i>${item.machineName}</div>` : ''}
                            ${spsBadge}
                        </div>
                    </div>
                    <div class="planning-result-name">${item.itemName || 'NO DESCRIPTION'}</div>
                    <div class="planning-result-meta"><i class="bi bi-calendar3"></i> ${item.dateShift || '---'}</div>
                `;
                div.onclick = () => selectPlanningItem(item);
                div.onmouseenter = () => highlightPlanningResult(index);
                container.appendChild(div);
            });

            container.classList.remove('d-none');
            planningResultIndex = showAll ? 0 : -1;
            if (showAll && items.length > 0) highlightPlanningResult(0);
        }

        function highlightPlanningResult(index) {
            const container = document.getElementById('planningResults');
            if (!container) return;
            const options = Array.from(container.querySelectorAll('.planning-result-item'));
            options.forEach(opt => opt.classList.remove('planning-result-highlight'));
            const target = options[index];
            if (!target) return;
            target.classList.add('planning-result-highlight');
            planningResultIndex = index;
            target.scrollIntoView({ block: 'nearest' });
        }

        function selectPlanningItem(item) {
            userHasSelectedData = true; // Set flag to prevent auto-fetch
            console.log('🎯 User selected planning - preventing auto-fetch override');
            
            const planningInput = document.getElementById('planningSearch');
            const displayText = item.machineName ? `[${item.itemCode}] ${item.machineName}` : `[${item.itemCode}]`;
            if (planningInput) {
                planningInput.value = displayText;
                planningInput.readOnly = true;
                planningInput.style.cursor = 'pointer';
            }
            document.getElementById('planningResults')?.classList.add('d-none');

            // Update all header elements from planning data
            const lineEl = document.getElementById('h-line');
            if (lineEl && item.machineName) {
                lineEl.innerText = item.machineName;
                lineEl.classList.add('animate__animated', 'animate__flash');
                setTimeout(() => lineEl.classList.remove('animate__flash'), 1000);
            }
            
            const itemCodeEl = document.getElementById('h-itemcode');
            if (itemCodeEl && item.itemCode) {
                itemCodeEl.innerText = item.itemCode;
            }
            
            const hoseEl = document.getElementById('h-hose');
            if (hoseEl && item.itemCode) {
                hoseEl.innerText = item.itemCode; // Initially same as itemCode, will be updated by loadMaster
            }
            
            if (item.date) setPlanningDateAndShift(item.date, item.shift);
            const manualInput = document.getElementById('manualItemSearch');
            if (manualInput) manualInput.value = item.itemCode;
            
            // Fetch SPS to get SpsId for database FK relationship
            // Pass flag to NOT override planning data
            fetchSpsByItem(item.itemCode, true);
        }

        function openPlanningDropdown() {
            const planningInput = document.getElementById('planningSearch');
            const results = document.getElementById('planningResults');
            if (results) {
                results.classList.remove('d-none');
                // Selalu render ulang agar up-to-date
                renderPlanningResults(planningResultItems, true);
            }
            if (planningItemsCache.length === 0) refreshPlanningItems();
        }

        function parseDisplayDate(displayText) {
            const monthMap = {
                JAN: '01', FEB: '02', MAR: '03', APR: '04', MAY: '05', JUN: '06',
                JUL: '07', AUG: '08', SEP: '09', OCT: '10', NOV: '11', DEC: '12'
            };
            const parts = (displayText || '').trim().split(' ');
            if (parts.length !== 3) return null;
            const [day, month, year] = parts;
            const monthNum = monthMap[month.toUpperCase()];
            if (!monthNum) return null;
            return `${year}-${monthNum}-${day.padStart(2, '0')}`;
        }

        function formatDisplayDate(dateValue) {
            const date = new Date(dateValue);
            if (isNaN(date.getTime())) return '';
            const monthNames = ['JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN', 'JUL', 'AUG', 'SEP', 'OCT', 'NOV', 'DEC'];
            const day = String(date.getDate()).padStart(2, '0');
            const month = monthNames[date.getMonth()];
            const year = date.getFullYear();
            return `${day} ${month} ${year}`;
        }

        function setPlanningDateAndShift(dateValue, shiftValue) {
            const dateEl = document.getElementById('h-date');
            const shiftEl = document.getElementById('h-shift');
            if (dateEl) {
                const formatted = formatDisplayDate(dateValue);
                if (formatted) dateEl.innerText = formatted;
            }
            if (shiftEl && shiftValue) {
                const normalized = shiftValue.toUpperCase();
                if (normalized === 'I') shiftEl.innerText = 'Shift 1';
                else if (normalized === 'II') shiftEl.innerText = 'Shift 2';
                else if (normalized === 'III') shiftEl.innerText = 'Shift 3';
                else shiftEl.innerText = shiftValue;
            }
        }

        function toggleShift() {
            const el = document.getElementById('h-shift');
            const current = el.innerText;
            let next = "Shift 1";
            if (current === "Shift 1") next = "Shift 2";
            else if (current === "Shift 2") next = "Shift 3";
            el.innerText = next;
            
            el.classList.remove('animate__animated', 'animate__pulse');
            setTimeout(() => el.classList.add('animate__animated', 'animate__pulse'), 10);
            
            Swal.fire({ 
                icon: 'info', 
                title: 'SHIFT UPDATED', 
                text: `Toggled to ${next}`, 
                timer: 1000, 
                showConfirmButton: false, 
                toast: true, 
                position: 'top-end' 
            });

            refreshPlanningItems();
        }

        // Close dropdown when clicking outside
        document.addEventListener('click', function(e) {
            const planningResults = document.getElementById('planningResults');
            const planningSearch = document.getElementById('planningSearch');
            if (planningResults && !planningResults.classList.contains('d-none')) {
                if (!planningResults.contains(e.target) && e.target !== planningSearch) {
                    planningResults.classList.add('d-none');
                }
            }
        });

        // Keyboard navigation for planning dropdown
        document.addEventListener('keydown', function(e) {
            const planningResults = document.getElementById('planningResults');
            const planningSearch = document.getElementById('planningSearch');
            
            if (!planningResults || planningResults.classList.contains('d-none')) return;
            if (document.activeElement !== planningSearch) return;

            if (e.key === 'ArrowDown') {
                e.preventDefault();
                movePlanningSelection(1);
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                movePlanningSelection(-1);
            } else if (e.key === 'Enter') {
                e.preventDefault();
                if (planningResultIndex >= 0 && planningResultIndex < planningResultItems.length) {
                    selectPlanningItem(planningResultItems[planningResultIndex]);
                }
            } else if (e.key === 'Escape') {
                planningResults.classList.add('d-none');
            }
        });

        function movePlanningSelection(direction) {
            if (!planningResultItems.length) return;
            planningResultIndex = Math.max(0, Math.min(planningResultItems.length - 1, planningResultIndex + direction));
            highlightPlanningResult(planningResultIndex);
        }

        // === MANUAL PROTOCOL (SPS) AUTOCOMPLETE ===
        let spsDebounceTimer = null;
        let spsResultItems = [];
        let spsResultIndex = -1;

        async function handleSpsAutocomplete(query) {
            console.log('🔍 SPS Autocomplete triggered:', query);
            clearTimeout(spsDebounceTimer);
            
            if (!query || query.trim().length < 2) {
                document.getElementById('spsDropdown')?.classList.add('d-none');
                return;
            }

            spsDebounceTimer = setTimeout(async () => {
                try {
                    console.log('📡 Fetching SPS items for:', query);
                    const res = await fetch(`/Dimensi/SearchSpsItems?query=${encodeURIComponent(query)}`);
                    const items = await res.json();
                    console.log('✅ SPS items received:', items.length, items);
                    
                    spsResultItems = items || [];
                    spsResultIndex = -1;
                    renderSpsDropdown(items || []);
                } catch (err) {
                    console.error('❌ SPS search error:', err);
                    document.getElementById('spsDropdown')?.classList.add('d-none');
                }
            }, 300);
        }

        function renderSpsDropdown(items) {
            const dropdown = document.getElementById('spsDropdown');
            if (!dropdown) return;

            dropdown.innerHTML = '';

            if (!items || items.length === 0) {
                dropdown.classList.add('d-none');
                return;
            }

            const header = document.createElement('div');
            header.style.cssText = 'padding:10px 20px;font-size:9px;font-weight:900;color:var(--accent-glow);letter-spacing:2px;text-transform:uppercase;border-bottom:1px solid rgba(255,255,255,0.05);margin-bottom:8px;';
            header.innerHTML = `SPS PROTOCOLS (${items.length})`;
            dropdown.appendChild(header);

            items.forEach((item, idx) => {
                const div = document.createElement('div');
                div.className = 'planning-result-item';
                div.dataset.index = idx;
                div.innerHTML = `
                    <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;">
                        <div class="planning-result-code">${item.itemCode || '---'}</div>
                    </div>
                    <div class="planning-result-name">${item.hoseType || 'NO DESCRIPTION'}</div>
                `;
                div.onclick = () => selectSpsItem(item);
                div.onmouseenter = () => highlightSpsResult(idx);
                dropdown.appendChild(div);
            });

            dropdown.classList.remove('d-none');
        }

        function highlightSpsResult(index) {
            const dropdown = document.getElementById('spsDropdown');
            if (!dropdown) return;
            
            const options = Array.from(dropdown.querySelectorAll('.planning-result-item'));
            options.forEach(opt => opt.classList.remove('planning-result-highlight'));
            
            const target = options[index];
            if (!target) return;
            
            target.classList.add('planning-result-highlight');
            spsResultIndex = index;
            target.scrollIntoView({ block: 'nearest' });
        }

        async function selectSpsItem(item) {
            userHasSelectedData = true; // Set flag to prevent auto-fetch
            console.log('🎯 User selected manual SPS - preventing auto-fetch override');
            console.log('📌 SPS item selected:', item);
            
            const manualInput = document.getElementById('manualItemSearch');
            if (manualInput) {
                manualInput.value = item.itemCode || '';
            }
            
            document.getElementById('spsDropdown')?.classList.add('d-none');
            
            // Fetch full SPS data
            await fetchSpsByItem(item.itemCode);
        }

        async function fetchSpsByItem(itemCode, fromPlanning = false) {
            if (!itemCode) return;
            
            console.log('🔄 Fetching full SPS data for:', itemCode, 'fromPlanning:', fromPlanning);
            
            // If user has selected data and this is not from planning, skip (prevent auto-fetch override)
            if (userHasSelectedData && !fromPlanning) {
                console.log('⛔ Skipping fetch - user has already selected planning/manual data');
                return;
            }
            
            try {
                const res = await fetch(`/Dimensi/GetSpsByItem?itemCode=${encodeURIComponent(itemCode)}`);
                const sps = await res.json();
                console.log('✅ SPS data received:', sps);
                
                if (sps && sps.success !== false) {
                    applySpsToForm(sps, fromPlanning);
                } else {
                    console.warn('⚠️ SPS not found for:', itemCode);
                    Swal.fire({ 
                        icon: 'warning', 
                        title: 'PROTOCOL NOT FOUND', 
                        text: 'Item code tidak ditemukan di database SPS',
                        timer: 1500, 
                        showConfirmButton: false 
                    });
                }
            } catch (err) {
                console.error('❌ Fetch SPS error:', err);
            }
        }

        function applySpsToForm(sps, fromPlanning = false) {
            console.log('📝 Applying SPS to form:', sps, 'fromPlanning:', fromPlanning);
            
            // Update SpsId (important for FK relationship)
            const spsIdField = document.getElementById('SpsId');
            
            // Check if SPS is from Masterlist (which doesn't have StandardParameterSetting ID)
            if (sps.Source === 'Masterlist' || sps.source === 'Masterlist') {
                console.log('ℹ️ SPS from Masterlist - SpsId will be NULL (expected behavior)');
                console.log('   Masterlist data:', { masterListId: sps.MasterlistId || sps.masterListId, itemList: sps.ItemList });
                if (spsIdField) {
                    spsIdField.value = '';
                    console.log('✅ SpsId field cleared (Masterlist source)');
                }
            } else if (spsIdField) {
                // FIX: Handle both 'id' (camelCase from JSON) and 'Id' (PascalCase)
                // FIX: Jika dari Masterlist, coba cari ID-nya di SPS (jika ada)
                const targetId = sps.id || sps.Id || sps.spsId;
                if (targetId) {
                    spsIdField.value = targetId;
                    console.log('💾 SpsId field set to:', targetId);
                } else {
                    spsIdField.value = '';
                    console.log('⚠️ No ID found, SpsId cleared');
                }
            } else {
                console.warn('⚠️ SpsId field not found or SPS has no ID:', {
                    fieldExists: !!spsIdField,
                    spsId: sps.Id,
                    spsSource: sps.Source || sps.source,
                    fullSpsData: sps
                });
            }
            
            // ONLY update header if NOT from planning selection
            if (!fromPlanning) {
                // Update ItemCode in header
                const itemCodeEl = document.getElementById('h-itemcode');
                if (itemCodeEl && sps.ItemList) {
                    itemCodeEl.innerText = sps.ItemList;
                }
                
                // Update HoseType in header
                const hoseEl = document.getElementById('h-hose');
                if (hoseEl && sps.HoseType) {
                    hoseEl.innerText = sps.HoseType;
                }

                // FIX: Update Nomor Dokumen (SOP/SPS No) di Header
                const docEl = document.getElementById('h-doc');
                const docNo = sps.DocumentNumber || sps.documentNumber;
                if (docEl && docNo && docNo !== '---') {
                    docEl.innerText = docNo;
                }
                
                // Update manualItemSearch display
                const manualInput = document.getElementById('manualItemSearch');
                if (manualInput && sps.ItemList) {
                    manualInput.value = sps.ItemList;
                }
            }

            // FIX: Update Nomor Dokumen (SOP/SPS No) di Header (Pindahkan ke luar IF supaya Planning juga update)
            const docEl = document.getElementById('h-doc');
            const docNo = sps.DocumentNumber || sps.documentNumber;
            console.log('🔍 SPS Data Received:', sps);
            if (docEl && docNo && docNo !== '---') {
                docEl.innerText = docNo;
                console.log('📄 Header DocNo updated to:', docNo);
            } else {
                console.warn('⚠️ No DocumentNumber found in SPS data');
            }

            // Trigger loadMaster to update standards (without overriding planning data)
            loadMaster(true);
            
            if (!fromPlanning) {
                const sourceInfo = sps.Source === 'Masterlist' ? ' (Masterlist)' : '';
                Swal.fire({ 
                    icon: 'success', 
                    title: 'PROTOCOL LOADED' + sourceInfo, 
                    text: sps.ItemList || 'Unknown',
                    timer: 1200, 
                    showConfirmButton: false,
                    position: 'top-end',
                    toast: true
                });
            }
        }

        // Attach SPS autocomplete listener
        document.addEventListener('DOMContentLoaded', () => {
            const manualInput = document.getElementById('manualItemSearch');
            if (manualInput) {
                manualInput.addEventListener('input', (e) => {
                    handleSpsAutocomplete(e.target.value);
                });
                
                // Keyboard navigation
                manualInput.addEventListener('keydown', (e) => {
                    const dropdown = document.getElementById('spsDropdown');
                    if (!dropdown || dropdown.classList.contains('d-none')) {
                        if (e.key === 'Enter') {
                            fetchSpsByItem(manualInput.value);
                        }
                        return;
                    }

                    if (e.key === 'ArrowDown') {
                        e.preventDefault();
                        moveSpsSelection(1);
                    } else if (e.key === 'ArrowUp') {
                        e.preventDefault();
                        moveSpsSelection(-1);
                    } else if (e.key === 'Enter') {
                        e.preventDefault();
                        if (spsResultIndex >= 0 && spsResultIndex < spsResultItems.length) {
                            selectSpsItem(spsResultItems[spsResultIndex]);
                        }
                    } else if (e.key === 'Escape') {
                        dropdown.classList.add('d-none');
                    }
                });
            }
            
            // Close SPS dropdown on outside click
            document.addEventListener('click', (e) => {
                const dropdown = document.getElementById('spsDropdown');
                const manualInput = document.getElementById('manualItemSearch');
                if (dropdown && !dropdown.classList.contains('d-none')) {
                    if (!dropdown.contains(e.target) && e.target !== manualInput) {
                        dropdown.classList.add('d-none');
                    }
                }
            });
            
            // Auto-fetch SPS if ItemCode exists but no StandardParameterSetting
            @if (Model?.StandardParameterSetting == null && !string.IsNullOrWhiteSpace(Model?.ItemCode))
            {
                <text>
                const autoItemCode = '@(Model?.ItemCode ?? "")';
                console.log('🚀 Auto-fetching SPS for ItemCode:', autoItemCode);
                if (autoItemCode && autoItemCode !== '---' && !userHasSelectedData) {
                    setTimeout(() => {
                        // Check again if user hasn't interacted yet
                        if (userHasSelectedData) {
                            console.log('⛔ Auto-fetch cancelled - user already selected data');
                            return;
                        }
                        const manualInput = document.getElementById('manualItemSearch');
                        if (manualInput) manualInput.value = autoItemCode;
                        // Use fromPlanning=true to prevent overriding existing header data
                        fetchSpsByItem(autoItemCode, true);
                    }, 500);
                }
                </text>
            }
        });

        function moveSpsSelection(direction) {
            if (!spsResultItems.length) return;
            spsResultIndex = Math.max(0, Math.min(spsResultItems.length - 1, spsResultIndex + direction));
            highlightSpsResult(spsResultIndex);
        }

        // === ORIGINAL EDIT FORM SCRIPT ===
        // RENDER DATABASE DATAsafely by selecting only needed properties (BREAKS CYCLE)
        const rawMeasurements = @Html.Raw(Json.Serialize(Model?.Measurements?.Select(m => new {
            pointName = m.PointName,
            r1 = m.R1,
            r2 = m.R2,
            r3 = m.R3,
            r4 = m.R4,
            r5 = m.R5,
            timeSection = m.TimeSection,
            status = m.Status
        })));
        let measurements = [];

        // Build slots with independent times
        const timeHeader = "@((Model?.Measurements?.FirstOrDefault())?.TimeSection ?? "")";
        const timeParts = timeHeader.split(',').map(s => s.trim());

        for (let i = 1; i <= 5; i++) {
            const hasData = rawMeasurements.some(m => {
                const v = m[`r${i}`] !== undefined ? m[`r${i}`] : m[`R${i}`];
                return v !== null && v !== "" && v !== undefined;
            });
            
            if (hasData || i === 1) {
                const getVal = (exactName) => {
                    const search = exactName.toLowerCase().trim();
                    const isInner = search.includes('inner');
                    const isTotal = search.includes('total');
                    const isThick = search.includes('thick');
                    
                    let row = rawMeasurements.find(m => (m.pointName || "").trim().toLowerCase() === search);
                    if (!row && isThick) {
                        row = rawMeasurements.find(m => {
                            const dbName = (m.pointName || "").trim().toLowerCase();
                            const dbIsInner = dbName.includes('inner');
                            const dbIsTotal = dbName.includes('total');
                            const hasX = search.includes('(x)');
                            const hasY = search.includes('(y)');
                            if (isInner && !dbIsInner) return false;
                            if (isTotal && !dbIsTotal) return false;
                            if (hasX && !dbName.includes('(x)')) return false;
                            if (hasY && !dbName.includes('(y)')) return false;
                            return dbName.includes('thick');
                        });
                    }
                    if (!row && !isThick) {
                        row = rawMeasurements.find(m => (m.pointName || "").trim().toLowerCase().includes(search.split(' ')[0]));
                    }
                    if (!row) return "";
                    const val = row[`r${i}`] !== undefined ? row[`r${i}`] : row[`R${i}`];
                    return (val !== null && val !== undefined) ? val : "";
                };
                
                const getVState = (itemName) => {
                    let row = rawMeasurements.find(m => (m.pointName || "").includes(itemName));
                    if (!row) row = rawMeasurements.find(m => (m.pointName || "").trim() === "Visual Check");
                    const val = row ? (row[`r${i}`] !== undefined ? row[`r${i}`] : row[`R${i}`]) : null;
                    return (val == 1) ? "ok" : (val == 0 && val !== null ? "ng" : null);
                };

                measurements.push({
                    time: timeParts[i-1] || "",
                    data: {
                        innerDia: getVal("Inner Diameter"),
                        innerTx: getVal("Inner Thickness (x)"),
                        innerTy: getVal("Inner Thickness (y)"),
                        totalTx: getVal("Total Thickness (x)"),
                        totalTy: getVal("Total Thickness (y)"),
                        spiral: getVal("Spiral Pitch"),
                        visual: { 
                            burry: getVState("Burry"), 
                            line: getVState("Line"), 
                            bubble: getVState("Bubble"), 
                            scratch: getVState("Scratch") 
                        }
                    }
                });
            }
        }

