                        <th class="marker-re"><span class="badge-re">RE</span>Cyl 2-1</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Cyl 3-1</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Screw 1</th>

                        <th class="marker-re"><span class="badge-re">RE</span>Head 2</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Cyl 1-2</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Cyl 2-2</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Cyl 3-2</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Screw 2</th>

                        <th class="marker-re"><span class="badge-re">RE</span>Head 3</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Cyl 1-3</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Cyl 2-3</th>
