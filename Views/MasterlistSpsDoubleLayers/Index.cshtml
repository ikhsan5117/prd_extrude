@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
             // Pre-fetch lists from server-side for fast JS filtering
             const itemsList = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ItemList));
             const docsList = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.DocList));

             // Real-time Filtering Logic (Main Table)
             $("#globalSearch, #machineFilter").on("keyup change", function() {
                 toggleClearButton();
                 filterTable();
             });

             // Clear search button
             $("#clearSearch").on("click", function() {
                 $("#globalSearch").val("").focus();
                 $(this).hide();
                 $("#customSuggestions").addClass("d-none");
                 filterTable();
             });

             function toggleClearButton() {
                 if ($("#globalSearch").val().length > 0) {
                     $("#clearSearch").show();
                 } else {
                     $("#clearSearch").hide();
                 }
             }

             // Auto-clear on focus for categorized search (User Request)
             $("#globalSearch").on("focus", function() {
                 let cat = $("#searchCategory").val();
                 if (cat !== "all" && $(this).val() !== "") {
                     // $(this).val(""); // Uncomment if you want total clear
                     // Or just show suggestions immediately
                     $(this).trigger("input");
                 }
             });

             // Custom Autocomplete / Searchable Dropdown Logic
             $("#globalSearch").on("input", function() {
                 let val = $(this).val().toLowerCase().trim();
                 let cat = $("#searchCategory").val();
                 let suggestions = $("#customSuggestions");
                 
                 toggleClearButton();

                 if (val.length < 1 || cat === "all") {
                     suggestions.addClass("d-none");
                     return;
                 }

                 let source = (cat === "item") ? itemsList : docsList;
                 let matches = source.filter(x => x.toLowerCase().includes(val)).slice(0, 20); // Limit 20 results

                 if (matches.length > 0) {
                     suggestions.empty().removeClass("d-none");
                     matches.forEach(m => {
                         suggestions.append(`<div class="suggestion-item" onclick="selectSuggestion('${m.replace(/'/g, "\\'")}')">${m}</div>`);
                     });
                 } else {
                     suggestions.addClass("d-none");
                 }
             });

             window.selectSuggestion = function(val) {
                 // Hilangkan dash untuk konsistensi tampilan
                 let cleanVal = val.replace(/-/g, "");
                 $("#globalSearch").val(cleanVal);
                 $("#customSuggestions").addClass("d-none");
                 filterTable();
             };

             // Hide suggestions when clicking outside
             $(document).on("click", function(e) {
                 if (!$(e.target).closest("#customSearchGroup").length) {
                     $("#customSuggestions").addClass("d-none");
                 }
             });

             // Category change handler
             $("#searchCategory").on("change", function() {
                 $("#globalSearch").val("").focus();
                 $("#customSuggestions").addClass("d-none");
                 filterTable();
             });
             
             // Trigger SweetAlert for messages from TempData
             @if (TempData["SuccessMessage"] != null)
             {
                  var successMsg = TempData["SuccessMessage"]?.ToString()?.Replace("\n", "<br>")?.Replace("\r", "");
                  var sheetLog = TempData["SheetLog"]?.ToString()?.Replace("\n", "\\n")?.Replace("\r", "")?.Replace("'", "\\'");
                 
                 <text>
                 Swal.fire({
                     icon: 'success',
                     title: 'Import Berhasil!',
                     html: '<div class="text-start" style="font-size: 0.9rem;">@Html.Raw(successMsg)</div>',
                     confirmButtonText: 'OK',
                     footer: '@(TempData["SheetLog"] != null ? "<a href=\"#\" onclick=\"showSheetLog()\">Lihat Log Deteksi</a>" : "")'
                 });
                 
                 window.showSheetLog = function() {
                     Swal.fire({
                         title: 'Sheet Detection Log',
                         html: '<pre style="text-align: left; font-size: 0.7rem; max-height: 300px; overflow-y: auto; background: #f8f9fa; padding: 10px;">@Html.Raw(sheetLog)</pre>',
                         width: '600px'
                     });
                 };
                 </text>
             }
             
             @if (TempData["ErrorMessage"] != null)
             {
                  var errorMsg = TempData["ErrorMessage"]?.ToString()?.Replace("\n", "<br>")?.Replace("\r", "");
                 
                 <text>
                 Swal.fire({
                     icon: 'error',
                     title: 'Import Gagal',
                     html: '<div class="text-start" style="font-size: 0.9rem;">@Html.Raw(errorMsg)</div>',
                     confirmButtonText: 'Tutup'
                 });
                 </text>
             }
        });
        
        // Toggle collapsible detail
        function toggleDetail(elementId) {
            var element = document.getElementById(elementId);
            if (element.style.display === 'none') {
                element.style.display = 'block';
                event.target.innerHTML = '<i class="bi bi-chevron-up"></i> Sembunyikan Detail';
            } else {
                element.style.display = 'none';
                event.target.innerHTML = '<i class="bi bi-chevron-down"></i> Lihat Detail Lengkap';
            }
        }

        function filterTable() {
            let category = $("#searchCategory").val();
            let searchValue = $("#globalSearch").val().toLowerCase().trim();
            // Hilangkan dash dari pencarian jika di mode Item
            if (category === "item") {
                searchValue = searchValue.replace(/-/g, "");
            }
            
            let machineValue = $("#machineFilter").val().toLowerCase().trim();
            let rowCount = 0;

            $("#spsTable tbody tr").each(function() {
                let row = $(this);
                let rowText = row.text().toLowerCase();
                
                // Extract machine columns
                let machineText = row.find("td:nth-child(5)").text().toLowerCase().trim(); // Machine column
                let machineCodeText = row.find("td:nth-child(11)").text().toLowerCase().trim(); // MC column (MachineCode)

                // Target specific columns based on category
                let targetText = rowText; // default for 'all'
                if (category === "item") {
                    targetText = row.find("td:nth-child(6)").text().toLowerCase().trim().replace(/-/g, ""); // Hilangkan dash untuk matching
                } else if (category === "doc") {
                    targetText = row.find("td:nth-child(7)").text().toLowerCase().trim(); // Doc No column
                }

                let matchesSearch = searchValue === "" || targetText.indexOf(searchValue) > -1;
                
                // Machine filter logic
                let matchesMachine = machineValue === "" || 
                                     machineText.indexOf(machineValue) > -1 || 
                                     machineCodeText.indexOf(machineValue) > -1;

                if (matchesSearch && matchesMachine) {
                    row.show();
                    rowCount++;
                } else {
                    row.hide();
                }
            });

            $("#countDisplay").text(rowCount);
        }

        function resetFilters() {
            $("#globalSearch").val("");
            $("#machineFilter").val("");
            filterTable();
        }

        function showLoading() {
            var fileRef = document.getElementById('file');
            if(fileRef.files.length > 0) {
                $('#importModal').modal('hide');
                Swal.fire({
                    title: 'Sinkronisasi...',
                    html: 'Sedang merekam data parameter standar ke database.<br>Harap tidak menutup browser.',
                    allowOutsideClick: false,
                    didOpen: () => { Swal.showLoading(); }
                });
            }
        }

        function enablePreview() {
            var fileRef = document.getElementById('file');
            var btnPreview = document.getElementById('btnPreview');
            if(fileRef.files.length > 0) {
                btnPreview.disabled = false;
            } else {
                btnPreview.disabled = true;
            }
        }

        function previewExcel() {
            var fileRef = document.getElementById('file');
            if(fileRef.files.length === 0) {
                alert('Pilih file Excel terlebih dahulu');
                return;
            }

            var formData = new FormData();
            formData.append('file', fileRef.files[0]);

            $('#previewArea').show().html(`
                <div class="alert alert-warning" role="alert">
                    <i class="bi bi-hourglass-split me-1"></i>
                    <small>Menganalisis file Excel...</small>
                </div>
            `);

            $.ajax({
                url: '@Url.Action("PreviewExcel", "MasterlistSpsDoubleLayers")',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function(response) {
                    if(response.success) {
                        var statusClass = response.isValid ? 'success' : 'warning';
                        var statusIcon = response.isValid ? 'check-circle' : 'exclamation-triangle';
                        var statusText = response.isValid ? '✓ Valid' : '⚠ Ada Masalah';
                        
                        var html = `
                            <div class="alert alert-${statusClass}" role="alert">
                                <i class="bi bi-${statusIcon} me-1"></i>
                                <strong>${statusText}</strong>
                            </div>
                            <div class="card bg-dark border-secondary mb-2">
                                <div class="card-body p-3">
                                    <h6 class="text-white mb-2"><i class="bi bi-file-earmark-check me-1"></i> Informasi File</h6>
                                    <table class="table table-sm table-dark table-bordered" style="font-size: 0.8rem;">
                                        <tr><td><strong>File:</strong></td><td>${response.fileName}</td></tr>
                                        <tr><td><strong>Ukuran:</strong></td><td>${(response.fileSize / 1024).toFixed(2)} KB</td></tr>
                                        <tr><td><strong>Sheet Dipilih:</strong></td><td>${response.selectedSheet}</td></tr>
                                        <tr><td><strong>Format Terdeteksi:</strong></td><td><span class="badge bg-info">${response.detectedFormat}</span></td></tr>
                                        <tr><td><strong>Kolom Item:</strong></td><td>${response.expectedItemColumn}</td></tr>
                                        <tr><td><strong>Total Rows:</strong></td><td>${response.totalRows}</td></tr>
                                        <tr><td><strong>Total Columns:</strong></td><td>${response.totalColumns}</td></tr>
                                        <tr><td><strong>Estimasi Data:</strong></td><td>${response.estimatedRecords}</td></tr>
                                    </table>
                                </div>
                            </div>
                        `;

                        if (!response.isValid) {
                            html += `
                                <div class="alert alert-danger" role="alert" style="font-size: 0.85rem;">
                                    <strong>⚠ Validasi Error:</strong><br>
                                    <pre class="mb-0 mt-1" style="font-size: 0.75rem;">${response.validationError}</pre>
                                </div>
                            `;
                        }

                        if (response.sampleData && response.sampleData.length > 0) {
                            html += `
                                <div class="card bg-dark border-secondary mb-2">
                                    <div class="card-body p-3">
                                        <h6 class="text-white mb-2"><i class="bi bi-table me-1"></i> Sample Data (${response.sampleData.length} baris)</h6>
                                        <div class="table-responsive">
                                            <table class="table table-sm table-dark table-bordered" style="font-size: 0.75rem;">
                                                <thead>
                                                    <tr>
                                                        <th>Row</th><th>ID Excel</th><th>No</th><th>Machine</th>
                                                        <th>Customer</th><th>Item List</th><th>Dimensi</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                            `;
                            
                            response.sampleData.forEach(function(row) {
                                html += `<tr>
                                    <td>${row.rowIndex}</td>
                                    <td>${row.idExcel}</td>
                                    <td>${row.no}</td>
                                    <td>${row.machine}</td>
                                    <td>${row.customer}</td>
                                    <td><strong class="text-info">${row.itemList}</strong></td>
                                    <td>${row.dimensi}</td>
                                </tr>`;
                            });
                            
                            html += `
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            `;
                        }

                        html += `
                            <div class="card bg-dark border-secondary">
                                <div class="card-body p-2">
                                    <details>
                                        <summary style="cursor: pointer; font-size: 0.8rem;" class="text-muted">
                                            <i class="bi bi-code-square me-1"></i> Detection Log
                                        </summary>
                                        <pre class="mb-0 mt-2 p-2 bg-black rounded" style="font-size: 0.7rem; max-height: 200px; overflow-y: auto;">${response.detectionLog}</pre>
                                    </details>
                                </div>
                            </div>
                        `;

                        $('#previewArea').html(html);
                    } else {
                        $('#previewArea').html(`
                            <div class="alert alert-danger" role="alert">
                                <i class="bi bi-x-circle me-1"></i>
                                <strong>Error:</strong> ${response.message}
                            </div>
                        `);
                    }
                },
                error: function(xhr, status, error) {
                    $('#previewArea').html(`
                        <div class="alert alert-danger" role="alert">
                            <i class="bi bi-x-circle me-1"></i>
                            <strong>Error:</strong> ${error}
                        </div>
                    `);
                }
            });
        }

        // --- Bulk Delete Logic ---
        const selectAll = document.getElementById('selectAll');
        const bulkDeleteBtn = document.getElementById('bulkDeleteBtn');
        const selectedCount = document.getElementById('selectedCount');

        function updateBulkDeleteButton() {
            const checkedCount = document.querySelectorAll('.row-check:checked').length;
            if (selectedCount) selectedCount.textContent = checkedCount;
            if (bulkDeleteBtn) bulkDeleteBtn.style.display = checkedCount > 0 ? 'inline-block' : 'none';
        }

        if (selectAll) {
            selectAll.addEventListener('change', function() {
                const isChecked = this.checked;
                // Hanya pilih baris yang terlihat (yang lolos filter)
                document.querySelectorAll('#spsTable tbody tr:not([style*="display: none"]) .row-check').forEach(check => {
                    check.checked = isChecked;
                });
                updateBulkDeleteButton();
            });
        }

        // Gunakan event delegation agar bekerja setelah filter atau reload
        document.querySelector('#spsTable tbody').addEventListener('change', function(e) {
            if (e.target.classList.contains('row-check')) {
                updateBulkDeleteButton();
            }
        });

        function confirmBulkDelete() {
            const checkedIds = Array.from(document.querySelectorAll('.row-check:checked')).map(cb => parseInt(cb.value));
            
            if (checkedIds.length === 0) return;

            Swal.fire({
                title: 'Hapus ' + checkedIds.length + ' data?',
                text: "Data yang dipilih akan dihapus secara permanen!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Ya, Hapus Semua!',
                cancelButtonText: 'Batal',
                background: '#1a1d21',
                color: '#fff'
            }).then((result) => {
                if (result.isConfirmed) {
                    deleteSelected(checkedIds);
                }
            });
        }

        function deleteSelected(ids) {
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            
            fetch('@Url.Action("DeleteMultiple")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify(ids)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Swal.fire({
                        title: 'Terhapus!',
                        text: data.message,
                        icon: 'success',
                        background: '#1a1d21',
                        color: '#fff'
                    }).then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire('Gagal!', data.message, 'error');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                Swal.fire('Error!', 'Terjadi kesalahan sistem.', 'error');
            });
        }
    </script>
}
