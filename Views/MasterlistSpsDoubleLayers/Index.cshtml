                            <td class="text-white-50">@item.InnerTarget</td>
                            <td class="text-white-50">@item.InnerTol</td>
                            <td class="text-white-50">@item.InnerLCL</td>
                            <td class="text-white-50">@item.InnerMin</td>
                            <td class="text-white-50">@item.InnerUCL</td>
                            <td class="text-white-50">@item.InnerMax</td>
                            <td class="text-info fw-bold">@item.InnerMidTarget</td>
                            <td class="text-info">@item.InnerMidTol</td>
                            <td class="text-info opacity-50">@item.InnerMidLCL</td>
                            <td class="text-info opacity-50">@item.InnerMidMin</td>
                            <td class="text-info opacity-50">@item.InnerMidUCL</td>
                            <td class="text-info opacity-50">@item.InnerMidMax</td>
                            <td class="text-white-50">@item.ThickTarget</td>
                            <td class="text-white-50">@item.ThickTol</td>
                            <td class="text-white-50">@item.ThickLCL</td>
                            <td class="text-white-50">@item.ThickMin</td>
                            <td class="text-white-50">@item.ThickUCL</td>
                            <td class="text-white-50">@item.ThickMax</td>
                            <td class="text-white-50">@item.TotalTarget</td>
                            <td class="text-white-50">@item.TotalTol</td>
                            <td class="text-white-50">@item.TotalLCL</td>
                            <td class="text-white-50">@item.TotalMin</td>
                            <td class="text-white-50">@item.TotalUCL</td>
                            <td class="text-white-50">@item.TotalMax</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-xs py-1 px-3 rounded-pill text-white fw-bold">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        </div>
    </div>
</div>

<!-- Modal Import -->
<div class="modal fade" id="importModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content bg-dark text-white border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-file-earmark-excel-fill text-success me-2"></i> Import SPS Excel</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="ImportExcel" method="post" enctype="multipart/form-data" id="importForm">
                <div class="modal-body p-4">
                    <div class="alert alert-info mb-3" role="alert" style="font-size: 0.85rem;">
                        <i class="bi bi-info-circle me-1"></i>
                        <strong>Format yang didukung:</strong>
                        <ul class="mb-0 mt-2">
                            <li><strong>CHS 3 Layer</strong> - Item di kolom 106 (DG)</li>
                            <li><strong>CHS 2 Layer</strong> - Item di kolom 88 (CJ)</li>
                            <li><strong>Legacy/Non-CHS</strong> - Item di kolom 49 (AW)</li>
                        </ul>
                        <small class="text-muted">Sheet: "Parameter Setting" atau "Master 1"</small>
                    </div>
                    
                    <div class="upload-area border border-secondary border-dashed p-4 text-center rounded-3 bg-black bg-opacity-25">
                         <i class="bi bi-cloud-arrow-up fs-1 text-info mb-2 d-block"></i>
                         <input class="form-control bg-dark text-white border-secondary mb-2" type="file" id="file" name="file" accept=".xlsx,.xls" required onchange="enablePreview()">
                         <small class="text-muted">Pilih file Excel SPS (.xlsx atau .xls)</small>
                    </div>
                    
                    <!-- Preview Area -->
                    <div id="previewArea" class="mt-3" style="display:none;">
                        <div class="alert alert-warning" role="alert">
                            <i class="bi bi-hourglass-split me-1"></i>
                            <small>Preview sedang dimuat...</small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0 pb-4 justify-content-center gap-2">
                    <button type="button" id="btnPreview" class="btn btn-info px-4 rounded-pill fw-bold shadow-sm" onclick="previewExcel()" disabled>
                        <i class="bi bi-eye"></i> Preview
                    </button>
                    <button type="submit" class="btn btn-success px-5 rounded-pill fw-bold shadow-sm" onclick="showLoading()">
                        <i class="bi bi-cloud-arrow-up"></i> IMPORT SEKARANG
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
             // Real-time Filtering Logic
             $("#globalSearch, #machineFilter").on("keyup change", function() {
                 filterTable();
             });
             
             // Trigger SweetAlert for messages from TempData
             @if (TempData["SuccessMessage"] != null)
             {
                  var successMsg = TempData["SuccessMessage"]?.ToString()?.Replace("\n", "<br>")?.Replace("\r", "");
                  var sheetLog = TempData["SheetLog"]?.ToString()?.Replace("\n", "\\n")?.Replace("\r", "")?.Replace("'", "\\'");
                 
                 <text>
                 Swal.fire({
                     icon: 'success',
                     title: 'Import Berhasil!',
                     html: '<div class="text-start" style="font-size: 0.9rem;">@Html.Raw(successMsg)</div>',
                     confirmButtonText: 'OK',
                     footer: '@(TempData["SheetLog"] != null ? "<a href=\"#\" onclick=\"showSheetLog()\">Lihat Log Deteksi</a>" : "")'
                 });
                 
                 window.showSheetLog = function() {
                     Swal.fire({
                         title: 'Sheet Detection Log',
                         html: '<pre style="text-align: left; font-size: 0.7rem; max-height: 300px; overflow-y: auto; background: #f8f9fa; padding: 10px;">@Html.Raw(sheetLog)</pre>',
                         width: '600px'
                     });
                 };
                 </text>
             }
             
             @if (TempData["ErrorMessage"] != null)
             {
                  var errorMsg = TempData["ErrorMessage"]?.ToString()?.Replace("\n", "<br>")?.Replace("\r", "");
                 
                 <text>
                 Swal.fire({
                     icon: 'error',
                     title: 'Import Gagal',
                     html: '<div class="text-start" style="font-size: 0.9rem;">@Html.Raw(errorMsg)</div>',
                     confirmButtonText: 'Tutup'
                 });
                 </text>
             }
        });
        
        // Toggle collapsible detail
        function toggleDetail(elementId) {
            var element = document.getElementById(elementId);
            if (element.style.display === 'none') {
                element.style.display = 'block';
                event.target.innerHTML = '<i class="bi bi-chevron-up"></i> Sembunyikan Detail';
            } else {
                element.style.display = 'none';
                event.target.innerHTML = '<i class="bi bi-chevron-down"></i> Lihat Detail Lengkap';
            }
        }

        function filterTable() {
            let searchValue = $("#globalSearch").val().toLowerCase();
            let machineValue = $("#machineFilter").val().toLowerCase();
            let rowCount = 0;

            $("#spsTable tbody tr").each(function() {
                let rowText = $(this).text().toLowerCase();
                let machineText = $(this).find("td:nth-child(3)").text().toLowerCase(); // Machine is 3rd column

                let matchesSearch = rowText.indexOf(searchValue) > -1;
                let matchesMachine = machineValue === "" || machineText.indexOf(machineValue) > -1;

                if (matchesSearch && matchesMachine) {
                    $(this).show();
                    rowCount++;
                } else {
                    $(this).hide();
                }
            });

            $("#countDisplay").text(rowCount);
        }

        function resetFilters() {
            $("#globalSearch").val("");
            $("#machineFilter").val("");
            filterTable();
        }

        function showLoading() {
            var fileRef = document.getElementById('file');
            if(fileRef.files.length > 0) {
                $('#importModal').modal('hide');
                Swal.fire({
                    title: 'Sinkronisasi...',
                    html: 'Sedang merekam data parameter standar ke database.<br>Harap tidak menutup browser.',
                    allowOutsideClick: false,
                    didOpen: () => { Swal.showLoading(); }
                });
            }
        }

        function enablePreview() {
            var fileRef = document.getElementById('file');
            var btnPreview = document.getElementById('btnPreview');
            if(fileRef.files.length > 0) {
                btnPreview.disabled = false;
            } else {
                btnPreview.disabled = true;
            }
        }

        function previewExcel() {
            var fileRef = document.getElementById('file');
            if(fileRef.files.length === 0) {
                alert('Pilih file Excel terlebih dahulu');
                return;
            }

            var formData = new FormData();
            formData.append('file', fileRef.files[0]);

            $('#previewArea').show().html(`
                <div class="alert alert-warning" role="alert">
                    <i class="bi bi-hourglass-split me-1"></i>
                    <small>Menganalisis file Excel...</small>
                </div>
            `);

            $.ajax({
                url: '@Url.Action("PreviewExcel", "MasterlistSpsDoubleLayers")',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function(response) {
                    if(response.success) {
                        var statusClass = response.isValid ? 'success' : 'warning';
                        var statusIcon = response.isValid ? 'check-circle' : 'exclamation-triangle';
                        var statusText = response.isValid ? '✓ Valid' : '⚠ Ada Masalah';
                        
                        var html = `
                            <div class="alert alert-${statusClass}" role="alert">
                                <i class="bi bi-${statusIcon} me-1"></i>
                                <strong>${statusText}</strong>
                            </div>
                            <div class="card bg-dark border-secondary mb-2">
                                <div class="card-body p-3">
                                    <h6 class="text-white mb-2"><i class="bi bi-file-earmark-check me-1"></i> Informasi File</h6>
                                    <table class="table table-sm table-dark table-bordered" style="font-size: 0.8rem;">
                                        <tr><td><strong>File:</strong></td><td>${response.fileName}</td></tr>
                                        <tr><td><strong>Ukuran:</strong></td><td>${(response.fileSize / 1024).toFixed(2)} KB</td></tr>
                                        <tr><td><strong>Sheet Dipilih:</strong></td><td>${response.selectedSheet}</td></tr>
                                        <tr><td><strong>Format Terdeteksi:</strong></td><td><span class="badge bg-info">${response.detectedFormat}</span></td></tr>
                                        <tr><td><strong>Kolom Item:</strong></td><td>${response.expectedItemColumn}</td></tr>
                                        <tr><td><strong>Total Rows:</strong></td><td>${response.totalRows}</td></tr>
                                        <tr><td><strong>Total Columns:</strong></td><td>${response.totalColumns}</td></tr>
                                        <tr><td><strong>Estimasi Data:</strong></td><td>${response.estimatedRecords}</td></tr>
                                    </table>
                                </div>
                            </div>
                        `;

                        if (!response.isValid) {
                            html += `
                                <div class="alert alert-danger" role="alert" style="font-size: 0.85rem;">
                                    <strong>⚠ Validasi Error:</strong><br>
                                    <pre class="mb-0 mt-1" style="font-size: 0.75rem;">${response.validationError}</pre>
                                </div>
                            `;
                        }

                        if (response.sampleData && response.sampleData.length > 0) {
                            html += `
                                <div class="card bg-dark border-secondary mb-2">
                                    <div class="card-body p-3">
                                        <h6 class="text-white mb-2"><i class="bi bi-table me-1"></i> Sample Data (${response.sampleData.length} baris)</h6>
                                        <div class="table-responsive">
                                            <table class="table table-sm table-dark table-bordered" style="font-size: 0.75rem;">
                                                <thead>
                                                    <tr>
                                                        <th>Row</th><th>ID Excel</th><th>No</th><th>Machine</th>
                                                        <th>Customer</th><th>Item List</th><th>Dimensi</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                            `;
                            
                            response.sampleData.forEach(function(row) {
                                html += `<tr>
                                    <td>${row.rowIndex}</td>
                                    <td>${row.idExcel}</td>
                                    <td>${row.no}</td>
                                    <td>${row.machine}</td>
                                    <td>${row.customer}</td>
                                    <td><strong class="text-info">${row.itemList}</strong></td>
                                    <td>${row.dimensi}</td>
                                </tr>`;
                            });
                            
                            html += `
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            `;
                        }

                        html += `
                            <div class="card bg-dark border-secondary">
                                <div class="card-body p-2">
                                    <details>
                                        <summary style="cursor: pointer; font-size: 0.8rem;" class="text-muted">
                                            <i class="bi bi-code-square me-1"></i> Detection Log
                                        </summary>
                                        <pre class="mb-0 mt-2 p-2 bg-black rounded" style="font-size: 0.7rem; max-height: 200px; overflow-y: auto;">${response.detectionLog}</pre>
                                    </details>
                                </div>
                            </div>
                        `;

                        $('#previewArea').html(html);
                    } else {
                        $('#previewArea').html(`
                            <div class="alert alert-danger" role="alert">
                                <i class="bi bi-x-circle me-1"></i>
                                <strong>Error:</strong> ${response.message}
                            </div>
                        `);
                    }
                },
                error: function(xhr, status, error) {
                    $('#previewArea').html(`
                        <div class="alert alert-danger" role="alert">
                            <i class="bi bi-x-circle me-1"></i>
                            <strong>Error:</strong> ${error}
                        </div>
                    `);
                }
            });
        }
    </script>
}
