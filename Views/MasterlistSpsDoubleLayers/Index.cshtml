                        <th class="marker-re"><span class="badge-re">RE</span>Am 1</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Am 2</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Am 3</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Preset</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Control</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Sp-Set</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Sp-Disp</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Sp-Spd</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Hose-S</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Unsmooth</th>
                        <th class="marker-re"><span class="badge-re">RE</span>OD Sensor</th>

