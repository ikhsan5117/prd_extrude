                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="sticky-check"><input type="checkbox" class="row-check form-check-input" value="@item.Id" /></td>
                            <td class="sticky-id">
                                <div class="d-flex gap-1">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-xs p-1 rounded text-white" title="Details">
