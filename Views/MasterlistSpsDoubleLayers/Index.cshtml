                        <th colspan="3" class="group-label">Mesh</th>
                        <th colspan="17" class="group-label group-label-orange">Suhu Pengerjaan (°C)</th>
                        <th colspan="21" class="group-label">Output Mesin</th>
                        <th colspan="11" class="group-label group-label-orange">Proses Akhir</th>
                        <th colspan="31" class="group-label">Final Quality Matrix</th>
                        <th rowspan="2" class="align-middle">Opsi</th>
                    </tr>
                    <!-- Secondary Header Labels -->
                    <tr>
                        <th class="sticky-id">ID EXCEL</th>
                        <th>NO</th>
                        <th>Machine</th>
                        <th>ITEM List</th>
                        <th>NO. DOC</th>
                        <th>NO. REV</th>
                        <th>REV. DATE</th>
                        <th>FORMULASI</th>
                        <th>MC</th>
                        
                        <th class="marker-im"><span class="badge-im">IM</span>Customer</th>
                        <th class="marker-im"><span class="badge-im">IM</span>Hose Type</th>
                        <th>Dimensi</th>
                        <th class="marker-im"><span class="badge-im">IM</span>Material</th>
                        <th>Inner Tube</th>
                        <th>Middle Tube</th>
                        <th>Outer Cover</th>
                        <th>Use Limits In</th>
                        <th>Use Limits Mid</th>
                        <th>Use Limits Out</th>
                        <th>Yarn</th>
                        <th>Pitch Yarn</th>
                        <th>Tension In</th>
                        <th>Tension Out</th>
                        <th class="marker-im"><span class="badge-im">IM</span>Nipple</th>
                        <th class="marker-im"><span class="badge-im">IM</span>Tube Die</th>
                        <th class="marker-im"><span class="badge-im">IM</span>Middle Die</th>
                        <th class="marker-im"><span class="badge-im">IM</span>Cover Die</th>
                        <th class="marker-im"><span class="badge-im">IM</span>Spacer</th>
                        <th class="marker-im"><span class="badge-im">IM</span>A Distance</th>

                        <th>Mesh 1</th>
                        <th>Mesh 2</th>
                        <th>Mesh 3</th>

                        <th class="marker-re"><span class="badge-re">RE</span>Head 1</th>
