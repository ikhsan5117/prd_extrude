@model IEnumerable<VelastoProductionSystem.Models.MasterlistSpsDoubleLayer>

@{
    ViewData["Title"] = "Masterlist SPS (Complete Mode)";
}

<style>
    .table-container {
        max-height: 75vh;
        overflow-y: auto;
        overflow-x: auto;
        border-radius: 15px;
        background: rgba(25, 30, 40, 0.4);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
    .main-table {
        margin-bottom: 0;
        border-collapse: separate;
        border-spacing: 0;
        width: max-content; /* Ensure table stretches to its full content width inside the scroll div */
        min-width: 100%;
    }
    .main-table thead th {
        position: sticky;
        top: 0;
        z-index: 10;
        background-color: #2c3e50 !important;
        white-space: nowrap;
        font-size: 0.7rem;
        padding: 12px 10px;
        color: #fff;
        border: 0.5px solid rgba(255,255,255,0.15); /* Garis vertikal & horizontal header lebih tegas */
        text-transform: uppercase;
        vertical-align: middle;
    }
    .main-table thead tr:nth-child(1) th {
        top: 0;
        z-index: 15;
    }
    .main-table thead tr:nth-child(2) th {
        top: 40px; /* Adjust based on primary header height */
        z-index: 14;
    }
    .main-table tbody td {
        white-space: nowrap;
        font-size: 0.78rem;
        padding: 8px 12px;
        background-color: rgba(255,255,255,0.02);
        border-bottom: 0.5px solid rgba(255,255,255,0.1);
        border-right: 0.5px solid rgba(255,255,255,0.1); /* Tambahkan garis vertikal di bodi tabel */
    }
    .sticky-id {
        position: sticky;
        left: 0;
        z-index: 12;
        background-color: #1a1d21 !important;
        border-right: 2px solid #0d6efd !important;
    }
    .sticky-hose {
        position: sticky;
        left: 100px; /* Adjust based on ID width */
        z-index: 11;
        background-color: #1a1d21 !important;
        border-right: 1px solid rgba(255,255,255,0.2) !important;
    }
    .group-label {
        background-color: #0d6efd !important;
        text-align: center;
        font-weight: 800;
        letter-spacing: 1px;
    }
    .group-label-orange {
        background-color: #e67e22 !important;
    }
    .marker-im { border-left: 3px solid #dc3545 !important; }
    .marker-re { border-left: 3px solid #17a2b8 !important; }
    
    .badge-im { background: #dc3545; font-size: 0.55rem; padding: 2px 4px; border-radius: 3px; vertical-align: middle; margin-right: 4px; }
    .badge-re { background: #3498db; font-size: 0.55rem; padding: 2px 4px; border-radius: 3px; vertical-align: middle; margin-right: 4px; }
    
    .legend-box {
        background: rgba(0,0,0,0.2);
        padding: 10px 20px;
        border-radius: 10px;
        display: inline-flex;
        gap: 20px;
        font-size: 0.75rem;
        border: 1px solid rgba(59, 130, 246, 0.15);
    }
    .search-hud {
        background: rgba(13, 17, 23, 0.6);
        border: 1px solid rgba(59, 130, 246, 0.2);
        padding: 15px;
        margin-bottom: 20px;
        position: relative;
        overflow: hidden;
    }
    .search-hud::before {
        content: '';
        position: absolute;
        top: 0; left: 0; width: 4px; height: 100%;
        background: #0d6efd;
    }
    .hud-input {
        background: rgba(0,0,0,0.4);
        border: 1px solid rgba(59, 130, 246, 0.3);
        color: #fff;
        font-size: 0.85rem;
        padding: 10px 15px;
        border-radius: 0;
        transition: all 0.3s;
        cursor: pointer;
    }
    .hud-input option {
        background: #1a1d21;
        color: #fff;
        padding: 10px;
    }
    .hud-input:focus {
        background: rgba(59, 130, 246, 0.1);
        border-color: #0d6efd;
        box-shadow: 0 0 10px rgba(13, 110, 253, 0.2);
        outline: none;
    }
    .hud-label {
        font-size: 0.65rem;
        font-weight: 800;
        color: #60a5fa;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: block;
        margin-bottom: 5px;
    }
    .results-count {
        font-size: 0.7rem;
        font-weight: 900;
        color: #94a3b8;
    }
    .btn-hud-reset {
        border-radius: 0;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
    }
</style>

<div class="row fade-in">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-end mb-3">
            <div>
                <h2 class="text-white fw-bold mb-1"><i class="bi bi-file-earmark-spreadsheet-fill text-info"></i> SPS Masterlist</h2>
                <div class="legend-box">
                    <span><span class="badge-im">IM</span> 🔴 Important (Penting/Kritikal)</span>
                    <span><span class="badge-re">RE</span> 🔵 Reference (Referensi Mesin)</span>
                </div>
            </div>
            
            <div class="d-flex gap-2 mb-3">
                <form asp-action="ClearData" method="post" onsubmit="return confirm('Hapus semua data?')">
                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                        <i class="bi bi-trash"></i> Reset Data
                    </button>
                </form>
                <button type="button" class="btn btn-success btn-sm rounded-pill px-4 fw-bold shadow" data-bs-toggle="modal" data-bs-target="#importModal">
                    <i class="bi bi-cloud-arrow-up-fill"></i> Sinkronisasi Excel
                </button>
            </div>
        </div>

                <div class="search-hud shadow-sm">
            <div class="row g-3 align-items-end">
                <div class="col-lg-5">
                    <label class="hud-label"><i class="bi bi-search me-1"></i> Pencarian Cepat (Item, Doc, Customer)</label>
                    <input type="text" id="globalSearch" class="form-control hud-input" placeholder="Ketik kata kunci pencarian..." />
                </div>
                <div class="col-lg-3">
                    <label class="hud-label"><i class="bi bi-cpu me-1"></i> Filter Machine</label>
                    <select id="machineFilter" class="form-select hud-input">
                        <option value="">-- SEMUA MESIN --</option>
                        @foreach (var machine in Model.Select(m => m.Machine).Where(m => !string.IsNullOrEmpty(m)).Distinct().OrderBy(m => m))
                        {
                            <option value="@machine">@machine</option>
                        }
                    </select>
                </div>
                <div class="col-lg-2">
                    <label class="hud-label"><i class="bi bi-funnel me-1"></i> Status</label>
                    <div class="results-count p-2 border border-primary border-opacity-10 text-center">
                        DITEMUKAN: <span id="countDisplay" class="text-info">@Model.Count()</span> DATA
                    </div>
                </div>
                <div class="col-lg-2">
                    <button type="button" onclick="resetFilters()" class="btn btn-outline-info btn-hud-reset w-100 p-2">
                        <i class="bi bi-arrow-counterclockwise"></i> Reset Filter
                    </button>
                </div>
            </div>
        </div>
        <div class="table-container shadow-lg">
            <table class="table table-dark table-hover main-table" id="spsTable">
                <thead>
                    <!-- Primary Header Category -->
                    <tr>
                        <th colspan="6" class="group-label">Identifikasi Utama</th>
                        <th colspan="8" class="group-label group-label-orange">Spesifikasi Hose & Dies</th>
                        <th colspan="2" class="group-label">Mesh</th>
                        <th colspan="6" class="group-label group-label-orange">Suhu Pengerjaan (°C)</th>
                        <th colspan="4" class="group-label">Output Mesin</th>
                        <th colspan="4" class="group-label group-label-orange">Proses Akhir</th>
                        <th colspan="6" class="group-label">Final Quality Matrix</th>
                        <th rowspan="2" class="align-middle">Opsi</th>
                    </tr>
                    <!-- Secondary Header Labels -->
                    <tr>
                        <th class="sticky-id">ID EXCEL</th>
                        <th>NO</th>
                        <th>Machine</th>
                        <th>ITEM List</th>
                        <th>NO. DOC</th>
                        <th>MC</th>
                        
                        <th class="marker-im sticky-hose"><span class="badge-im">IM</span>Customer/Hose</th>
                        <th class="marker-im"><span class="badge-im">IM</span>Hose Type</th>
                        <th class="marker-im"><span class="badge-im">IM</span>Yarn</th>
                        <th class="marker-im"><span class="badge-im">IM</span>Material</th>
                        <th>Dimensi</th>
                        <th class="marker-im"><span class="badge-im">IM</span>Nipple</th>
                        <th class="marker-im"><span class="badge-im">IM</span>Tube Die</th>
                        <th class="marker-im"><span class="badge-im">IM</span>Cover Die</th>

                        <th>Mesh 1</th>
                        <th>Mesh 2</th>

                        <th class="marker-re"><span class="badge-re">RE</span>Head 1</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Head 2</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Cyl 1-1</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Cyl 1-2</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Cyl 2-1</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Cyl 2-2</th>

                        <th class="marker-re"><span class="badge-re">RE</span>Screw V1</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Screw V2</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Press 1</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Press 2</th>

                        <th class="marker-im"><span class="badge-im">IM</span>Chiller</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Cutting</th>
                        <th class="marker-re"><span class="badge-re">RE</span>Take-up</th>
                        <th>Mark Sort</th>

                        <th class="marker-im"><span class="badge-im">IM</span>± Inner</th>
                        <th class="marker-im"><span class="badge-im">IM</span>± Outer</th>
                        <th class="marker-im"><span class="badge-im">IM</span>Tebal In</th>
                        <th class="marker-im"><span class="badge-im">IM</span>Tebal Out</th>
                        <th class="marker-im bg-primary bg-opacity-10"><span class="badge-im">IM</span>Tot Tebal</th>
                        <th>Selisih</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="sticky-id text-info fw-bold">@item.ExcelId</td>
                            <td>@item.No</td>
                            <td>@item.Machine</td>
                            <td class="x-small" style="min-width: 250px; white-space: normal; line-height: 1.2;">@item.ItemList</td>
                            <td class="x-small text-white-50">@item.DocumentNumber</td>
                            <td class="fw-bold text-warning">@item.MachineCode</td>
                            
                            <td class="sticky-hose fw-bold">@item.Customer</td>
                            <td class="small text-truncate" style="max-width: 140px;">@item.HoseType</td>
                            <td class="fw-bold text-white">@item.Yarn</td>
                            <td><span class="badge bg-secondary">@item.Material</span></td>
                            <td class="text-info">@item.Dimensi</td>
                            <td>@item.Nipple</td>
                            <td>@item.TubeDie</td>
                            <td>@item.CoverDie</td>

                            <td>@item.MeshScreen1</td>
                            <td>@item.MeshScreen2</td>

                            <td class="text-warning">@item.HeadTemp1</td>
                            <td class="text-warning">@item.HeadTemp2</td>
                            <td>@item.Cylinder1_1</td>
                            <td>@item.Cylinder1_2</td>
                            <td>@item.Cylinder2_1</td>
                            <td>@item.Cylinder2_2</td>

                            <td>@item.ScrewSpeed1</td>
                            <td>@item.ScrewSpeed2</td>
                            <td>@item.Pressure1</td>
                            <td>@item.Pressure2</td>

                            <td class="text-info fw-bold">@item.ChillerWaterTemp</td>
                            <td>@item.CuttingSpeed</td>
                            <td>@item.TakeUpConveyorSpeed</td>
                            <td>@item.MarkingSort</td>

                            <td class="fw-bold">@item.ToleranceInner</td>
                            <td class="fw-bold">@item.ToleranceOuter</td>
                            <td>@item.TebalInner</td>
                            <td>@item.TebalOuter</td>
                            <td class="text-primary fw-bold">@item.TebalTotal</td>
                            <td>@item.SelisihTebal</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-xs py-1 px-3 rounded-pill text-white fw-bold">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Import -->
<div class="modal fade" id="importModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-white border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-file-earmark-excel-fill text-success me-2"></i> Import Matrix Excel</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="ImportExcel" method="post" enctype="multipart/form-data">
                <div class="modal-body p-4">
                    <p class="text-white-50 small mb-4">Sistem akan otomatis mengabaikan header dan hanya menarik baris ber-ID (contoh: 1-0, 14-0).</p>
                    <div class="upload-area border border-secondary border-dashed p-4 text-center rounded-3 bg-black bg-opacity-25">
                         <i class="bi bi-cloud-arrow-up fs-1 text-info mb-2 d-block"></i>
                         <input class="form-control bg-dark text-white border-secondary mb-2" type="file" id="file" name="file" accept=".xlsx,.xls" required>
                         <small class="text-muted">Masterlist SPS Double Layer.xlsx</small>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0 pb-4 justify-content-center">
                    <button type="submit" class="btn btn-success px-5 rounded-pill fw-bold shadow-sm" onclick="showLoading()">SINKRONISASIKAN SEKARANG</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
             // Real-time Filtering Logic
             $("#globalSearch, #machineFilter").on("keyup change", function() {
                 filterTable();
             });
        });

        function filterTable() {
            let searchValue = $("#globalSearch").val().toLowerCase();
            let machineValue = $("#machineFilter").val().toLowerCase();
            let rowCount = 0;

            $("#spsTable tbody tr").each(function() {
                let rowText = $(this).text().toLowerCase();
                let machineText = $(this).find("td:nth-child(3)").text().toLowerCase(); // Machine is 3rd column

                let matchesSearch = rowText.indexOf(searchValue) > -1;
                let matchesMachine = machineValue === "" || machineText.indexOf(machineValue) > -1;

                if (matchesSearch && matchesMachine) {
                    $(this).show();
                    rowCount++;
                } else {
                    $(this).hide();
                }
            });

            $("#countDisplay").text(rowCount);
        }

        function resetFilters() {
            $("#globalSearch").val("");
            $("#machineFilter").val("");
            filterTable();
        }

        function showLoading() {
            var fileRef = document.getElementById('file');
            if(fileRef.files.length > 0) {
                $('#importModal').modal('hide');
                Swal.fire({
                    title: 'Sinkronisasi...',
                    html: 'Sedang merekam data parameter standar ke database.<br>Harap tidak menutup browser.',
                    allowOutsideClick: false,
                    didOpen: () => { Swal.showLoading(); }
                });
            }
        }
    </script>
}
