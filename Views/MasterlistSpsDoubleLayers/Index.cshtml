@model IEnumerable<VelastoProductionSystem.Models.MasterlistSpsDoubleLayer>

@{
    ViewData["Title"] = "Masterlist SPS (Complete Mode)";
}

<style>
    .table-container {
        max-height: 75vh;
        overflow-y: auto;
        overflow-x: auto;
        border-radius: 15px;
        background: rgba(25, 30, 40, 0.4);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
    .main-table {
        margin-bottom: 0;
        border-collapse: separate;
        border-spacing: 0;
    }
    .main-table thead th {
        position: sticky;
        top: 0;
        z-index: 10;
        background-color: #2c3e50 !important;
        white-space: nowrap;
        font-size: 0.7rem;
        padding: 12px 10px;
        color: #fff;
        border: 0.5px solid rgba(255,255,255,0.15); /* Garis vertikal & horizontal header lebih tegas */
        text-transform: uppercase;
        vertical-align: middle;
    }
    .main-table thead th.sub-header {
        top: 45px; /* Adjust based on primary header height */
    }
    .main-table tbody td {
        white-space: nowrap;
        font-size: 0.78rem;
        padding: 8px 12px;
        background-color: rgba(255,255,255,0.02);
        border-bottom: 0.5px solid rgba(255,255,255,0.1);
        border-right: 0.5px solid rgba(255,255,255,0.1); /* Tambahkan garis vertikal di bodi tabel */
    }
    .sticky-id {
        position: sticky;
        left: 0;
        z-index: 11;
        background-color: #1a1d21 !important;
        border-right: 2px solid #0d6efd !important;
    }
    .group-label {
        background-color: #0d6efd !important;
        text-align: center;
        font-weight: 800;
        letter-spacing: 1px;
    }
    .group-label-orange {
        background-color: #e67e22 !important;
    }
    .marker-im { border-left: 3px solid #dc3545 !important; }
    .marker-re { border-left: 3px solid #17a2b8 !important; }
    
    .badge-im { background: #dc3545; font-size: 0.55rem; padding: 2px 4px; border-radius: 3px; vertical-align: middle; margin-right: 4px; }
    .badge-re { background: #3498db; font-size: 0.55rem; padding: 2px 4px; border-radius: 3px; vertical-align: middle; margin-right: 4px; }
    
    .legend-box {
        background: rgba(0,0,0,0.2);
        padding: 10px 20px;
        border-radius: 10px;
        display: inline-flex;
        gap: 20px;
        font-size: 0.75rem;
        border: 1px solid rgba(59, 130, 246, 0.15);
    }
    .search-hud {
        background: rgba(13, 17, 23, 0.6);
        border: 1px solid rgba(59, 130, 246, 0.2);
        padding: 15px;
        margin-bottom: 20px;
        position: relative;
        overflow: hidden;
    }
    .search-hud::before {
        content: '';
        position: absolute;
        top: 0; left: 0; width: 4px; height: 100%;
        background: #0d6efd;
    }
    .hud-input {
        background: rgba(0,0,0,0.4);
        border: 1px solid rgba(59, 130, 246, 0.3);
        color: #fff;
        font-size: 0.85rem;
        padding: 10px 15px;
        border-radius: 0;
        transition: all 0.3s;
        cursor: pointer;
    }
    .hud-input option {
        background: #1a1d21;
        color: #fff;
        padding: 10px;
    }
    .hud-input:focus {
        background: rgba(59, 130, 246, 0.1);
        border-color: #0d6efd;
        box-shadow: 0 0 10px rgba(13, 110, 253, 0.2);
        outline: none;
    }
    .hud-label {
        font-size: 0.65rem;
        font-weight: 800;
        color: #60a5fa;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: block;
        margin-bottom: 5px;
    }
    .results-count {
        font-size: 0.7rem;
        font-weight: 900;
        color: #94a3b8;
    }
    .btn-hud-reset {
        border-radius: 0;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
    }
    
    /* Modern Alert Notifications */
    .modern-alert {
        position: fixed;
        top: 20px;
        right: 20px;
        max-width: 450px;
        min-width: 350px;
        z-index: 9999;
        animation: slideInRight 0.4s ease-out;
        box-shadow: 0 10px 40px rgba(0,0,0,0.4);
    }
    
    @@keyframes slideInRight {
        from {
            transform: translateX(500px);
            opacity: 0;
        }
        to {
            transform: translateX(0);
            opacity: 1;
        }
    }
    
    @@keyframes slideDown {
        from {
            transform: translateY(-100px);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }
    
    /* Stack multiple alerts vertically */
    #successAlert {
        top: 20px;
    }
    
    #errorAlert {
        top: 20px;
    }
    
    #infoAlert {
        top: 180px; /* Below success/error alert */
    }
    
    .alert-compact {
        padding: 15px 20px;
        border-radius: 12px;
        border: none;
        backdrop-filter: blur(10px);
    }
    
    .alert-success-modern {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: white;
    }
    
    .alert-danger-modern {
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        color: white;
    }
    
    .alert-info-modern {
        background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
        color: white;
    }
    
    .alert-detail {
        font-size: 0.85rem;
        margin-top: 10px;
        padding: 10px;
        background: rgba(255,255,255,0.15);
        border-radius: 6px;
        border-left: 3px solid rgba(255,255,255,0.5);
    }
    
    .alert-detail-row {
        display: flex;
        justify-content: space-between;
        padding: 3px 0;
        font-size: 0.8rem;
    }
    
    .alert-detail-label {
        font-weight: 600;
        opacity: 0.9;
    }
    
    .alert-detail-value {
        font-weight: 700;
    }
    
    .alert-collapsible {
        cursor: pointer;
        user-select: none;
        font-size: 0.75rem;
        opacity: 0.8;
        margin-top: 8px;
        padding: 5px 10px;
        background: rgba(255,255,255,0.1);
        border-radius: 4px;
        display: inline-block;
    }
    
    .alert-collapsible:hover {
        opacity: 1;
        background: rgba(255,255,255,0.2);
    }
    
    .alert-collapsible-content {
        max-height: 150px;
        overflow-y: auto;
        font-size: 0.7rem;
        margin-top: 8px;
        padding: 8px;
        background: rgba(0,0,0,0.2);
        border-radius: 4px;
        font-family: 'Courier New', monospace;
        white-space: pre-wrap;
    }
    
    .btn-close-white {
        filter: brightness(0) invert(1);
        opacity: 0.8;
    }
    
    .btn-close-white:hover {
        opacity: 1;
    }
    
    /* Responsive Design */
    @@media (max-width: 768px) {
        .modern-alert {
            max-width: calc(100vw - 40px);
            min-width: unset;
            right: 10px;
            left: 10px;
            top: 10px;
        }
        
        #infoAlert {
            top: 150px;
        }
    }
</style>

<div class="row fade-in">
    <div class="col-12">
        <!-- Modern Alert Notifications -->
        <!-- Alerts removed from here to use SweetAlert instead -->

        <div class="d-flex justify-content-between align-items-end mb-3">
            <div>
                <h2 class="text-white fw-bold mb-1"><i class="bi bi-file-earmark-spreadsheet-fill text-info"></i> SPS Masterlist</h2>
                <div class="legend-box">
                    <span><span class="badge-im">IM</span> 🔴 Important (Penting/Kritikal)</span>
                    <span><span class="badge-re">RE</span> 🔵 Reference (Referensi Mesin)</span>
                </div>
            </div>
            
            <div class="d-flex gap-2 mb-3">
                <form asp-action="ClearData" method="post" onsubmit="return confirm('Hapus semua data?')">
                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                        <i class="bi bi-trash"></i> Reset Data
                    </button>
                </form>
                <button type="button" class="btn btn-success btn-sm rounded-pill px-4 fw-bold shadow" data-bs-toggle="modal" data-bs-target="#importModal">
                    <i class="bi bi-cloud-arrow-up-fill"></i> Sinkronisasi Excel
                </button>
            </div>
        </div>

                <div class="search-hud shadow-sm">
            <div class="row g-3 align-items-end">
                <div class="col-lg-5">
                    <label class="hud-label"><i class="bi bi-search me-1"></i> Pencarian Cepat (Item, Doc, Customer)</label>
                    <input type="text" id="globalSearch" class="form-control hud-input" placeholder="Ketik kata kunci pencarian..." />
                </div>
                <div class="col-lg-3">
                    <label class="hud-label"><i class="bi bi-cpu me-1"></i> Filter Machine</label>
                    <select id="machineFilter" class="form-select hud-input">
                        <option value="">-- SEMUA MESIN --</option>
                        @foreach (var machine in Model.Select(m => m.Machine).Where(m => !string.IsNullOrEmpty(m)).Distinct().OrderBy(m => m))
                        {
                            <option value="@machine">@machine</option>
                        }
                    </select>
                </div>
                <div class="col-lg-2">
                    <label class="hud-label"><i class="bi bi-funnel me-1"></i> Status</label>
                    <div class="results-count p-2 border border-primary border-opacity-10 text-center">
                        DITEMUKAN: <span id="countDisplay" class="text-info">@Model.Count()</span> DATA
                    </div>
                </div>
                <div class="col-lg-2">
                    <button type="button" onclick="resetFilters()" class="btn btn-outline-info btn-hud-reset w-100 p-2">
                        <i class="bi bi-arrow-counterclockwise"></i> Reset Filter
                    </button>
                </div>
            </div>
        </div>
        <div class="table-container shadow-lg">
            <table class="table table-dark table-hover main-table" id="spsTable">
                <thead>
