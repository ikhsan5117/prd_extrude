@model VelastoProductionSystem.Models.MasterlistSpsDoubleLayer

@{
    ViewData["Title"] = "Tambah SPS Master";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-white fw-bold mb-0"><i class="bi bi-plus-circle-fill text-primary me-2"></i> Tambah SPS Master</h2>
            <p class="text-white-50 small mb-0">Input data spesifikasi teknis produksi baru secara manual</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-light rounded-pill px-4">
            <i class="bi bi-arrow-left me-2"></i> Kembali ke Daftar
        </a>
    </div>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        
        <partial name="_SpsForm" />

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary rounded-pill px-5 py-2 fw-bold shadow">
                <i class="bi bi-check-circle-fill me-2"></i> Simpan Data
            </button>
            <button type="reset" class="btn btn-outline-secondary rounded-pill px-4 py-2">
                <i class="bi bi-arrow-counterclockwise me-2"></i> Reset
            </button>
        </div>
    </form>
</div>
