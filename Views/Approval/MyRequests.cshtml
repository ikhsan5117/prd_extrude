@model List<VelastoProductionSystem.Models.ApprovalRequest>
@using VelastoProductionSystem.Models
@{
    ViewData["Title"] = "My Approval Requests";
}

<div class="container-fluid py-3">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-info text-dark d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Approval Request Saya</h5>
            <div class="d-flex gap-2">
                <a asp-action="Request" asp-route-actionType="SpsDocumentCreate" class="btn btn-sm btn-success">Tambah Request</a>
                <a asp-controller="SpsMaster" asp-action="Index" class="btn btn-sm btn-outline-dark">Kembali ke SPS</a>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Status</th>
                            <th>Aksi</th>
                            <th>Target</th>
                            <th>Komentar Request</th>
                            <th>Komentar Admin</th>
                            <th>Dibuat</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">Belum ada request approval.</td></tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.RequestCode</td>
                                <td>
                                    @if (item.Status == ApprovalRequestStatus.Pending)
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                    else if (item.Status == ApprovalRequestStatus.Approved)
                                    {
                                        <span class="badge bg-success">Approved</span>
                                    }
                                    else if (item.Status == ApprovalRequestStatus.Rejected)
                                    {
                                        <span class="badge bg-danger">Rejected</span>
                                    }
                                    else if (item.Status == ApprovalRequestStatus.Consumed)
                                    {
                                        <span class="badge bg-secondary">Consumed</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-dark">@item.Status</span>
                                    }
                                </td>
                                <td>@item.ActionType</td>
                                <td>@item.TargetKey</td>
                                <td>@item.RequestComment</td>
                                <td>@item.ApproverComment</td>
                                <td>@item.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                                <td><a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Detail</a></td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
