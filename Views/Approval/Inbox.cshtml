@model List<VelastoProductionSystem.Models.ApprovalRequest>
@using VelastoProductionSystem.Models
@{
    ViewData["Title"] = "Approval Inbox";
    var filter = (string?)ViewBag.StatusFilter;
}

<style>
    .approval-inbox-card {
        overflow: visible !important;
    }
    .approval-table-scroll {
        max-height: 70vh;
        overflow: auto;
    }
    .approval-table-scroll thead th {
        position: sticky;
        top: 0;
        z-index: 2;
        background-color: #212529; /* bg-dark equivalent */
        color: white;
    }
</style>

<div class="container-fluid py-3">
    <div class="card shadow-sm border-0 approval-inbox-card">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Admin Approval Inbox</h5>
            <form method="get" class="d-flex gap-2">
                <select class="form-select form-select-sm" name="status">
                    <option value="">Semua Status</option>
                    <option value="Pending" selected="@(filter == "Pending")">Pending</option>
                    <option value="RevisionRequired" selected="@(filter == "RevisionRequired")">Revision Required</option>
                    <option value="Approved" selected="@(filter == "Approved")">Approved</option>
                    <option value="Rejected" selected="@(filter == "Rejected")">Rejected</option>
                    <option value="Consumed" selected="@(filter == "Consumed")">Consumed</option>
                </select>
                <button class="btn btn-sm btn-primary" type="submit">Filter</button>
            </form>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive approval-table-scroll">
                <table class="table table-striped table-hover mb-0" id="inboxTable">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Status</th>
                            <th>Requester</th>
                            <th>Aksi</th>
                            <th>Target</th>
                            <th>Pesan Request</th>
                            <th>Tanggal</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">Inbox approval kosong.</td></tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr class="inbox-row">
                                <td>@item.RequestCode</td>
                                <td>
                                    @if (item.Status == ApprovalRequestStatus.Pending)
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                    else if (item.Status == ApprovalRequestStatus.RevisionRequired)
                                    {
                                        <span class="badge bg-warning text-dark">Revision Required</span>
                                    }
                                    else if (item.Status == ApprovalRequestStatus.Approved)
                                    {
                                        <span class="badge bg-success">Approved</span>
                                    }
                                    else if (item.Status == ApprovalRequestStatus.Rejected)
                                    {
                                        <span class="badge bg-danger">Rejected</span>
                                    }
                                    else if (item.Status == ApprovalRequestStatus.Consumed)
                                    {
                                        <span class="badge bg-secondary">Consumed</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-dark">@item.Status</span>
                                    }
                                </td>
                                <td>@item.RequesterUserName (@item.RequesterRole)</td>
                                <td>@item.ActionType</td>
                                <td>@item.TargetKey</td>
                                <td>@item.RequestComment</td>
                                <td>@item.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                                <td><a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Review</a></td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer d-flex justify-content-between align-items-center bg-white" id="inboxPaginationBar">
            <span id="inboxPageInfo" class="text-muted small"></span>
            <div class="d-flex gap-2">
                <button type="button" id="inboxPrevBtn" class="btn btn-sm btn-outline-secondary">Prev</button>
                <button type="button" id="inboxNextBtn" class="btn btn-sm btn-outline-secondary">Next</button>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        const rowsPerPage = 50;
        const rows = Array.from(document.querySelectorAll('#inboxTable tbody tr.inbox-row'));
        const paginationBar = document.getElementById('inboxPaginationBar');
        const pageInfo = document.getElementById('inboxPageInfo');
        const prevBtn = document.getElementById('inboxPrevBtn');
        const nextBtn = document.getElementById('inboxNextBtn');

        if (!rows.length || !paginationBar || !pageInfo || !prevBtn || !nextBtn) {
            if (paginationBar) {
                paginationBar.classList.add('d-none');
            }
            return;
        }

        let currentPage = 1;
        const totalPages = Math.max(1, Math.ceil(rows.length / rowsPerPage));

        const renderPage = function () {
            const start = (currentPage - 1) * rowsPerPage;
            const end = start + rowsPerPage;

            rows.forEach(function (row, index) {
                row.style.display = index >= start && index < end ? '' : 'none';
            });

            pageInfo.textContent = 'Page ' + currentPage + ' / ' + totalPages + ' (' + rows.length + ' rows)';
            prevBtn.disabled = currentPage <= 1;
            nextBtn.disabled = currentPage >= totalPages;
        };

        prevBtn.addEventListener('click', function () {
            if (currentPage > 1) {
                currentPage--;
                renderPage();
            }
        });

        nextBtn.addEventListener('click', function () {
            if (currentPage < totalPages) {
                currentPage++;
                renderPage();
            }
        });

        if (totalPages <= 1) {
            paginationBar.classList.add('d-none');
        }

        renderPage();
    })();
</script>
