@model VelastoProductionSystem.Models.ApprovalRequest
@using VelastoProductionSystem.Models
@using System.Text.Json
@using System.Reflection
@using System.ComponentModel.DataAnnotations
@{
    ViewData["Title"] = "Approval Details";
    var role = Context.Session.GetString("UserRole") ?? string.Empty;
    var canReview = role == "SUPERADMIN";
    var isOwner = string.Equals(Context.Session.GetString("UserName"), Model.RequesterUserName, StringComparison.OrdinalIgnoreCase);

    SpsMaster? spsPayload = null;
    SpsMaster? beforeSpsPayload = null;
    SpsItemList? itemPayload = null;
    SpsItemList? beforeItemPayload = null;
    var payloadKind = string.Empty;
    var payloadError = string.Empty;

    string Normalize(string? value) => string.IsNullOrWhiteSpace(value) ? string.Empty : value.Trim();

    var propMap = typeof(SpsMaster)
        .GetProperties(BindingFlags.Public | BindingFlags.Instance)
        .ToDictionary(p => p.Name, p => p, StringComparer.OrdinalIgnoreCase);

    string GetDisplayLabel(string propertyName)
    {
        if (!propMap.TryGetValue(propertyName, out var prop))
        {
            return propertyName;
        }

        var display = prop.GetCustomAttribute<DisplayAttribute>();
        return string.IsNullOrWhiteSpace(display?.Name) ? propertyName : display!.Name!;
    }

    string GetValue(SpsMaster model, string propertyName)
    {
        if (!propMap.TryGetValue(propertyName, out var prop))
        {
            return string.Empty;
        }

        var raw = prop.GetValue(model);
        if (raw == null)
        {
            return string.Empty;
        }

        if (raw is bool boolValue)
        {
            return boolValue ? "Active" : "Inactive";
        }

        return raw.ToString() ?? string.Empty;
    }

    string GetTripletParameterLabel(string propertyBase)
    {
        if (propMap.ContainsKey(propertyBase))
        {
            return GetDisplayLabel(propertyBase);
        }

        foreach (var suffix in new[] { "_Asli", "_Min", "_Max" })
        {
            var propName = propertyBase + suffix;
            if (propMap.TryGetValue(propName, out var prop))
            {
                var display = prop.GetCustomAttribute<DisplayAttribute>()?.Name ?? propName;
                return display
                    .Replace(" Asli", string.Empty, StringComparison.OrdinalIgnoreCase)
                    .Replace(" Min", string.Empty, StringComparison.OrdinalIgnoreCase)
                    .Replace(" Max", string.Empty, StringComparison.OrdinalIgnoreCase)
                    .Trim();
            }
        }

        return propertyBase;
    }

    var requiredSpsFields = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
    {
        "DocumentNumber", "Machine", "MachineCode", "Customer", "HoseType", "Dimensi", "Material"
    };

    List<(string PropertyName, string Label, string Value, bool Required, bool Missing)> BuildRows(SpsMaster model, IEnumerable<string> propertyNames)
    {
        var rows = new List<(string PropertyName, string Label, string Value, bool Required, bool Missing)>();
        foreach (var propertyName in propertyNames.Distinct(StringComparer.OrdinalIgnoreCase))
        {
            if (!propMap.ContainsKey(propertyName))
            {
                continue;
            }

            var value = Normalize(GetValue(model, propertyName));
            var required = requiredSpsFields.Contains(propertyName);
            var missing = required && string.IsNullOrWhiteSpace(value);
            rows.Add((propertyName, GetDisplayLabel(propertyName), value, required, missing));
        }

        return rows;
    }

    if (!string.IsNullOrWhiteSpace(Model.PayloadJson))
    {
        try
        {
            switch (Model.ActionType)
            {
                case ApprovalActionType.SpsDocumentCreate:
                case ApprovalActionType.SpsDocumentEdit:
                    {
                        payloadKind = Model.ActionType == ApprovalActionType.SpsDocumentCreate ? "No.Document - Create" : "No.Document - Revisi";
                        spsPayload = JsonSerializer.Deserialize<SpsMaster>(Model.PayloadJson);
                    }
                    break;

                case ApprovalActionType.SpsItemCreate:
                case ApprovalActionType.SpsItemEdit:
                    {
                        payloadKind = Model.ActionType == ApprovalActionType.SpsItemCreate ? "Item List - Create" : "Item List - Revisi";
                        itemPayload = JsonSerializer.Deserialize<SpsItemList>(Model.PayloadJson);
                    }
                    break;
            }
        }
        catch (Exception ex)
        {
            payloadError = ex.Message;
        }
    }

    var beforeSpsPayloadJson = ViewBag.BeforeSpsPayloadJson as string;
    if (!string.IsNullOrWhiteSpace(beforeSpsPayloadJson))
    {
        try
        {
            beforeSpsPayload = JsonSerializer.Deserialize<SpsMaster>(beforeSpsPayloadJson);
        }
        catch
        {
            beforeSpsPayload = null;
        }
    }

    var beforeItemPayloadJson = ViewBag.BeforeItemPayloadJson as string;
    if (!string.IsNullOrWhiteSpace(beforeItemPayloadJson))
    {
        try
        {
            beforeItemPayload = JsonSerializer.Deserialize<SpsItemList>(beforeItemPayloadJson);
        }
        catch
        {
            beforeItemPayload = null;
        }
    }

    var compareSpsMode = Model.ActionType == ApprovalActionType.SpsDocumentEdit && spsPayload != null && beforeSpsPayload != null;
    var compareItemMode = Model.ActionType == ApprovalActionType.SpsItemEdit && itemPayload != null && beforeItemPayload != null;

    var headerInfoFields = new List<string>
    {
        "No", "DocumentNumber", "RevisionNumber", "RevisionDate", "Machine", "MachineCode", "Customer", "HoseType", "Formulasi", "IsActive"
    };

    var productSpecFields = new List<string>
    {
        "Dimensi", "Material", "InnerTube", "MiddleTube", "OuterCover", "UseLimitsInner", "UseLimitsMiddle", "UseLimitsOuter",
        "Yarn", "TensionYarnInner", "TensionYarnOuter", "Nipple", "TubeDie", "MiddleDie", "CoverDie", "SpacerDie", "ADistance",
        "MeshDim1", "MeshScreen1", "MeshDim2", "MeshScreen2", "MeshDim3", "MeshScreen3"
    };

    var machineSettingFields = new List<string>
    {
        "MarkingSort", "TextMarkingMaterial", "MarkingColour", "OdSensor", "AmMeter", "AmMeter2", "AmMeter3",
        "TakeUpConveyorSpeed", "CoolConveyorSpeed", "CoolConveyorSpeed2", "ConveyorRatio", "CaterpillarGap", "DancerPosition"
    };

    var processParameterFields = new List<string>
    {
        "HeadTemp1", "HeadTemp2", "HeadTemp3", "Cylinder1_1", "Cylinder1_2", "Cylinder1_3",
        "Cylinder2_1", "Cylinder2_2", "Cylinder2_3", "Cylinder3_1", "Cylinder3_2", "Cylinder3_3",
        "ScrewTemp1", "ScrewTemp2", "ScrewTemp3", "Feed1", "Feed2", "Feed3",
        "ScrewSpeed1", "ScrewSpeed2", "ScrewSpeed3", "Pressure1", "Pressure2", "Pressure3",
        "ChillerWaterTemp", "CuttingSpeed", "PitchYarn", "FeedRollRatio1", "FeedRollRatio2", "FeedRollRatio3",
        "CurrentValue", "PresetValue", "ControlValue", "SpiralPitchSetting", "SpiralPitchDisplay", "SpiralSpeed", "HoseSpeed", "UnsmoothSurface"
    };

    // Legacy single-value fields with triplet counterparts.
    var tripletBackedLegacyFields = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
    {
        "OdSensor", "AmMeter", "AmMeter2", "AmMeter3",
        "TakeUpConveyorSpeed", "ChillerWaterTemp", "CuttingSpeed",
        "CaterpillarGap", "CoolConveyorSpeed", "CoolConveyorSpeed2", "ConveyorRatio", "DancerPosition",
        "CurrentValue", "PresetValue", "ControlValue",
        "SpiralPitchSetting", "SpiralPitchDisplay", "SpiralSpeed", "HoseSpeed",
        "PitchYarn", "FeedRollRatio1", "FeedRollRatio2", "FeedRollRatio3"
    };

    var toleranceFields = propMap.Keys
        .Where(k => k.EndsWith("_Min", StringComparison.OrdinalIgnoreCase)
            || k.EndsWith("_Asli", StringComparison.OrdinalIgnoreCase)
            || k.EndsWith("_Max", StringComparison.OrdinalIgnoreCase)
            || k is "ToleranceInner" or "ToleranceOuter" or "ToleranceSpiralPitch"
            || k is "TebalInner" or "TebalInnerMiddle" or "TebalOuter" or "TebalTotal" or "SelisihTebal"
            || k is "InnerTarget" or "InnerTol" or "InnerLCL" or "InnerMin" or "InnerUCL" or "InnerMax"
            || k is "InnerMidTarget" or "InnerMidTol" or "InnerMidLCL" or "InnerMidMin" or "InnerMidUCL" or "InnerMidMax"
            || k is "ThickTarget" or "ThickTol" or "ThickLCL" or "ThickMin" or "ThickUCL" or "ThickMax"
            || k is "TotalTarget" or "TotalTol" or "TotalLCL" or "TotalMin" or "TotalUCL" or "TotalMax")
        .OrderBy(k => k)
        .ToList();

    // Any base field that already has _Min/_Asli/_Max should be shown only in Standard Toleransi.
    var tripletBackedFields = new HashSet<string>(tripletBackedLegacyFields, StringComparer.OrdinalIgnoreCase);
    foreach (var baseField in toleranceFields
        .Where(f => f.EndsWith("_Min", StringComparison.OrdinalIgnoreCase))
        .Select(f => f.Substring(0, f.Length - 4)))
    {
        tripletBackedFields.Add(baseField);
    }

    productSpecFields = productSpecFields
        .Where(f => !tripletBackedFields.Contains(f))
        .ToList();

    machineSettingFields = machineSettingFields
        .Where(f => !tripletBackedFields.Contains(f))
        .ToList();

    processParameterFields = processParameterFields
        .Where(f => !tripletBackedFields.Contains(f))
        .ToList();

    var allSectionFields = headerInfoFields
        .Concat(productSpecFields)
        .Concat(machineSettingFields)
        .Concat(processParameterFields)
        .Concat(toleranceFields)
        .ToHashSet(StringComparer.OrdinalIgnoreCase);

    var remainingFields = propMap.Keys
        .Where(k => !allSectionFields.Contains(k)
            && !string.Equals(k, "ItemList", StringComparison.OrdinalIgnoreCase)
            && !tripletBackedFields.Contains(k))
        .OrderBy(k => k)
        .ToList();

    processParameterFields.AddRange(remainingFields);

    var spsHeaderRows = spsPayload == null ? new List<(string PropertyName, string Label, string Value, bool Required, bool Missing)>() : BuildRows(spsPayload, headerInfoFields);
    var spsProductRows = spsPayload == null ? new List<(string PropertyName, string Label, string Value, bool Required, bool Missing)>() : BuildRows(spsPayload, productSpecFields);
    var spsMachineRows = spsPayload == null ? new List<(string PropertyName, string Label, string Value, bool Required, bool Missing)>() : BuildRows(spsPayload, machineSettingFields);
    var spsProcessRows = spsPayload == null ? new List<(string PropertyName, string Label, string Value, bool Required, bool Missing)>() : BuildRows(spsPayload, processParameterFields);
    var spsToleranceRows = spsPayload == null ? new List<(string PropertyName, string Label, string Value, bool Required, bool Missing)>() : BuildRows(spsPayload, toleranceFields);

    var toleranceTripletRows = new List<(string PropertyBase, string Label, string Min, string Actual, string Max)>();
    var toleranceSingleRows = new List<(string PropertyName, string Label, string Value)>();

    if (spsPayload != null)
    {
        var tripletBases = toleranceFields
            .Where(f => f.EndsWith("_Min", StringComparison.OrdinalIgnoreCase))
            .Select(f => f.Substring(0, f.Length - 4))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(f => f)
            .ToList();

        foreach (var propertyBase in tripletBases)
        {
            var minValue = Normalize(GetValue(spsPayload, propertyBase + "_Min"));
            var actualValue = Normalize(GetValue(spsPayload, propertyBase + "_Asli"));
            var maxValue = Normalize(GetValue(spsPayload, propertyBase + "_Max"));

            toleranceTripletRows.Add((
                propertyBase,
                GetTripletParameterLabel(propertyBase),
                minValue,
                actualValue,
                maxValue));
        }

        var singleToleranceFields = toleranceFields
            .Where(f => !f.EndsWith("_Min", StringComparison.OrdinalIgnoreCase)
                && !f.EndsWith("_Asli", StringComparison.OrdinalIgnoreCase)
                && !f.EndsWith("_Max", StringComparison.OrdinalIgnoreCase))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(f => f)
            .ToList();

        foreach (var propertyName in singleToleranceFields)
        {
            var value = Normalize(GetValue(spsPayload, propertyName));
            if (string.IsNullOrWhiteSpace(value))
            {
                continue;
            }

            toleranceSingleRows.Add((propertyName, GetDisplayLabel(propertyName), value));
        }
    }

    var allSpsRows = spsHeaderRows
        .Concat(spsProductRows)
        .Concat(spsMachineRows)
        .Concat(spsProcessRows)
        .Concat(spsToleranceRows)
        .ToList();

    var missingRequired = allSpsRows.Where(r => r.Required && r.Missing).ToList();
    var filledCount = allSpsRows.Count(r => !string.IsNullOrWhiteSpace(r.Value));

    var approvalDetailsReturnUrl = Url.Action("Details", "Approval", new { id = Model.Id });
    string? editRequestUrl = null;
    var supervisorMarkedFields = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    var supervisorMarkedFieldComments = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

    string NormalizeFieldKey(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var chars = value
            .Where(char.IsLetterOrDigit)
            .Select(char.ToLowerInvariant)
            .ToArray();

        return new string(chars);
    }

    if (!string.IsNullOrWhiteSpace(Model.ApproverComment))
    {
        var lines = Model.ApproverComment
            .Replace("\r", string.Empty)
            .Split('\n', StringSplitOptions.RemoveEmptyEntries);

        foreach (var rawLine in lines)
        {
            var line = rawLine.Trim();
            if (!line.StartsWith("-"))
            {
                continue;
            }

            var field = line.TrimStart('-').Trim();
            string? fieldComment = null;

            var separatorIndex = field.IndexOf(':');
            if (separatorIndex > 0)
            {
                fieldComment = field[(separatorIndex + 1)..].Trim();
                field = field[..separatorIndex].Trim();
            }

            if (!string.IsNullOrWhiteSpace(field))
            {
                var normalizedField = NormalizeFieldKey(field);
                if (!string.IsNullOrWhiteSpace(normalizedField))
                {
                    supervisorMarkedFields.Add(normalizedField);
                    if (!string.IsNullOrWhiteSpace(fieldComment))
                    {
                        supervisorMarkedFieldComments[normalizedField] = fieldComment;
                    }
                }
            }
        }
    }

    var supervisorMarkedFieldListJson = JsonSerializer.Serialize(supervisorMarkedFields.ToList());
    var supervisorMarkedFieldCommentsJson = JsonSerializer.Serialize(supervisorMarkedFieldComments);

    bool IsSupervisorMarked(params string[] candidates)
    {
        foreach (var candidate in candidates)
        {
            var normalized = NormalizeFieldKey(candidate);
            if (!string.IsNullOrWhiteSpace(normalized) && supervisorMarkedFields.Contains(normalized))
            {
                return true;
            }
        }

        return false;
    }

    if (isOwner && (Model.Status == ApprovalRequestStatus.Draft || Model.Status == ApprovalRequestStatus.RevisionRequired))
    {
        switch (Model.ActionType)
        {
            case ApprovalActionType.SpsDocumentCreate:
                editRequestUrl = Url.Action("Create", "SpsMaster", new { requestId = Model.Id, returnUrl = approvalDetailsReturnUrl });
                break;
            case ApprovalActionType.SpsDocumentEdit:
                editRequestUrl = Url.Action("Edit", "SpsMaster", new { documentNumber = Model.TargetKey, requestId = Model.Id, returnUrl = approvalDetailsReturnUrl });
                break;
            case ApprovalActionType.SpsItemCreate:
                editRequestUrl = Url.Action("Create", "SpsItemList", new { requestId = Model.Id, returnUrl = approvalDetailsReturnUrl });
                break;
            case ApprovalActionType.SpsItemEdit:
                if (int.TryParse(Model.TargetKey, out var itemId))
                {
                    editRequestUrl = Url.Action("Edit", "SpsItemList", new { id = itemId, requestId = Model.Id, returnUrl = approvalDetailsReturnUrl });
                }
                break;
        }
    }

    var canEditPayload = isOwner
        && (Model.Status == ApprovalRequestStatus.Draft || Model.Status == ApprovalRequestStatus.RevisionRequired)
        && (spsPayload != null || itemPayload != null);

    var statusBadgeClass = Model.Status switch
    {
        ApprovalRequestStatus.Pending => "bg-warning text-dark",
        ApprovalRequestStatus.RevisionRequired => "bg-warning text-dark",
        ApprovalRequestStatus.Approved => "bg-success",
        ApprovalRequestStatus.Rejected => "bg-danger",
        ApprovalRequestStatus.Draft => "bg-secondary",
        ApprovalRequestStatus.Consumed => "bg-secondary",
        _ => "bg-dark"
    };
}

