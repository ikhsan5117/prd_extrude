                                @foreach (var row in spsProcessRows)
                                {
                                    var beforeValue = compareSpsMode ? Normalize(GetValue(beforeSpsPayload!, row.PropertyName)) : string.Empty;
                                    var afterValue = Normalize(row.Value);
                                    <tr class="@(compareSpsMode && !string.Equals(beforeValue, afterValue, StringComparison.Ordinal) ? "compare-row-changed" : string.Empty)">
                                        <td>@row.Label <small class="text-muted">(@row.PropertyName)</small></td>
                                        @if (compareSpsMode)
                                        {
                                            <td><span class="compare-before">@(string.IsNullOrWhiteSpace(beforeValue) ? "-" : beforeValue)</span></td>
                                            <td>
                                                @if (canEditPayload)
                                                {
                                                    <input type="text" name="payload_@row.PropertyName" class="form-control form-control-sm" value="@row.Value" />
                                                }
                                                else
                                                {
                                                    @(string.IsNullOrWhiteSpace(row.Value) ? "-" : row.Value)
                                                }
                                            </td>
                                        }
                                        else
                                        {
                                            <td>
                                                @if (canEditPayload)
                                                {
                                                    <input type="text" name="payload_@row.PropertyName" class="form-control form-control-sm" value="@row.Value" />
                                                }
                                                else
                                                {
                                                    @(string.IsNullOrWhiteSpace(row.Value) ? "-" : row.Value)
                                                }
                                            </td>
                                        }
                                        <td>
                                            @if (canReview && Model.Status == ApprovalRequestStatus.Pending)
                                            {
                                                <select class="form-select form-select-sm manual-validation-mark" aria-label="Validasi admin">
                                                    <option value="">-</option>
                                                    <option value="x">X</option>
                                                </select>
                                            }
                                            else
                                            {
                                                @if (Model.Status == ApprovalRequestStatus.RevisionRequired && IsSupervisorMarked(row.Label, row.PropertyName, $"{row.Label} ({row.PropertyName})"))
                                                {
                                                    <span class="badge bg-danger">X</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            }
                                        </td>
                                    </tr>
                                }
                                </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm border-0 mt-3 submission-section">
                    <div class="card-header bg-dark text-white">
                        <strong>5. Standard Toleransi (Min / Actual / Max)</strong>
                        <p class="tolerance-note">Geser horizontal untuk melihat semua kolom Min/Actual/Max dengan jelas.</p>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive tolerance-primary-wrap">
                            <table class="table table-sm table-striped mb-0 tolerance-primary-table">
                                <thead>
                                    <tr>
                                        <th style="width: 34%;">Parameter</th>
                                        <th style="width: 16%;">Min</th>
                                        <th style="width: 16%;">Actual</th>
                                        <th style="width: 16%;">Max</th>
                                        <th style="width: 10%;">Status</th>
                                        <th style="width: 8%;">Validasi</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @if (!toleranceTripletRows.Any())
                                {
                                    <tr><td colspan="6" class="text-muted text-center">Belum ada struktur parameter Min / Actual / Max.</td></tr>
                                }
                                else
                                {
                                    @foreach (var row in toleranceTripletRows)
                                    {
                                        var beforeMin = compareSpsMode ? Normalize(GetValue(beforeSpsPayload!, row.PropertyBase + "_Min")) : string.Empty;
                                        var beforeActual = compareSpsMode ? Normalize(GetValue(beforeSpsPayload!, row.PropertyBase + "_Asli")) : string.Empty;
                                        var beforeMax = compareSpsMode ? Normalize(GetValue(beforeSpsPayload!, row.PropertyBase + "_Max")) : string.Empty;
                                        var minFilled = !string.IsNullOrWhiteSpace(row.Min);
                                        var actualFilled = !string.IsNullOrWhiteSpace(row.Actual);
                                        var maxFilled = !string.IsNullOrWhiteSpace(row.Max);
                                        var filledCountRow = (minFilled ? 1 : 0) + (actualFilled ? 1 : 0) + (maxFilled ? 1 : 0);
                                        var statusText = filledCountRow == 3 ? "Terisi" : filledCountRow == 0 ? "Kosong" : "Sebagian";
                                        var statusClass = filledCountRow == 3 ? "bg-success" : filledCountRow == 0 ? "bg-secondary" : "bg-warning text-dark";

                                        <tr class="@((filledCountRow == 0 ? "table-secondary " : string.Empty) + (compareSpsMode && (!string.Equals(beforeMin, Normalize(row.Min), StringComparison.Ordinal) || !string.Equals(beforeActual, Normalize(row.Actual), StringComparison.Ordinal) || !string.Equals(beforeMax, Normalize(row.Max), StringComparison.Ordinal)) ? "compare-row-changed" : string.Empty))">
                                            <td>@row.Label <small class="text-muted">(@row.PropertyBase)</small></td>
                                            <td>
                                                @if (compareSpsMode)
                                                {
                                                    <span class="compare-before-inline">Before: @(string.IsNullOrWhiteSpace(beforeMin) ? "-" : beforeMin)</span>
                                                }
                                                @if (canEditPayload)
                                                {
