                <div class="card shadow-sm border-0 mt-3">
                    <div class="card-header bg-dark text-white"><strong>5. Standard Toleransi (Min / Actual / Max)</strong></div>
                    <div class="card-body p-0">
                        <div class="table-responsive" style="max-height: 500px; overflow:auto;">
                            <table class="table table-sm table-striped mb-0">
                                <thead>
                                    <tr>
                                        <th style="width: 34%;">Parameter</th>
                                        <th style="width: 16%;">Min</th>
                                        <th style="width: 16%;">Actual</th>
                                        <th style="width: 16%;">Max</th>
                                        <th style="width: 10%;">Status</th>
                                        <th style="width: 8%;">Validasi</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @if (!toleranceTripletRows.Any())
                                {
                                    <tr><td colspan="6" class="text-muted text-center">Belum ada struktur parameter Min / Actual / Max.</td></tr>
                                }
                                else
                                {
                                    @foreach (var row in toleranceTripletRows)
                                    {
                                        var minFilled = !string.IsNullOrWhiteSpace(row.Min);
                                        var actualFilled = !string.IsNullOrWhiteSpace(row.Actual);
                                        var maxFilled = !string.IsNullOrWhiteSpace(row.Max);
                                        var filledCountRow = (minFilled ? 1 : 0) + (actualFilled ? 1 : 0) + (maxFilled ? 1 : 0);
                                        var statusText = filledCountRow == 3 ? "Terisi" : filledCountRow == 0 ? "Kosong" : "Sebagian";
                                        var statusClass = filledCountRow == 3 ? "bg-success" : filledCountRow == 0 ? "bg-secondary" : "bg-warning text-dark";

                                        <tr class="@(filledCountRow == 0 ? "table-secondary" : string.Empty)">
                                            <td>@row.Label <small class="text-muted">(@row.PropertyBase)</small></td>
                                            <td>
                                                @if (canEditPayload)
                                                {
                                                    <input type="text" name="payload_@(row.PropertyBase)_Min" class="form-control form-control-sm" value="@row.Min" />
                                                }
                                                else
                                                {
                                                    @if (minFilled) { @row.Min } else { <span class="text-muted">-</span> }
                                                }
                                            </td>
                                            <td>
                                                @if (canEditPayload)
                                                {
                                                    <input type="text" name="payload_@(row.PropertyBase)_Asli" class="form-control form-control-sm" value="@row.Actual" />
                                                }
                                                else
                                                {
                                                    @if (actualFilled) { @row.Actual } else { <span class="text-muted">-</span> }
                                                }
                                            </td>
                                            <td>
                                                @if (canEditPayload)
                                                {
                                                    <input type="text" name="payload_@(row.PropertyBase)_Max" class="form-control form-control-sm" value="@row.Max" />
                                                }
                                                else
                                                {
                                                    @if (maxFilled) { @row.Max } else { <span class="text-muted">-</span> }
                                                }
                                            </td>
                                            <td><span class="badge @statusClass">@statusText</span></td>
                                            <td>
                                                @if (canReview && Model.Status == ApprovalRequestStatus.Pending)
                                                {
                                                    <select class="form-select form-select-sm manual-validation-mark" aria-label="Validasi admin">
                                                        <option value="">-</option>
                                                        <option value="x">X</option>
                                                    </select>
                                                }
                                                else
                                                {
                                                    @if (Model.Status == ApprovalRequestStatus.RevisionRequired && IsSupervisorMarked(row.Label, row.PropertyBase, $"{row.Label} ({row.PropertyBase})"))
                                                    {
                                                        <span class="badge bg-danger">X</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                </tbody>
                            </table>
                        </div>

                        @if (toleranceSingleRows.Any())
                        {
                            <div class="table-responsive border-top" style="max-height: 220px; overflow:auto;">
                                <table class="table table-sm table-striped mb-0">
                                    <thead>
                                        <tr>
                                            <th style="width: 40%;">Parameter Tambahan</th>
                                            <th>Value</th>
                                            <th style="width: 12%;">Validasi</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                    @foreach (var row in toleranceSingleRows)
                                    {
                                        <tr>
                                            <td>@row.Label</td>
                                            <td>
                                                @if (canEditPayload)
                                                {
                                                    <input type="text" name="payload_@row.PropertyName" class="form-control form-control-sm" value="@row.Value" />
                                                }
                                                else
                                                {
                                                    @row.Value
                                                }
                                            </td>
                                            <td>
                                                @if (canReview && Model.Status == ApprovalRequestStatus.Pending)
                                                {
                                                    <select class="form-select form-select-sm manual-validation-mark" aria-label="Validasi admin">
                                                        <option value="">-</option>
                                                        <option value="x">X</option>
                                                    </select>
                                                }
                                                else
                                                {
                                                    @if (Model.Status == ApprovalRequestStatus.RevisionRequired && IsSupervisorMarked(row.Label))
                                                    {
                                                        <span class="badge bg-danger">X</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                }
                                            </td>
                                        </tr>
                                    }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>

                <div class="card shadow-sm border-0 mt-3">
                    <div class="card-header bg-dark text-white"><strong>6. Approval & Revision History</strong></div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-sm table-striped mb-0">
                                <tbody>
                                    <tr><td style="width:35%;">Request Code</td><td>@Model.RequestCode</td></tr>
                                    <tr><td>Action Type</td><td>@Model.ActionType</td></tr>
                                    <tr><td>Status Request</td><td>@Model.Status</td></tr>
                                    <tr><td>Dokumen Aktif Saat Ini</td><td>@(spsPayload?.IsActive == true ? "Active" : "Inactive")</td></tr>
                                    <tr><td>Revision Number</td><td>@(string.IsNullOrWhiteSpace(spsPayload?.RevisionNumber) ? "-" : spsPayload.RevisionNumber)</td></tr>
                                    <tr><td>Revision Date</td><td>@(string.IsNullOrWhiteSpace(spsPayload?.RevisionDate) ? "-" : spsPayload.RevisionDate)</td></tr>
                                    <tr><td>Dibuat</td><td>@Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td></tr>
                                    <tr><td>Direview</td><td>@(Model.ReviewedAt.HasValue ? Model.ReviewedAt.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm") : "-")</td></tr>
                                    <tr><td>Approver</td><td>@(string.IsNullOrWhiteSpace(Model.ApproverUserName) ? "-" : $"{Model.ApproverUserName} ({Model.ApproverRole})")</td></tr>
                                    <tr><td>Komentar Approver</td><td>@(string.IsNullOrWhiteSpace(Model.ApproverComment) ? "-" : Model.ApproverComment)</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
