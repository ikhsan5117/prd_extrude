                </form>
            }
        </div>
    </div>

    @if (canReview && Model.Status == ApprovalRequestStatus.Pending)
    {
        <div class="row g-3 mt-1">
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-success text-white">Approve</div>
                    <div class="card-body">
                        <form asp-action="Approve" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <div class="mb-2">
                                <label class="form-label">Komentar (opsional)</label>
                                <textarea name="approverComment" class="form-control" rows="3" maxlength="1024"></textarea>
                            </div>
                            <button type="submit" class="btn btn-success">Approve Request</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-warning text-dark">Revision Required</div>
                    <div class="card-body">
                        <form asp-action="Reject" method="post" id="revisionRequiredForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <div class="mb-2">
                                <label class="form-label">Catatan Revisi (wajib)</label>
                                <textarea id="revisionRequiredComment" name="approverComment" class="form-control" rows="3" maxlength="1024" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-warning text-dark">Set Revision Required</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-danger text-white">Rejected (Final)</div>
                    <div class="card-body">
                        <form asp-action="FinalReject" method="post" id="finalRejectForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <div class="mb-2">
                                <label class="form-label">Alasan Reject Final (wajib)</label>
                                <textarea id="finalRejectComment" name="approverComment" class="form-control" rows="3" maxlength="1024" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-danger">Set Rejected Final</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="card shadow-sm border-0 mt-3">
        <div class="card-header bg-light">
            <strong>Riwayat Approval</strong>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Waktu</th>
                            <th>Actor</th>
                            <th>Transisi</th>
                            <th>Komentar</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (!Model.Logs.Any())
                    {
                        <tr><td colspan="4" class="text-center text-muted">Belum ada log.</td></tr>
                    }
                    else
                    {
                        foreach (var log in Model.Logs.OrderByDescending(x => x.CreatedAt))
                        {
                            <tr>
                                <td>@log.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                                <td>@log.ActorUserName (@log.ActorRole)</td>
                                <td>@(log.FromStatus?.ToString() ?? "-") → @log.ToStatus</td>
                                <td>@log.Comment</td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@if (spsPayload != null || itemPayload != null)
{
    <script>
        (function () {
            const toggleBtn = document.getElementById('toggleDetailPengajuanBtn');
            const detailSection = document.getElementById('detail-pengajuan');
            const baseLabel = '@(Model.Status == ApprovalRequestStatus.RevisionRequired ? "Revision Required" : "Detail Pengajuan")';
            const supervisorMarkedFields = @Html.Raw(supervisorMarkedFieldListJson);

            if (!toggleBtn || !detailSection) {
                return;
            }

            toggleBtn.addEventListener('click', function () {
                const isHidden = detailSection.classList.contains('d-none');
                detailSection.classList.toggle('d-none');
                toggleBtn.textContent = isHidden ? 'Sembunyikan ' + baseLabel : baseLabel;

                if (isHidden) {
                    detailSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });

            const buildManualValidationNotes = function () {
                const failedFields = [];
                const marks = document.querySelectorAll('.manual-validation-mark');

                marks.forEach(function (mark) {
                    if (mark.value !== 'x') {
                        return;
                    }

                    const row = mark.closest('tr');
                    const fieldCell = row ? row.querySelector('td') : null;
                    const fieldName = fieldCell ? (fieldCell.innerText || '').trim() : '';
                    if (fieldName) {
                        failedFields.push(fieldName);
                    }
                });

                return failedFields;
            };

            const normalizeFieldKey = function (value) {
                return (value || '').toLowerCase().replace(/[^a-z0-9]/g, '');
            };

            const normalizedSupervisorMarks = Array.isArray(supervisorMarkedFields)
                ? supervisorMarkedFields.map(normalizeFieldKey).filter(function (item) { return item.length > 0; })
                : [];

            const shouldMarkField = function (fieldName) {
                const normalizedField = normalizeFieldKey(fieldName);
                if (!normalizedField) {
                    return false;
                }

                return normalizedSupervisorMarks.some(function (marker) {
                    return marker === normalizedField
                        || marker.includes(normalizedField)
                        || normalizedField.includes(marker);
                });
            };

            const restoreManualValidationMarks = function () {
                if (!normalizedSupervisorMarks.length) {
                    return;
                }

                const marks = document.querySelectorAll('.manual-validation-mark');
                marks.forEach(function (mark) {
                    const row = mark.closest('tr');
                    const fieldCell = row ? row.querySelector('td') : null;
                    const fieldName = fieldCell ? (fieldCell.innerText || '').trim() : '';
                    if (shouldMarkField(fieldName)) {
                        mark.value = 'x';
                    }
                });
            };

            const wireDecisionForm = function (formId, textareaId) {
                const form = document.getElementById(formId);
                const textarea = document.getElementById(textareaId);

                if (!form || !textarea) {
                    return;
                }

                form.addEventListener('submit', function () {
                    const failedFields = buildManualValidationNotes();
                    if (failedFields.length === 0) {
                        return;
                    }

                    const autoNotes = 'Perlu perbaikan pada field berikut:\n' + failedFields.map(function (field) {
                        return '- ' + field;
                    }).join('\n');

                    const currentText = (textarea.value || '').trim();
                    if (!currentText) {
                        textarea.value = autoNotes;
                        return;
                    }

                    if (currentText.toLowerCase().includes('perlu perbaikan pada field berikut')) {
                        return;
                    }

                    textarea.value = currentText + '\n\n' + autoNotes;
                });
            };

            wireDecisionForm('revisionRequiredForm', 'revisionRequiredComment');
            wireDecisionForm('finalRejectForm', 'finalRejectComment');
            restoreManualValidationMarks();
        })();
    </script>
}


