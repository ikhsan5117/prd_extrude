@if (spsPayload != null || itemPayload != null)
{
    <script>
        (function () {
            const toggleBtn = document.getElementById('toggleDetailPengajuanBtn');
            const detailSection = document.getElementById('detail-pengajuan');
            const baseLabel = 'Detail Pengajuan';
            const supervisorMarkedFields = @Html.Raw(supervisorMarkedFieldListJson);
            const supervisorMarkedFieldComments = @Html.Raw(supervisorMarkedFieldCommentsJson);

            if (!toggleBtn || !detailSection) {
                return;
            }

            toggleBtn.textContent = detailSection.classList.contains('d-none')
                ? baseLabel
                : 'Sembunyikan ' + baseLabel;

            toggleBtn.addEventListener('click', function () {
                const isHidden = detailSection.classList.contains('d-none');
                detailSection.classList.toggle('d-none');
                toggleBtn.textContent = isHidden ? 'Sembunyikan ' + baseLabel : baseLabel;

                if (isHidden) {
                    detailSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });

            const normalizeCommentText = function (value) {
                return (value || '').replace(/\s+/g, ' ').trim();
            };

            const buildManualValidationNotes = function () {
                const failedFields = [];
                const marks = document.querySelectorAll('.manual-validation-mark');

                marks.forEach(function (mark) {
                    if (mark.value !== 'x') {
                        return;
                    }

                    const row = mark.closest('tr');
                    const fieldCell = row ? row.querySelector('td') : null;
                    const fieldName = fieldCell ? (fieldCell.innerText || '').trim() : '';
                    if (fieldName) {
                        failedFields.push({
                            fieldName: fieldName,
                            comment: normalizeCommentText(mark.dataset.comment || '')
                        });
                    }
                });

                return failedFields;
            };

            const normalizeFieldKey = function (value) {
                return (value || '').toLowerCase().replace(/[^a-z0-9]/g, '');
            };

            const normalizedSupervisorMarks = Array.isArray(supervisorMarkedFields)
                ? supervisorMarkedFields.map(normalizeFieldKey).filter(function (item) { return item.length > 0; })
                : [];

            const normalizedSupervisorFieldComments = (function () {
                const map = {};
                if (!supervisorMarkedFieldComments || typeof supervisorMarkedFieldComments !== 'object') {
                    return map;
                }

                Object.keys(supervisorMarkedFieldComments).forEach(function (key) {
                    const normalizedKey = normalizeFieldKey(key);
                    if (!normalizedKey) {
                        return;
                    }

                    const value = normalizeCommentText(supervisorMarkedFieldComments[key]);
                    if (value) {
                        map[normalizedKey] = value;
                    }
                });

                return map;
            })();

            const getFieldComment = function (fieldName) {
                const normalizedField = normalizeFieldKey(fieldName);
                if (!normalizedField) {
                    return '';
                }

                return normalizedSupervisorFieldComments[normalizedField] || '';
            };

            const shouldMarkField = function (fieldName) {
                const normalizedField = normalizeFieldKey(fieldName);
                if (!normalizedField) {
                    return false;
                }

                return normalizedSupervisorMarks.some(function (marker) {
                    return marker === normalizedField
                        || marker.includes(normalizedField)
                        || normalizedField.includes(marker);
                });
            };

            const restoreManualValidationMarks = function () {
                if (!normalizedSupervisorMarks.length) {
                    return;
                }

                const marks = document.querySelectorAll('.manual-validation-mark');
                marks.forEach(function (mark) {
                    const row = mark.closest('tr');
                    const fieldCell = row ? row.querySelector('td') : null;
                    const fieldName = fieldCell ? (fieldCell.innerText || '').trim() : '';
                    if (shouldMarkField(fieldName)) {
                        mark.value = 'x';
                        mark.dataset.comment = getFieldComment(fieldName);
                    }
                });
            };

            const initializeManualValidationBoxes = function () {
                let activePopover = null;
                let activeAnchor = null;

                const closePopover = function () {
                    if (!activePopover) {
                        return;
                    }

                    activePopover.remove();
                    activePopover = null;
                    activeAnchor = null;
                };

                const positionPopover = function (anchor, popover) {
                    const anchorRect = anchor.getBoundingClientRect();
                    const viewportWidth = window.innerWidth;
                    const viewportHeight = window.innerHeight;
                    const popoverRect = popover.getBoundingClientRect();

                    let left = anchorRect.left - popoverRect.width - 12;
                    let side = 'left';
                    if (left < 8) {
                        left = anchorRect.right + 12;
                        side = 'right';
                    }

                    let top = anchorRect.top - 6;
                    if (top + popoverRect.height > viewportHeight - 8) {
                        top = viewportHeight - popoverRect.height - 8;
                    }
                    if (top < 8) {
                        top = 8;
                    }

                    popover.dataset.side = side;
                    popover.style.left = left + 'px';
                    popover.style.top = top + 'px';
                };

                const openInfoPopover = function (anchor, fieldName, message) {
                    closePopover();

                    const popover = document.createElement('div');
                    popover.className = 'manual-popover';
                    popover.innerHTML =
                        '<div class="manual-popover-title">' + fieldName + '</div>' +
                        '<div class="manual-popover-message"></div>';

                    const messageNode = popover.querySelector('.manual-popover-message');
                    if (messageNode) {
                        messageNode.textContent = message || 'Perlu revisi pada field ini';
                    }

                    document.body.appendChild(popover);
                    positionPopover(anchor, popover);
                    activePopover = popover;
                    activeAnchor = anchor;
                };

                const openEditorPopover = function (anchor, mark, fieldName, syncVisual) {
                    closePopover();

                    const popover = document.createElement('div');
                    popover.className = 'manual-popover';
                    popover.innerHTML =
                        '<div class="manual-popover-title">Komentar Revisi: ' + fieldName + '</div>' +
                        '<textarea class="manual-popover-textarea" maxlength="1024" placeholder="Tulis catatan revisi untuk field ini"></textarea>' +
                        '<div class="manual-popover-actions">' +
                        '<button type="button" class="manual-popover-btn danger" data-action="clear">Kosongkan X</button>' +
                        '<button type="button" class="manual-popover-btn" data-action="close">Tutup</button>' +
                        '<button type="button" class="manual-popover-btn primary" data-action="save">Simpan</button>' +
                        '</div>';

                    document.body.appendChild(popover);
                    positionPopover(anchor, popover);

                    const textarea = popover.querySelector('.manual-popover-textarea');
                    if (textarea) {
                        textarea.value = normalizeCommentText(mark.dataset.comment || '');
                        textarea.focus();
                    }

                    popover.addEventListener('click', function (event) {
                        const actionButton = event.target.closest('button[data-action]');
                        if (!actionButton) {
                            return;
                        }

                        const action = actionButton.getAttribute('data-action');
                        if (action === 'save') {
                            const nextComment = textarea ? normalizeCommentText(textarea.value) : '';
                            mark.dataset.comment = nextComment;
                            syncVisual();
                            closePopover();
                            return;
                        }

                        if (action === 'clear') {
                            mark.value = '';
                            mark.dataset.comment = '';
                            syncVisual();
                            closePopover();
                            return;
                        }

                        closePopover();
                    });

                    activePopover = popover;
                    activeAnchor = anchor;
                };

                document.addEventListener('click', function (event) {
                    if (!activePopover) {
                        return;
                    }

                    if (activePopover.contains(event.target)) {
                        return;
                    }

                    if (activeAnchor && activeAnchor.contains(event.target)) {
                        return;
                    }

                    closePopover();
                });

                document.addEventListener('keydown', function (event) {
                    if (event.key === 'Escape') {
                        closePopover();
                    }
                });

                window.addEventListener('resize', closePopover);
                window.addEventListener('scroll', closePopover, true);

                const marks = document.querySelectorAll('select.manual-validation-mark');
                marks.forEach(function (mark) {
                    if (mark.dataset.enhanced === 'true') {
                        return;
                    }

                    const box = document.createElement('button');
                    box.type = 'button';
                    box.className = 'manual-validation-box';
                    box.setAttribute('aria-label', 'Tandai perlu revisi');

                    const row = mark.closest('tr');
                    const fieldCell = row ? row.querySelector('td') : null;
                    const fieldName = fieldCell ? (fieldCell.innerText || '').trim() : '';
                    const presetComment = normalizeCommentText(mark.dataset.comment || getFieldComment(fieldName));
                    if (presetComment) {
                        mark.dataset.comment = presetComment;
                    }

                    const syncVisual = function () {
                        const checked = (mark.value || '').toLowerCase() === 'x';
                        box.dataset.checked = checked ? 'true' : 'false';
                        box.textContent = checked ? 'X' : '';
                    };

                    box.addEventListener('click', function () {
                        const isChecked = (mark.value || '').toLowerCase() === 'x';
                        if (!isChecked) {
                            mark.value = 'x';
                            syncVisual();
                        }

                        openEditorPopover(box, mark, fieldName || 'Field', syncVisual);
                    });

                    mark.classList.add('manual-validation-mark-hidden');
                    mark.dataset.enhanced = 'true';
                    mark.insertAdjacentElement('afterend', box);
                    syncVisual();
                });
            };

            const initializeStaticValidationTooltips = function () {
                const badges = detailSection.querySelectorAll('span.badge.bg-danger');
                badges.forEach(function (badge) {
                    const text = (badge.textContent || '').trim().toUpperCase();
                    if (text !== 'X') {
                        return;
                    }

                    const row = badge.closest('tr');
                    const fieldCell = row ? row.querySelector('td') : null;
                    const fieldName = fieldCell ? (fieldCell.innerText || '').trim() : '';
                    const comment = getFieldComment(fieldName);
                    if (!comment) {
                        return;
                    }

                    badge.classList.add('manual-validation-static');
                    badge.setAttribute('tabindex', '0');
                    badge.setAttribute('title', 'Klik untuk lihat komentar');
                    badge.addEventListener('click', function () {
                        const localFieldName = fieldName || 'Field';
                        const containerRect = badge.getBoundingClientRect();

                        const popover = document.createElement('div');
                        popover.className = 'manual-popover';
                        popover.innerHTML =
                            '<div class="manual-popover-title">Komentar Revisi: ' + localFieldName + '</div>' +
                            '<div class="manual-popover-message"></div>';

                        const messageNode = popover.querySelector('.manual-popover-message');
                        if (messageNode) {
                            messageNode.textContent = comment;
                        }

                        document.body.appendChild(popover);

                        const popRect = popover.getBoundingClientRect();
                        let left = containerRect.left - popRect.width - 12;
                        let side = 'left';
                        if (left < 8) {
                            left = containerRect.right + 12;
                            side = 'right';
                        }

                        let top = containerRect.top - 6;
                        if (top + popRect.height > window.innerHeight - 8) {
                            top = window.innerHeight - popRect.height - 8;
                        }
                        if (top < 8) {
                            top = 8;
                        }

                        popover.dataset.side = side;
                        popover.style.left = left + 'px';
                        popover.style.top = top + 'px';

                        const close = function (event) {
                            if (event && (popover.contains(event.target) || badge.contains(event.target))) {
                                return;
                            }

                            popover.remove();
                            document.removeEventListener('click', close);
                            window.removeEventListener('resize', close);
                            window.removeEventListener('scroll', close, true);
                        };

                        setTimeout(function () {
                            document.addEventListener('click', close);
                        }, 0);
                        window.addEventListener('resize', close);
                        window.addEventListener('scroll', close, true);
                    });
                });
            };

            const decisionForm = document.getElementById('decisionForm');
            const decisionComment = document.getElementById('decisionComment');

            if (decisionForm && decisionComment) {
                decisionForm.addEventListener('click', function (event) {
                    const button = event.target.closest('button[data-decision-mode]');
                    if (!button) {
                        return;
                    }

                    decisionForm.dataset.decisionMode = button.dataset.decisionMode || 'approve';
                });

                decisionForm.addEventListener('submit', function () {
                    const mode = (decisionForm.dataset.decisionMode || 'approve').toLowerCase();
                    if (mode === 'approve') {
                        return;
                    }

                    const failedFields = buildManualValidationNotes();
                    if (failedFields.length === 0) {
                        return;
                    }

                    const autoNotes = 'Perlu perbaikan pada field berikut:\n' + failedFields.map(function (item) {
                        return item.comment
                            ? '- ' + item.fieldName + ': ' + item.comment
                            : '- ' + item.fieldName;
                    }).join('\n');

                    const currentText = (decisionComment.value || '').trim();
                    if (!currentText) {
                        decisionComment.value = autoNotes;
                        return;
                    }

                    if (currentText.toLowerCase().includes('perlu perbaikan pada field berikut')) {
                        return;
                    }

                    decisionComment.value = currentText + '\n\n' + autoNotes;
                });
            }

            restoreManualValidationMarks();
            initializeManualValidationBoxes();
            initializeStaticValidationTooltips();
        })();
    </script>
}


