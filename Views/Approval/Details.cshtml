                                                @if (compareSpsMode)
                                                {
                                                    <span class="compare-before-inline">Before: @(string.IsNullOrWhiteSpace(beforeActual) ? "-" : beforeActual)</span>
                                                }
                                                @if (canEditPayload)
                                                {
                                                    <input type="text" name="payload_@(row.PropertyBase)_Asli" class="form-control form-control-sm tolerance-input" value="@row.Actual" />
                                                }
                                                else
                                                {
                                                    @if (actualFilled) { @row.Actual } else { <span class="text-muted">-</span> }
                                                }
                                            </td>
                                            <td>
                                                @if (compareSpsMode)
                                                {
                                                    <span class="compare-before-inline">Before: @(string.IsNullOrWhiteSpace(beforeMax) ? "-" : beforeMax)</span>
                                                }
                                                @if (canEditPayload)
                                                {
                                                    <input type="text" name="payload_@(row.PropertyBase)_Max" class="form-control form-control-sm tolerance-input" value="@row.Max" />
                                                }
