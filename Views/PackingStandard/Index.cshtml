@model IEnumerable<VelastoProductionSystem.Models.PackingStandard>

@{
    ViewData["Title"] = "Packing Standard";
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2><i class="bi bi-box-seam"></i> Packing Standard</h2>
            <a asp-action="Create" class="btn btn-velasto">
                <i class="bi bi-plus-circle"></i> Tambah Standard Baru
            </a>
        </div>

        <div class="card">
            <div class="card-header">
                <i class="bi bi-list-ul"></i> Daftar Packing Standard
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>NA Code</th>
                                <th>Material</th>
                                <th>Part Number</th>
                                <th>Vin Code</th>
                                <th>Dandori</th>
                                <th>DH*</th>
                                <th>Std Qty</th>
                                <th>Status</th>
                                <th class="text-center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td><strong>@item.NACode</strong></td>
                                    <td>@item.MaterialName</td>
                                    <td>@item.PartNumber</td>
                                    <td>@item.VinCode</td>
                                    <td>@item.Dandori</td>
                                    <td>@item.DH</td>
                                    <td>@item.StdQty</td>
                                    <td>
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success">Aktif</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Tidak Aktif</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info" title="Detail">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Hapus">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    
                    @if (!Model.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-inbox" style="font-size: 3rem; color: #ccc;"></i>
                            <p class="text-muted mt-3">Belum ada data packing standard.</p>
                            <a asp-action="Create" class="btn btn-velasto">
                                <i class="bi bi-plus-circle"></i> Tambah Standard Pertama
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
