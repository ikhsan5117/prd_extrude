@model VelastoProductionSystem.Models.NowProducing

@{
    Layout = "_Layout";
    ViewData["Title"] = "NOW I'M PRODUCE - Extruder";
    var currentId = Model?.Id ?? 0;
}

@section Styles {
<style>
    :root {
        --ep-bg: #0a0f1e;
        --ep-surface: #0d1526;
        --ep-card: #111d35;
        --ep-border: rgba(59, 130, 246, 0.25);
        --ep-blue: #3b82f6;
        --ep-blue-bright: #60a5fa;
        --ep-green: #10b981;
        --ep-yellow: #f59e0b;
        --ep-red: #ef4444;
        --ep-text: #e2e8f0;
        --ep-muted: #64748b;
    }

    .ep-wrapper {
        max-width: 1500px;
        margin: 0 auto;
        padding: 10px 15px;
        font-family: 'Segoe UI', sans-serif;
    }

    /* ── TOP BAR ── */
    .ep-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: linear-gradient(90deg, #0d1526 0%, #111d35 100%);
        border: 1px solid var(--ep-border);
        border-radius: 10px;
        padding: 10px 18px;
        margin-bottom: 12px;
        gap: 12px;
    }
    .ep-topbar-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        flex: 0 0 auto;
    }
    .ep-live-dot {
        width: 10px; height: 10px;
        border-radius: 50%;
        background: var(--ep-green);
        box-shadow: 0 0 8px var(--ep-green);
        animation: pulse-dot 1.5s ease-in-out infinite;
    }
    @@keyframes pulse-dot {
        0%,100% { opacity: 1; transform: scale(1); }
        50%      { opacity: 0.5; transform: scale(1.3); }
    }
    .ep-brand-label {
        font-size: 13px;
        font-weight: 900;
        color: var(--ep-text);
        letter-spacing: 2px;
        text-transform: uppercase;
    }
    .ep-brand-sub {
        font-size: 9px;
        color: var(--ep-muted);
        letter-spacing: 1px;
    }

    /* ── BARCODE SCANNER BOX ── */
    .ep-scanner-wrap {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 8px;
        max-width: 480px;
        margin: 0 auto;
    }
    .ep-scanner-input {
        flex: 1;
        background: rgba(59,130,246,0.07);
        border: 1.5px solid var(--ep-blue);
        border-radius: 7px;
        padding: 9px 14px;
        color: var(--ep-text);
        font-size: 14px;
        font-weight: 600;
        outline: none;
        transition: box-shadow .2s;
    }
    .ep-scanner-input:focus {
        box-shadow: 0 0 0 3px rgba(59,130,246,0.25);
    }
    .ep-scanner-input::placeholder { color: var(--ep-muted); font-weight:400; }
    .ep-scan-btn {
        padding: 9px 20px;
        background: var(--ep-blue);
        border: none;
        border-radius: 7px;
        color: white;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: background .2s, transform .15s;
        white-space: nowrap;
    }
    .ep-scan-btn:hover { background: #2563eb; transform: translateY(-1px); }
    .ep-topbar-actions { display: flex; gap: 8px; flex: 0 0 auto; }
    .ep-action-btn {
        padding: 8px 16px;
        border-radius: 7px;
        border: 1px solid var(--ep-border);
        background: rgba(255,255,255,0.04);
        color: var(--ep-text);
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        display: flex; align-items: center; gap: 6px;
        transition: all .2s;
        text-decoration: none;
    }
    .ep-action-btn:hover { background: rgba(255,255,255,0.09); color: white; }
    .ep-action-btn.save { background: var(--ep-blue); border-color: var(--ep-blue); color: white; }
    .ep-action-btn.save:hover { background: #2563eb; }

    /* ── PAGE TITLE ── */
    .ep-page-title {
        text-align: center;
        margin-bottom: 14px;
    }
    .ep-page-title h1 {
        font-size: 22px;
        font-weight: 900;
        color: var(--ep-text);
        letter-spacing: 3px;
        text-transform: uppercase;
        margin: 0;
    }
    .ep-page-title p {
        font-size: 11px;
        color: var(--ep-muted);
        margin: 3px 0 0;
        letter-spacing: 1px;
    }

    /* ── MAIN GRID ── */
    .ep-main-grid {
        display: grid;
        grid-template-columns: 300px 1fr 280px;
        grid-template-rows: auto auto;
        gap: 12px;
    }

    /* ── CARDS ── */
    .ep-card {
        background: var(--ep-card);
        border: 1px solid var(--ep-border);
        border-radius: 10px;
        overflow: hidden;
    }
    .ep-card-head {
        background: rgba(59,130,246,0.1);
        border-bottom: 1px solid var(--ep-border);
        padding: 8px 14px;
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 2px;
        color: var(--ep-blue-bright);
        text-transform: uppercase;
        display: flex; align-items: center; gap: 6px;
    }
    .ep-card-body { padding: 14px; }

    /* ── SPEC FIELDS (Left Column) ── */
    .ep-spec-item {
        margin-bottom: 14px;
    }
    .ep-spec-label {
        font-size: 9px;
        font-weight: 700;
        color: var(--ep-muted);
        letter-spacing: 1.5px;
        text-transform: uppercase;
        margin-bottom: 5px;
        display: flex;
        align-items: center;
        gap: 5px;
    }
    .ep-spec-label i { color: var(--ep-blue); font-size: 11px; }
    .ep-spec-label .num {
        width: 16px; height: 16px;
        background: var(--ep-blue);
        border-radius: 50%;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 8px; font-weight: 900; color: white;
    }
    .ep-spec-val {
        font-size: 14px;
        font-weight: 700;
        color: var(--ep-text);
        padding: 8px 12px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 6px;
        min-height: 38px;
        display: flex;
        align-items: center;
        word-break: break-word;
        transition: all .3s;
    }
    .ep-spec-val.highlight { color: var(--ep-blue-bright); border-color: rgba(59,130,246,0.3); }
    .ep-spec-val.dim { color: var(--ep-yellow); }

    /* ── TIME CONTROL (Center Column) ── */
    .ep-time-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 14px;
        background: rgba(59,130,246,0.1);
        border-bottom: 1px solid var(--ep-border);
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 2px;
        color: var(--ep-blue-bright);
        text-transform: uppercase;
    }
    .ep-date-badge {
        background: rgba(59,130,246,0.15);
        border: 1px solid var(--ep-border);
        border-radius: 5px;
        padding: 4px 10px;
        font-size: 11px;
        font-weight: 600;
        color: var(--ep-text);
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .ep-phase-tabs {
        display: flex;
        border-bottom: 1px solid var(--ep-border);
        background: rgba(0,0,0,0.2);
    }
    .ep-phase-tab {
        flex: 1;
        padding: 8px 12px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1px;
        color: var(--ep-muted);
        text-align: center;
        cursor: pointer;
        border: none;
        background: transparent;
        border-bottom: 2px solid transparent;
        transition: all .2s;
        text-transform: uppercase;
    }
    .ep-phase-tab.active {
        color: var(--ep-blue-bright);
        border-bottom-color: var(--ep-blue);
        background: rgba(59,130,246,0.05);
    }

    .ep-time-section { padding: 14px; }
    .ep-time-section h6 {
        font-size: 9px;
        font-weight: 700;
        color: var(--ep-muted);
        letter-spacing: 2px;
        text-transform: uppercase;
        text-align: center;
        margin-bottom: 10px;
    }
    .ep-time-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
    }
    .ep-time-table th {
        padding: 6px 10px;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 1px;
        color: var(--ep-muted);
        border-bottom: 1px solid var(--ep-border);
        text-align: center;
        text-transform: uppercase;
    }
    .ep-time-table th:first-child { text-align: left; }
    .ep-time-table td {
        padding: 8px 10px;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        text-align: center;
    }
    .ep-time-table td:first-child { text-align: left; color: var(--ep-muted); font-weight: 600; font-size: 11px; }
    .ep-time-input {
        width: 100%;
        background: rgba(59,130,246,0.07);
        border: 1px solid rgba(59,130,246,0.2);
        border-radius: 5px;
        padding: 5px 8px;
        color: var(--ep-text);
        font-size: 12px;
        font-weight: 600;
        outline: none;
        text-align: center;
        color-scheme: dark;
        transition: border-color .2s;
    }
    .ep-time-input:focus { border-color: var(--ep-blue); }
    .ep-time-divider {
        height: 1px;
        background: var(--ep-border);
        margin: 10px 0;
        opacity: 0.5;
    }

    /* ── TARGET TABLE (Right Columns) ── */
    .ep-target-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 10px;
    }
    .ep-target-table th {
        padding: 5px 6px;
        font-size: 8px;
        font-weight: 700;
        letter-spacing: 0.8px;
        color: var(--ep-muted);
        text-transform: uppercase;
        border-bottom: 1px solid var(--ep-border);
        text-align: center;
    }
    .ep-target-table td {
        padding: 5px 6px;
        border-bottom: 1px solid rgba(255,255,255,0.03);
        text-align: center;
        color: var(--ep-text);
    }
    .ep-target-table td:first-child { color: var(--ep-muted); font-weight: 600; font-size: 9px; text-align: left; }
    .ep-target-num-input {
        width: 100%;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 4px;
        padding: 4px 3px;
        color: var(--ep-text);
        font-size: 10px;
        font-weight: 600;
        outline: none;
        text-align: center;
        transition: border-color .2s;
    }
    .ep-target-num-input:focus { border-color: var(--ep-blue); }

    /* ── MATERIAL VERIFICATION (Bottom span-3) ── */
    .ep-mat-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0; }
    .ep-mat-row {
        display: contents;
    }
    .ep-mat-cell {
        padding: 8px 14px;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .ep-mat-label {
        font-size: 10px;
        font-weight: 700;
        color: var(--ep-muted);
        white-space: nowrap;
        min-width: 75px;
    }
    .ep-mat-input {
        flex: 1;
        background: transparent;
        border: none;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        color: var(--ep-text);
        font-size: 12px;
        font-weight: 600;
        outline: none;
        padding: 3px 6px;
        transition: border-color .2s;
        min-width: 0;
    }
    .ep-mat-input:focus { border-bottom-color: var(--ep-blue); }
    .ep-mat-input::placeholder { color: var(--ep-muted); font-weight: 400; }

    .ep-mat-sg-label {
        font-size: 9px;
        font-weight: 700;
        color: var(--ep-muted);
        white-space: nowrap;
    }
    .ep-mat-sg-input {
        width: 70px;
        background: transparent;
        border: none;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        color: var(--ep-text);
        font-size: 12px;
        font-weight: 600;
        outline: none;
        padding: 3px 4px;
        text-align: center;
        transition: border-color .2s;
    }
    .ep-mat-sg-input:focus { border-bottom-color: var(--ep-blue); }
    .ep-mat-sg-input::placeholder { color: var(--ep-muted); }

    /* ── SPV CHECK (right side in material row) ── */
    .ep-spv-block {
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding: 10px 14px;
        height: 100%;
        justify-content: center;
        align-items: center;
    }
    .ep-spv-title {
        font-size: 9px;
        font-weight: 800;
        color: var(--ep-muted);
        letter-spacing: 2px;
        text-transform: uppercase;
    }
    .ep-spv-btn {
        width: 44px; height: 44px;
        border-radius: 50%;
        border: 2px solid rgba(255,255,255,0.15);
        background: rgba(255,255,255,0.05);
        color: var(--ep-muted);
        font-size: 18px;
        cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        transition: all .3s;
    }
    .ep-spv-btn.checked {
        border-color: var(--ep-green);
        background: rgba(16,185,129,0.15);
        color: var(--ep-green);
        box-shadow: 0 0 15px rgba(16,185,129,0.3);
    }

    /* ── NOTE BAR ── */
    .ep-note-bar {
        background: rgba(239,68,68,0.08);
        border-top: 1px solid rgba(239,68,68,0.2);
        padding: 8px 18px;
        font-size: 11px;
        font-weight: 600;
        color: #f87171;
        letter-spacing: 0.5px;
    }
    .ep-note-bar span { color: var(--ep-red); }
    .ep-note-bar strong { color: #fca5a5; }

    /* ── SCAN TOAST ── */
    .ep-scan-status {
        font-size: 10px;
        color: var(--ep-muted);
        margin-top: 3px;
        text-align: center;
        min-height: 16px;
        transition: color .3s;
    }
    .ep-scan-status.ok { color: var(--ep-green); }
    .ep-scan-status.err { color: var(--ep-red); }

    /* loaded state pulse */
    @@keyframes loaded-flash {
        0%,100% { box-shadow: none; }
        50%      { box-shadow: 0 0 12px rgba(16,185,129,0.5); }
    }
    .ep-spec-val.loaded { animation: loaded-flash 0.8s ease; }
</style>
}

<div class="ep-wrapper">

    <!-- TOP BAR -->
    <div class="ep-topbar">
        <div class="ep-topbar-brand">
            <div class="ep-live-dot"></div>
            <div>
                <div class="ep-brand-label">LINE CONTROL F1</div>
                <div class="ep-brand-sub">EXTRUDER PRODUCTION MODULE</div>
            </div>
        </div>

        <!-- BARCODE SCANNER -->
        <div style="flex:1; display:flex; flex-direction:column; align-items:center; max-width:500px; margin:0 auto;">
            <div class="ep-scanner-wrap">
                <i class="bi bi-upc-scan" style="color:var(--ep-blue-bright); font-size:22px;"></i>
                <input type="text" id="barcodeInput" class="ep-scanner-input"
                       placeholder="Scan atau ketik Item Code / Part Number..."
                       autocomplete="off" autofocus />
                <button class="ep-scan-btn" onclick="doScan()" id="scanBtn">
                    <i class="bi bi-search"></i> SCAN ITEM
                </button>
            </div>
            <div class="ep-scan-status" id="scanStatus"></div>
        </div>

        <div class="ep-topbar-actions">
            <button class="ep-action-btn save" onclick="saveData()" id="saveBtn">
                <i class="bi bi-save"></i> SIMPAN
            </button>
            <a href="/NowProducing/Current" class="ep-action-btn">
                <i class="bi bi-arrow-left"></i> BACK
            </a>
        </div>
    </div>

    <!-- PAGE TITLE -->
    <div class="ep-page-title">
        <h1>NOW I'M PRODUCE :</h1>
        <p>PT. VELASTO INDONESIA</p>
    </div>

    <!-- MAIN GRID -->
    <div class="ep-main-grid">

        <!-- ── LEFT: Spec Info ── -->
        <div class="ep-card" style="grid-column:1; grid-row:1;">
            <div class="ep-card-head"><i class="bi bi-card-list"></i> Spesifikasi Produk</div>
            <div class="ep-card-body">
                <div class="ep-spec-item">
                    <div class="ep-spec-label"><span class="num">✕</span> 1. HOSE TYPE</div>
                    <div class="ep-spec-val" id="valHoseType">@(Model?.HoseType ?? "---")</div>
                </div>
                <div class="ep-spec-item">
                    <div class="ep-spec-label"><span class="num">2</span> CLASS</div>
                    <div class="ep-spec-val" id="valClass">@(Model?.Class ?? "-")</div>
                </div>
                <div class="ep-spec-item">
                    <div class="ep-spec-label"><i class="bi bi-rulers"></i> 3. DIMENSION</div>
                    <div class="ep-spec-val dim" id="valDimension">@(Model?.Dimension ?? "---")</div>
                </div>
                <div class="ep-spec-item">
                    <div class="ep-spec-label"><i class="bi bi-star"></i> 4. YARN</div>
                    <div class="ep-spec-val highlight" id="valYarn">@(Model?.Yarn ?? "---")</div>
                </div>
            </div>
        </div>

        <!-- ── CENTER: Time Control ── -->
        <div class="ep-card" style="grid-column:2; grid-row:1;">
            <div class="ep-time-head">
                <span><i class="bi bi-clock"></i> TIME CONTROL</span>
                <div class="ep-date-badge">
                    <i class="bi bi-calendar3"></i>
                    <span id="todayDate">@DateTime.Today.ToString("MM/dd/yyyy")</span>
                    <i class="bi bi-calendar-date" style="cursor:pointer" onclick="document.getElementById('datePicker').showPicker()"></i>
                    <input type="date" id="datePicker" style="opacity:0;width:0;position:absolute;" value="@DateTime.Today.ToString("yyyy-MM-dd")" onchange="updateDate(this)"/>
                </div>
            </div>

            <!-- Phase tabs -->
            <div class="ep-phase-tabs">
                <button class="ep-phase-tab active" data-phase="dandori" onclick="switchPhase('dandori', this)">DANDORI PHASE</button>
                <button class="ep-phase-tab" data-phase="monitoring" onclick="switchPhase('monitoring', this)">MONITORING</button>
            </div>

            <!-- DANDORI PHASE -->
            <div id="phase-dandori" class="ep-time-section">
                <h6>WAKTU</h6>
                <table class="ep-time-table">
                    <thead>
                        <tr>
                            <th>PHASE</th>
                            <th>AWAL</th>
                            <th>AKHIR</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>START PROD.</td>
                            <td><input type="time" class="ep-time-input" id="dandoriStartAwal" value="@(Model?.DandoriStartProdTime?.ToString("HH:mm") ?? "--:--")" /></td>
                            <td><input type="time" class="ep-time-input" id="dandoriStartAkhir" value="@(Model?.DandoriEndProdTime?.ToString("HH:mm") ?? "--:--")" /></td>
                        </tr>
                        <tr>
                            <td>AKHIR PROD.</td>
                            <td><input type="time" class="ep-time-input" id="dandoriEndAwal" /></td>
                            <td><input type="time" class="ep-time-input" id="dandoriEndAkhir" /></td>
                        </tr>
                    </tbody>
                </table>

                <div class="ep-time-divider"></div>
                <h6>PRODUCTION PHASE / ACTUAL RUN</h6>
                <h6 style="margin-top:-5px;">WAKTU</h6>
                <table class="ep-time-table">
                    <thead>
                        <tr>
                            <th>PHASE</th>
                            <th>AWAL</th>
                            <th>AKHIR</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>PRODUKSI</td>
                            <td><input type="time" class="ep-time-input" id="prodStart" value="@(Model?.ProductionStartTime?.ToString("HH:mm") ?? "--:--")" /></td>
                            <td><input type="time" class="ep-time-input" id="prodEnd" value="@(Model?.ProductionEndTime?.ToString("HH:mm") ?? "--:--")" /></td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- MONITORING PHASE (hidden by default) -->
            <div id="phase-monitoring" class="ep-time-section" style="display:none;">
                <h6>STATUS MONITORING PRODUKSI</h6>
                <div style="text-align:center; padding:30px 0; color:var(--ep-muted);">
                    <i class="bi bi-graph-up" style="font-size:36px; color:var(--ep-blue); opacity:.5;"></i>
                    <p style="margin-top:12px; font-size:12px;">Live monitoring akan tersedia setelah data disimpan dan produksi berjalan.</p>
                </div>
            </div>
        </div>

        <!-- ── RIGHT: Target Tables ── -->
        <div style="grid-column:3; grid-row:1; display:flex; flex-direction:column; gap:12px;">

            <!-- CHS 2L Target -->
            <div class="ep-card">
                <div class="ep-card-head"><i class="bi bi-table"></i> CHS 2-L DANDORI TARGET</div>
                <div class="ep-card-body" style="padding:10px;">
                    <table class="ep-target-table">
                        <thead>
                            <tr>
                                <th>TARGET TIME</th>
                                <th>DIET</th>
                                <th>MATERIAL</th>
                                <th>BENANG</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in new[] { "30 Min", "45 Min", "60 Min" })
                            {
                                <tr>
                                    <td>@row</td>
                                    <td><input type="number" class="ep-target-num-input" placeholder="0" /></td>
                                    <td><input type="number" class="ep-target-num-input" placeholder="0" /></td>
                                    <td><input type="number" class="ep-target-num-input" placeholder="-" /></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- CHS 3L Target -->
            <div class="ep-card">
                <div class="ep-card-head"><i class="bi bi-table"></i> CHS 3-L DANDORI TARGET</div>
                <div class="ep-card-body" style="padding:10px;">
                    <table class="ep-target-table">
                        <thead>
                            <tr>
                                <th>TARGET TIME</th>
                                <th>DIET</th>
                                <th>MATERIAL</th>
                                <th>BENANG</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in new[] { "30 Min", "45 Min", "60 Min" })
                            {
                                <tr>
                                    <td>@row</td>
                                    <td><input type="number" class="ep-target-num-input" placeholder="0" /></td>
                                    <td><input type="number" class="ep-target-num-input" placeholder="0" /></td>
                                    <td><input type="number" class="ep-target-num-input" placeholder="-" /></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ── BOTTOM: Material Verification + SPV Check ── -->
        <div class="ep-card" style="grid-column:1/3; grid-row:2;">
            <div class="ep-card-head"><i class="bi bi-layers-half"></i> MATERIAL VERIFICATION</div>
            <div>
                <!-- Inner -->
                <div style="display:grid; grid-template-columns:auto 1fr auto 1fr auto 1fr; align-items:center; padding:9px 14px; border-bottom:1px solid rgba(255,255,255,0.04); gap:6px;">
                    <span class="ep-mat-label">1) Inner :</span>
                    <input type="text" class="ep-mat-input" id="matInner" placeholder="———" value="@(Model?.MaterialInner ?? "")" />
                    <span class="ep-mat-label" style="padding-left:14px;">No.Lot :</span>
                    <input type="text" class="ep-mat-input" id="matInnerLot" placeholder="———" value="@(Model?.MaterialInnerLotNo ?? "")" />
                    <span class="ep-mat-sg-label" style="padding-left:14px;">SG :</span>
                    <input type="number" step="0.0001" class="ep-mat-sg-input" id="matInnerSG" placeholder="0.0" value="@(Model != null && Model.MaterialInnerSG != 0 ? Model.MaterialInnerSG.ToString("0.0000") : "")" />
                </div>
                <!-- Middle -->
                <div style="display:grid; grid-template-columns:auto 1fr auto 1fr auto 1fr; align-items:center; padding:9px 14px; border-bottom:1px solid rgba(255,255,255,0.04); gap:6px;">
                    <span class="ep-mat-label">2) Middle :</span>
                    <input type="text" class="ep-mat-input" id="matMiddle" placeholder="———" value="@(Model?.MaterialMiddle ?? "")" />
                    <span class="ep-mat-label" style="padding-left:14px;">No.Lot :</span>
                    <input type="text" class="ep-mat-input" id="matMiddleLot" placeholder="———" value="@(Model?.MaterialMiddleLotNo ?? "")" />
                    <span class="ep-mat-sg-label" style="padding-left:14px;">SG :</span>
                    <input type="number" step="0.0001" class="ep-mat-sg-input" id="matMiddleSG" placeholder="0.0" value="@(Model != null && Model.MaterialMiddleSG.HasValue ? Model.MaterialMiddleSG.GetValueOrDefault().ToString("0.0000") : "")" />
                </div>
                <!-- Outer -->
                <div style="display:grid; grid-template-columns:auto 1fr auto 1fr auto 1fr; align-items:center; padding:9px 14px; gap:6px;">
                    <span class="ep-mat-label">3) Outer :</span>
                    <input type="text" class="ep-mat-input" id="matOuter" placeholder="———" value="@(Model?.MaterialOuter ?? "")" />
                    <span class="ep-mat-label" style="padding-left:14px;">No.Lot :</span>
                    <input type="text" class="ep-mat-input" id="matOuterLot" placeholder="———" value="@(Model?.MaterialOuterLotNo ?? "")" />
                    <span class="ep-mat-sg-label" style="padding-left:14px;">SG :</span>
                    <input type="number" step="0.0001" class="ep-mat-sg-input" id="matOuterSG" placeholder="0.0" value="@(Model != null && Model.MaterialOuterSG != 0 ? Model.MaterialOuterSG.ToString("0.0000") : "")" />
                </div>
            </div>
        </div>

        <!-- SPV CHECK -->
        <div class="ep-card" style="grid-column:3; grid-row:2;">
            <div class="ep-card-head"><i class="bi bi-shield-check"></i> SPV CHECK</div>
            <div class="ep-spv-block">
                <div class="ep-spv-title">Supervisor</div>
                <button class="ep-spv-btn @(Model?.SPVCheck == true ? "checked" : "")" id="spvBtn" onclick="toggleSpv()" title="Toggle SPV Check">
                    <i class="bi bi-shield-check"></i>
                </button>
                <div class="ep-spv-title" id="spvLabel">@(Model?.SPVCheck == true ? "CHECKED ✓" : "PENDING")</div>

                <div style="margin-top:8px; width:100%;">
                    <button class="ep-spv-btn @(Model?.SPVCheck == true ? "checked" : "")" id="spvBtn2" onclick="toggleSpv()" style="width:44px; height:44px; margin: 0 auto;">
                        <i class="bi bi-person-check"></i>
                    </button>
                </div>
                <div class="ep-spv-title" id="spvLabel2">OPR</div>
            </div>
        </div>

    </div><!-- /main grid -->

    <!-- NOTE BAR -->
    <div class="ep-note-bar" style="margin-top:12px; border-radius:0 0 10px 10px; border:1px solid rgba(239,68,68,0.2); border-top:none;">
        <strong>NOTE :</strong> <span>JANGAN MENJALANKAN PRODUKSI SEBELUM CHECKSHEET INI DI CHECK OLEH SUPERVISOR.</span>
    </div>

</div> <!-- /ep-wrapper -->

@section Scripts {
<script>
    const recordId = @currentId;
    let spvChecked = @(Model?.SPVCheck == true ? "true" : "false");

    // ─── BARCODE SCAN ───
    document.getElementById('barcodeInput').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') { e.preventDefault(); doScan(); }
    });

    async function doScan() {
        const code = document.getElementById('barcodeInput').value.trim();
        if (!code) return;

        const btn = document.getElementById('scanBtn');
        btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Loading...';
        btn.disabled = true;
        setStatus('Mencari data dari SPS Masterlist...', '');

        try {
            const res = await fetch('/NowProducing/GetMasterByItem?itemCode=' + encodeURIComponent(code));
            const json = await res.json();

            if (json.success) {
                const d = json.data;
                fillSpec('valHoseType', d.hoseType || '---');
                fillSpec('valDimension', d.dimensi || '---');
                fillSpec('valYarn', d.innerTube || d.material || '---');

                if (d.innerTube)  setVal('matInner', d.innerTube);
                if (d.outerCover) setVal('matOuter', d.outerCover);

                setStatus('✓ Data berhasil dimuat: ' + (d.hoseType || code), 'ok');
                document.getElementById('barcodeInput').value = '';
            } else {
                setStatus('✗ ' + json.message, 'err');
            }
        } catch(e) {
            setStatus('✗ Error jaringan! Cek koneksi server.', 'err');
        }

        btn.innerHTML = '<i class="bi bi-search"></i> SCAN ITEM';
        btn.disabled = false;
        document.getElementById('barcodeInput').focus();
    }

    function fillSpec(id, text) {
        const el = document.getElementById(id);
        if (!el) return;
        el.textContent = text;
        el.classList.add('loaded');
        setTimeout(() => el.classList.remove('loaded'), 900);
    }

    function setVal(id, val) {
        const el = document.getElementById(id);
        if (el) el.value = val;
    }

    function setStatus(msg, type) {
        const el = document.getElementById('scanStatus');
        el.textContent = msg;
        el.className = 'ep-scan-status ' + type;
    }

    // ─── PHASE TABS ───
    function switchPhase(name, btn) {
        document.querySelectorAll('.ep-phase-tab').forEach(t => t.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('phase-dandori').style.display    = name === 'dandori'    ? '' : 'none';
        document.getElementById('phase-monitoring').style.display = name === 'monitoring' ? '' : 'none';
    }

    // ─── DATE PICKER ───
    function updateDate(input) {
        const d = new Date(input.value);
        const fmt = (d.getMonth()+1).toString().padStart(2,'0') + '/' +
                    d.getDate().toString().padStart(2,'0') + '/' +
                    d.getFullYear();
        document.getElementById('todayDate').textContent = fmt;
    }

    // ─── SPV TOGGLE ───
    function toggleSpv() {
        spvChecked = !spvChecked;
        const btns  = [document.getElementById('spvBtn'), document.getElementById('spvBtn2')];
        const label = document.getElementById('spvLabel');
        btns.forEach(b => b.classList.toggle('checked', spvChecked));
        label.textContent = spvChecked ? 'CHECKED ✓' : 'PENDING';
    }

    // ─── SAVE DATA ───
    async function saveData() {
        const btn = document.getElementById('saveBtn');
        btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Menyimpan...';
        btn.disabled = true;

        function makeDateTime(timeVal) {
            if (!timeVal || timeVal === '--:--') return null;
            return document.getElementById('datePicker').value + 'T' + timeVal + ':00';
        }

        const payload = {
            Id:               recordId,
            HoseType:         document.getElementById('valHoseType').textContent,
            Dimension:        document.getElementById('valDimension').textContent,
            Yarn:             document.getElementById('valYarn').textContent,
            MaterialInner:    document.getElementById('matInner').value,
            MaterialInnerLotNo: document.getElementById('matInnerLot').value,
            MaterialInnerSG:  parseFloat(document.getElementById('matInnerSG').value) || null,
            MaterialMiddle:   document.getElementById('matMiddle').value || null,
            MaterialMiddleLotNo: document.getElementById('matMiddleLot').value || null,
            MaterialMiddleSG: parseFloat(document.getElementById('matMiddleSG').value) || null,
            MaterialOuter:    document.getElementById('matOuter').value,
            MaterialOuterLotNo: document.getElementById('matOuterLot').value,
            MaterialOuterSG:  parseFloat(document.getElementById('matOuterSG').value) || null,
            DandoriStart:     makeDateTime(document.getElementById('dandoriStartAwal').value),
            DandoriEnd:       makeDateTime(document.getElementById('dandoriStartAkhir').value),
            ProductionStart:  makeDateTime(document.getElementById('prodStart').value),
            SPVCheck:         spvChecked
        };

        try {
            const res = await fetch('/NowProducing/SaveExtruderProduce', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const json = await res.json();

            if (json.success) {
                showNotification('Data berhasil disimpan!', 'success');
            } else {
                showNotification('Gagal: ' + json.message, 'error');
            }
        } catch(e) {
            showNotification('Error jaringan!', 'error');
        }

        btn.innerHTML = '<i class="bi bi-save"></i> SIMPAN';
        btn.disabled = false;
    }

    function showNotification(msg, type) {
        const t = document.createElement('div');
        t.style.cssText = `position:fixed; top:20px; right:20px; background:${type==='success'?'#10b981':'#ef4444'}; color:white; padding:14px 22px; border-radius:8px; z-index:9999; font-weight:600; font-size:13px; box-shadow:0 4px 20px rgba(0,0,0,.4);`;
        t.textContent = msg;
        document.body.appendChild(t);
        setTimeout(() => t.remove(), 3500);
    }
</script>
}
