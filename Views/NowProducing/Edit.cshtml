@model VelastoProductionSystem.Models.NowProducing

@{
    ViewData["Title"] = "Edit Production #" + Model.Id;
}

<div class="production-view">
    <div class="card tactical-glass animate-fadeInUp">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h4 class="production-header-title mb-1">
                    <i class="bi bi-pencil-square me-2" style="font-size:0.8em; vertical-align:middle; -webkit-text-fill-color: #fbbf24;"></i>
                    Edit Production
                </h4>
                <span class="text-white-50 small" style="letter-spacing:1px;">Record #@Model.Id &mdash; @Model.ProductionDate.ToString("dd MMM yyyy")</span>
            </div>
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-dark rounded-pill px-4 border border-white border-opacity-10">
                <i class="bi bi-arrow-left me-1"></i> Back
            </a>
        </div>

        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4 mb-4"></div>
                <input type="hidden" asp-for="Id" />

                @* Section 1: Identity *@
                <h5 class="text-uppercase fw-bold mb-4 d-flex align-items-center" style="letter-spacing:2px; font-size:0.85rem;">
                    <i class="bi bi-card-list me-2 text-info"></i> Identitas Produksi
                    <hr class="flex-grow-1 ms-3 opacity-25">
                </h5>
                <div class="row g-3 mb-5">
                    <div class="col-md-4">
                        <div class="info-chip-tactical">
                            <label asp-for="ProductionDate" class="data-label-tactical"></label>
                            <input asp-for="ProductionDate" class="form-control form-control-sm bg-transparent border-0 text-white p-0" type="date" style="outline:none; box-shadow:none;" />
                        </div>
                        <span asp-validation-for="ProductionDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <div class="info-chip-tactical">
                            <label asp-for="HoseType" class="data-label-tactical"></label>
                            <input asp-for="HoseType" class="form-control form-control-sm bg-transparent border-0 text-white p-0 fw-bold" style="outline:none; box-shadow:none;" />
                        </div>
                        <span asp-validation-for="HoseType" class="text-danger small"></span>
                    </div>
                    <div class="col-md-2">
                        <div class="info-chip-tactical">
                            <label asp-for="Class" class="data-label-tactical"></label>
                            <input asp-for="Class" class="form-control form-control-sm bg-transparent border-0 text-white p-0" style="outline:none; box-shadow:none;" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="info-chip-tactical">
                            <label asp-for="Dimension" class="data-label-tactical"></label>
                            <input asp-for="Dimension" class="form-control form-control-sm bg-transparent border-0 text-white p-0" style="outline:none; box-shadow:none;" />
                        </div>
                        <span asp-validation-for="Dimension" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <div class="info-chip-tactical border-start border-info border-3">
                            <label asp-for="Yarn" class="data-label-tactical"></label>
                            <input asp-for="Yarn" class="form-control form-control-sm bg-transparent border-0 text-white p-0" style="outline:none; box-shadow:none;" />
                        </div>
                        <span asp-validation-for="Yarn" class="text-danger small"></span>
                    </div>
                </div>

                @* Section 2: Materials *@
                <h5 class="text-uppercase fw-bold mb-4 d-flex align-items-center" style="letter-spacing:2px; font-size:0.85rem;">
                    <i class="bi bi-layers me-2 text-warning"></i> Material
                    <hr class="flex-grow-1 ms-3 opacity-25">
                </h5>
                <div class="row g-4 mb-5">
                    <!-- Inner -->
                    <div class="col-md-4">
                        <div class="card material-card-tactical inner h-100">
                            <div class="card-header">1) Inner</div>
                            <div class="info-row d-flex flex-column gap-3">
                                <div>
                                    <label asp-for="MaterialInner" class="data-label-tactical"></label>
                                    <input asp-for="MaterialInner" class="form-control form-control-sm bg-transparent border-0 text-info p-0 fw-bold" style="outline:none; box-shadow:none;" />
                                </div>
                                <div>
                                    <label asp-for="MaterialInnerLotNo" class="data-label-tactical"></label>
                                    <input asp-for="MaterialInnerLotNo" class="form-control form-control-sm bg-transparent border-0 text-white p-0" style="outline:none; box-shadow:none;" />
                                </div>
                                <div>
                                    <label asp-for="MaterialInnerSG" class="data-label-tactical"></label>
                                    <input asp-for="MaterialInnerSG" class="form-control form-control-sm bg-transparent border-0 text-white p-0" type="number" step="0.0001" style="outline:none; box-shadow:none;" />
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Middle -->
                    <div class="col-md-4">
                        <div class="card material-card-tactical middle h-100">
                            <div class="card-header">2) Middle <span class="opacity-50 small">(Optional)</span></div>
                            <div class="info-row d-flex flex-column gap-3">
                                <div>
                                    <label asp-for="MaterialMiddle" class="data-label-tactical"></label>
                                    <input asp-for="MaterialMiddle" class="form-control form-control-sm bg-transparent border-0 text-warning p-0 fw-bold" style="outline:none; box-shadow:none;" />
                                </div>
                                <div>
                                    <label asp-for="MaterialMiddleLotNo" class="data-label-tactical"></label>
                                    <input asp-for="MaterialMiddleLotNo" class="form-control form-control-sm bg-transparent border-0 text-white p-0" style="outline:none; box-shadow:none;" />
                                </div>
                                <div>
                                    <label asp-for="MaterialMiddleSG" class="data-label-tactical"></label>
                                    <input asp-for="MaterialMiddleSG" class="form-control form-control-sm bg-transparent border-0 text-white p-0" type="number" step="0.0001" style="outline:none; box-shadow:none;" />
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Outer -->
                    <div class="col-md-4">
                        <div class="card material-card-tactical outer h-100">
                            <div class="card-header">3) Outer</div>
                            <div class="info-row d-flex flex-column gap-3">
                                <div>
                                    <label asp-for="MaterialOuter" class="data-label-tactical"></label>
                                    <input asp-for="MaterialOuter" class="form-control form-control-sm bg-transparent border-0 text-success p-0 fw-bold" style="outline:none; box-shadow:none;" />
                                </div>
                                <div>
                                    <label asp-for="MaterialOuterLotNo" class="data-label-tactical"></label>
                                    <input asp-for="MaterialOuterLotNo" class="form-control form-control-sm bg-transparent border-0 text-white p-0" style="outline:none; box-shadow:none;" />
                                </div>
                                <div>
                                    <label asp-for="MaterialOuterSG" class="data-label-tactical"></label>
                                    <input asp-for="MaterialOuterSG" class="form-control form-control-sm bg-transparent border-0 text-white p-0" type="number" step="0.0001" style="outline:none; box-shadow:none;" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* Section 3: Time *@
                <h5 class="text-uppercase fw-bold mb-4 d-flex align-items-center" style="letter-spacing:2px; font-size:0.85rem;">
                    <i class="bi bi-stopwatch me-2 text-success"></i> Waktu Produksi
                    <hr class="flex-grow-1 ms-3 opacity-25">
                </h5>
                <div class="performance-container mb-5">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <div class="info-chip-tactical">
                                <label asp-for="DandoriStartProdTime" class="data-label-tactical">Dandori Start</label>
                                <input asp-for="DandoriStartProdTime" class="form-control form-control-sm bg-transparent border-0 text-white p-0" type="datetime-local" style="outline:none; box-shadow:none;" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="info-chip-tactical">
                                <label asp-for="DandoriEndProdTime" class="data-label-tactical">Dandori End</label>
                                <input asp-for="DandoriEndProdTime" class="form-control form-control-sm bg-transparent border-0 text-white p-0" type="datetime-local" style="outline:none; box-shadow:none;" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="info-chip-tactical border-start border-success border-3">
                                <label asp-for="ProductionStartTime" class="data-label-tactical">Production Start</label>
                                <input asp-for="ProductionStartTime" class="form-control form-control-sm bg-transparent border-0 text-white p-0" type="datetime-local" style="outline:none; box-shadow:none;" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="info-chip-tactical border-start border-warning border-3">
                                <label asp-for="ProductionEndTime" class="data-label-tactical">Production End</label>
                                <input asp-for="ProductionEndTime" class="form-control form-control-sm bg-transparent border-0 text-white p-0" type="datetime-local" style="outline:none; box-shadow:none;" />
                            </div>
                        </div>
                    </div>
                </div>

                @* Section 4: SPV & Notes *@
                <h5 class="text-uppercase fw-bold mb-4 d-flex align-items-center" style="letter-spacing:2px; font-size:0.85rem;">
                    <i class="bi bi-shield-check me-2 text-primary"></i> SPV & Notes
                    <hr class="flex-grow-1 ms-3 opacity-25">
                </h5>
                <div class="row g-3 mb-5">
                    <div class="col-md-4">
                        <div class="info-chip-tactical">
                            <div class="form-check d-flex align-items-center gap-3 mb-0">
                                <input asp-for="SPVCheck" class="form-check-input mt-0" style="width:22px; height:22px; border-radius:8px;" />
                                <label asp-for="SPVCheck" class="data-value-tactical mb-0" style="cursor:pointer;">SPV Checked</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-chip-tactical">
                            <label asp-for="SPVCheckBy" class="data-label-tactical">SPV Name</label>
                            <input asp-for="SPVCheckBy" class="form-control form-control-sm bg-transparent border-0 text-white p-0" placeholder="Nama SPV..." style="outline:none; box-shadow:none;" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-chip-tactical">
                            <label asp-for="SPVCheckTime" class="data-label-tactical">SPV Check Time</label>
                            <input asp-for="SPVCheckTime" class="form-control form-control-sm bg-transparent border-0 text-white p-0" type="datetime-local" style="outline:none; box-shadow:none;" />
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="info-chip-tactical">
                            <label asp-for="Notes" class="data-label-tactical">Catatan</label>
                            <textarea asp-for="Notes" class="form-control form-control-sm bg-transparent border-0 text-white p-0" rows="2" placeholder="Catatan tambahan..." style="outline:none; box-shadow:none; resize:none;"></textarea>
                        </div>
                    </div>
                </div>

                @* Buttons *@
                <div class="d-flex gap-3">
                    <button type="submit" class="btn tactical-btn tactical-btn-primary px-5">
                        <i class="bi bi-save me-2"></i> Save Changes
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-dark rounded-pill px-4 border border-white border-opacity-10">
                        <i class="bi bi-x-circle me-1"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <style>
        /* Make native date inputs visible in dark theme */
        input[type="date"], input[type="datetime-local"] {
            color-scheme: dark;
        }
        /* Subtle focus glow on editable fields */
        .info-chip-tactical input:focus,
        .info-chip-tactical textarea:focus {
            color: #60a5fa !important;
        }
    </style>
}
