@model VelastoProductionSystem.Models.NowProducing

@{
    ViewData["Title"] = "Start New Production";
}

<div class="production-view">
    <div class="card tactical-glass animate-fadeInUp">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h4 class="production-header-title mb-1">
                    <i class="bi bi-plus-square-dotted me-2" style="font-size:0.8em; vertical-align:middle; -webkit-text-fill-color: var(--velasto-blue);"></i>
                    Start New Production
                </h4>
                <span class="text-white-50 small" style="letter-spacing:1px;">Initialize live production tracking</span>
            </div>
            <a asp-action="Index" class="btn btn-dark rounded-pill px-4 border border-white border-opacity-10">
                <i class="bi bi-arrow-left me-1"></i> Back to History
            </a>
        </div>

        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4 mb-4"></div>

                @* Section 1: Identity *@
                <h5 class="text-uppercase fw-bold mb-4 d-flex align-items-center" style="letter-spacing:2px; font-size:0.85rem;">
                    <i class="bi bi-card-list me-2 text-info"></i> Identitas Produksi
                    <hr class="flex-grow-1 ms-3 opacity-25">
                </h5>
                <div class="row g-3 mb-5">
                    <div class="col-md-4">
                        <div class="info-chip-tactical">
                            <label asp-for="ProductionDate" class="data-label-tactical"></label>
                            <input asp-for="ProductionDate" class="form-control form-control-sm bg-transparent border-0 text-white p-0" type="date" style="outline:none; box-shadow:none;" />
                        </div>
                        <span asp-validation-for="ProductionDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <div class="info-chip-tactical">
                            <label asp-for="HoseType" class="data-label-tactical"></label>
                            <input asp-for="HoseType" class="form-control form-control-sm bg-transparent border-0 text-white p-0 fw-bold" placeholder="e.g., Fuel Hose" style="outline:none; box-shadow:none;" />
                        </div>
                        <span asp-validation-for="HoseType" class="text-danger small"></span>
                    </div>
                    <div class="col-md-2">
                        <div class="info-chip-tactical">
                            <label asp-for="Class" class="data-label-tactical"></label>
                            <input asp-for="Class" class="form-control form-control-sm bg-transparent border-0 text-white p-0" placeholder="Class" style="outline:none; box-shadow:none;" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="info-chip-tactical">
                            <label asp-for="Dimension" class="data-label-tactical"></label>
                            <input asp-for="Dimension" class="form-control form-control-sm bg-transparent border-0 text-white p-0" placeholder="e.g., Ø 11" style="outline:none; box-shadow:none;" />
                        </div>
                        <span asp-validation-for="Dimension" class="text-danger small"></span>
                    </div>
                    <div class="col-md-12">
                        <div class="info-chip-tactical border-start border-white border-opacity-10">
                            <label asp-for="Yarn" class="data-label-tactical"></label>
                            <input asp-for="Yarn" class="form-control form-control-sm bg-transparent border-0 text-white p-0" placeholder="e.g., Polyester 1500D" style="outline:none; box-shadow:none;" />
                        </div>
                        <span asp-validation-for="Yarn" class="text-danger small"></span>
                    </div>
                </div>

                @* Section 2: Materials Verification (Screenshot Layout) *@
                <div class="material-verification-container mb-1 animate-fadeInUp">
                    <div class="row g-0 border border-info border-opacity-25 rounded-1 overflow-hidden">
                        <!-- Main Content Area -->
                        <div class="col-10 border-end border-info border-opacity-25 bg-black bg-opacity-40">
                            <!-- Header (Optional title bar) -->
                            <div class="p-1 px-3 bg-info bg-opacity-10 border-bottom border-info border-opacity-25">
                                <span class="data-label-tactical text-info mb-0" style="font-size:0.6rem;">MATERIAL VERIFICATION</span>
                            </div>
                            
                            <!-- Rows -->
                            <div class="p-3 d-flex flex-column gap-3">
                                <!-- Inner Row -->
                                <div class="d-flex align-items-center gap-4 text-nowrap">
                                    <div style="width: 80px;"><span class="fw-bold">1) Inner :</span></div>
                                    <div class="flex-grow-1"><input asp-for="MaterialInner" class="tactical-line-input text-info w-100" placeholder="Material code..." /></div>
                                    <div><span class="fw-bold">No.Lot :</span></div>
                                    <div style="width: 150px;"><input asp-for="MaterialInnerLotNo" class="tactical-line-input w-100" placeholder="..." /></div>
                                    <div><span class="fw-bold">SG :</span></div>
                                    <div style="width: 100px;"><input asp-for="MaterialInnerSG" class="tactical-line-input w-100" placeholder="..." /></div>
                                </div>
                                
                                <!-- Middle Row -->
                                <div class="d-flex align-items-center gap-4 text-nowrap">
                                    <div style="width: 80px;"><span class="fw-bold">2) Middle :</span></div>
                                    <div class="flex-grow-1"><input asp-for="MaterialMiddle" class="tactical-line-input text-warning w-100" placeholder="Optional code..." /></div>
                                    <div><span class="fw-bold">No.Lot :</span></div>
                                    <div style="width: 150px;"><input asp-for="MaterialMiddleLotNo" class="tactical-line-input w-100" placeholder="..." /></div>
                                    <div><span class="fw-bold">SG :</span></div>
                                    <div style="width: 100px;"><input asp-for="MaterialMiddleSG" class="tactical-line-input w-100" placeholder="..." /></div>
                                </div>
                                
                                <!-- Outer Row -->
                                <div class="d-flex align-items-center gap-4 text-nowrap">
                                    <div style="width: 80px;"><span class="fw-bold">3) Outer :</span></div>
                                    <div class="flex-grow-1"><input asp-for="MaterialOuter" class="tactical-line-input text-success w-100" placeholder="Material code..." /></div>
                                    <div><span class="fw-bold">No.Lot :</span></div>
                                    <div style="width: 150px;"><input asp-for="MaterialOuterLotNo" class="tactical-line-input w-100" placeholder="..." /></div>
                                    <div><span class="fw-bold">SG :</span></div>
                                    <div style="width: 100px;"><input asp-for="MaterialOuterSG" class="tactical-line-input w-100" placeholder="..." /></div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- SPV Check Column -->
                        <div class="col-2 bg-black bg-opacity-60 d-flex flex-column">
                            <div class="p-1 text-center bg-info bg-opacity-10 border-bottom border-info border-opacity-25">
                                <span class="data-label-tactical text-info mb-0" style="font-size:0.6rem;">SPV CHECK</span>
                            </div>
                            <div class="flex-grow-1 d-flex flex-column justify-content-center align-items-center gap-3">
                                <div class="spv-status-icon @(Model != null && Model.SPVCheck ? "active" : "")">
                                    <i class="bi bi-shield-check"></i>
                                </div>
                                <div class="spv-status-icon">
                                    <i class="bi bi-shield-slash opacity-50"></i>
                                </div>
                                <div class="spv-status-icon">
                                    <i class="bi bi-shield-slash opacity-50"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* Red Note Bar *@
                <div class="red-warning-bar mb-5 animate-fadeInUp">
                    <span class="fw-bold">NOTE:</span> JANGAN MENJALANKAN PRODUKSI SEBELUM CHECKSHEET INI DI CHECK OLEH SUPERVISOR.
                </div>

                @* Hidden Verification Field (controlled by standard UI elsewhere or a modal) *@
                <input type="hidden" asp-for="SPVCheck" value="false" id="spvCheckHidden" />

                @* Buttons (Right Aligned like screenshot) *@
                <div class="d-flex justify-content-end gap-3 mt-4 animate-fadeInUp">
                    <button type="submit" class="btn btn-velasto-green px-5 py-2">
                         <i class="bi bi-play-fill me-2 fs-5"></i> START PRODUCTION
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <style>
        input[type="date"], input[type="datetime-local"] {
            color-scheme: dark;
        }
        .info-chip-tactical input:focus {
            color: #60a5fa !important;
        }
        .extra-small {
            font-size: 0.65rem;
            display: block;
            margin-top: 2px;
        }

        /* Tactical Table styles based on screenshot */
        .tactical-line-input {
            background: transparent;
            border: none;
            border-bottom: 1px dotted rgba(255, 255, 255, 0.4);
            color: white;
            font-size: 0.85rem;
            padding: 2px 5px;
            outline: none;
            transition: all 0.3s ease;
        }
        
        .tactical-line-input:focus {
            border-bottom: 1px solid var(--velasto-blue);
            background: rgba(0, 102, 255, 0.05);
        }

        .spv-status-icon {
            width: 32px;
            height: 32px;
            border: 1px solid rgba(255, 255, 255, 0.15);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            color: rgba(255, 255, 255, 0.3);
            background: rgba(255, 255, 255, 0.02);
            border-radius: 4px;
        }

        .spv-status-icon.active {
            border-color: #10b981;
            color: #10b981;
            background: rgba(16, 185, 129, 0.1);
            box-shadow: 0 0 10px rgba(16, 185, 129, 0.2);
        }

        .red-warning-bar {
            background: rgba(227, 6, 19, 0.15);
            border: 1px solid rgba(227, 6, 19, 0.3);
            border-left: 4px solid #E30613;
            color: #ff6b6b;
            padding: 8px 15px;
            font-size: 0.8rem;
            letter-spacing: 0.5px;
        }

        .btn-velasto-green {
            background: #10b981;
            color: white;
            border: none;
            border-radius: 4px;
            font-weight: 800;
            letter-spacing: 1px;
            box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
            transition: all 0.3s ease;
        }

        .btn-velasto-green:hover {
            background: #059669;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(16, 185, 129, 0.4);
            color: white;
        }
    </style>
}
