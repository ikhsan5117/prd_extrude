@model VelastoProductionSystem.Models.NowProducing

@{
    ViewData["Title"] = "Start New Production";
}

<div class="production-view">
    <div class="card tactical-glass animate-fadeInUp">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h4 class="production-header-title mb-1">
                    <i class="bi bi-plus-square-dotted me-2" style="font-size:0.8em; vertical-align:middle; -webkit-text-fill-color: var(--velasto-blue);"></i>
                    Start New Production
                </h4>
                <span class="text-white-50 small" style="letter-spacing:1px;">Initialize live production tracking</span>
            </div>
            <a asp-action="Index" class="btn btn-dark rounded-pill px-4 border border-white border-opacity-10">
                <i class="bi bi-arrow-left me-1"></i> Back to History
            </a>
        </div>

        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4 mb-4"></div>

                @* Section 1: Identity *@
                <h5 class="text-uppercase fw-bold mb-4 d-flex align-items-center" style="letter-spacing:2px; font-size:0.85rem;">
                    <i class="bi bi-card-list me-2 text-info"></i> Identitas Produksi
                    <hr class="flex-grow-1 ms-3 opacity-25">
                </h5>
                <div class="row g-3 mb-5">
                    <div class="col-md-4">
                        <div class="info-chip-tactical">
                            <label asp-for="ProductionDate" class="data-label-tactical"></label>
                            <input asp-for="ProductionDate" class="form-control form-control-sm bg-transparent border-0 text-white p-0" type="date" style="outline:none; box-shadow:none;" />
                        </div>
                        <span asp-validation-for="ProductionDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <div class="info-chip-tactical">
                            <label asp-for="HoseType" class="data-label-tactical"></label>
                            <input asp-for="HoseType" class="form-control form-control-sm bg-transparent border-0 text-white p-0 fw-bold" placeholder="e.g., Fuel Hose" style="outline:none; box-shadow:none;" />
                        </div>
                        <span asp-validation-for="HoseType" class="text-danger small"></span>
                    </div>
                    <div class="col-md-2">
                        <div class="info-chip-tactical">
                            <label asp-for="Class" class="data-label-tactical"></label>
                            <input asp-for="Class" class="form-control form-control-sm bg-transparent border-0 text-white p-0" placeholder="Class" style="outline:none; box-shadow:none;" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="info-chip-tactical">
                            <label asp-for="Dimension" class="data-label-tactical"></label>
                            <input asp-for="Dimension" class="form-control form-control-sm bg-transparent border-0 text-white p-0" placeholder="e.g., Ø 11" style="outline:none; box-shadow:none;" />
                        </div>
                        <span asp-validation-for="Dimension" class="text-danger small"></span>
                    </div>
                    <div class="col-md-12">
                        <div class="info-chip-tactical border-start border-white border-opacity-10">
                            <label asp-for="Yarn" class="data-label-tactical"></label>
                            <input asp-for="Yarn" class="form-control form-control-sm bg-transparent border-0 text-white p-0" placeholder="e.g., Polyester 1500D" style="outline:none; box-shadow:none;" />
                        </div>
                        <span asp-validation-for="Yarn" class="text-danger small"></span>
                    </div>
                </div>

                @* Section 2: Materials *@
                <h5 class="text-uppercase fw-bold mb-4 d-flex align-items-center" style="letter-spacing:2px; font-size:0.85rem;">
                    <i class="bi bi-layers-half me-2 text-warning"></i> Material Information
                    <hr class="flex-grow-1 ms-3 opacity-25">
                </h5>
                <div class="row g-4 mb-5">
                    <!-- Inner -->
                    <div class="col-md-4">
                        <div class="card material-card-tactical inner h-100">
                            <div class="card-header">1) Inner</div>
                            <div class="info-row d-flex flex-column gap-3">
                                <div>
                                    <label asp-for="MaterialInner" class="data-label-tactical"></label>
                                    <input asp-for="MaterialInner" class="form-control form-control-sm bg-transparent border-0 text-info p-0 fw-bold" placeholder="Material code..." style="outline:none; box-shadow:none;" />
                                    <span asp-validation-for="MaterialInner" class="text-danger extra-small"></span>
                                </div>
                                <div>
                                    <label asp-for="MaterialInnerLotNo" class="data-label-tactical"></label>
                                    <input asp-for="MaterialInnerLotNo" class="form-control form-control-sm bg-transparent border-0 text-white p-0" placeholder="Lot number..." style="outline:none; box-shadow:none;" />
                                    <span asp-validation-for="MaterialInnerLotNo" class="text-danger extra-small"></span>
                                </div>
                                <div>
                                    <label asp-for="MaterialInnerSG" class="data-label-tactical"></label>
                                    <input asp-for="MaterialInnerSG" class="form-control form-control-sm bg-transparent border-0 text-white p-0" type="number" step="0.0001" placeholder="0.0000" style="outline:none; box-shadow:none;" />
                                    <span asp-validation-for="MaterialInnerSG" class="text-danger extra-small"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Middle -->
                    <div class="col-md-4">
                        <div class="card material-card-tactical middle h-100">
                            <div class="card-header">2) Middle <span class="opacity-50 small">(Optional)</span></div>
                            <div class="info-row d-flex flex-column gap-3">
                                <div>
                                    <label asp-for="MaterialMiddle" class="data-label-tactical"></label>
                                    <input asp-for="MaterialMiddle" class="form-control form-control-sm bg-transparent border-0 text-warning p-0 fw-bold" placeholder="Optional..." style="outline:none; box-shadow:none;" />
                                </div>
                                <div>
                                    <label asp-for="MaterialMiddleLotNo" class="data-label-tactical"></label>
                                    <input asp-for="MaterialMiddleLotNo" class="form-control form-control-sm bg-transparent border-0 text-white p-0" placeholder="Optional..." style="outline:none; box-shadow:none;" />
                                </div>
                                <div>
                                    <label asp-for="MaterialMiddleSG" class="data-label-tactical"></label>
                                    <input asp-for="MaterialMiddleSG" class="form-control form-control-sm bg-transparent border-0 text-white p-0" type="number" step="0.0001" placeholder="0.0000" style="outline:none; box-shadow:none;" />
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Outer -->
                    <div class="col-md-4">
                        <div class="card material-card-tactical outer h-100">
                            <div class="card-header">3) Outer</div>
                            <div class="info-row d-flex flex-column gap-3">
                                <div>
                                    <label asp-for="MaterialOuter" class="data-label-tactical"></label>
                                    <input asp-for="MaterialOuter" class="form-control form-control-sm bg-transparent border-0 text-success p-0 fw-bold" placeholder="Material code..." style="outline:none; box-shadow:none;" />
                                    <span asp-validation-for="MaterialOuter" class="text-danger extra-small"></span>
                                </div>
                                <div>
                                    <label asp-for="MaterialOuterLotNo" class="data-label-tactical"></label>
                                    <input asp-for="MaterialOuterLotNo" class="form-control form-control-sm bg-transparent border-0 text-white p-0" placeholder="Lot number..." style="outline:none; box-shadow:none;" />
                                    <span asp-validation-for="MaterialOuterLotNo" class="text-danger extra-small"></span>
                                </div>
                                <div>
                                    <label asp-for="MaterialOuterSG" class="data-label-tactical"></label>
                                    <input asp-for="MaterialOuterSG" class="form-control form-control-sm bg-transparent border-0 text-white p-0" type="number" step="0.0001" placeholder="0.0000" style="outline:none; box-shadow:none;" />
                                    <span asp-validation-for="MaterialOuterSG" class="text-danger extra-small"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* Section 3: Time *@
                <h5 class="text-uppercase fw-bold mb-4 d-flex align-items-center" style="letter-spacing:2px; font-size:0.85rem;">
                    <i class="bi bi-clock-history me-2 text-primary"></i> Production Timeline
                    <hr class="flex-grow-1 ms-3 opacity-25">
                </h5>
                <div class="performance-container mb-5">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="info-chip-tactical">
                                <label asp-for="DandoriStartProdTime" class="data-label-tactical">Dandori Start</label>
                                <input asp-for="DandoriStartProdTime" class="form-control form-control-sm bg-transparent border-0 text-white p-0" type="datetime-local" style="outline:none; box-shadow:none;" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="info-chip-tactical">
                                <label asp-for="DandoriEndProdTime" class="data-label-tactical">Dandori End</label>
                                <input asp-for="DandoriEndProdTime" class="form-control form-control-sm bg-transparent border-0 text-white p-0" type="datetime-local" style="outline:none; box-shadow:none;" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="info-chip-tactical border-start border-success border-3">
                                <label asp-for="ProductionStartTime" class="data-label-tactical">Production Start</label>
                                <input asp-for="ProductionStartTime" class="form-control form-control-sm bg-transparent border-0 text-white p-0" type="datetime-local" style="outline:none; box-shadow:none;" />
                            </div>
                        </div>
                    </div>
                </div>

                @* Section 4: SPV *@
                <div class="p-4 rounded-4 bg-white bg-opacity-5 border border-white border-opacity-10 mb-5">
                    <div class="form-check d-flex align-items-center gap-3">
                        <input asp-for="SPVCheck" class="form-check-input mt-0" style="width:24px; height:24px; border-radius:8px;" />
                        <div>
                            <label asp-for="SPVCheck" class="text-white fw-bold mb-0" style="cursor:pointer; font-size:1rem;">Verified by Supervisor</label>
                            <p class="text-white-50 small mb-0">Check this if the production setup has been authorized.</p>
                        </div>
                    </div>
                </div>

                @* Buttons *@
                <div class="d-flex gap-3">
                    <button type="submit" class="btn tactical-btn tactical-btn-primary px-5 py-3">
                        <i class="bi bi-play-fill me-2 fs-5"></i> START PRODUCTION
                    </button>
                    <a asp-action="Index" class="btn btn-dark rounded-pill px-5 border border-white border-opacity-10 d-flex align-items-center">
                        CANCEL
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <style>
        input[type="date"], input[type="datetime-local"] {
            color-scheme: dark;
        }
        .info-chip-tactical input:focus {
            color: #60a5fa !important;
        }
        .extra-small {
            font-size: 0.65rem;
            display: block;
            margin-top: 2px;
        }
    </style>
}
