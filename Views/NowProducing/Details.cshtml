@model VelastoProductionSystem.Models.NowProducing

@{
    ViewData["Title"] = "Production Record #" + Model.Id;
    var isActive = Model.ProductionEndTime == null;
    var duration = isActive
        ? (DateTime.Now - (Model.ProductionStartTime ?? Model.CreatedDate))
        : (Model.ProductionEndTime!.Value - (Model.ProductionStartTime ?? Model.CreatedDate));
}

<div class="production-view">
    <div class="card tactical-glass animate-fadeInUp">
        <!-- Header -->
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h4 class="production-header-title mb-1">
                    <i class="bi bi-file-earmark-text me-2" style="font-size: 0.8em; vertical-align: middle; -webkit-text-fill-color: var(--velasto-blue);"></i>
                    Production Record
                </h4>
                <span class="text-white-50 small" style="letter-spacing: 1px;">#@Model.Id &mdash; @Model.ProductionDate.ToString("dd MMM yyyy")</span>
            </div>
            <div class="d-flex gap-2 flex-wrap no-print">
                @if (isActive)
                {
                    <span class="running-glow align-self-center">
                        <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>ACTIVE
                    </span>
                }
                else
                {
                    <span class="badge bg-secondary rounded-pill px-3 py-2 align-self-center fw-bold">COMPLETED</span>
                }
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn tactical-btn tactical-btn-warning">
                    <i class="bi bi-pencil me-1"></i> Edit
                </a>
                <button onclick="window.print()" class="btn btn-outline-light tactical-btn">
                    <i class="bi bi-printer me-1"></i> Print
                </button>
                <a asp-action="Index" class="btn btn-dark rounded-pill px-4 border border-white border-opacity-10">
                    <i class="bi bi-arrow-left me-1"></i> Back
                </a>
            </div>
        </div>

        <div class="card-body p-4">

            <!-- Section 1: Identity & Time -->
            <div class="row g-4 mb-5">
                <!-- Left: Identity Chips -->
                <div class="col-lg-6">
                    <p class="data-label-tactical mb-3"><i class="bi bi-card-list me-1"></i> IDENTITAS PRODUKSI</p>
                    <div class="row g-3">
                        <div class="col-6">
                            <div class="info-chip-tactical">
                                <span class="data-label-tactical">Hose Type</span>
                                <span class="data-value-tactical">@Model.HoseType</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="info-chip-tactical">
                                <span class="data-label-tactical">Date</span>
                                <span class="data-value-tactical">@Model.ProductionDate.ToString("dd MMM yyyy")</span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="info-chip-tactical">
                                <span class="data-label-tactical">Class</span>
                                <span class="data-value-tactical">@(Model.Class ?? "-")</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="info-chip-tactical border-start border-primary border-3">
                                <span class="data-label-tactical">Dimension</span>
                                <span class="data-value-tactical">@Model.Dimension</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="info-chip-tactical border-start border-info border-3">
                                <span class="data-label-tactical">Yarn</span>
                                <span class="data-value-tactical">@Model.Yarn</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right: Time Performance -->
                <div class="col-lg-6">
                    <p class="data-label-tactical mb-3"><i class="bi bi-stopwatch me-1"></i> WAKTU PRODUKSI</p>
                    <div class="performance-container">
                        <table class="time-table-tactical text-center w-100">
                            <thead>
                                <tr>
                                    <th class="text-start">Process</th>
                                    <th>Starting</th>
                                    <th>Ending</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="fw-bold text-start text-white-50">Dandori</td>
                                    <td>@(Model.DandoriStartProdTime?.ToString("HH:mm") ?? "-")</td>
                                    <td>@(Model.DandoriEndProdTime?.ToString("HH:mm") ?? "-")</td>
                                </tr>
                                <tr>
                                    <td class="fw-bold text-start text-white-50">Production</td>
                                    <td>@(Model.ProductionStartTime?.ToString("HH:mm") ?? "-")</td>
                                    <td>
                                        @if (Model.ProductionEndTime != null)
                                        {
                                            @Model.ProductionEndTime.Value.ToString("HH:mm")
                                        }
                                        else
                                        {
                                            <span class="running-glow">Running...</span>
                                        }
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                        @if (Model.ProductionStartTime != null)
                        {
                            <div class="mt-3 pt-3 border-top border-white border-opacity-10 text-center">
                                <span class="data-label-tactical">Total Duration</span>
                                <span class="data-value-tactical text-info" style="font-size: 1.4rem;">
                                    @($"{(int)duration.TotalHours:D2}:{duration.Minutes:D2}:{duration.Seconds:D2}")
                                </span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Section 2: Materials -->
            <h5 class="text-uppercase fw-bold mb-4 d-flex align-items-center" style="letter-spacing: 2px;">
                <span class="me-3">Material</span>
                <hr class="flex-grow-1 opacity-25">
            </h5>
            <div class="row g-4 mb-5">
                <div class="col-md-4">
                    <div class="card material-card-tactical inner">
                        <div class="card-header">1) Inner</div>
                        <div class="info-row">
                            <span class="data-label-tactical">Material</span>
                            <span class="data-value-tactical text-info">@Model.MaterialInner</span>
                            <hr class="my-2 opacity-10">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <span class="data-label-tactical">No. Lot</span>
                                    <span class="data-value-tactical fs-6">@Model.MaterialInnerLotNo</span>
                                </div>
                                <div class="text-end">
                                    <span class="data-label-tactical">SG</span>
                                    <span class="data-value-tactical fs-6">@Model.MaterialInnerSG</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.MaterialMiddle))
                {
                    <div class="col-md-4">
                        <div class="card material-card-tactical middle">
                            <div class="card-header">2) Middle</div>
                            <div class="info-row">
                                <span class="data-label-tactical">Material</span>
                                <span class="data-value-tactical text-warning">@Model.MaterialMiddle</span>
                                <hr class="my-2 opacity-10">
                                <div class="d-flex justify-content-between">
                                    <div>
                                        <span class="data-label-tactical">No. Lot</span>
                                        <span class="data-value-tactical fs-6">@Model.MaterialMiddleLotNo</span>
                                    </div>
                                    <div class="text-end">
                                        <span class="data-label-tactical">SG</span>
                                        <span class="data-value-tactical fs-6">@Model.MaterialMiddleSG</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <div class="col-md-4">
                    <div class="card material-card-tactical outer">
                        <div class="card-header">3) Outer</div>
                        <div class="info-row">
                            <span class="data-label-tactical">Material</span>
                            <span class="data-value-tactical text-success">@Model.MaterialOuter</span>
                            <hr class="my-2 opacity-10">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <span class="data-label-tactical">No. Lot</span>
                                    <span class="data-value-tactical fs-6">@Model.MaterialOuterLotNo</span>
                                </div>
                                <div class="text-end">
                                    <span class="data-label-tactical">SG</span>
                                    <span class="data-value-tactical fs-6">@Model.MaterialOuterSG</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section 3: SPV + Notes -->
            <div class="row g-4">
                <div class="col-lg-8">
                    <div class="spv-glow-container @(Model.SPVCheck ? "checked" : "")">
                        @if (Model.SPVCheck)
                        {
                            <i class="bi bi-check-circle-fill spv-icon-glow text-success"></i>
                            <h4 class="text-white fw-bold mb-1">SUPERVISOR CHECKED</h4>
                            <p class="text-success opacity-75 mb-0">Production is authorized to continue.</p>
                            @if (Model.SPVCheckBy != null)
                            {
                                <p class="text-white-50 small mt-2">
                                    <i class="bi bi-person-check me-1"></i>By: @Model.SPVCheckBy
                                    @if (Model.SPVCheckTime != null) { <span>&nbsp;at @Model.SPVCheckTime.Value.ToString("HH:mm")</span> }
                                </p>
                            }
                        }
                        else
                        {
                            <i class="bi bi-clock-history spv-icon-glow text-warning"></i>
                            <h4 class="text-white fw-bold mb-1">WAITING FOR SPV CHECK</h4>
                            <p class="text-warning opacity-75 mb-0">Awaiting supervisor verification.</p>
                        }
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="h-100 p-4 rounded-4 bg-white bg-opacity-5 border border-white border-opacity-10">
                        <span class="data-label-tactical"><i class="bi bi-info-circle me-1"></i>RECORD INFO</span>
                        <div class="mt-3 d-flex flex-column gap-3">
                            <div>
                                <span class="data-label-tactical">Created By</span>
                                <span class="data-value-tactical fs-6">@(string.IsNullOrEmpty(Model.CreatedBy) ? "-" : Model.CreatedBy)</span>
                            </div>
                            <div>
                                <span class="data-label-tactical">Created At</span>
                                <span class="data-value-tactical fs-6">@Model.CreatedDate.ToString("dd MMM yyyy HH:mm")</span>
                            </div>
                            <div>
                                <span class="data-label-tactical">Status</span>
                                @if (isActive)
                                {
                                    <span class="running-glow d-inline-block mt-1">Active</span>
                                }
                                else
                                {
                                    <span class="data-value-tactical fs-6 text-secondary">Completed</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(Model.Notes))
                            {
                                <div>
                                    <span class="data-label-tactical">Notes</span>
                                    <span class="data-value-tactical fs-6">@Model.Notes</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <div class="mt-4 no-print d-flex justify-content-between align-items-center">
        <a asp-action="Index" class="btn btn-dark rounded-pill px-4 border border-white border-opacity-10">
            <i class="bi bi-arrow-left me-2"></i> Back to List
        </a>
        <div class="text-white-50 small">
            <i class="bi bi-shield-lock me-1"></i> Velasto Secure Production System v4.0
        </div>
    </div>
</div>
