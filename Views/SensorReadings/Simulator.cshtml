@{
    ViewData["Title"] = "Sensor Simulator";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var apiKey    = ViewBag.ApiKey    as string ?? "VS-SENSOR-KEY-2026";
    var ingestUrl = ViewBag.IngestUrl as string ?? "/api/sensor-readings/ingest";
}

@section Styles {
<style>
    /* ── Layout ────────────────────────────────────────────────────── */
    .sim-card       { border: 1px solid rgba(255,255,255,.1); border-radius: 10px;
                      background: var(--bs-body-bg); transition: box-shadow .2s; }
    .sim-card:hover { box-shadow: 0 4px 18px rgba(0,0,0,.25); }
    .sim-card.running { 
        border-color: #198754; 
        box-shadow: 0 0 20px rgba(25,135,84,0.3);
        background: linear-gradient(to bottom, rgba(25,135,84,0.05), transparent);
    }
    .sim-card.stopped { border-color: rgba(108,117,125,.3); opacity: 0.85; }

    /* ── Header strip ──────────────────────────────────────────────── */
    .sensor-header  { border-radius: 8px 8px 0 0; padding: 10px 14px;
                      border-bottom: 1px solid rgba(255,255,255,.08); }
    .sensor-header.running { background: rgba(25,135,84,.15); }
    .sensor-header.stopped { background: rgba(108,117,125,.1); }

    /* ── Value display ─────────────────────────────────────────────── */
    .live-val       { font-size: 2rem; font-weight: 800; line-height: 1; }
    .live-unit      { font-size: .85rem; opacity: .6; }
    .sent-count     { font-size: .72rem; opacity: .6; }

    /* ── Pulse dot ─────────────────────────────────────────────────── */
    .pulse-dot      { width: 9px; height: 9px; border-radius: 50%;
                      display: inline-block; margin-right: 5px; }
    .pulse-green    { background:#198754; animation: pulse 1.2s infinite; }
    .pulse-grey     { background:#6c757d; }
    @@keyframes pulse {
        0%  { box-shadow: 0 0 0 0 rgba(25,135,84,.6); }
        70% { box-shadow: 0 0 0 7px rgba(25,135,84,0); }
        100%{ box-shadow: 0 0 0 0 rgba(25,135,84,0); }
    }

    /* ── Mini chart ────────────────────────────────────────────────── */
    .mini-chart-wrap { height: 80px; }

    /* ── Log panel ─────────────────────────────────────────────────── */
    #logPanel       { height: 340px; overflow-y: auto; font-size: .75rem;
                      font-family: monospace; background: #0d1117;
                      border-radius: 8px; padding: 10px 12px; }
    .log-ok         { color: #3fb950; }
    .log-dup        { color: #d29922; }
    .log-err        { color: #f85149; }
    .log-info       { color: #79c0ff; }
    .log-ts         { color: #8b949e; margin-right: 6px; }

    /* ── Config panel ──────────────────────────────────────────────── */
    .config-label   { font-size: .72rem; text-transform: uppercase;
                      letter-spacing: .06em; opacity: .6; margin-bottom: 2px; }
    .form-control-sim, .form-select-sim {
        font-size: .82rem; padding: 4px 8px;
    }

    /* ── Global stats bar ──────────────────────────────────────────── */
    .gstat-box  { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08);
                  border-radius: 8px; padding: 10px 16px; text-align: center; }
    .gstat-val  { font-size: 1.4rem; font-weight: 700; }
    .gstat-lbl  { font-size: .68rem; text-transform: uppercase; opacity: .55; }

    /* ── Preset pills ──────────────────────────────────────────────── */
    .preset-pill { cursor: pointer; font-size: .75rem; padding: 3px 10px;
                   border-radius: 20px; border: 1px solid rgba(255,255,255,.15);
                   background: rgba(255,255,255,.05); transition: background .15s; }
    .preset-pill:hover { background: rgba(255,255,255,.12); }

    /* ── Mode badge ────────────────────────────────────────────────── */
    .badge-normal { background: rgba(13,202,240,.15); color:#0dcaf0; border:1px solid rgba(13,202,240,.3); }
    .badge-spike  { background: rgba(255,193,7,.15);  color:#ffc107; border:1px solid rgba(255,193,7,.3); }
    .badge-drift  { background: rgba(220,53,69,.15);  color:#f85149; border:1px solid rgba(220,53,69,.3); }
    .badge-step   { background: rgba(111,66,193,.15); color:#c084fc; border:1px solid rgba(111,66,193,.3); }

    /* Fix Dropdown & Input Visibility */
    .form-select, .form-control {
        background-color: rgba(11, 26, 41, 0.8) !important;
        border: 1px solid rgba(255,255,255,0.1) !important;
        color: #fff !important;
        transition: all 0.2s;
    }
    .form-select:focus, .form-control:focus {
        background-color: #122a3d !important;
        border-color: #0dcaf0 !important;
        box-shadow: 0 0 12px rgba(13, 202, 240, 0.2) !important;
    }
    .form-select option {
        background-color: #051424;
        color: #fff;
    }
</style>
}

<div class="container-fluid py-3">

    <!-- ── Header ─────────────────────────────────────────────────── -->
    <div class="d-flex align-items-center flex-wrap gap-3 mb-3">
        <div>
            <h4 class="mb-0"><i class="bi bi-cpu text-warning me-2"></i>Sensor Simulator</h4>
            <small class="text-muted">Simulasikan data sensor yang dikirim ke API — untuk uji coba &amp; demo</small>
        </div>
        <div class="ms-auto d-flex gap-2 flex-wrap">
            <a href="/SensorReadings/Monitor"  class="btn btn-sm btn-outline-secondary"><i class="bi bi-broadcast me-1"></i>Monitor</a>
            <a href="/SensorReadings/Analysis" class="btn btn-sm btn-outline-info"><i class="bi bi-graph-up-arrow me-1"></i>Analisis</a>
            <button class="btn btn-sm btn-success" onclick="startAll()"><i class="bi bi-play-fill me-1"></i>Start Semua</button>
            <button class="btn btn-sm btn-danger"  onclick="stopAll()"><i class="bi bi-stop-fill me-1"></i>Stop Semua</button>
        </div>
    </div>

    <!-- ── Global Config Bar ──────────────────────────────────────── -->
    <div class="sim-card p-3 mb-4">
        <div class="row g-3 align-items-end">
            <div class="col-sm-6 col-md-3">
                <div class="config-label">API Endpoint</div>
                <input type="text" class="form-control form-control-sim" id="cfgEndpoint" value="@ingestUrl" readonly>
            </div>
            <div class="col-sm-6 col-md-2">
                <div class="config-label">API Key</div>
                <div class="input-group input-group-sm">
                    <input type="password" class="form-control form-control-sim" id="cfgApiKey" value="@apiKey">
                    <button class="btn btn-outline-secondary btn-sm" type="button" onclick="toggleKey()">
                        <i class="bi bi-eye" id="eyeIcon"></i>
                    </button>
                </div>
            </div>
            <div class="col-sm-4 col-md-2">
                <div class="config-label">Max Log Baris</div>
                <input type="number" class="form-control form-control-sim" id="cfgMaxLog" value="200" min="50" max="1000">
            </div>
            <div class="col-sm-8 col-md-5">
                <div class="config-label">Preset Cepat</div>
                <div class="d-flex flex-wrap gap-2 pt-1">
                    <span class="preset-pill" onclick="loadPreset('extruder1')">🏭 Extruder 1 Lengkap</span>
                    <span class="preset-pill" onclick="loadPreset('extruder2')">🏭 Extruder 2 Lengkap</span>
                    <span class="preset-pill" onclick="loadPreset('quality')">🔬 Quality Check OD/ID</span>
                    <span class="preset-pill" onclick="loadPreset('stress')">⚡ Stress Test (cepat)</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Global Stats ───────────────────────────────────────────── -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-sm-3 col-lg-3">
            <div class="gstat-box">
                <div class="gstat-val text-success" id="gTotalSent">0</div>
                <div class="gstat-lbl">Total Terkirim</div>
            </div>
        </div>
        <div class="col-6 col-sm-3 col-lg-3">
            <div class="gstat-box">
                <div class="gstat-val text-danger" id="gTotalErr">0</div>
                <div class="gstat-lbl">Error / Gagal</div>
            </div>
        </div>
        <div class="col-6 col-sm-3 col-lg-3">
            <div class="gstat-box">
                <div class="gstat-val text-info" id="gActiveSensors">0</div>
                <div class="gstat-lbl">Sensor Aktif</div>
            </div>
        </div>
        <div class="col-6 col-sm-3 col-lg-3">
            <div class="gstat-box">
                <div class="gstat-val text-warning" id="gUptime">00:00:00</div>
                <div class="gstat-lbl">Uptime Sesi</div>
            </div>
        </div>
    </div>

    <!-- ── Sensor Cards Grid ──────────────────────────────────────── -->
    <div class="row g-3 mb-4" id="sensorGrid">
        <!-- diisi oleh JS -->
    </div>

    <!-- ── Tambah Sensor ──────────────────────────────────────────── -->
    <div class="d-flex gap-2 mb-4">
        <button class="btn btn-outline-primary btn-sm" onclick="addSensorCard()">
            <i class="bi bi-plus-circle me-1"></i>Tambah Sensor
        </button>
        <button class="btn btn-outline-secondary btn-sm" onclick="clearAllCards()">
            <i class="bi bi-trash3 me-1"></i>Hapus Semua
        </button>
        <button class="btn btn-outline-success btn-sm ms-auto" onclick="saveConfig()">
            <i class="bi bi-save me-1"></i>Simpan Config
        </button>
        <button class="btn btn-outline-info btn-sm" onclick="loadConfig()">
            <i class="bi bi-folder2-open me-1"></i>Load Config
        </button>
    </div>

    <!-- ── Log Panel ─────────────────────────────────────────────── -->
    <div class="sim-card mb-2">
        <div class="d-flex align-items-center px-3 py-2 border-bottom border-white border-opacity-10">
            <i class="bi bi-terminal text-secondary me-2"></i>
            <span class="fw-semibold small">Activity Log</span>
            <span class="badge bg-secondary ms-2" id="logCount">0</span>
            <div class="ms-auto d-flex gap-2">
                <div class="form-check form-switch mb-0 d-flex align-items-center gap-2">
                    <input class="form-check-input" type="checkbox" id="chkAutoScroll" checked>
                    <label class="form-check-label small" for="chkAutoScroll">Auto Scroll</label>
                </div>
                <button class="btn btn-sm btn-outline-secondary btn-sm py-0" onclick="clearLog()">
                    <i class="bi bi-x-circle"></i> Clear
                </button>
            </div>
        </div>
        <div id="logPanel"></div>
    </div>

</div>

<!-- ── Modal Edit Sensor ──────────────────────────────────────────── -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title"><i class="bi bi-sliders me-2"></i>Konfigurasi Sensor</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editSensorId">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Device ID</label>
                        <input type="text" class="form-control form-control-sm" id="editDeviceId" placeholder="cth: SENSOR-OD-EXT01">
                        <div class="form-text">Identitas unik perangkat sensor</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Machine Code</label>
                        <input type="text" class="form-control form-control-sm" id="editMachineCode" placeholder="cth: EXT-01">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Metric Type</label>
                        <select class="form-select form-select-sm" id="editMetricType">
                            <option value="outer_diameter">outer_diameter — Outer Diameter (mm)</option>
                            <option value="inner_diameter">inner_diameter — Inner Diameter (mm)</option>
                            <option value="hose_speed">hose_speed — Hose Speed (m/min)</option>
                            <option value="head_temp_inner">head_temp_inner — Head Temp Inner (°C)</option>
                            <option value="head_temp_outer">head_temp_outer — Head Temp Outer (°C)</option>
                            <option value="chiller_water_temp">chiller_water_temp — Chiller Water Temp (°C)</option>
                            <option value="screw_speed_inner">screw_speed_inner — Screw Speed Inner (rpm)</option>
                            <option value="screw_speed_outer">screw_speed_outer — Screw Speed Outer (rpm)</option>
                            <option value="pressure_inner">pressure_inner — Pressure Inner (MPa)</option>
                            <option value="pressure_outer">pressure_outer — Pressure Outer (MPa)</option>
                            <option value="spiral_pitch">spiral_pitch — Spiral Pitch (mm)</option>
                            <option value="caterpillar_gap">caterpillar_gap — Caterpillar Gap (mm)</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Nilai Target</label>
                        <input type="number" class="form-control form-control-sm" id="editTargetVal" step="0.01" placeholder="25.40">
                        <div class="form-text">Nilai tengah simulasi</div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Noise / Variasi (±)</label>
                        <input type="number" class="form-control form-control-sm" id="editNoise" step="0.001" value="0.05" min="0">
                        <div class="form-text">Standar deviasi acak</div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Interval Kirim (detik)</label>
                        <input type="number" class="form-control form-control-sm" id="editInterval" value="5" min="1" max="3600">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Mode Simulasi</label>
                        <select class="form-select form-select-sm" id="editMode">
                            <option value="normal">Normal — Acak di sekitar target</option>
                            <option value="spike">Spike — Sesekali lonjakan keluar batas</option>
                            <option value="drift">Drift — Nilai perlahan bergerak (naik/turun)</option>
                            <option value="step">Step — Naik-turun bertahap (tangga)</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Quality Default</label>
                        <select class="form-select form-select-sm" id="editQuality">
                            <option value="OK">OK</option>
                            <option value="WARN">WARN</option>
                            <option value="NG">NG</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <div class="alert alert-secondary py-2 small mb-0">
                            <strong>Mode Spike:</strong> ~10% peluang nilai melompat ±(noise × 5)<br>
                            <strong>Mode Drift:</strong> nilai bergeser perlahan ±(noise × 0.2) per tick, berbalik di ujung<br>
                            <strong>Mode Step:</strong> nilai berubah setiap 10 tick (naik atau turun noise × 3)
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Batal</button>
                <button type="button" class="btn btn-primary btn-sm" onclick="saveEditModal()">Simpan</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
// ═══════════════════════════════════════════════════════════════════════
//  GLOBALS
// ═══════════════════════════════════════════════════════════════════════
const API_KEY_STORE  = '@apiKey';
const INGEST_URL     = '@ingestUrl';

let sensors        = [];   // array of sensor configs
let timers         = {};   // sensorId → setInterval handle
let charts         = {};   // sensorId → Chart.js instance
let gTotalSent     = 0;
let gTotalErr      = 0;
let sessionStart   = Date.now();
let logLineCount   = 0;

// Metadata per metricType
const METRIC_META = {
    outer_diameter:    { unit: 'mm',    defaultTarget: 25.4,  defaultNoise: 0.05 },
    inner_diameter:    { unit: 'mm',    defaultTarget: 18.0,  defaultNoise: 0.04 },
    hose_speed:        { unit: 'm/min', defaultTarget: 3.5,   defaultNoise: 0.1  },
    head_temp_inner:   { unit: '°C',    defaultTarget: 185,   defaultNoise: 1.5  },
    head_temp_outer:   { unit: '°C',    defaultTarget: 175,   defaultNoise: 1.5  },
    chiller_water_temp:{ unit: '°C',    defaultTarget: 22,    defaultNoise: 0.5  },
    screw_speed_inner: { unit: 'rpm',   defaultTarget: 45,    defaultNoise: 0.8  },
    screw_speed_outer: { unit: 'rpm',   defaultTarget: 38,    defaultNoise: 0.8  },
    pressure_inner:    { unit: 'MPa',   defaultTarget: 12.5,  defaultNoise: 0.3  },
    pressure_outer:    { unit: 'MPa',   defaultTarget: 10.0,  defaultNoise: 0.3  },
    spiral_pitch:      { unit: 'mm',    defaultTarget: 20.0,  defaultNoise: 0.08 },
    caterpillar_gap:   { unit: 'mm',    defaultTarget: 1.5,   defaultNoise: 0.02 },
};

// ═══════════════════════════════════════════════════════════════════════
//  UPTIME CLOCK
// ═══════════════════════════════════════════════════════════════════════
setInterval(() => {
    const elapsed = Math.floor((Date.now() - sessionStart) / 1000);
    const h = String(Math.floor(elapsed / 3600)).padStart(2, '0');
    const m = String(Math.floor((elapsed % 3600) / 60)).padStart(2, '0');
    const s = String(elapsed % 60).padStart(2, '0');
    document.getElementById('gUptime').textContent = `${h}:${m}:${s}`;
}, 1000);

// ═══════════════════════════════════════════════════════════════════════
//  GENERATE NEXT VALUE (based on mode)
// ═══════════════════════════════════════════════════════════════════════
function nextValue(sensor) {
    const { mode, targetVal, noise } = sensor;
    const r = () => (Math.random() * 2 - 1); // -1..1

    if (mode === 'normal') {
        return targetVal + r() * noise;
    }
    if (mode === 'spike') {
        const isSpike = Math.random() < 0.10;
        return isSpike
            ? targetVal + (Math.random() > 0.5 ? 1 : -1) * noise * 5 * (0.8 + Math.random())
            : targetVal + r() * noise;
    }
    if (mode === 'drift') {
        if (sensor._drift === undefined) sensor._drift = 0;
        sensor._drift += r() * noise * 0.25;
        // Batasi drift agar tidak lari jauh
        if (Math.abs(sensor._drift) > noise * 6) sensor._drift *= -0.7;
        return targetVal + sensor._drift + r() * noise * 0.3;
    }
    if (mode === 'step') {
        if (sensor._stepCount === undefined) { sensor._stepCount = 0; sensor._stepDir = 1; sensor._stepAcc = 0; }
        sensor._stepCount++;
        if (sensor._stepCount % 10 === 0) {
            sensor._stepDir *= -1;
            sensor._stepAcc += sensor._stepDir * noise * 3;
            if (Math.abs(sensor._stepAcc) > noise * 9) sensor._stepAcc = 0;
        }
        return targetVal + sensor._stepAcc + r() * noise * 0.3;
    }
    return targetVal;
}

// ═══════════════════════════════════════════════════════════════════════
//  SEND ONE READING
// ═══════════════════════════════════════════════════════════════════════
async function sendReading(sensorId) {
    const sensor = sensors.find(s => s.id === sensorId);
    if (!sensor || !sensor.running) return;

    const value    = nextValue(sensor);
    const rounded  = Math.round(value * 10000) / 10000;
    const meta     = METRIC_META[sensor.metricType] || { unit: '' };
    const apiKey   = document.getElementById('cfgApiKey').value.trim();
    const endpoint = document.getElementById('cfgEndpoint').value.trim();

    const payload = {
        deviceId:    sensor.deviceId,
        machineCode: sensor.machineCode,
        metricType:  sensor.metricType,
        metricValue: rounded,
        unit:        meta.unit,
        quality:     sensor.quality,
        timestamp:   new Date().toISOString()
    };

    try {
        const res  = await fetch(endpoint, {
            method:  'POST',
            headers: { 'Content-Type': 'application/json', 'X-Api-Key': apiKey },
            body:    JSON.stringify(payload)
        });
        const json = await res.json();

        const isDup = json.status === 'DUPLICATE';
        sensor.sentCount = (sensor.sentCount || 0) + (isDup ? 0 : 1);
        sensor.lastValue = rounded;
        if (!isDup) {
            gTotalSent++;
            addChartPoint(sensorId, rounded);
        }

        // Update UI
        const liveEl = document.getElementById(`live-${sensorId}`);
        if (liveEl) liveEl.textContent = rounded.toFixed(4);
        const cntEl = document.getElementById(`cnt-${sensorId}`);
        if (cntEl)  cntEl.textContent  = `${sensor.sentCount} terkirim`;

        document.getElementById('gTotalSent').textContent = gTotalSent;

        if (isDup) {
            logLine('dup', `[${sensor.deviceId}] DUP — ${sensor.metricType}=${rounded} ${meta.unit}`);
        } else {
            logLine('ok', `[${sensor.deviceId}] OK — ${sensor.metricType}=${rounded} ${meta.unit}  (id:${json.logId ?? '?'})`);
        }
    } catch (e) {
        gTotalErr++;
        document.getElementById('gTotalErr').textContent = gTotalErr;
        logLine('err', `[${sensor.deviceId}] ERROR — ${e.message}`);
    }
    updateActiveBadge();
}

// ═══════════════════════════════════════════════════════════════════════
//  START / STOP per sensor
// ═══════════════════════════════════════════════════════════════════════
function startSensor(sensorId) {
    const sensor = sensors.find(s => s.id === sensorId);
    if (!sensor || sensor.running) return;

    sensor.running   = true;
    sensor.sentCount = sensor.sentCount || 0;
    sensor._drift    = undefined;
    sensor._stepCount= undefined;

    // kirim langsung 1x, lalu setiap interval
    sendReading(sensorId);
    timers[sensorId] = setInterval(() => sendReading(sensorId), sensor.interval * 1000);

    updateCardState(sensorId, true);
    logLine('info', `▶ Sensor ${sensor.deviceId} [${sensor.machineCode}] STARTED — interval ${sensor.interval}s, mode: ${sensor.mode}`);
    updateActiveBadge();
}

function stopSensor(sensorId) {
    const sensor = sensors.find(s => s.id === sensorId);
    if (!sensor) return;

    sensor.running = false;
    if (timers[sensorId]) { clearInterval(timers[sensorId]); delete timers[sensorId]; }

    updateCardState(sensorId, false);
    logLine('info', `■ Sensor ${sensor.deviceId} STOPPED  (${sensor.sentCount || 0} data terkirim)`);
    updateActiveBadge();
}

function startAll() { sensors.forEach(s => { if (!s.running) startSensor(s.id); }); }
function stopAll()  { sensors.forEach(s => { if  (s.running) stopSensor(s.id);  }); }

function updateActiveBadge() {
    const active = sensors.filter(s => s.running).length;
    document.getElementById('gActiveSensors').textContent = active;
}

// ═══════════════════════════════════════════════════════════════════════
//  CARD UI HELPERS
// ═══════════════════════════════════════════════════════════════════════
function updateCardState(sensorId, running) {
    const card   = document.getElementById(`card-${sensorId}`);
    const header = document.getElementById(`hdr-${sensorId}`);
    const dot    = document.getElementById(`dot-${sensorId}`);
    const btnS   = document.getElementById(`btnStart-${sensorId}`);
    const btnSt  = document.getElementById(`btnStop-${sensorId}`);
    if (!card) return;

    card.classList.toggle('running', running);
    card.classList.toggle('stopped', !running);
    header.classList.toggle('running', running);
    header.classList.toggle('stopped', !running);
    dot.className  = 'pulse-dot ' + (running ? 'pulse-green' : 'pulse-grey');
    
    if (btnS) {
        btnS.disabled  = running;
        btnS.innerHTML = running ? '<span class="spinner-grow spinner-grow-sm me-1"></span>Running...' : '<i class="bi bi-play-fill"></i> Start';
        btnS.classList.toggle('opacity-50', running);
    }
    if (btnSt) {
        btnSt.disabled = !running;
        btnSt.classList.toggle('opacity-50', !running);
    }
}

function addChartPoint(sensorId, value) {
    if (!charts[sensorId]) return;
    const ch = charts[sensorId];
    const ts = new Date().toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    ch.data.labels.push(ts);
    ch.data.datasets[0].data.push(value);
    if (ch.data.labels.length > 50) {
        ch.data.labels.shift();
        ch.data.datasets[0].data.shift();
    }
    ch.update('none');
}

// ═══════════════════════════════════════════════════════════════════════
//  ADD / REMOVE SENSOR CARD
// ═══════════════════════════════════════════════════════════════════════
let _idCounter = 0;

function addSensorCard(cfg) {
    const id     = 's' + (++_idCounter);
    const meta   = METRIC_META[cfg?.metricType ?? 'outer_diameter'] || {};
    const sensor = {
        id:          id,
        deviceId:    cfg?.deviceId    ?? `SENSOR-${id.toUpperCase()}`,
        machineCode: cfg?.machineCode ?? 'EXT-01',
        metricType:  cfg?.metricType  ?? 'outer_diameter',
        targetVal:   cfg?.targetVal   ?? (meta.defaultTarget ?? 25.4),
        noise:       cfg?.noise       ?? (meta.defaultNoise  ?? 0.05),
        interval:    cfg?.interval    ?? 5,
        mode:        cfg?.mode        ?? 'normal',
        quality:     cfg?.quality     ?? 'OK',
        running:     false,
        sentCount:   0,
        lastValue:   null
    };
    sensors.push(sensor);

    const modeBadge = { normal:'badge-normal', spike:'badge-spike', drift:'badge-drift', step:'badge-step' };
    const modeIcon  = { normal:'🌊', spike:'⚡', drift:'📉', step:'🪜' };
    const unitLabel = (METRIC_META[sensor.metricType] || {}).unit ?? '';

    const col = document.createElement('div');
    col.className = 'col-12 col-sm-6 col-xl-4';
    col.id = `wrap-${id}`;
    col.innerHTML = `
    <div class="sim-card stopped h-100" id="card-${id}">
        <div class="sensor-header stopped d-flex align-items-center gap-2" id="hdr-${id}">
            <span class="pulse-dot pulse-grey" id="dot-${id}"></span>
            <span class="fw-bold small text-truncate" style="max-width:160px;" title="${sensor.deviceId}">${sensor.deviceId}</span>
            <span class="badge ${modeBadge[sensor.mode]} ms-1" style="font-size:.65rem;">${modeIcon[sensor.mode]} ${sensor.mode}</span>
            <div class="ms-auto d-flex gap-1">
                <button class="btn btn-sm btn-link py-0 px-1 text-secondary" onclick="openEdit('${id}')" title="Edit"><i class="bi bi-pencil"></i></button>
                <button class="btn btn-sm btn-link py-0 px-1 text-secondary" onclick="removeSensor('${id}')" title="Hapus"><i class="bi bi-trash3"></i></button>
            </div>
        </div>
        <div class="p-3">
            <div class="d-flex align-items-end gap-2 mb-1">
                <span class="live-val text-primary" id="live-${id}">—</span>
                <span class="live-unit">${unitLabel}</span>
                <span class="live-unit ms-auto">${sensor.metricType}</span>
            </div>
            <div class="d-flex gap-3 mb-2 text-muted" style="font-size:.72rem;">
                <span>🎯 Target: <strong>${sensor.targetVal}</strong></span>
                <span>±${sensor.noise}</span>
                <span>⏱ ${sensor.interval}s</span>
                <span class="sent-count ms-auto" id="cnt-${id}">0 terkirim</span>
            </div>
            <div class="mb-2" style="font-size:.7rem; opacity:.6;">
                <i class="bi bi-hdd me-1"></i>${sensor.machineCode}
            </div>
            <!-- Mini chart -->
            <div class="mini-chart-wrap mb-3">
                <canvas id="chart-${id}"></canvas>
            </div>
            <!-- Buttons -->
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-success flex-fill" id="btnStart-${id}" onclick="startSensor('${id}')">
                    <i class="bi bi-play-fill"></i> Start
                </button>
                <button class="btn btn-sm btn-danger flex-fill" id="btnStop-${id}" onclick="stopSensor('${id}')" disabled>
                    <i class="bi bi-stop-fill"></i> Stop
                </button>
                <button class="btn btn-sm btn-outline-secondary" onclick="sendOnce('${id}')" title="Kirim 1x manual">
                    <i class="bi bi-send"></i>
                </button>
            </div>
        </div>
    </div>`;
    document.getElementById('sensorGrid').appendChild(col);

    // Init mini chart
    const ctx = document.getElementById(`chart-${id}`).getContext('2d');
    charts[id] = new Chart(ctx, {
        type: 'line',
        data: {
            labels: [],
            datasets: [{
                data: [],
                borderColor: '#0d6efd',
                backgroundColor: 'rgba(13,110,253,.1)',
                pointRadius: 2,
                tension: 0.4,
                fill: true,
                borderWidth: 1.5
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            animation: false,
            plugins: { legend: { display: false }, tooltip: { enabled: false } },
            scales: {
                x: { display: false },
                y: { display: true, ticks: { maxTicksLimit: 3, font: { size: 8 } } }
            }
        }
    });

    // Tambah target line jika ada
    if (sensor.targetVal) {
        charts[id].data.datasets.push({
            data: Array(50).fill(sensor.targetVal),
            borderColor: 'rgba(255,193,7,.6)',
            borderDash: [4,3],
            borderWidth: 1,
            pointRadius: 0,
            fill: false
        });
    }
}

function sendOnce(sensorId) {
    const sensor = sensors.find(s => s.id === sensorId);
    if (!sensor) return;
    const wasRunning = sensor.running;
    sensor.running = true;
    sendReading(sensorId).finally(() => { if (!wasRunning) sensor.running = false; });
}

function removeSensor(sensorId) {
    stopSensor(sensorId);
    if (charts[sensorId]) { charts[sensorId].destroy(); delete charts[sensorId]; }
    sensors = sensors.filter(s => s.id !== sensorId);
    const wrap = document.getElementById(`wrap-${sensorId}`);
    if (wrap) wrap.remove();
    updateActiveBadge();
}

function clearAllCards() {
    stopAll();
    sensors.slice().forEach(s => removeSensor(s.id));
}

// ═══════════════════════════════════════════════════════════════════════
//  EDIT MODAL
// ═══════════════════════════════════════════════════════════════════════
function openEdit(sensorId) {
    const sensor = sensors.find(s => s.id === sensorId);
    if (!sensor) return;

    document.getElementById('editSensorId').value    = sensorId;
    document.getElementById('editDeviceId').value    = sensor.deviceId;
    document.getElementById('editMachineCode').value = sensor.machineCode;
    document.getElementById('editMetricType').value  = sensor.metricType;
    document.getElementById('editTargetVal').value   = sensor.targetVal;
    document.getElementById('editNoise').value       = sensor.noise;
    document.getElementById('editInterval').value    = sensor.interval;
    document.getElementById('editMode').value        = sensor.mode;
    document.getElementById('editQuality').value     = sensor.quality;

    new bootstrap.Modal(document.getElementById('editModal')).show();
}

function saveEditModal() {
    const sensorId = document.getElementById('editSensorId').value;
    const sensor   = sensors.find(s => s.id === sensorId);
    if (!sensor) return;

    const wasRunning = sensor.running;
    if (wasRunning) stopSensor(sensorId);

    const newMetric = document.getElementById('editMetricType').value;
    sensor.deviceId    = document.getElementById('editDeviceId').value.trim();
    sensor.machineCode = document.getElementById('editMachineCode').value.trim();
    sensor.metricType  = newMetric;
    sensor.targetVal   = parseFloat(document.getElementById('editTargetVal').value) || 25.4;
    sensor.noise       = parseFloat(document.getElementById('editNoise').value)     || 0.05;
    sensor.interval    = parseInt(document.getElementById('editInterval').value)    || 5;
    sensor.mode        = document.getElementById('editMode').value;
    sensor.quality     = document.getElementById('editQuality').value;

    // Re-render card — easiest approach is remove + re-add
    const pos = sensors.indexOf(sensor);
    const cfg = { ...sensor };

    // Bersihkan chart lama jika ada
    const oldChart = Chart.getChart(`chart-${sensorId}`);
    if (oldChart) oldChart.destroy();
    if (charts[sensorId]) { charts[sensorId].destroy(); delete charts[sensorId]; }

    const wrap = document.getElementById(`wrap-${sensorId}`);
    if (wrap) wrap.remove();
    sensors.splice(pos, 1);

    // Langsung tambah sebagai card baru (ID akan otomatis bertambah)
    addSensorCard(cfg);
    
    bootstrap.Modal.getInstance(document.getElementById('editModal')).hide();
    logLine('info', `⚙ Sensor ${sensor.deviceId} dikonfigurasi ulang`);
}

