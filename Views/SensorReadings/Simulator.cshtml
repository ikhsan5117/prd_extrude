}

// ═══════════════════════════════════════════════════════════════════════
//  SAVE / LOAD CONFIG (localStorage)
// ═══════════════════════════════════════════════════════════════════════
function saveConfig() {
    const cfgs = sensors.map(s => ({
        deviceId: s.deviceId, machineCode: s.machineCode,
        metricType: s.metricType, targetVal: s.targetVal,
        noise: s.noise, interval: s.interval,
        mode: s.mode, quality: s.quality
    }));
    localStorage.setItem('sensorSimConfig', JSON.stringify(cfgs));
    logLine('info', `💾 Konfigurasi ${cfgs.length} sensor disimpan ke localStorage`);
    alert(`✅ ${cfgs.length} konfigurasi sensor disimpan.`);
}

function loadConfig() {
    const raw = localStorage.getItem('sensorSimConfig');
    if (!raw) { alert('Tidak ada konfigurasi tersimpan.'); return; }
    try {
        const cfgs = JSON.parse(raw);
        clearAllCards();
        cfgs.forEach(cfg => addSensorCard(cfg));
        logLine('info', `📂 Konfigurasi ${cfgs.length} sensor dimuat dari localStorage`);
    } catch { alert('Format konfigurasi tidak valid.'); }
}

// ═══════════════════════════════════════════════════════════════════════
//  LOG PANEL
// ═══════════════════════════════════════════════════════════════════════
function logLine(type, msg) {
    const maxLog = parseInt(document.getElementById('cfgMaxLog').value) || 200;
    const panel  = document.getElementById('logPanel');
    const ts     = new Date().toLocaleTimeString('id-ID');

    const line = document.createElement('div');
    line.className = `log-${type}`;
    line.innerHTML = `<span class="log-ts">${ts}</span>${escHtml(msg)}`;
    panel.appendChild(line);

    logLineCount++;
    document.getElementById('logCount').textContent = logLineCount;

    // Trim old lines
    while (panel.childElementCount > maxLog) panel.removeChild(panel.firstChild);

    // Auto scroll
    if (document.getElementById('chkAutoScroll').checked)
        panel.scrollTop = panel.scrollHeight;
}

function clearLog() {
    document.getElementById('logPanel').innerHTML = '';
    logLineCount = 0;
    document.getElementById('logCount').textContent = 0;
}

function escHtml(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ═══════════════════════════════════════════════════════════════════════
//  API KEY TOGGLE
// ═══════════════════════════════════════════════════════════════════════
function toggleKey() {
    const inp  = document.getElementById('cfgApiKey');
    const icon = document.getElementById('eyeIcon');
    if (inp.type === 'password') {
        inp.type = 'text';
        icon.className = 'bi bi-eye-slash';
    } else {
        inp.type = 'password';
        icon.className = 'bi bi-eye';
    }
}

// ═══════════════════════════════════════════════════════════════════════
//  INIT — load 2 sensor default supaya langsung ada isi
// ═══════════════════════════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded', () => {
    // Coba load dari localStorage dulu
    const saved = localStorage.getItem('sensorSimConfig');
    if (saved) {
        try {
            const cfgs = JSON.parse(saved);
            cfgs.forEach(cfg => addSensorCard(cfg));
            logLine('info', `📂 Konfigurasi ${cfgs.length} sensor dimuat otomatis dari localStorage`);
            return;
        } catch {}
    }
    // Default: 2 sensor starter
    addSensorCard({ deviceId:'SENSOR-OD-EXT01', machineCode:'EXT-01', metricType:'outer_diameter', targetVal:25.4,  noise:0.05,  interval:5, mode:'normal' });
    addSensorCard({ deviceId:'SENSOR-TEMP-EXT01', machineCode:'EXT-01', metricType:'head_temp_inner', targetVal:185, noise:1.5, interval:10, mode:'drift'  });
    logLine('info', '🚀 Sensor Simulator siap. Klik Start untuk mulai mengirim data.');
});
