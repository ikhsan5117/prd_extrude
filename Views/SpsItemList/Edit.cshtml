@model VelastoProductionSystem.Models.SpsItemList

@{
    ViewData["Title"] = "Edit Item List SPS";
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm col-md-6 mx-auto">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i>@ViewData["Title"]</h4>
        </div>
        <div class="card-body p-4">
            @if (Context.Session.GetString("IsAdmin") != "true" || Context.Session.GetString("UserRole") == "ADMIN_ENG")
            {
                <div class="alert alert-warning" role="alert">
                    <i class="bi bi-shield-lock-fill me-2"></i>
                    Edit Item List membutuhkan approval admin.
                    <a asp-controller="Approval" asp-action="MyRequests" class="alert-link">Cek request approval</a>.
                </div>
            }

            <form asp-action="Edit">
                <input type="hidden" name="sourceRequestId" value="@ViewBag.SourceRequestId" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Id" />
                
                <div class="mb-3">
                    <label asp-for="ItemList" class="form-label fw-bold"></label>
                    <input asp-for="ItemList" class="form-control" />
                    <span asp-validation-for="ItemList" class="text-danger"></span>
                </div>
                
                <div class="mb-3">
                    <label asp-for="DocumentNumber" class="form-label fw-bold"></label>
                    <select asp-for="DocumentNumber" class="form-select" asp-items="ViewBag.DocumentNumber"></select>
                    <span asp-validation-for="DocumentNumber" class="text-danger"></span>
                </div>
                
                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">Kembali</a>
                    @if (Context.Session.GetString("IsAdmin") == "true" && Context.Session.GetString("UserRole") != "ADMIN_ENG")
                    {
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i> Simpan Data
                        </button>
                    }
                    else
                    {
                        <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-outline-warning" name="saveAsDraft" value="true">
                            <i class="bi bi-save2 me-1"></i> Simpan Draft
                        </button>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-send me-1"></i> Approval Request
                        </button>
                        </div>
                    }
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
