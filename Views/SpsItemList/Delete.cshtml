@model VelastoProductionSystem.Models.SpsItemList

@{
    ViewData["Title"] = "Hapus Item List SPS";
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm col-md-6 mx-auto border-danger">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0"><i class="bi bi-exclamation-triangle-fill me-2"></i>Konfirmasi Hapus</h4>
        </div>
        <div class="card-body p-4">
            <h5 class="text-danger mb-4">Apakah Anda yakin ingin menghapus Item ini?</h5>
            
            <dl class="row mb-4">
                <dt class="col-sm-4">Item List</dt>
                <dd class="col-sm-8"><span class="badge bg-danger fs-6">@Model.ItemList</span></dd>
                
                <dt class="col-sm-4">No. Document</dt>
                <dd class="col-sm-8">@Model.DocumentNumber</dd>
            </dl>
            
            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary">Batal</a>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i> Hapus Permanen
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
