@model IEnumerable<VelastoProductionSystem.Models.SpsItemList>

@{
    ViewData["Title"] = "Daftar Item List SPS";
    var currentPage = ViewBag.Page != null ? (int)ViewBag.Page : 1;
    var pageSize = ViewBag.PageSize != null ? (int)ViewBag.PageSize : 50;
    var totalPages = ViewBag.TotalPages != null ? (int)ViewBag.TotalPages : 1;
    var totalCount = ViewBag.TotalCount != null ? (int)ViewBag.TotalCount : Model.Count();
    var rowNo = (currentPage - 1) * pageSize;
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
        <div>
            <button type="button" id="bulkDeleteBtn" class="btn btn-danger shadow-sm me-2 fw-bold" style="display:none;" onclick="confirmBulkDelete()">
                <i class="bi bi-trash3-fill"></i> Hapus Terpilih (<span id="selectedCount">0</span>)
            </button>
            <button type="button" class="btn btn-warning shadow-sm me-2 fw-bold" data-bs-toggle="modal" data-bs-target="#importItemListModal">
                <i class="bi bi-list-ul"></i> Import Item List
            </button>
            <a asp-action="DownloadExcel" asp-route-search="@ViewBag.Search" class="btn btn-success shadow-sm me-2 fw-bold">
                <i class="bi bi-file-earmark-excel-fill"></i> Download Excel
            </a>
            <a asp-action="Create" class="btn btn-primary shadow-sm fw-bold">
                <i class="bi bi-plus-circle me-1"></i> Tambah Item List
            </a>
        </div>
    </div>

    <!-- Filter/Search Section -->
    <div class="card shadow-sm mb-4 border-0" style="background: rgba(33, 37, 41, 0.5);">
        <div class="card-body">
            <form method="get" asp-action="Index" class="d-flex flex-column flex-md-row gap-2">
                <div class="input-group">
                    <span class="input-group-text bg-dark text-white border-secondary">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control bg-dark text-white border-secondary" placeholder="Cari Item List atau No. Document..." />
                </div>
                <button type="submit" class="btn btn-primary fw-bold px-4 shadow-sm">
                    Cari
                </button>
                @if (!string.IsNullOrEmpty(ViewBag.Search))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary fw-bold shadow-sm">
                        <i class="bi bi-x-circle"></i> Reset
                    </a>
                }
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="small text-muted">Total data: <strong>@totalCount</strong> | Halaman: <strong>@currentPage / @totalPages</strong> | 50 data per halaman</div>
            </div>
            <div class="table-responsive" style="max-height: 50vh; overflow: auto;">
            <table class="table table-striped table-hover align-middle" id="spsItemListTable">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 40px; text-align: center;">
                            <input type="checkbox" id="selectAll" class="form-check-input" />
                        </th>
                        <th style="width: 70px;">No</th>
                        <th>Item List</th>
                        <th>No. Document</th>
                        <th class="text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        rowNo++;
                        <tr>
                            <td class="text-center">
                                <input type="checkbox" class="row-check form-check-input" value="@item.Id" />
                            </td>
                            <td>@rowNo</td>
                            <td>
                                <span class="badge bg-info text-dark fw-bold fs-6">@(item.ItemList?.Replace("-", "") ?? "")</span>
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.DocumentNumber)
                            </td>
                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Detail">
                                        <i class="bi bi-info-circle"></i>
                                    </a>
                                    <button type="button" onclick="confirmSingleDelete(@item.Id)" class="btn btn-sm btn-outline-danger" title="Hapus">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-3">
                <a asp-action="Index"
                   asp-route-search="@ViewBag.Search"
                   asp-route-page="@(currentPage > 1 ? currentPage - 1 : 1)"
                   asp-route-pageSize="@pageSize"
                   class="btn btn-outline-secondary @(currentPage <= 1 ? "disabled" : "")">
                    <i class="bi bi-chevron-left"></i> Prev
                </a>

                <span class="small text-muted">Page @currentPage of @totalPages</span>

                <a asp-action="Index"
                   asp-route-search="@ViewBag.Search"
                   asp-route-page="@(currentPage < totalPages ? currentPage + 1 : totalPages)"
                   asp-route-pageSize="@pageSize"
                   class="btn btn-outline-primary @(currentPage >= totalPages ? "disabled" : "")">
                    Next <i class="bi bi-chevron-right"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- ========================================
     MODAL: IMPORT ITEM LIST ONLY (MODE 1)
     ======================================== -->
<div class="modal fade" id="importItemListModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content bg-dark text-white border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-list-ul text-warning me-2"></i> Import Item List (Mode Ringan)</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="ImportItemListOnly" method="post" enctype="multipart/form-data" id="importItemListForm">
                <div class="modal-body p-4">
                    <!-- Info Card -->
                    <div class="card bg-gradient mb-3 border-0 shadow-sm" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                        <div class="card-body p-3">
                            <h6 class="text-white fw-bold mb-2">
                                <i class="bi bi-info-circle-fill me-2"></i>Mode Import Cepat - Hanya 2 Kolom
                            </h6>
                            <p class="text-white mb-2" style="font-size: 0.9rem;">
                                Mode ini untuk menambahkan <strong>Item List</strong> ke dokumen SPS yang sudah ada atau membuat dokumen baru dengan parameter default.
                            </p>
                            <div class="bg-white bg-opacity-10 rounded-3 p-3 mt-2">
                                <strong class="text-warning d-block mb-2">Logika Import:</strong>
                                <ul class="mb-0 text-white" style="font-size: 0.85rem;">
                                    <li><strong>Jika NO.DOC SUDAH ADA:</strong> Item akan ditambahkan ke dokumen tersebut</li>
                                    <li><strong>Jika NO.DOC BELUM ADA:</strong> Baris akan gagal diimport dan ditampilkan di detail popup hasil</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- Download Template -->
                    <div class="alert alert-info mb-3" role="alert" style="font-size: 0.85rem;">
                        <i class="bi bi-download me-1"></i>
                        <strong>Format Template Item List (2 Kolom):</strong>
                        <ul class="mb-2 mt-2">
                            <li><strong>Kolom A:</strong> Item List (Kode Item - Wajib)</li>
                            <li><strong>Kolom B:</strong> No.Doc (Nomor Dokumen - Wajib)</li>
                        </ul>
                        <hr class="border-info border-opacity-25 my-2">
                        <div class="d-flex align-items-center justify-content-between">
                            <span class="text-info"><i class="bi bi-file-earmark-spreadsheet me-1"></i> Download template 2 kolom:</span>
                            <a asp-action="DownloadTemplateItemList" class="btn btn-info btn-sm fw-bold shadow-sm">
                                <i class="bi bi-download me-1"></i> Download Template
                            </a>
                        </div>
                    </div>

                    <!-- Upload Area -->
                    <div class="upload-area border border-warning border-dashed p-4 text-center rounded-3 bg-black bg-opacity-25 position-relative">
                         <i class="bi bi-cloud-arrow-up fs-1 text-warning mb-2 d-block"></i>
                         <p class="text-white fw-bold mb-2">Upload Excel Item List (2 Kolom)</p>
                         <input class="form-control bg-dark text-white border-secondary mb-2" type="file" id="fileItemList" name="file" accept=".xlsx,.xls" required>
                         <small class="text-muted d-block mb-2">File Excel dengan format: Item List, No.Doc</small>
                         <div class="d-flex justify-content-center align-items-center gap-3 flex-wrap mt-3" style="font-size: 0.7rem;">
                             <span class="badge bg-warning bg-opacity-75 text-dark">
                                 <i class="bi bi-lightning-fill me-1"></i>Import Cepat
                             </span>
                             <span class="badge bg-danger bg-opacity-75">
                                 <i class="bi bi-exclamation-triangle me-1"></i>No.Doc wajib terdaftar
                             </span>
                             <span class="badge bg-info bg-opacity-75">
                                 <i class="bi bi-shield-check me-1"></i>Skip duplikat
                             </span>
                         </div>
                    </div>

                    <!-- Contoh Format -->
                    <div class="alert alert-dark border border-secondary mt-3 mb-0" role="alert" style="font-size: 0.75rem;">
                        <strong class="text-success d-block mb-2">
                            <i class="bi bi-table me-1"></i>Format Template Excel:
                        </strong>
                        <table class="table table-sm table-dark table-bordered mb-2" style="font-size: 0.7rem;">
                            <thead>
                                <tr class="bg-primary bg-opacity-25">
                                    <th>Item List</th>
                                    <th>No.Doc</th>
                                </tr>
                            </thead>
                        </table>
                        <div class="bg-success bg-opacity-10 p-2 rounded mb-2">
                            <strong class="text-success d-block mb-1">Contoh Pengisian:</strong>
                            <code class="d-block text-success" style="font-size: 0.65rem;">
                                Row 2: VHFUNC12345 | SPS-001-2024<br>
                                Row 3: VHFUNC67890 | SPS-001-2024<br>
                                Row 4: ITEMCODE001 | SPS-002-2024
                            </code>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0 pb-4 justify-content-center gap-2">
                    <button type="submit" class="btn btn-warning px-5 rounded-pill fw-bold shadow-sm text-dark">
                        <i class="bi bi-upload"></i> IMPORT ITEM LIST SEKARANG
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function() {
            @if (TempData["SuccessMessage"] != null)
            {
                 var successMsg = TempData["SuccessMessage"]?.ToString()?.Replace("\n", "<br>")?.Replace("\r", "")?.Replace("'", "\\'");
                <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Berhasil!',
                    html: '<div class="text-start" style="font-size: 0.9rem;">@Html.Raw(successMsg)</div>',
                    confirmButtonText: 'OK'
                });
                </text>
            }
            
            @if (TempData["ErrorMessage"] != null)
            {
                 var errorMsg = TempData["ErrorMessage"]?.ToString()?.Replace("\n", "<br>")?.Replace("\r", "")?.Replace("'", "\\'");
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    html: '<div class="text-start" style="font-size: 0.9rem;">@Html.Raw(errorMsg)</div>',
                    confirmButtonText: 'Tutup'
                });
                </text>
            }
        });

        // Checkboxes & Bulk Delete Logic
        const selectAll = document.getElementById('selectAll');
        const bulkDeleteBtn = document.getElementById('bulkDeleteBtn');
        const selectedCountSpan = document.getElementById('selectedCount');

        function updateBulkDeleteButton() {
            const checkedBoxes = document.querySelectorAll('.row-check:checked');
            const count = checkedBoxes.length;
            
            if (count > 0) {
                bulkDeleteBtn.style.display = 'inline-block';
                selectedCountSpan.textContent = count;
            } else {
                bulkDeleteBtn.style.display = 'none';
            }
            
            if (selectAll) {
                const totalVisibleBoxes = document.querySelectorAll('#spsItemListTable tbody tr:not([style*="display: none"]) .row-check').length;
                selectAll.checked = (count > 0 && count === totalVisibleBoxes);
            }
        }

        if (selectAll) {
            selectAll.addEventListener('change', function() {
                const isChecked = this.checked;
                document.querySelectorAll('tbody tr:not([style*="display: none"]) .row-check').forEach(check => {
                    check.checked = isChecked;
                });
                updateBulkDeleteButton();
            });
        }

        document.querySelector('tbody').addEventListener('change', function(e) {
            if (e.target.classList.contains('row-check')) {
                updateBulkDeleteButton();
            }
        });

        function confirmSingleDelete(id) {
            Swal.fire({
                title: 'Hapus data ini?',
                text: "Item List ini akan dihapus permanen!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Ya, Hapus!',
                cancelButtonText: 'Batal',
                background: '#1a1d21',
                color: '#fff'
            }).then((result) => {
                if (result.isConfirmed) {
                    deleteSelected([id]);
                }
            });
        }

        function confirmBulkDelete() {
            const checkedIds = Array.from(document.querySelectorAll('.row-check:checked')).map(cb => parseInt(cb.value));
            
            if (checkedIds.length === 0) return;

            Swal.fire({
                title: 'Hapus ' + checkedIds.length + ' data?',
                text: "Item List yang dipilih akan dihapus permanen!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Ya, Hapus Semua!',
                cancelButtonText: 'Batal',
                background: '#1a1d21',
                color: '#fff'
            }).then((result) => {
                if (result.isConfirmed) {
                    deleteSelected(checkedIds);
                }
            });
        }

        function deleteSelected(ids) {
            fetch('@Url.Action("DeleteMultiple")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(ids)
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Network response was not ok');
                }
                return response.json();
            })
            .then(data => {
                if (data.success) {
                    Swal.fire({
                        title: 'Terhapus!',
                        text: data.message,
                        icon: 'success',
                        background: '#1a1d21',
                        color: '#fff'
                    }).then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire('Gagal!', data.message, 'error');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                Swal.fire('Error!', 'Terjadi kesalahan sistem.', 'error');
            });
        }

        // Script existing
        $('#importItemListForm').on('submit', function(e) {
            e.preventDefault();
            
            var fileInput = $('#fileItemList')[0];
            if (!fileInput.files || fileInput.files.length === 0) {
                Swal.fire({
                    icon: 'warning',
                    title: 'File Belum Dipilih',
                    text: 'Silakan pilih file Excel terlebih dahulu',
                    background: '#1a1d21',
                    color: '#fff'
                });
                return;
            }

            Swal.fire({
                title: 'Uploading...',
                html: 'Sedang memproses import Item List.',
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); }
            });

            var formData = new FormData(this);

            $.ajax({
                url: $(this).attr('action'),
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function(response) {
                    const status = (response.status || '').toLowerCase();
                    let icon = 'info';
                    let title = 'Informasi';

                    if (status === 'success') {
                        icon = 'success';
                        title = 'Berhasil!';
                    } else if (status === 'partial') {
                        icon = 'warning';
                        title = 'Sebagian Berhasil';
                    } else if (status === 'approval_required') {
                        icon = 'info';
                        title = 'Approval Diperlukan';
                    } else if (status === 'warning') {
                        icon = 'warning';
                        title = 'Tidak Ada Data Tersimpan';
                    } else if (response.success) {
                        icon = 'success';
                        title = 'Berhasil!';
                    } else {
                        icon = 'error';
                        title = 'Gagal Import';
                    }

                    let detailHtml = '';

                    if (response.missingDocuments && response.missingDocuments.length > 0) {
                        detailHtml += '<div class="mt-2 text-start"><strong>No.Doc belum dibuat:</strong><ul class="mb-0">' +
                            response.missingDocuments.map(doc => '<li>' + doc + '</li>').join('') +
                            '</ul></div>';
                    }

                    if (response.errorDetails && response.errorDetails.length > 0) {
                        detailHtml += '<div class="mt-2 text-start"><strong>Detail error (maks 10):</strong><ul class="mb-0">' +
                            response.errorDetails.map(err => '<li>' + err + '</li>').join('') +
                            '</ul></div>';
                    }

                    Swal.fire({
                        icon: icon,
                        title: title,
                        html: '<div class="text-start">' + (response.message || 'Proses selesai.') + '</div>' + detailHtml,
                        background: '#1a1d21',
                        color: '#fff'
                    }).then(() => {
                        if (response.success) {
                            window.location.reload();
                        }
                    });
                },
                error: function() {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error Sistem',
                        text: 'Terjadi kesalahan saat menghubungi server.',
                        background: '#1a1d21',
                        color: '#fff'
                    });
                }
            });
        });
    </script>
}
