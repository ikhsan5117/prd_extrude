@model VelastoProductionSystem.Models.SpsItemList

@{
    ViewData["Title"] = "Detail Item List SPS";
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm col-md-6 mx-auto">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0"><i class="bi bi-info-circle me-2"></i>@ViewData["Title"]</h4>
        </div>
        <div class="card-body p-4">
            <dl class="row mb-0">
                <dt class="col-sm-4">Item List</dt>
                <dd class="col-sm-8"><span class="badge bg-primary fs-6">@Model.ItemList</span></dd>
                
                <dt class="col-sm-4">No. Document</dt>
                <dd class="col-sm-8">@Model.DocumentNumber</dd>
            </dl>
            
            <hr />
            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-outline-secondary">Kembali</a>
                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">Edit</a>
            </div>
        </div>
    </div>
</div>
