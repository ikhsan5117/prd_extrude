@model IEnumerable<VelastoProductionSystem.Models.PartMaster>
@{
    ViewData["Title"] = "Part Master (DL0)";
}

<style>
    .pm-header { background: #1e2229; border-radius: 16px; border: 1px solid rgba(255,255,255,0.06); padding: 20px 24px; margin-bottom: 20px; }
    .search-box { background: rgba(0,0,0,0.35); border: 1px solid rgba(255,255,255,0.1); color: #fff; border-radius: 10px; padding: 9px 14px; width: 300px; }
    .search-box:focus { outline: none; border-color: #3b82f6; }
    .part-table { font-size: 0.82rem; }
    .part-table th { background: rgba(0,0,0,0.4); color: #94a3b8; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.8px; border-bottom: 1px solid rgba(255,255,255,0.1); border-right: 1px solid rgba(255,255,255,0.08); padding: 10px 12px; white-space: nowrap; }
    .part-table th:last-child { border-right: none; }
    .part-table td { border-bottom: 1px solid rgba(255,255,255,0.04); border-right: 1px solid rgba(255,255,255,0.04); padding: 9px 12px; vertical-align: middle; }
    .part-table td:last-child { border-right: none; }
    .part-table tr:hover td { background: rgba(255,255,255,0.03); }
    .day-badge { font-size: 0.65rem; padding: 2px 6px; border-radius: 4px; font-weight: 700; }
    .day-on  { background: rgba(16,185,129,0.2); color: #34d399; }
    .day-off { background: rgba(100,116,139,0.15); color: #475569; }
    .ct-pill { background: rgba(59,130,246,0.15); color: #93c5fd; border-radius: 6px; padding: 2px 8px; font-weight: 700; font-size: 0.8rem; }
    .table-container { background: #1a1e26; border-radius: 16px; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); }
    .stat-mini { background: rgba(255,255,255,0.04); border-radius: 10px; padding: 12px 18px; text-align: center; }
    .upload-zone { border: 2px dashed rgba(59,130,246,0.4); border-radius: 14px; padding: 30px; text-align: center; background: rgba(59,130,246,0.05); }
</style>

<div class="fade-in">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3">
        <div>
            <h2 class="text-white fw-bold mb-1"><i class="bi bi-database-fill-gear text-warning me-2"></i> Part Master</h2>
            <p class="text-white-50 small mb-0">Data referensi part dari sheet <strong class="text-warning">DL0</strong> — sumber kalkulasi planning otomatis</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-danger btn-sm rounded-pill" data-bs-toggle="modal" data-bs-target="#clearModal">
                <i class="bi bi-trash3 me-1"></i> Hapus Semua
            </button>
        </div>
    </div>

    <!-- Stats + Import -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="stat-mini">
                <div class="fw-bold text-white" style="font-size:1.8rem;">@Model.Count()</div>
                <div class="text-white-50 small">Total Part</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-mini">
                <div class="fw-bold text-success" style="font-size:1.8rem;">@Model.Count(x => x.CtAwal.HasValue)</div>
                <div class="text-white-50 small">Punya CT Awal</div>
            </div>
        </div>
        <div class="col-md-6">
            <!-- Upload Box -->
            <form asp-action="ImportExcel" enctype="multipart/form-data" method="post">
                <div class="upload-zone">
                    <i class="bi bi-file-earmark-excel text-success" style="font-size:1.8rem;"></i>
                    <p class="text-white-50 small mt-2 mb-2">Upload file Excel Planning (sheet DL0)</p>
                    <div class="d-flex gap-2 justify-content-center">
                        <input type="file" name="file" id="fileInput" accept=".xlsx,.xls" class="form-control form-control-sm w-auto" style="background:#111;color:#fff;border-color:rgba(255,255,255,0.1);" />
                        <button type="submit" class="btn btn-warning btn-sm rounded-pill fw-bold px-3">
                            <i class="bi bi-lightning-fill me-1"></i> Scan DL0
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success rounded-3 border-0 mb-3"><i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger rounded-3 border-0 mb-3"><i class="bi bi-x-circle-fill me-2"></i>@TempData["ErrorMessage"]</div>
    }

    <!-- Search -->
    <div class="mb-3">
        <input type="text" id="searchInput" class="search-box" placeholder="🔍  Cari Part Code / Part Number / Description..." />
    </div>

    <!-- Table -->
    <div class="table-container shadow-lg">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-white-50">
                <i class="bi bi-inbox" style="font-size:3rem;"></i>
                <p class="mt-3">Belum ada data. Upload file Excel DL0 untuk mulai.</p>
            </div>
        }
        else
        {
            <div style="overflow-x:auto; max-height: 65vh; overflow-y: auto;">
                <table class="table table-dark table-hover mb-0 part-table" id="partTable">
                    <thead style="position:sticky;top:0;z-index:2;">
                        <tr>
                            <th>Part Code</th>
                            <th>Part Number</th>
                            <th>Description</th>
                            <th>Length</th>
                            <th>Dia</th>
                            <th>Inner</th>
                            <th>Outer</th>
                            <th>Combo</th>
                            <th title="Need Kg Inner (Ref)">INNER</th>
                            <th title="Need Kg Outer (Ref)">OUTER</th>
                            <th title="Cycle Time (sec/pcs)">sec/pcs</th>
                            <th title="Cycle Time dikurangi 20%">ct -20%</th>
                            <th title="Cycle Time Awal">ct awal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model)
                        {
                            <tr data-search="@($"{p.PartCode} {p.PartNumber} {p.Description}".ToLower())">
                                <td class="text-warning fw-bold">@p.PartCode</td>
                                <td class="text-info">@p.PartNumber</td>
                                <td class="text-white-50" style="max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="@p.Description">@p.Description</td>
                                <td>@p.Length</td>
                                <td>@p.Diameter</td>
                                <td class="text-white-50 small">@p.CompoundInner</td>
                                <td class="text-white-50 small">@p.CompoundOuter</td>
                                <td class="text-white-50 small">@p.CompoundCombo</td>
                                <td class="text-info fw-bold small">@(p.NeedKgInner?.ToString("0.###") ?? "-")</td>
                                <td class="text-warning fw-bold small">@(p.NeedKgOuter?.ToString("0.###") ?? "-")</td>
                                <td><span class="ct-pill">@(p.SecPerPcs?.ToString("0.##") ?? "-")</span></td>
                                <td class="text-white-50">@(p.CtMinus20?.ToString("0.##") ?? "-")</td>
                                <td class="text-white-50">@(p.CtAwal?.ToString("0.##") ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Clear Modal -->
<div class="modal fade" id="clearModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border border-danger">
            <div class="modal-header border-danger"><h5 class="modal-title text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Hapus Semua Data?</h5></div>
            <div class="modal-body text-white-50">Semua data Part Master (@Model.Count() part) akan dihapus permanen.</div>
            <div class="modal-footer border-0">
                <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Batal</button>
                <form asp-action="ClearData" method="post">
                    <button type="submit" class="btn btn-danger btn-sm rounded-pill">Ya, Hapus Semua</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $('#searchInput').on('input', function () {
        const q = $(this).val().toLowerCase();
        $('#partTable tbody tr').each(function () {
            const search = $(this).data('search') || '';
            $(this).toggle(search.includes(q));
        });
    });
</script>
}
