@model IEnumerable<VelastoProductionSystem.Models.ElwpPlanningDisplay>
@{
    ViewData["Title"] = "Planning Master";
}

<style>
    :root {
        --neon-green: #00ff88;
        --neon-glow: 0 0 10px rgba(0, 255, 136, 0.4), 0 0 20px rgba(0, 255, 136, 0.2);
        --bg-dark: #0f1319;
        --card-bg: #1a1e26;
    }

    /* ─── Plan Builder container ─── */
    .plan-builder { 
        background: var(--card-bg); 
        border-radius: 18px; 
        border: 1px solid rgba(0, 255, 136, 0.15); 
        overflow: hidden; 
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }
    .plan-header { background: rgba(0,0,0,0.3); padding: 18px 22px; }
    .col-lbl { font-size: 0.6rem; color: var(--neon-green); text-transform: uppercase; letter-spacing: 1px; font-weight: 800; opacity: 0.8; }
    
    .form-control-dark { 
        background: rgba(0,0,0,0.5); 
        border: 1px solid rgba(0, 255, 136, 0.2); 
        color: var(--neon-green); 
        border-radius: 12px; 
        padding: 10px 16px; 
        transition: all 0.3s ease;
    }
    .form-control-dark:focus { 
        outline: none; 
        border-color: var(--neon-green); 
        color: #fff; 
        background: rgba(0,0,0,0.7); 
        box-shadow: var(--neon-glow);
    }

    /* ─── Table Styles ─── */
    .hist-table th { 
        background: #080a0c; 
        color: var(--neon-green); 
        font-size: 0.6rem; 
        text-transform: uppercase; 
        padding: 14px 10px; 
        letter-spacing: 1.5px;
        font-weight: 900;
        border-bottom: 2px solid rgba(0, 255, 136, 0.2);
        border-right: 1px solid rgba(0, 255, 136, 0.12);
        border-top: none;
        border-left: none;
    }
    .hist-table th:last-child { border-right: none; }
    .hist-table td { 
        font-size: 0.77rem; 
        padding: 12px 10px; 
        border-bottom: 1px solid rgba(255,255,255,0.04);
        border-right: 1px solid rgba(255,255,255,0.05);
        border-top: none;
        border-left: none;
        vertical-align: middle; 
    }
    .hist-table td:last-child { border-right: none; }
    .hist-table tr:hover td { background: rgba(0, 255, 136, 0.03) !important; }
    
    .neon-btn {
        background: var(--neon-green);
        color: #000;
        border: none;
        font-weight: 800;
        border-radius: 50px;
        padding: 12px 30px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(0, 255, 136, 0.3);
    }
    .neon-btn:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: var(--neon-glow);
        background: #fff;
        color: #000;
    }
    .neon-btn:disabled { opacity: 0.6; cursor: not-allowed; }

    .glow-border { border: 1px solid rgba(0, 255, 136, 0.3) !important; }
    .neon-text { color: var(--neon-green); text-shadow: 0 0 5px rgba(0, 255, 136, 0.3); }
    
    .breadcrumb-item + .breadcrumb-item::before { color: rgba(255,255,255,0.3); }
    .fw-black { font-weight: 900; }
</style>

<div class="fade-in">
    <!-- ═══ TOP NAVBAR & ACTIONS ═══ -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px;">
                    <li class="breadcrumb-item"><a href="/" class="text-white-50 text-decoration-none">Home</a></li>
                    <li class="breadcrumb-item active neon-text fw-bold" aria-current="page">Planning Master</li>
                </ol>
            </nav>
            <h2 class="text-white fw-bold mb-0" style="letter-spacing: -1px;">
                <i class="bi bi-calendar-week text-warning me-2"></i> Planning Master
                @{
                    var filterDate = ViewBag.FilterDate as DateTime?;
                    if (filterDate.HasValue)
                    {
                        <span class="ms-2 opacity-50" style="font-size: 1.1rem; font-weight: 300;">— @filterDate.Value.ToString("dd MMM yyyy")</span>
                    }
                }
            </h2>
            <p class="text-white-50 small mb-0">Sinkronisasi jadwal harian langsung dari <strong class="neon-text">ELWP Production System</strong></p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="PartMaster" asp-action="Index" class="btn btn-sm btn-outline-success rounded-pill px-3" style="border-color:rgba(0,255,136,0.3); color:var(--neon-green);">
                <i class="bi bi-database-fill me-1"></i> Part Master
            </a>
            <form asp-action="ClearData" method="post" onsubmit="return confirm('Hapus semua data planning?')">
                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                    <i class="bi bi-trash3 me-1"></i> Kosongkan
                </button>
            </form>
        </div>
    </div>

    <!-- ═══ CONTROL PANEL CARD ═══ -->
    <div class="plan-builder shadow-lg mb-5" style="background: linear-gradient(145deg, #13171e, #0a0d12); border: 1px solid rgba(0,255,136,0.25);">
        <div class="plan-header" style="border-bottom: 1px solid rgba(0,255,136,0.1);">
            <div class="row align-items-center g-4">
                <div class="col-lg-4">
                    <div class="d-flex align-items-center gap-3">
                        <div style="width:52px;height:52px;background:rgba(0,255,136,0.08);border:1px solid rgba(0,255,136,0.25);border-radius:16px;display:flex;align-items:center;justify-content:center;box-shadow:inset 0 0 10px rgba(0,255,136,0.1);">
                            <i class="bi bi-cpu" style="font-size:1.6rem;color:var(--neon-green);filter:drop-shadow(0 0 5px rgba(0,255,136,0.5));"></i>
                        </div>
                        <div>
                            <div style="font-size:0.65rem;font-weight:900;letter-spacing:3px;color:var(--neon-green);text-transform:uppercase;opacity:0.7;">System Link</div>
                            <div style="font-size:1.2rem;font-weight:800;color:#fff;letter-spacing:-0.5px;">ELWP Production Gateway</div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-8">
                    <form method="get" class="row g-2 justify-content-end">
                        <div class="col-md-3">
                            <label class="col-lbl ms-2 mb-1 d-block">Filter Date</label>
                            <input type="date" name="filterDate" value="@(ViewBag.FilterDate?.ToString("yyyy-MM-dd"))" class="form-control form-control-dark form-control-sm w-100" />
                        </div>
                        <div class="col-md-3">
                            <label class="col-lbl ms-2 mb-1 d-block">Filter Mesin</label>
                            <select name="machineId" asp-items="ViewBag.ExtrudeMachines" class="form-select form-control-dark form-select-sm w-100">
                                <option value="">Semua Mesin</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="col-lbl ms-2 mb-1 d-block">Search Keyword</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-transparent border-0 pe-0" style="z-index: 5;"><i class="bi bi-search text-white-50"></i></span>
                                <input type="text" name="query" value="@ViewBag.Query" placeholder="Part code, shift..." class="form-control form-control-dark border-0 ms-n3" style="padding-left: 40px;" />
                            </div>
                        </div>
                        <div class="col-md-auto d-flex align-items-end gap-2">
                            <button type="submit" class="btn btn-sm neon-btn py-2 px-4 shadow-sm h-100" style="min-height: 38px;">
                                <i class="bi bi-filter me-1"></i> APPLY FILTER
                            </button>
                            <a href="@Url.Action("Index", new { filterDate = DateTime.Today.ToString("yyyy-MM-dd") })" class="btn btn-sm btn-info py-2 px-4 shadow-sm h-100" style="min-height: 38px;" title="Tampilkan planning hari ini">
                                <i class="bi bi-calendar-check me-1"></i> PLANNING HARI INI
                            </a>
                            @if (ViewBag.FilterDate != null || !string.IsNullOrEmpty(ViewBag.Query) || ViewBag.MachineId != null)
                            {
                                <a asp-action="Index" class="btn btn-sm btn-link text-white-50 text-decoration-none pb-2">Reset</a>
                            }
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- ═══ QUICK STATS ═══ -->
        <div class="p-4" style="background: rgba(0,0,0,0.15);">
            <div class="row g-4">
                <div class="col-md-3">
                    <div class="p-3 rounded-4 h-100" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
                        <div class="text-white-50 small text-uppercase mb-1 fw-bold" style="font-size:0.6rem; letter-spacing:1px;">Total Items</div>
                        <div class="d-flex align-items-center gap-2">
                            <div class="h3 mb-0 fw-black text-white">@Model.Count()</div>
                            <div class="badge rounded-pill bg-success bg-opacity-10 text-success" style="font-size:0.6rem; border:1px solid rgba(0,255,136,0.2);">ACTIVE</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="p-3 rounded-4 h-100" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
                        <div class="text-white-50 small text-uppercase mb-1 fw-bold" style="font-size:0.6rem; letter-spacing:1px;">Total Target (pcs)</div>
                        <div class="h3 mb-0 fw-black neon-text">@Model.Sum(x => x.QtyPlanning ?? 0).ToString("N0")</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="p-3 rounded-4 h-100" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
                        <div class="text-white-50 small text-uppercase mb-1 fw-bold" style="font-size:0.6rem; letter-spacing:1px;">Unique Machines</div>
                        <div class="h3 mb-0 fw-black text-white">@Model.Select(x => x.MachineName).Distinct().Count()</div>
                    </div>
                </div>
                <div class="col-lg-3">
                    <!-- Action Buttons in Card -->
                    <div class="d-flex h-100 gap-2">
                        <a asp-action="ExportCsv" asp-route-filterDate="@(ViewBag.FilterDate?.ToString("yyyy-MM-dd"))" asp-route-query="@ViewBag.Query" asp-route-machineId="@ViewBag.MachineId" class="btn btn-outline-info flex-grow-1 rounded-4 d-flex flex-column align-items-center justify-content-center gap-1" style="border-style: dashed; background: rgba(0, 150, 255, 0.05);">
                            <i class="bi bi-file-earmark-text fs-5"></i>
                            <span style="font-size: 0.65rem; font-weight: 800;">EXPORT CSV</span>
                        </a>
                        <a asp-action="ExportExcel" asp-route-filterDate="@(ViewBag.FilterDate?.ToString("yyyy-MM-dd"))" asp-route-query="@ViewBag.Query" asp-route-machineId="@ViewBag.MachineId" class="btn btn-outline-success flex-grow-1 rounded-4 d-flex flex-column align-items-center justify-content-center gap-1" style="border-style: dashed; background: rgba(0, 200, 100, 0.05);">
                            <i class="bi bi-file-earmark-excel fs-5"></i>
                            <span style="font-size: 0.65rem; font-weight: 800;">DOWNLOAD EXCEL</span>
                        </a>
                        <button type="button" class="btn btn-outline-warning flex-grow-1 rounded-4 d-flex flex-column align-items-center justify-content-center gap-1" style="border-style: dashed; background: rgba(255, 193, 7, 0.05);" data-bs-toggle="modal" data-bs-target="#syncModal">
                            <i class="bi bi-arrow-repeat fs-5"></i>
                            <span style="font-size: 0.65rem; font-weight: 800;">SYNC DATA</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    { <div class="alert alert-success rounded-4 border-0 mb-4 py-3 shadow-lg fade-in" style="background:rgba(0,255,136,0.15);color:var(--neon-green);border:1px solid rgba(0,255,136,0.2) !important;"><i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]</div> }
    @if (TempData["ErrorMessage"] != null)
    { <div class="alert alert-danger rounded-4 border-0 mb-4 py-3 shadow-lg fade-in"><i class="bi bi-x-circle-fill me-2"></i>@TempData["ErrorMessage"]</div> }

    <!-- ═══ DATA TABLE ═══ -->
    <div class="mb-5">
        <div style="background:var(--card-bg);border-radius:24px;border:1px solid rgba(255,255,255,0.05);overflow:hidden;box-shadow:0 15px 35px rgba(0,0,0,0.4);">
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-white-50" style="background: repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(255,255,255,0.02) 10px, rgba(255,255,255,0.02) 20px);">
                    <div class="mb-3" style="opacity:0.2;">
                        <i class="bi bi-search" style="font-size:4rem;color:var(--neon-green);"></i>
                    </div>
                    <div class="fw-bold mb-1 fs-5">No Records Found</div>
                    <div style="font-size:0.75rem; max-width: 400px; margin: 0 auto;">Try adjusting your filters or use the <strong>Sync Data</strong> button to fetch the latest planning from the ELWP server.</div>
                </div>
            }
            else
            {
                <div style="overflow-x:auto;max-height:65vh;overflow-y:auto;">
                    <table class="table table-dark table-hover mb-0 hist-table">
                        <thead style="position:sticky;top:0;z-index:10;">
                            <tr>
                                <th style="width:180px;">Tanggal</th>
                                <th>Mesin</th>
                                <th style="width:100px;">Shift</th>
                                <th>Kode Item</th>
                                <th>Part Name</th>
                                <th>PN SAP</th>
                                <th style="text-align:center;">Target (pcs)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var sortedData = Model
                                    .OrderByDescending(x => x.DateValue)
                                    .ThenBy(x => x.MachineName)
                                    .ThenBy(x => x.Shift);
                            }
                            @foreach (var item in sortedData)
                            {
                                <tr style="border-left:4px solid var(--neon-green);">
                                    <td class="text-white-50 fw-bold" style="font-size:0.7rem;">
                                        @item.DateString
                                    </td>
                                    <td>
                                        <div style="color:var(--neon-green);font-weight:800;letter-spacing:-0.2px;">
                                            @item.MachineName
                                        </div>
                                    </td>
                                    <td>
                                        <div class="badge rounded-pill" style="background:rgba(0, 255, 136, 0.1);color:var(--neon-green);border:1px solid rgba(0, 255, 136, 0.2);padding:6px 14px;font-size:0.65rem;font-weight:900;">
                                            @item.Shift
                                        </div>
                                    </td>
                                    <td>
                                        <span class="text-info fw-bold" style="font-family:'Courier New', Courier, monospace;font-size:0.85rem;">@item.KodeItem</span>
                                    </td>
                                    <td class="text-white-50 small" style="max-width:300px;overflow:hidden;text-overflow:ellipsis;">@item.PartName</td>
                                    <td class="text-white-50 small" style="font-family:monospace;letter-spacing:0.5px;">@item.PnSap</td>
                                    <td class="text-center">
                                        <span class="px-3 py-1 rounded-pill fw-bold text-white" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);font-size:0.85rem;">
                                            @(item.QtyPlanning.HasValue ? item.QtyPlanning.Value.ToString("N0") : "-")
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- ═══ SYNC MODAL ═══ -->
<div class="modal fade" id="syncModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: var(--card-bg); border: 1px solid rgba(0,255,136,0.3); border-radius: 20px; box-shadow: 0 0 30px rgba(0,255,136,0.1);">
            <div class="modal-header border-0 pb-0 pt-4 px-4">
                <h5 class="modal-title text-white fw-bold"><i class="bi bi-arrow-repeat text-warning me-2"></i> Sync from ELWP System</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="SyncFromElwp" method="post">
                <div class="modal-body py-4 px-4">
                    <div class="p-3 rounded-4 mb-3" style="background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.05);">
                        <label class="col-lbl mb-2 d-block text-white-50">Select Target Planning Date</label>
                        <input type="date" name="syncDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" class="form-control form-control-dark" required />
                        <p class="small text-white-50 mt-3 mb-0" style="font-size: 0.7rem; line-height: 1.4;">
                            <i class="bi bi-info-circle-fill text-info me-1"></i> 
                            Data yang sudah ada di lokal untuk tanggal & shift yang sama akan <strong>ditimpa (overwrite)</strong> dengan data terbaru dari server ELWP.
                        </p>
                    </div>
                </div>
                <div class="modal-footer border-0 pb-4 px-4 pt-0">
                    <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill px-3" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-sm neon-btn px-4">
                        <i class="bi bi-cloud-download me-1"></i> START SYNC
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Auto-focus search input if query exists
        const qInput = document.querySelector('input[name="query"]');
        if (qInput && qInput.value) { 
            qInput.focus(); 
            qInput.setSelectionRange(qInput.value.length, qInput.value.length); 
        }
    });
</script>



