@model IEnumerable<VelastoProductionSystem.Models.PlanningMaster>
@{
    ViewData["Title"] = "Planning Master";
}

<style>
    :root {
        --neon-green: #00ff88;
        --neon-glow: 0 0 10px rgba(0, 255, 136, 0.4), 0 0 20px rgba(0, 255, 136, 0.2);
        --bg-dark: #0f1319;
        --card-bg: #1a1e26;
    }

    /* ─── Plan Builder container ─── */
    .plan-builder { 
        background: var(--card-bg); 
        border-radius: 18px; 
        border: 1px solid rgba(0, 255, 136, 0.15); 
        overflow: hidden; 
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }
    .plan-header { background: rgba(0,0,0,0.3); padding: 18px 22px; }
    .col-lbl { font-size: 0.6rem; color: var(--neon-green); text-transform: uppercase; letter-spacing: 1px; font-weight: 800; opacity: 0.8; }
    
    .form-control-dark { 
        background: rgba(0,0,0,0.5); 
        border: 1px solid rgba(0, 255, 136, 0.2); 
        color: var(--neon-green); 
        border-radius: 12px; 
        padding: 10px 16px; 
        transition: all 0.3s ease;
    }
    .form-control-dark:focus { 
        outline: none; 
        border-color: var(--neon-green); 
        color: #fff; 
        background: rgba(0,0,0,0.7); 
        box-shadow: var(--neon-glow);
    }

    /* ─── Table Styles ─── */
    .hist-table th { 
        background: #080a0c; 
        color: var(--neon-green); 
        font-size: 0.6rem; 
        text-transform: uppercase; 
        padding: 14px 10px; 
        border: none; 
        letter-spacing: 1.5px;
        font-weight: 900;
        border-bottom: 2px solid rgba(0, 255, 136, 0.1);
    }
    .hist-table td { 
        font-size: 0.77rem; 
        padding: 12px 10px; 
        border-color: rgba(255,255,255,0.03); 
        vertical-align: middle; 
    }
    .hist-table tr:hover { background: rgba(0, 255, 136, 0.03) !important; }
    
    .neon-btn {
        background: var(--neon-green);
        color: #000;
        border: none;
        font-weight: 800;
        border-radius: 50px;
        padding: 12px 30px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(0, 255, 136, 0.3);
    }
    .neon-btn:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: var(--neon-glow);
        background: #fff;
        color: #000;
    }
    .neon-btn:disabled { opacity: 0.6; cursor: not-allowed; }

    .glow-border { border: 1px solid rgba(0, 255, 136, 0.3) !important; }
    .neon-text { color: var(--neon-green); text-shadow: 0 0 5px rgba(0, 255, 136, 0.3); }
</style>

<div class="fade-in">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3">
        <div>
            <h2 class="text-white fw-bold mb-1"><i class="bi bi-calendar-week text-warning me-2"></i> Planning Master</h2>
            <p class="text-white-50 small mb-0">Sinkronisasi jadwal harian langsung dari <strong class="neon-text">ELWP Production System</strong></p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="PartMaster" asp-action="Index" class="btn btn-sm btn-outline-success rounded-pill px-3" style="border-color:rgba(0,255,136,0.3); color:var(--neon-green);">
                <i class="bi bi-database-fill me-1"></i> Part Master
            </a>
            <form asp-action="ClearData" method="post" onsubmit="return confirm('Hapus semua data planning?')">
                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                    <i class="bi bi-trash3 me-1"></i> Kosongkan
                </button>
            </form>
        </div>
    </div>

    <!-- ═══ ELWP SYNC CARD ═══ -->
    <div class="plan-builder shadow-lg mb-5" style="background: linear-gradient(145deg, #13171e, #0a0d12); border: 1px solid rgba(0,255,136,0.25);">
        <div class="plan-header" style="border-bottom: 1px solid rgba(0,255,136,0.1);">
            <div class="d-flex align-items-center gap-3 mb-4">
                <div style="width:52px;height:52px;background:rgba(0,255,136,0.08);border:1px solid rgba(0,255,136,0.25);border-radius:16px;display:flex;align-items:center;justify-content:center;box-shadow:inset 0 0 10px rgba(0,255,136,0.1);">
                    <i class="bi bi-lightning-charge-fill" style="font-size:1.6rem;color:var(--neon-green);filter:drop-shadow(0 0 5px rgba(0,255,136,0.5));"></i>
                </div>
                <div>
                    <div style="font-size:0.7rem;font-weight:900;letter-spacing:4px;color:var(--neon-green);text-transform:uppercase;opacity:0.8;">Primary Sync Engine</div>
                    <div style="font-size:1.3rem;font-weight:800;color:#fff;letter-spacing:-0.5px;">ELWP Production Synchronizer</div>
                </div>
                <div class="ms-auto d-none d-md-block">
                    <span class="badge" style="background:rgba(0,255,136,0.1);color:var(--neon-green);border:1px solid rgba(0,255,136,0.2);font-size:0.65rem;padding:8px 16px;border-radius:50px;letter-spacing:1px;font-weight:800;box-shadow:var(--neon-glow);">
                        <i class="bi bi-broadcast me-1"></i> LIVE DATABASE ACCESS
                    </span>
                </div>
            </div>

            <form asp-action="SyncFromElwp" method="post" id="syncElwpForm">
                <div class="row g-4 align-items-end">
                    <div class="col-md-3">
                        <label class="col-lbl d-block mb-2">Pilih Tanggal Produksi</label>
                        <input type="date" name="syncDate" id="syncDate" class="form-control-dark w-100"
                               value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-4">
                        <button type="submit" id="btnSyncElwp"
                                class="neon-btn w-100 shadow-lg"
                                onclick="this.disabled=true;this.innerHTML='<span class=spinner-border spinner-border-sm me-2></span> Menyambungkan...';this.form.submit();">
                            <i class="bi bi-cloud-download-fill me-2"></i> Sinkronisasi Data ELWP
                        </button>
                    </div>
                    <div class="col-md-5">
                        <div class="p-3 rounded-4" style="background:rgba(0,0,0,0.25);border:1px solid rgba(255,255,255,0.03);">
                            <p class="text-white-50 small mb-0" style="font-size:0.7rem;line-height:1.5;">
                                <i class="bi bi-info-circle-fill me-1" style="color:var(--neon-green);"></i>
                                Menarik data dari tabel <span class="badge bg-dark text-success border border-success border-opacity-25">tb_elwp_produksi_plannings</span>. 
                                Seluruh data lokal pada tanggal yang dipilih akan diperbarui secara otomatis.
                            </p>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    { <div class="alert alert-success rounded-4 border-0 mb-4 py-3 shadow-lg" style="background:rgba(0,255,136,0.15);color:var(--neon-green);border:1px solid rgba(0,255,136,0.2) !important;"><i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]</div> }
    @if (TempData["ErrorMessage"] != null)
    { <div class="alert alert-danger rounded-4 border-0 mb-4 py-3 shadow-lg"><i class="bi bi-x-circle-fill me-2"></i>@TempData["ErrorMessage"]</div> }

    <!-- ═══ SAVED DATA ═══ -->
    <div class="mb-5">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div class="d-flex align-items-center gap-3">
                <h6 class="text-white text-uppercase fw-bold mb-0 shadow-text" style="letter-spacing:2px;font-size:0.85rem;">
                    <i class="bi bi-grid-3x3-gap-fill me-2" style="color:var(--neon-green);"></i> Jadwal Planning Tersimpan
                </h6>
                <div style="width:1px;height:20px;background:rgba(255,255,255,0.1);"></div>
                <span class="text-white-50 small">@Model.Count() records found</span>
            </div>
        </div>

        <div style="background:var(--card-bg);border-radius:24px;border:1px solid rgba(255,255,255,0.05);overflow:hidden;box-shadow:0 15px 35px rgba(0,0,0,0.4);">
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-white-50">
                    <div class="mb-3" style="opacity:0.2;">
                        <i class="bi bi-folder2-open" style="font-size:4rem;color:var(--neon-green);"></i>
                    </div>
                    <div class="fw-bold mb-1">Database Kosong</div>
                    <div style="font-size:0.75rem;">Silakan lakukan sinkronisasi untuk menampilkan data ELWP.</div>
                </div>
            }
            else
            {
                <div style="overflow-x:auto;max-height:65vh;overflow-y:auto;">
                    <table class="table table-dark table-hover mb-0 hist-table">
                        <thead style="position:sticky;top:0;z-index:10;">
                            <tr>
                                <th style="width:180px;">Tanggal</th>
                                <th>Mesin</th>
                                <th>Shift</th>
                                <th>Kode Item</th>
                                <th>Part Name</th>
                                <th>PN SAP</th>
                                <th style="text-align:center;">Target (pcs)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var sortedData = Model
                                    .OrderByDescending(x => x.DateShiftString)
                                    .ThenBy(x => x.MachineName)
                                    .ThenBy(x => x.WaktuMulai);
                            }
                            @foreach (var item in sortedData)
                            {
                                <tr style="border-left:4px solid var(--neon-green);">
                                    <td class="text-white-50 fw-bold" style="font-size:0.7rem;">
                                        @item.DateShiftString?.Split(" SHIFT ").FirstOrDefault()
                                    </td>
                                    <td>
                                        <div style="color:var(--neon-green);font-weight:800;letter-spacing:-0.2px;">
                                            @item.MachineName
                                        </div>
                                    </td>
                                    <td>
                                        <div class="badge rounded-pill" style="background:rgba(0, 255, 136, 0.1);color:var(--neon-green);border:1px solid rgba(0, 255, 136, 0.2);padding:6px 14px;font-size:0.65rem;font-weight:900;">
                                            SHIFT @(item.DateShiftString?.Split("SHIFT ").LastOrDefault()?.Trim() ?? "1")
                                        </div>
                                    </td>
                                    <td>
                                        <span class="text-info fw-bold" style="font-family:'Courier New', Courier, monospace;font-size:0.85rem;">@item.PartName1</span>
                                    </td>
                                    <td class="text-white-50 small" style="max-width:300px;overflow:hidden;text-overflow:ellipsis;">@item.PartName2</td>
                                    <td class="text-white-50 small" style="font-family:monospace;letter-spacing:0.5px;">@item.Kode</td>
                                    <td class="text-center">
                                        <span class="px-3 py-1 rounded-pill fw-bold text-white" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);font-size:0.85rem;">
                                            @(item.PlanTargetPcs.HasValue ? item.PlanTargetPcs.Value.ToString("N0") : "-")
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>


