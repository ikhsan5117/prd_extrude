@{ Layout = "_Layout"; ViewData["Title"] = "Chart Analysis"; }

<style>
:root{--bg:#010409;--tile:rgba(21,27,38,.7);--accent:#0066ff;--glow:rgba(0,102,255,.4);--ok:#00ff88;--ng:#ff4d4d;--warn:#fbbf24;--border:rgba(255,255,255,.06)}
body{background:var(--bg);color:#e6edf3;font-family:'Outfit',sans-serif}
.ca-page{padding:20px 15px 60px}
.ca-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:30px;border-bottom:1px solid var(--border);padding-bottom:25px}
.ca-title{font-size:2.8rem;font-weight:1000;letter-spacing:-2px;color:#fff;line-height:.9}
.ca-sub{color:#8b949e;font-size:.75rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;margin-top:10px}
.search-panel{display:grid;grid-template-columns:2fr 1fr auto;gap:15px;margin-bottom:30px}
.s-box{position:relative;display:flex;align-items:center;background:rgba(10,15,25,.8);border:1px solid rgba(255,255,255,.08);border-left:3px solid var(--accent);padding:0 15px;height:46px}
.s-box i{color:var(--accent);margin-right:12px;flex-shrink:0}
.s-box input,.s-box select{background:0 0;border:none;color:#fff;width:100%;height:100%;font-size:.8rem;font-weight:600;outline:0;text-transform:uppercase;letter-spacing:.5px}
.s-box select{cursor:pointer;color:#8b949e}
.s-box select option{background:#0d1117;color:#fff}
.btn-load{background:var(--accent);color:#fff;border:none;padding:0 28px;height:46px;font-weight:900;font-size:.75rem;letter-spacing:1px;cursor:pointer;transition:.3s}
.btn-load:hover{transform:translateY(-2px);box-shadow:0 8px 30px var(--glow)}
.info-cards{display:grid;grid-template-columns:repeat(4,1fr);gap:15px;margin-bottom:30px}
.i-card{padding:14px 18px;background:linear-gradient(145deg,rgba(21,27,38,.7),rgba(1,4,9,.8));border:1px solid rgba(255,255,255,.05);border-radius:2px}
.i-lbl{font-size:.5rem;font-weight:800;color:#484f58;text-transform:uppercase;letter-spacing:1.5px}
.i-val{font-size:1.1rem;font-weight:900;color:#fff;margin-top:2px}
.i-val.cyan{color:#00ccff}.i-val.yellow{color:#fbbf24}.i-val.green{color:#00ff88}.i-val.red{color:#ff4d4d}
.tab-bar{display:flex;gap:8px;margin-bottom:20px;border-bottom:1px solid var(--border);padding-bottom:10px}
.tab-btn{background:0 0;border:none;color:#64748b;font-size:.7rem;font-weight:800;padding:10px 20px;cursor:pointer;border-radius:8px;transition:.2s;text-transform:uppercase;letter-spacing:1px}
.tab-btn.active{background:rgba(0,102,255,.15);color:#38bdf8}
.tab-btn:hover:not(.active){background:rgba(255,255,255,.04);color:#e2e8f0}
.tab-pane{display:none}.tab-pane.active{display:block}
.chart-card{background:rgba(21,27,38,.4);border:1px solid var(--border);border-radius:12px;padding:20px;margin-bottom:20px}
.chart-card h3{font-size:.7rem;font-weight:900;color:#8b949e;letter-spacing:2px;text-transform:uppercase;margin-bottom:15px}
.chart-wrap{position:relative;height:300px}
.tbl-wrap{background:rgba(21,27,38,.4);border:1px solid var(--border);border-radius:12px;overflow-x:auto;margin-bottom:20px}
.cmp-table{width:100%;border-collapse:collapse;font-size:.8rem;min-width:700px}
.cmp-table th{padding:10px 14px;text-align:left;font-weight:900;font-size:.6rem;letter-spacing:1px;text-transform:uppercase;color:#8b949e;border-bottom:2px solid rgba(0,102,255,.3);white-space:nowrap}
.cmp-table td{padding:10px 14px;border-bottom:1px solid var(--border);white-space:nowrap}
.cmp-table tr:hover{background:rgba(0,102,255,.04)}
.st-ok{color:var(--ok);font-weight:900}.st-ng{color:var(--ng);font-weight:900}.st-warn{color:var(--warn);font-weight:900}
.alert-zone{background:rgba(255,77,77,.05);border:1px solid rgba(255,77,77,.2);border-radius:12px;padding:15px 20px;margin-bottom:20px}
.alert-zone h3{font-size:.65rem;font-weight:900;color:#ff4d4d;letter-spacing:2px;margin-bottom:10px}
.alert-item{font-size:.8rem;color:#ff9999;padding:4px 0;font-weight:600}
#noData{text-align:center;padding:80px 20px;color:#484f58;font-weight:900;font-size:1.2rem}
.legend-box{display:flex;gap:20px;margin-top:10px;font-size:.65rem;font-weight:700;color:#8b949e}
.legend-box span::before{content:'';display:inline-block;width:20px;height:3px;margin-right:6px;vertical-align:middle}
.leg-actual::before{background:#0088ff}.leg-upper::before{background:#ff4d4d;border-top:2px dashed #ff4d4d;height:0}.leg-lower::before{background:#fbbf24;border-top:2px dashed #fbbf24;height:0}
@@media(max-width:900px){.search-panel{grid-template-columns:1fr}.info-cards{grid-template-columns:repeat(2,1fr)}}
</style>

<div class="ca-page">
<div class="ca-header"><div><div class="ca-title">Chart Analysis</div><div class="ca-sub">Production Parameter vs SPS Standard</div></div></div>

<div class="search-panel">
<div class="s-box"><i class="bi bi-search"></i><input id="docSearch" placeholder="CARI NO. DOCUMENT / VIN CODE..." list="docList" /><datalist id="docList"></datalist></div>
<div class="s-box"><i class="bi bi-cpu"></i><select id="docSelect"><option value="">-- PILIH DOCUMENT --</option></select></div>
<button class="btn-load" onclick="loadChart()"><i class="bi bi-lightning-charge-fill"></i> LOAD</button>
</div>

<div id="noData"><i class="bi bi-bar-chart-line" style="font-size:3rem;display:block;margin-bottom:10px"></i>PILIH DOCUMENT UNTUK MEMUAT DATA</div>

<div id="chartMainContent" style="display:none">
<div class="info-cards" id="infoCards"></div>

<div class="tab-bar">
<button class="tab-btn active" onclick="switchTab('temp',this)">Temperature</button>
<button class="tab-btn" onclick="switchTab('speed',this)">Speed / Pressure</button>
<button class="tab-btn" onclick="switchTab('dim',this)">Dimension</button>
<button class="tab-btn" onclick="switchTab('table',this)">Detail Table</button>
</div>

<div id="pane-temp" class="tab-pane active">
<div class="chart-card"><h3>Inner (Material 1) — Head / Cylinder / Screw Temperature</h3><div class="chart-wrap"><canvas id="chartTempInner"></canvas></div>
<div class="legend-box"><span class="leg-actual">Actual (solid)</span><span class="leg-upper">Batas Atas (dashed)</span><span class="leg-lower">Batas Bawah (dashed)</span></div></div>
<div class="chart-card"><h3>Outer (Material 2) — Head / Cylinder / Screw Temperature</h3><div class="chart-wrap"><canvas id="chartTempOuter"></canvas></div></div>
</div>

<div id="pane-speed" class="tab-pane">
<div class="chart-card"><h3>Screw Speed &amp; Pressure — Inner vs Outer</h3><div class="chart-wrap"><canvas id="chartSpeed"></canvas></div></div>
<div class="chart-card"><h3>Hose Speed &amp; Machine Parameters</h3><div class="chart-wrap"><canvas id="chartMachine"></canvas></div></div>
</div>

<div id="pane-dim" class="tab-pane">
<div class="chart-card"><h3>Inner Diameter — SPC Chart</h3><div class="chart-wrap"><canvas id="chartDimInner"></canvas></div></div>
<div class="chart-card"><h3>Total Thickness — SPC Chart</h3><div class="chart-wrap"><canvas id="chartDimTotal"></canvas></div></div>
</div>

<div id="pane-table" class="tab-pane">
<div id="alertZone" class="alert-zone" style="display:none"><h3><i class="bi bi-exclamation-triangle-fill"></i> OUT-OF-SPEC ALERTS</h3><div id="alertList"></div></div>
<div class="tbl-wrap"><table class="cmp-table"><thead><tr><th>Parameter</th><th>Standard</th><th>Batas Bawah</th><th>Batas Atas</th><th>Actual (Initial)</th><th>Status</th></tr></thead><tbody id="cmpBody"></tbody></table></div>
</div>
</div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<script>
let DATA=null, CHARTS={};
const P=v=>{if(!v)return null;let s=String(v);if(s.includes('~')){let p=s.split('~').map(Number);return(p[0]+p[1])/2}return parseFloat(s)||null};
const RANGE=v=>{if(!v)return null;let s=String(v);if(s.includes('~'))return s.split('~').map(Number);return null};

async function loadDocList(){
  try{const r=await fetch('/ProductionReport/GetDocumentList');const d=await r.json();
  const sel=document.getElementById('docSelect');const dl=document.getElementById('docList');
  sel.innerHTML='<option value="">-- PILIH --</option>';dl.innerHTML='';
  d.forEach(x=>{sel.innerHTML+=`<option value="${x.documentNumber}">${x.documentNumber} | ${x.hoseType||'-'} | ${x.vinCode||'-'}</option>`;
  dl.innerHTML+=`<option value="${x.documentNumber}">${x.hoseType} - ${x.vinCode} (${x.date})</option>`;});
  // Auto-load first document with readings, fallback to first available
  const docWithData=d.find(x=>x.readingsCount>0);
  const firstDoc=docWithData||d[0];
  if(firstDoc){sel.value=firstDoc.documentNumber;await loadChart();}
  }catch(e){console.error('Error loading doc list:',e);}
}

function showMsg(icon,title,text){
  if(typeof Swal!=='undefined')Swal.fire({icon,title,text,background:'#0d1117',color:'#fff'});
  else alert(title+': '+text);
}

async function loadChart(){
  const selVal=document.getElementById('docSelect').value;
  const searchVal=document.getElementById('docSearch').value.trim();
  const doc=selVal||searchVal;
  if(!doc){showMsg('warning','Pilih Document','Masukkan No. Document terlebih dahulu');return;}
  
  const nd=document.getElementById('noData');
  const mc=document.getElementById('chartMainContent');
  nd.innerHTML='<i class="bi bi-hourglass-split" style="font-size:3rem;display:block;margin-bottom:10px;animation:spin 1s linear infinite"></i>MEMUAT DATA...';
  nd.style.display='block';
  mc.style.display='none';
  
  try{
    console.log('[ChartAnalysis] Loading doc:', doc);
    const r=await fetch('/ProductionReport/GetChartData?documentNumber='+encodeURIComponent(doc));
    if(!r.ok){showMsg('error','HTTP Error','Status: '+r.status);nd.innerHTML='<i class="bi bi-bar-chart-line" style="font-size:3rem;display:block;margin-bottom:10px"></i>GAGAL MEMUAT DATA';return;}
    DATA=await r.json();
    console.log('[ChartAnalysis] Response:', DATA);
    if(!DATA.success){showMsg('error','Tidak Ditemukan',DATA.message||'Document tidak ditemukan');nd.innerHTML='<i class="bi bi-x-circle" style="font-size:3rem;display:block;margin-bottom:10px;color:#ff4d4d"></i>'+( DATA.message||'DOCUMENT TIDAK DITEMUKAN');return;}
    nd.style.display='none';
    mc.style.display='block';
    renderInfo();renderCharts();renderTable();
    if((DATA.readings||[]).length===0){showMsg('info','Data Tersedia','Report ditemukan tapi belum ada data readings (interval). Tabel comparison tetap ditampilkan dari data initial.');}
  }catch(e){
    console.error('[ChartAnalysis] Error:', e);
    showMsg('error','Gagal Memuat',e.message||'Network error');
    nd.innerHTML='<i class="bi bi-wifi-off" style="font-size:3rem;display:block;margin-bottom:10px;color:#ff4d4d"></i>ERROR: '+e.message;
  }
}

function renderInfo(){
  const rp=DATA.report;const sp=DATA.spsFound;
  document.getElementById('infoCards').innerHTML=`
  <div class="i-card"><div class="i-lbl">Hose Type</div><div class="i-val cyan">${rp.hoseType||'—'}</div></div>
  <div class="i-card"><div class="i-lbl">Machine</div><div class="i-val yellow">${rp.machineName||'—'}</div></div>
  <div class="i-card"><div class="i-lbl">VIN / Dimension</div><div class="i-val">${rp.vinCode||'—'} | ${rp.dimension||'—'}</div></div>
  <div class="i-card"><div class="i-lbl">SPS Match</div><div class="i-val ${sp?'green':'red'}">${sp?'✅ MATCHED':'❌ NOT FOUND'}</div></div>`;
}

function makeChart(id,labels,datasets,yLabel){
  if(CHARTS[id])CHARTS[id].destroy();
  const ctx=document.getElementById(id);if(!ctx)return;
  CHARTS[id]=new Chart(ctx,{type:'line',data:{labels,datasets},options:{responsive:true,maintainAspectRatio:false,
  interaction:{mode:'index',intersect:false},plugins:{legend:{labels:{color:'#8b949e',font:{size:10,weight:'bold'}}}},
  scales:{x:{ticks:{color:'#8b949e',font:{size:9}},grid:{color:'rgba(255,255,255,.03)'}},
  y:{title:{display:!!yLabel,text:yLabel||'',color:'#8b949e'},ticks:{color:'#8b949e',font:{size:9}},grid:{color:'rgba(255,255,255,.05)'}}}}});
}

function stdLine(label,val,len,color,dash){
  const v=P(val);if(v==null)return null;
  return{label,data:Array(len).fill(v),borderColor:color,borderWidth:1.5,borderDash:dash,pointRadius:0,fill:false};
}

function renderCharts(){
  const rd=DATA.readings||[];const sp=DATA.spsStandard;const labels=rd.length>0?rd.map(r=>r.timeLabel):['No Data'];const len=Math.max(labels.length,1);

  // TEMP INNER
  let dsTI=[{label:'Head Temp',data:rd.map(r=>r.headTempInner),borderColor:'#0088ff',borderWidth:2.5,pointRadius:3,tension:.3},
  {label:'Cyl1',data:rd.map(r=>r.cylinder1TempInner),borderColor:'#22d3ee',borderWidth:2,pointRadius:2,tension:.3},
  {label:'Cyl2',data:rd.map(r=>r.cylinder2TempInner),borderColor:'#a78bfa',borderWidth:2,pointRadius:2,tension:.3},
  {label:'Cyl3',data:rd.map(r=>r.cylinder3TempInner),borderColor:'#34d399',borderWidth:2,pointRadius:2,tension:.3},
  {label:'Screw',data:rd.map(r=>r.screwTempInner),borderColor:'#f472b6',borderWidth:2,pointRadius:2,tension:.3}];
  if(sp){[['HeadTemp1 ↑','headTemp1','#ff4d4d'],['HeadTemp1 ↓','headTemp1','#fbbf24']].forEach(([l,f,c])=>{
    const v=P(sp[f.charAt(0).toLowerCase()+f.slice(1)]);if(v!=null){
    if(l.includes('↑'))dsTI.push({label:l,data:Array(len).fill(v+5),borderColor:c,borderWidth:1,borderDash:[5,5],pointRadius:0});
    else dsTI.push({label:l,data:Array(len).fill(v-5),borderColor:c,borderWidth:1,borderDash:[5,5],pointRadius:0});}});}
  makeChart('chartTempInner',labels,dsTI.filter(Boolean),'°C');

  // TEMP OUTER
  let dsTO=[{label:'Head Temp',data:rd.map(r=>r.headTempOuter),borderColor:'#0088ff',borderWidth:2.5,pointRadius:3,tension:.3},
  {label:'Cyl1',data:rd.map(r=>r.cylinder1TempOuter),borderColor:'#22d3ee',borderWidth:2,pointRadius:2,tension:.3},
  {label:'Cyl2',data:rd.map(r=>r.cylinder2TempOuter),borderColor:'#a78bfa',borderWidth:2,pointRadius:2,tension:.3},
  {label:'Cyl3',data:rd.map(r=>r.cylinder3TempOuter),borderColor:'#34d399',borderWidth:2,pointRadius:2,tension:.3},
  {label:'Screw',data:rd.map(r=>r.screwTempOuter),borderColor:'#f472b6',borderWidth:2,pointRadius:2,tension:.3}];
  makeChart('chartTempOuter',labels,dsTO.filter(Boolean),'°C');

  // SPEED
  let dsS=[{label:'ScrewSpd Inner',data:rd.map(r=>r.screwSpeedInner),borderColor:'#0088ff',borderWidth:2.5,pointRadius:3,tension:.3},
  {label:'ScrewSpd Outer',data:rd.map(r=>r.screwSpeedOuter),borderColor:'#22d3ee',borderWidth:2.5,pointRadius:3,tension:.3},
  {label:'Pressure Inner',data:rd.map(r=>r.pressureInner),borderColor:'#f472b6',borderWidth:2,pointRadius:2,tension:.3,yAxisID:'y1'},
  {label:'Pressure Outer',data:rd.map(r=>r.pressureOuter),borderColor:'#fbbf24',borderWidth:2,pointRadius:2,tension:.3,yAxisID:'y1'}];
  if(sp){const s1=P(sp.screwSpeed1),s2=P(sp.screwSpeed2);
  if(s1!=null){dsS.push(stdLine('ScrewSpd1 ↑',s1+2,len,'#ff4d4d',[5,5]));dsS.push(stdLine('ScrewSpd1 ↓',s1-2,len,'#fbbf24',[5,5]));}
  if(s2!=null){dsS.push(stdLine('ScrewSpd2 ↑',s2+2,len,'#ff4d4d',[5,5]));dsS.push(stdLine('ScrewSpd2 ↓',s2-2,len,'#fbbf24',[5,5]));}}
  dsS=dsS.filter(Boolean);
  if(CHARTS['chartSpeed'])CHARTS['chartSpeed'].destroy();
  const ctxS=document.getElementById('chartSpeed');
  if(ctxS)CHARTS['chartSpeed']=new Chart(ctxS,{type:'line',data:{labels,datasets:dsS},options:{responsive:true,maintainAspectRatio:false,
  interaction:{mode:'index',intersect:false},plugins:{legend:{labels:{color:'#8b949e',font:{size:10,weight:'bold'}}}},
  scales:{x:{ticks:{color:'#8b949e',font:{size:9}},grid:{color:'rgba(255,255,255,.03)'}},
  y:{title:{display:true,text:'RPM',color:'#8b949e'},ticks:{color:'#8b949e'},grid:{color:'rgba(255,255,255,.05)'}},
  y1:{position:'right',title:{display:true,text:'MPa',color:'#8b949e'},ticks:{color:'#8b949e'},grid:{display:false}}}}});

  // MACHINE
  let dsM=[{label:'Hose Speed',data:rd.map(r=>r.hoseSpeed),borderColor:'#0088ff',borderWidth:2.5,pointRadius:3,tension:.3}];
  if(sp){const rng=RANGE(sp.hoseSpeed);if(rng){dsM.push(stdLine('HoseSpd ↑',rng[1],len,'#ff4d4d',[5,5]));dsM.push(stdLine('HoseSpd ↓',rng[0],len,'#fbbf24',[5,5]));}}
  dsM=dsM.filter(Boolean);
  makeChart('chartMachine',labels,dsM,'m/min');

  // DIM INNER
  let dsDI=[{label:'Inner Diameter',data:rd.map(r=>r.innerDiameter),borderColor:'#0088ff',borderWidth:2.5,pointRadius:4,tension:.3}];
  if(sp){const mn=P(sp.innerMin),mx=P(sp.innerMax),lcl=P(sp.innerLCL),ucl=P(sp.innerUCL);
  if(mx!=null)dsDI.push(stdLine('Max',mx,len,'#ff4d4d',[5,5]));
  if(mn!=null)dsDI.push(stdLine('Min',mn,len,'#fbbf24',[5,5]));
  if(ucl!=null)dsDI.push(stdLine('UCL',ucl,len,'rgba(255,77,77,.4)',[3,3]));
  if(lcl!=null)dsDI.push(stdLine('LCL',lcl,len,'rgba(251,191,36,.4)',[3,3]));}
  dsDI=dsDI.filter(Boolean);makeChart('chartDimInner',labels,dsDI,'mm');

  // DIM TOTAL
  let dsDT=[{label:'Total Thick X',data:rd.map(r=>r.totalThicknessX),borderColor:'#0088ff',borderWidth:2.5,pointRadius:4,tension:.3},
  {label:'Total Thick Y',data:rd.map(r=>r.totalThicknessY),borderColor:'#22d3ee',borderWidth:2,pointRadius:3,tension:.3}];
  if(sp){const mn=P(sp.totalMin),mx=P(sp.totalMax);
  if(mx!=null)dsDT.push(stdLine('Max',mx,len,'#ff4d4d',[5,5]));
  if(mn!=null)dsDT.push(stdLine('Min',mn,len,'#fbbf24',[5,5]));}
  dsDT=dsDT.filter(Boolean);makeChart('chartDimTotal',labels,dsDT,'mm');
}

function evalParam(name,actual,spsVal,tolOrRange){
  if(actual==null||actual==undefined)return null;
  const a=parseFloat(actual);if(isNaN(a))return null;
  let std=null,lo=null,hi=null;
  if(spsVal==null||spsVal==undefined||spsVal==='')return{name,actual:a,standard:'—',lo:'—',hi:'—',status:'NO_STD'};
  const sv=String(spsVal);
  if(sv.includes('~')){const p=sv.split('~').map(Number);lo=p[0];hi=p[1];std=(lo+hi)/2;}
  else{std=parseFloat(sv);if(isNaN(std))return{name,actual:a,standard:sv,lo:'—',hi:'—',status:'NO_STD'};
  if(tolOrRange!=null){const t=parseFloat(tolOrRange);lo=std-Math.abs(t);hi=std+Math.abs(t);}else{lo=std*0.9;hi=std*1.1;}}
  const status=(a>=lo&&a<=hi)?'OK':'NG';
  return{name,actual:a,standard:std,lo:lo!=null?lo.toFixed(1):'—',hi:hi!=null?hi.toFixed(1):'—',status};
}

function renderTable(){
  const sp=DATA.spsStandard||{};const ini=DATA.initials||{};const body=document.getElementById('cmpBody');
  const params=[
    ['Head Temp Inner',ini.initHeadTempInner,sp.headTemp1,5],
    ['Cyl1 Temp Inner',ini.initCylinder1TempInner,sp.cylinder1_1,5],
    ['Cyl2 Temp Inner',ini.initCylinder2TempInner,sp.cylinder2_1,5],
    ['Cyl3 Temp Inner',ini.initCylinder3TempInner,sp.cylinder3_1,5],
    ['Screw Temp Inner',ini.initScrewTempInner,sp.screwTemp1,5],
    ['Screw Speed Inner',ini.initScrewSpeedInner,sp.screwSpeed1,2],
    ['Pressure Inner',ini.initPressureInner,sp.pressure1,1],
    ['Feed Roll Inner',ini.initFeedRollRatioInner,sp.feedRollRatio1||sp.feed1,null],
    ['—','—','—',null],
    ['Head Temp Outer',ini.initHeadTempOuter,sp.headTemp2,5],
    ['Cyl1 Temp Outer',ini.initCylinder1TempOuter,sp.cylinder1_2,5],
    ['Cyl2 Temp Outer',ini.initCylinder2TempOuter,sp.cylinder2_2,5],
    ['Cyl3 Temp Outer',ini.initCylinder3TempOuter,sp.cylinder3_2,5],
    ['Screw Temp Outer',ini.initScrewTempOuter,sp.screwTemp2,5],
    ['Screw Speed Outer',ini.initScrewSpeedOuter,sp.screwSpeed2,2],
    ['Pressure Outer',ini.initPressureOuter,sp.pressure2,1],
    ['—','—','—',null],
    ['Hose Speed',ini.initHoseSpeed,sp.hoseSpeed,null],
    ['Chiller Water Temp',ini.initChillerWaterTemp,sp.chillerWaterTemp,3],
    ['Caterpillar Gap',ini.initCaterpillarGap,sp.caterpillarGap,null],
  ];
  let html='';let alerts=[];
  params.forEach(([name,act,std,tol])=>{
    if(name==='—'){html+=`<tr><td colspan="6" style="color:#484f58;font-weight:900;font-size:.7rem;letter-spacing:2px;text-align:center">── OUTER ──</td></tr>`;return;}
    const ev=evalParam(name,act,std,tol);
    if(!ev)return;
    const cls=ev.status==='OK'?'st-ok':ev.status==='NG'?'st-ng':'';
    const icon=ev.status==='OK'?'✅':ev.status==='NG'?'⚠️':'—';
    html+=`<tr><td style="font-weight:800">${ev.name}</td><td>${ev.standard}</td><td>${ev.lo}</td><td>${ev.hi}</td><td class="${cls}">${ev.actual}</td><td class="${cls}">${icon} ${ev.status}</td></tr>`;
    if(ev.status==='NG')alerts.push(`⚠️ ${ev.name}: ${ev.actual} (Batas: ${ev.lo} ~ ${ev.hi})`);
  });
  body.innerHTML=html;
  const az=document.getElementById('alertZone');const al=document.getElementById('alertList');
  if(alerts.length>0){az.style.display='block';al.innerHTML=alerts.map(a=>`<div class="alert-item">${a}</div>`).join('');}
  else{az.style.display='none';}
}

function switchTab(id,btn){
  document.querySelectorAll('.tab-pane').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('pane-'+id).classList.add('active');
  btn.classList.add('active');
}

document.getElementById('docSearch').addEventListener('input',function(){
  const v=this.value;if(v.length>2){const sel=document.getElementById('docSelect');
  for(let o of sel.options){if(o.value&&o.value.toUpperCase().includes(v.toUpperCase())){sel.value=o.value;break;}}}
});

window.addEventListener('load',loadDocList);
</script>
