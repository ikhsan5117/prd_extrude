function filterSpsItems(q){
  if(!window._SPS_RESULTS || window._SPS_RESULTS.length === 0) return;
  const query=q.trim().toUpperCase();
  const filtered=query ? window._SPS_RESULTS.filter(x=>
    (x.itemCode && x.itemCode.toUpperCase().includes(query)) ||
    (x.hoseType && x.hoseType.toUpperCase().includes(query))
  ) : window._SPS_RESULTS;
  renderAcItems(filtered,false);
}

(function initAutocomplete(){
  const inp=document.getElementById('docSearch');
  const clr=document.getElementById('acClear');
  const dd=document.getElementById('acDropdown');
  window._SPS_RESULTS=[];

  // Focus: tampilkan semua items sesuai filter
  inp.addEventListener('focus',function(){
    if(this.value.length === 0){
      // Always refetch to respect current filter values
      window._SPS_RESULTS=[]; // Clear cache
      fetchAllSpsItems();
    }
  });

  // Input: real-time filter
  inp.addEventListener('input',function(){
    const v=this.value.trim();
    AC_SELECTED=null;
    clr.style.display=v?'inline-flex':'none';
    clearTimeout(AC_DEBOUNCE);
    
    if(window._SPS_RESULTS && window._SPS_RESULTS.length > 0){
      filterSpsItems(v); // Filter dari cache
    } else if(v.length > 0){
      AC_DEBOUNCE=setTimeout(()=>fetchAllSpsItems().then(()=>filterSpsItems(v)),200);
    } else {
      closeAcDropdown();
    }
  });

  inp.addEventListener('keydown',function(e){
    const items=dd.querySelectorAll('.ac-item');
    if(e.key==='ArrowDown'){e.preventDefault();AC_IDX=Math.min(AC_IDX+1,items.length-1);items.forEach((el,i)=>el.classList.toggle('highlighted',i===AC_IDX));}
    else if(e.key==='ArrowUp'){e.preventDefault();AC_IDX=Math.max(AC_IDX-1,0);items.forEach((el,i)=>el.classList.toggle('highlighted',i===AC_IDX));}
    else if(e.key==='Enter'){if(AC_IDX>=0&&window._DISPLAYED_RESULTS[AC_IDX]){selectSpsItem(AC_IDX);}else{loadChart();}}
    else if(e.key==='Escape'){closeAcDropdown();}
  });

  clr.addEventListener('click',function(){
    inp.value='';AC_SELECTED=null;AC_SELECTED_ITEM=null;this.style.display='none';
    document.getElementById('docSelect').innerHTML='<option value="">-- PILIH DOCUMENT --</option>';
    closeAcDropdown();inp.focus();
  });

  // Sinkron: saat user pilih dari dropdown kanan, update AC_SELECTED
  document.getElementById('docSelect').addEventListener('change',function(){
    AC_SELECTED=this.value||null;
  });

  document.addEventListener('click',function(e){
    if(!document.getElementById('acWrapper').contains(e.target))closeAcDropdown();
    if(!document.getElementById('dateFilterWrap').contains(e.target))closeDatePopup();
  });
})();

