  const inp=document.getElementById('docSearch');
  const clr=document.getElementById('acClear');
  const rawCode=(item.itemCode||'').trim();
  const rawDoc=(item.documentNumber||'').trim();
  const codeIsPlaceholder = !rawCode || ['-','--','---','N/A','NA'].includes(rawCode.toUpperCase());
  const displayCode = codeIsPlaceholder ? (rawDoc || 'ITEM') : rawCode;
