  lbl.textContent=s||e;
}

function setDatePreset(type){
  const now=new Date();
  const start=new Date(now);
  const end=new Date(now);

  if(type==='week'){
    const day=(now.getDay()+6)%7; // Monday as first day
    start.setDate(now.getDate()-day);
  }else if(type==='month'){
    start.setDate(1);
  }else if(type==='year'){
    start.setMonth(0,1);
  }

  document.getElementById('filterStartDate').value=toYMD(start);
  document.getElementById('filterEndDate').value=toYMD(end);
  updateDateLabel();
}

function clearDateFilter(){
  document.getElementById('filterStartDate').value='';
  document.getElementById('filterEndDate').value='';
  updateDateLabel();
  onSubFilterChanged();
}

function applyDateFilter(){
  const s=document.getElementById('filterStartDate').value;
  const e=document.getElementById('filterEndDate').value;
  if(s&&e&&s>e){
    showMsg('warning','Tanggal Tidak Valid','Tanggal mulai tidak boleh lebih besar dari tanggal selesai');
    return;
  }
  updateDateLabel();
  closeDatePopup();
  onSubFilterChanged();
}

