    }
    if(dimStd.innerThickness){
      console.log('[ChartAnalysis] Inner Thickness Standards:', {
        target: dimStd.innerThickness.target,
        min: dimStd.innerThickness.min,
        max: dimStd.innerThickness.max
      });
    }
    if(dimStd.totalThickness){
      console.log('[ChartAnalysis] Total Thickness Standards:', {
        target: dimStd.totalThickness.target,
        min: dimStd.totalThickness.min,
        max: dimStd.totalThickness.max
      });
    }
  } else {
    console.log('[ChartAnalysis] ⚠️ No dimension standards (dimStd is null)');
  }

  // TEMP INNER
  const stdL=(lbl,obj,len,cMx,cMn)=>{
    let r=[]; if(!obj||obj.target==null)return r;
    if(obj.max!=null)r.push({label:lbl+' Max',data:Array(len).fill(obj.max),borderColor:cMx,borderWidth:1,borderDash:[5,5],pointRadius:0,fill:false});
    if(obj.min!=null)r.push({label:lbl+' Min',data:Array(len).fill(obj.min),borderColor:cMn,borderWidth:1,borderDash:[5,5],pointRadius:0,fill:false});
    return r;
  };
  let dsTI=[{label:'Head Temp',data:rd.map(r=>r.headTempInner),borderColor:'#0088ff',borderWidth:2.5,pointRadius:3,tension:.3},
  {label:'Cyl1',data:rd.map(r=>r.cylinder1TempInner),borderColor:'#22d3ee',borderWidth:2,pointRadius:2,tension:.3},
  {label:'Cyl2',data:rd.map(r=>r.cylinder2TempInner),borderColor:'#a78bfa',borderWidth:2,pointRadius:2,tension:.3},
  {label:'Cyl3',data:rd.map(r=>r.cylinder3TempInner),borderColor:'#34d399',borderWidth:2,pointRadius:2,tension:.3},
  {label:'Screw',data:rd.map(r=>r.screwTempInner),borderColor:'#f472b6',borderWidth:2,pointRadius:2,tension:.3}];
  if(sp){dsTI.push(...stdL('HeadTemp',sp.headTemp1,len,'#ff4d4d','#fbbf24'));}
  makeChart('chartTempInner',labels,dsTI.filter(Boolean),'°C');

  // TEMP OUTER
  let dsTO=[{label:'Head Temp',data:rd.map(r=>r.headTempOuter),borderColor:'#0088ff',borderWidth:2.5,pointRadius:3,tension:.3},
  {label:'Cyl1',data:rd.map(r=>r.cylinder1TempOuter),borderColor:'#22d3ee',borderWidth:2,pointRadius:2,tension:.3},
  {label:'Cyl2',data:rd.map(r=>r.cylinder2TempOuter),borderColor:'#a78bfa',borderWidth:2,pointRadius:2,tension:.3},
  {label:'Cyl3',data:rd.map(r=>r.cylinder3TempOuter),borderColor:'#34d399',borderWidth:2,pointRadius:2,tension:.3},
  {label:'Screw',data:rd.map(r=>r.screwTempOuter),borderColor:'#f472b6',borderWidth:2,pointRadius:2,tension:.3}];
  if(sp){dsTO.push(...stdL('HeadTemp Outer',sp.headTemp2,len,'#ff4d4d','#fbbf24'));}
  makeChart('chartTempOuter',labels,dsTO.filter(Boolean),'°C');

  // SPEED
  let dsS=[{label:'ScrewSpd Inner',data:rd.map(r=>r.screwSpeedInner),borderColor:'#0088ff',borderWidth:2.5,pointRadius:3,tension:.3},
  {label:'ScrewSpd Outer',data:rd.map(r=>r.screwSpeedOuter),borderColor:'#22d3ee',borderWidth:2.5,pointRadius:3,tension:.3},
  {label:'Pressure Inner',data:rd.map(r=>r.pressureInner),borderColor:'#f472b6',borderWidth:2,pointRadius:2,tension:.3,yAxisID:'y1'},
  {label:'Pressure Outer',data:rd.map(r=>r.pressureOuter),borderColor:'#fbbf24',borderWidth:2,pointRadius:2,tension:.3,yAxisID:'y1'}];
  if(sp){dsS.push(...stdL('ScrewSpd1',sp.screwSpeed1,len,'#ff4d4d','#fbbf24'));dsS.push(...stdL('ScrewSpd2',sp.screwSpeed2,len,'#f472b6','#a78bfa'));}
  dsS=dsS.filter(Boolean);
  if(CHARTS['chartSpeed'])CHARTS['chartSpeed'].destroy();
  const ctxS=document.getElementById('chartSpeed');
  if(ctxS)CHARTS['chartSpeed']=new Chart(ctxS,{type:'line',data:{labels,datasets:dsS},options:{responsive:true,maintainAspectRatio:false,
  interaction:{mode:'index',intersect:false},
  plugins:{
    legend:{labels:{color:'#8b949e',font:{size:10,weight:'bold'}}},
    zoom:{
      pan:{enabled:true,mode:'xy',modifierKey:'shift'},
      zoom:{wheel:{enabled:true,speed:0.1},pinch:{enabled:true},mode:'xy'}
    }
  },
  scales:{
    x:{
      ticks:{
        color:'#8b949e',
        font:{size:9},
        maxRotation:45,
        minRotation:45,
        autoSkip:true,
        maxTicksLimit:20
      },
      grid:{color:'rgba(255,255,255,.03)'}
    },
    y:{title:{display:true,text:'RPM',color:'#8b949e'},ticks:{color:'#8b949e'},grid:{color:'rgba(255,255,255,.05)'}},
    y1:{position:'right',title:{display:true,text:'MPa',color:'#8b949e'},ticks:{color:'#8b949e'},grid:{display:false}}
  }}});

  // MACHINE
  let dsM=[{label:'Hose Speed',data:rd.map(r=>r.hoseSpeed),borderColor:'#0088ff',borderWidth:2.5,pointRadius:3,tension:.3}];
  if(sp){dsM.push(...stdL('HoseSpd',sp.hoseSpeed,len,'#ff4d4d','#fbbf24'));}
  dsM=dsM.filter(Boolean);
  makeChart('chartMachine',labels,dsM,'m/min');

  // DIM INNER
  const dimInnerLabels=(dim&&dim.innerDiameter&&dim.innerDiameter.length>0)?dim.innerDiameter.map(r=>r.label):labels;
  const dimInnerValues=(dim&&dim.innerDiameter&&dim.innerDiameter.length>0)?dim.innerDiameter.map(r=>r.value):rd.map(r=>r.innerDiameter);
  let dsDI=[{label:'Inner Diameter',data:dimInnerValues,borderColor:'#0088ff',borderWidth:2.5,pointRadius:4,tension:.3}];
  if(dimStd&&dimStd.innerDiameter){
    const s=dimStd.innerDiameter; const iLen=Math.max(dimInnerLabels.length,1);
    console.log('[ChartAnalysis] Rendering Inner Diameter lines:', {
      target: s.target, 
      min: s.min, 
      max: s.max, 
      ucl: s.ucl, 
      lcl: s.lcl,
      dataLength: iLen
    });
    if(s.target!=null)dsDI.push(stdLine('Target',s.target,iLen,'#22d3ee',[2,4]));
    if(s.max!=null)dsDI.push(stdLine('Max',s.max,iLen,'#ff4d4d',[5,5]));
    if(s.min!=null)dsDI.push(stdLine('Min',s.min,iLen,'#fbbf24',[5,5]));
    if(s.ucl!=null)dsDI.push(stdLine('UCL',s.ucl,iLen,'rgba(255,77,77,.4)',[3,3]));
    if(s.lcl!=null)dsDI.push(stdLine('LCL',s.lcl,iLen,'rgba(251,191,36,.4)',[3,3]));
  }
  dsDI=dsDI.filter(Boolean);makeChart('chartDimInner',dimInnerLabels,dsDI,'mm');



  // DIM TOTAL
  const dimTotalLabels=(dim&&((dim.totalThicknessX&&dim.totalThicknessX.length>0)||(dim.totalThicknessY&&dim.totalThicknessY.length>0)))
    ? ((dim.totalThicknessX&&dim.totalThicknessX.length>0)?dim.totalThicknessX:dim.totalThicknessY).map(r=>r.label)
    : labels;
  const dimTotalX=(dim&&dim.totalThicknessX&&dim.totalThicknessX.length>0)?dim.totalThicknessX.map(r=>r.value):rd.map(r=>r.totalThicknessX);
  const dimTotalY=(dim&&dim.totalThicknessY&&dim.totalThicknessY.length>0)?dim.totalThicknessY.map(r=>r.value):rd.map(r=>r.totalThicknessY);
  let dsDT=[{label:'Total Thick X',data:dimTotalX,borderColor:'#0088ff',borderWidth:2.5,pointRadius:4,tension:.3},
  {label:'Total Thick Y',data:dimTotalY,borderColor:'#22d3ee',borderWidth:2,pointRadius:3,tension:.3}];
  if(dimStd&&dimStd.totalThickness){
    const s=dimStd.totalThickness; const tLen=Math.max(dimTotalLabels.length,1);
    console.log('[ChartAnalysis] Rendering Total Thickness lines:', {
      target: s.target, 
      min: s.min, 
      max: s.max,
      dataLength: tLen
    });
    if(s.target!=null)dsDT.push(stdLine('Target',s.target,tLen,'#a78bfa',[2,4]));
    if(s.max!=null)dsDT.push(stdLine('Max',s.max,tLen,'#ff4d4d',[5,5]));
    if(s.min!=null)dsDT.push(stdLine('Min',s.min,tLen,'#fbbf24',[5,5]));
  }
  dsDT=dsDT.filter(Boolean);makeChart('chartDimTotal',dimTotalLabels,dsDT,'mm');
}

function evalParam(name,actual,stdObj){
  if(actual==null||actual==undefined)return null;
  const a=parseFloat(actual);if(isNaN(a))return null;
  if(!stdObj||stdObj.target==null)return{name,actual:a,standard:'—',lo:'—',hi:'—',status:'NO_STD'};
  const lo=stdObj.min, hi=stdObj.max, std=stdObj.target;
  const status=(lo!=null&&hi!=null)?(a>=lo&&a<=hi?'OK':'NG'):'OK';
  return{name,actual:a,standard:std,lo:lo!=null?lo.toFixed(1):'—',hi:hi!=null?hi.toFixed(1):'—',status};
}

function renderTable(){
  const sp=DATA.spsStandard||{};const ini=DATA.initials||{};const body=document.getElementById('cmpBody');
  const params=[
    ['Head Temp Inner',ini.initHeadTempInner,sp.headTemp1],
    ['Cyl1 Temp Inner',ini.initCylinder1TempInner,sp.cylinder1_1],
    ['Cyl2 Temp Inner',ini.initCylinder2TempInner,sp.cylinder2_1],
    ['Cyl3 Temp Inner',ini.initCylinder3TempInner,sp.cylinder3_1],
    ['Screw Temp Inner',ini.initScrewTempInner,sp.screwTemp1],
    ['Screw Speed Inner',ini.initScrewSpeedInner,sp.screwSpeed1],
    ['Pressure Inner',ini.initPressureInner,sp.pressure1],
    ['Feed Roll Inner',ini.initFeedRollRatioInner,sp.feedRollRatio1],
    ['—','—','—'],
    ['Head Temp Outer',ini.initHeadTempOuter,sp.headTemp2],
    ['Cyl1 Temp Outer',ini.initCylinder1TempOuter,sp.cylinder1_2],
    ['Cyl2 Temp Outer',ini.initCylinder2TempOuter,sp.cylinder2_2],
    ['Cyl3 Temp Outer',ini.initCylinder3TempOuter,sp.cylinder3_2],
    ['Screw Temp Outer',ini.initScrewTempOuter,sp.screwTemp2],
    ['Screw Speed Outer',ini.initScrewSpeedOuter,sp.screwSpeed2],
    ['Pressure Outer',ini.initPressureOuter,sp.pressure2],
    ['—','—','—'],
    ['Hose Speed',ini.initHoseSpeed,sp.hoseSpeed],
    ['Chiller Water Temp',ini.initChillerWaterTemp,sp.chillerWaterTemp],
    ['Caterpillar Gap',ini.initCaterpillarGap,sp.caterpillarGap],
  ];
  let html='';let alerts=[];
  params.forEach(([name,act,std])=>{
    if(name==='—'){html+=`<tr><td colspan="6" style="color:#484f58;font-weight:900;font-size:.7rem;letter-spacing:2px;text-align:center">── SEPARATOR ──</td></tr>`;return;}
    const ev=evalParam(name,act,std);
    if(!ev)return;
    const cls=ev.status==='OK'?'st-ok':ev.status==='NG'?'st-ng':'';
    const icon=ev.status==='OK'?'✅':ev.status==='NG'?'⚠️':'—';
    html+=`<tr><td style="font-weight:800">${ev.name}</td><td>${ev.standard}</td><td>${ev.lo}</td><td>${ev.hi}</td><td class="${cls}">${ev.actual}</td><td class="${cls}">${icon} ${ev.status}</td></tr>`;
    if(ev.status==='NG')alerts.push(`⚠️ ${ev.name}: ${ev.actual} (Batas: ${ev.lo} ~ ${ev.hi})`);
  });
  body.innerHTML=html;
  const az=document.getElementById('alertZone');const al=document.getElementById('alertList');
  if(alerts.length>0){az.style.display='block';al.innerHTML=alerts.map(a=>`<div class="alert-item">${a}</div>`).join('');}
  else{az.style.display='none';}
}

function switchTab(id,btn){
  document.querySelectorAll('.tab-pane').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('pane-'+id).classList.add('active');
  btn.classList.add('active');
}

