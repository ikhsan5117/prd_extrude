@{ Layout = "_Layout"; ViewData["Title"] = "Chart Analysis"; }

<style>
:root{--bg:#010409;--tile:rgba(21,27,38,.7);--accent:#0066ff;--glow:rgba(0,102,255,.4);--ok:#00ff88;--ng:#ff4d4d;--warn:#fbbf24;--border:rgba(255,255,255,.06)}
body{background:var(--bg);color:#e6edf3;font-family:'Outfit',sans-serif}
.ca-page{padding:20px 15px 60px; transition: all 0.3s ease;}
.ca-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:30px;border-bottom:1px solid var(--border);padding-bottom:25px}
.ca-title{font-size:2.8rem;font-weight:1000;letter-spacing:-2px;color:#fff;line-height:.9}
.ca-sub{color:#8b949e;font-size:.75rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;margin-top:10px}

/* ── MONITORING MODE (TV) ── */
body.monitoring-mode .sidebar, 
body.monitoring-mode .top-navbar,
body.monitoring-mode .ca-sub,
body.monitoring-mode .filter-row,
body.monitoring-mode .footer-content { display: none !important; }

body.monitoring-mode .main-content { margin: 0 !important; padding: 0 !important; width: 100vw; }
body.monitoring-mode .ca-page { padding: 30px 40px; max-width: 100%; }
body.monitoring-mode .ca-header { margin-bottom: 40px; padding-bottom: 30px; border-color: rgba(0,102,255,0.3); }
body.monitoring-mode .ca-title { font-size: 4rem; color: #38bdf8; text-shadow: 0 0 20px rgba(56,189,248,0.3); }
body.monitoring-mode .i-card { padding: 25px; border-width: 2px; }
body.monitoring-mode .i-lbl { font-size: 0.75rem; letter-spacing: 3px; }
body.monitoring-mode .i-val { font-size: 2rem; }
body.monitoring-mode .chart-card { padding: 30px; border-radius: 20px; border-width: 2px; }
body.monitoring-mode .chart-card h3 { font-size: 1.2rem; margin-bottom: 25px; color: #fff; }
body.monitoring-mode .chart-wrap { height: 500px !important; }
body.monitoring-mode .tab-btn { font-size: 1rem; padding: 15px 30px; border-radius: 12px; }

.tv-toggle-btn {
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(255,255,255,0.1);
    color: #94a3b8;
    padding: 8px 16px;
    border-radius: 8px;
    font-size: 0.7rem;
    font-weight: 800;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.2s;
    text-transform: uppercase;
    letter-spacing: 1px;
}
.tv-toggle-btn:hover { background: var(--accent); color: #fff; border-color: var(--accent); }
.tv-toggle-btn.active { background: #ef4444; color: #fff; border-color: #ef4444; }
.tv-toggle-btn.nav-btn { background: rgba(56, 189, 248, 0.15); color: #38bdf8; border-color: rgba(56, 189, 248, 0.3); }
.tv-toggle-btn.nav-btn:hover { background: #38bdf8; color: #fff; }

.nav-tile {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 12px; padding: 25px; background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1); border-radius: 16px;
    color: #fff; text-decoration: none; transition: all 0.2s;
    font-weight: 800; font-size: 0.85rem; letter-spacing: 1px;
}
.nav-tile i { font-size: 2.5rem; color: #38bdf8; }
.nav-tile:hover { background: var(--accent); transform: translateY(-5px); border-color: #fff; }
.nav-tile:hover i { color: #fff; }

.refresh-badge {
    position: fixed; top: 20px; right: 20px;
    background: rgba(16, 185, 129, 0.2);
    border: 1px solid rgba(16, 185, 129, 0.4);
    color: #10b981;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 0.65rem;
    font-weight: 900;
    display: none;
    align-items: center;
    gap: 8px;
    z-index: 10005;
    backdrop-filter: blur(10px);
}
.refresh-badge i { animation: spin 4s linear infinite; }
@@keyframes spin { from{transform:rotate(0)} to{transform:rotate(360deg)} }

.search-panel{display:grid;grid-template-columns:2fr 1fr auto;gap:15px;margin-bottom:30px}
.s-box{position:relative;display:flex;align-items:center;background:rgba(10,15,25,.8);border:1px solid rgba(255,255,255,.08);border-left:3px solid var(--accent);padding:0 15px;height:46px}
.s-box i{color:var(--accent);margin-right:12px;flex-shrink:0}
.s-box input,.s-box select{background:0 0;border:none;color:#fff;width:100%;height:100%;font-size:.8rem;font-weight:600;outline:0;text-transform:uppercase;letter-spacing:.5px}
.s-box select{cursor:pointer;color:#8b949e}
.s-box select option{background:#0d1117;color:#fff}
.btn-load{background:var(--accent);color:#fff;border:none;padding:0 28px;height:46px;font-weight:900;font-size:.75rem;letter-spacing:1px;cursor:pointer;transition:.3s}
.btn-load:hover{transform:translateY(-2px);box-shadow:0 8px 30px var(--glow)}
/* ── Autocomplete Dropdown ── */
.ac-wrap{position:relative;flex:1}
.ac-input{background:0 0;border:none;color:#fff;width:100%;height:100%;font-size:.8rem;font-weight:600;outline:0;text-transform:uppercase;letter-spacing:.5px}
.ac-clear{background:none;border:none;color:#484f58;cursor:pointer;padding:0 4px;font-size:.85rem;line-height:1;flex-shrink:0;transition:.2s}
.ac-clear:hover{color:#ff4d4d}
.ac-dropdown{position:absolute;top:calc(100% + 4px);left:-15px;right:0;background:#0d1117;border:1px solid rgba(0,102,255,.4);border-radius:8px;z-index:9999;max-height:280px;overflow-y:auto;box-shadow:0 12px 40px rgba(0,0,0,.7);display:none}
.ac-dropdown.open{display:block}
.ac-item{padding:10px 14px;cursor:pointer;transition:.15s;border-bottom:1px solid rgba(255,255,255,.04)}
.ac-item:hover,.ac-item.highlighted{background:rgba(0,102,255,.15)}
.ac-item-doc{font-size:.78rem;font-weight:900;color:#38bdf8;letter-spacing:.5px}
.ac-item-sub{font-size:.65rem;color:#8b949e;margin-top:2px;font-weight:600}
.ac-badge{display:inline-block;background:rgba(0,255,136,.1);border:1px solid rgba(0,255,136,.3);color:#00ff88;font-size:.55rem;font-weight:900;padding:1px 5px;border-radius:3px;margin-left:6px;letter-spacing:.5px;vertical-align:middle}
.ac-badge.no-data{background:rgba(255,77,77,.08);border-color:rgba(255,77,77,.3);color:#ff4d4d}
.ac-no-result{padding:16px 14px;text-align:center;color:#484f58;font-size:.75rem;font-weight:700}
.ac-loading{padding:14px;text-align:center;color:#8b949e;font-size:.7rem}
.info-cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:15px;margin-bottom:30px}
.i-card{padding:14px 18px;background:linear-gradient(145deg,rgba(21,27,38,.7),rgba(1,4,9,.8));border:1px solid rgba(255,255,255,.05);border-radius:2px}
.i-lbl{font-size:.5rem;font-weight:800;color:#484f58;text-transform:uppercase;letter-spacing:1.5px}
.i-val{font-size:1.1rem;font-weight:900;color:#fff;margin-top:2px}
.i-val.cyan{color:#00ccff}.i-val.yellow{color:#fbbf24}.i-val.green{color:#00ff88}.i-val.red{color:#ff4d4d}
.tab-bar{display:flex;gap:8px;margin-bottom:20px;border-bottom:1px solid var(--border);padding-bottom:10px}
.tab-btn{background:0 0;border:none;color:#64748b;font-size:.7rem;font-weight:800;padding:10px 20px;cursor:pointer;border-radius:8px;transition:.2s;text-transform:uppercase;letter-spacing:1px}
.tab-btn.active{background:rgba(0,102,255,.15);color:#38bdf8}
.tab-btn:hover:not(.active){background:rgba(255,255,255,.04);color:#e2e8f0}
.tab-pane{display:none}.tab-pane.active{display:block}
.chart-card{background:rgba(21,27,38,.4);border:1px solid var(--border);border-radius:12px;padding:20px;margin-bottom:20px;position:relative}
.chart-card h3{font-size:.7rem;font-weight:900;color:#8b949e;letter-spacing:2px;text-transform:uppercase;margin-bottom:15px;display:inline-block}
.chart-wrap{position:relative;height:300px}
.btn-reset-zoom{position:absolute;top:18px;right:20px;background:rgba(0,102,255,.1);border:1px solid rgba(0,102,255,.3);color:#38bdf8;font-size:.6rem;font-weight:900;padding:6px 12px;border-radius:6px;cursor:pointer;transition:.2s;letter-spacing:.5px;z-index:10}
.btn-reset-zoom:hover{background:#0066ff;color:#fff;transform:translateY(-1px)}
.btn-reset-zoom i{margin-right:4px}
.tbl-wrap{background:rgba(21,27,38,.4);border:1px solid var(--border);border-radius:12px;overflow-x:auto;margin-bottom:20px}
.cmp-table{width:100%;border-collapse:collapse;font-size:.8rem;min-width:700px}
.cmp-table th{padding:10px 14px;text-align:left;font-weight:900;font-size:.6rem;letter-spacing:1px;text-transform:uppercase;color:#8b949e;border-bottom:2px solid rgba(0,102,255,.3);white-space:nowrap}
.cmp-table td{padding:10px 14px;border-bottom:1px solid var(--border);white-space:nowrap}
.cmp-table tr:hover{background:rgba(0,102,255,.04)}
.st-ok{color:var(--ok);font-weight:900}.st-ng{color:var(--ng);font-weight:900}.st-warn{color:var(--warn);font-weight:900}
.alert-zone{background:rgba(255,77,77,.05);border:1px solid rgba(255,77,77,.2);border-radius:12px;padding:15px 20px;margin-bottom:20px}
.alert-zone h3{font-size:.65rem;font-weight:900;color:#ff4d4d;letter-spacing:2px;margin-bottom:10px}
.alert-item{font-size:.8rem;color:#ff9999;padding:4px 0;font-weight:600}
#noData{text-align:center;padding:80px 20px;color:#484f58;font-weight:900;font-size:1.2rem}
.legend-box{display:flex;gap:20px;margin-top:10px;font-size:.65rem;font-weight:700;color:#8b949e}
.legend-box span::before{content:'';display:inline-block;width:20px;height:3px;margin-right:6px;vertical-align:middle}
.leg-actual::before{background:#0088ff}.leg-upper::before{background:#ff4d4d;border-top:2px dashed #ff4d4d;height:0}.leg-lower::before{background:#fbbf24;border-top:2px dashed #fbbf24;height:0}
@@media(max-width:900px){.search-panel{grid-template-columns:1fr}.info-cards{grid-template-columns:repeat(2,1fr)}}

  /* ── Filter Row Styles ── */
  .filter-row{grid-column:span 3;display:flex;gap:10px;margin-top:15px;padding-top:15px;border-top:1px solid rgba(255,255,255,.05);align-items:center}
  .combined-filter-box{flex:1;display:grid;grid-template-columns:repeat(2,minmax(180px,1fr));background:rgba(15,23,42,.6);border:1px solid rgba(255,255,255,.1);height:38px;overflow:hidden}
  .combined-filter-box:focus-within{border-color:var(--accent);background:rgba(15,23,42,.9)}
  .mini-filter{display:flex;align-items:center;padding:0 10px;border-right:1px solid rgba(255,255,255,.08)}
  .mini-filter:last-child{border-right:none}
  .mini-filter i{color:#64748b;font-size:.8rem;margin-right:8px;flex-shrink:0}
  .mini-filter select{background:transparent;border:none;color:#fff;font-size:.68rem;font-weight:700;width:100%;height:100%;outline:none;text-transform:uppercase;letter-spacing:.45px}
  .mini-filter select option{background:#0d1117;color:#fff}
  .mini-filter select:invalid{color:#64748b}
  .btn-reset-f{background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);color:#ef4444;width:38px;height:38px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:.2s}
  .btn-reset-f:hover{background:#ef4444;color:#fff}

  /* ── Date Popup ── */
  .date-filter-wrap{position:relative;min-width:220px;max-width:220px}
  .btn-date-popup{width:100%;height:38px;display:flex;align-items:center;gap:8px;background:rgba(15,23,42,.6);border:1px solid rgba(255,255,255,.1);color:#e2e8f0;font-size:.72rem;font-weight:800;letter-spacing:.5px;padding:0 12px;cursor:pointer;transition:.2s;text-transform:uppercase}
  .btn-date-popup:hover{border-color:var(--accent);background:rgba(15,23,42,.9)}
  .btn-date-popup .date-pill{margin-left:auto;font-size:.6rem;color:#94a3b8;font-weight:700;text-transform:none}
  .date-popup{position:absolute;top:calc(100% + 8px);left:0;z-index:10050;width:360px;max-width:min(94vw,360px);background:#0f172a;border:1px solid rgba(255,255,255,.12);box-shadow:0 18px 50px rgba(0,0,0,.6);border-radius:10px;padding:14px;display:none}
  .date-popup.open{display:block}
  .dp-title{font-size:.78rem;color:#cbd5e1;font-weight:900;letter-spacing:.6px;margin-bottom:10px}
  .dp-sec-title{font-size:.65rem;color:#94a3b8;font-weight:800;letter-spacing:.5px;margin:8px 0 6px}
  .dp-preset-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:6px}
  .dp-preset-btn{height:30px;background:#1e293b;border:1px solid rgba(255,255,255,.12);color:#cbd5e1;font-size:.62rem;font-weight:800;cursor:pointer;border-radius:6px;transition:.2s}
  .dp-preset-btn:hover{background:#334155;border-color:#60a5fa}
  .dp-range{display:grid;grid-template-columns:1fr 1fr;gap:10px}
  .dp-input-wrap label{display:block;font-size:.62rem;color:#94a3b8;font-weight:800;margin-bottom:4px}
  .dp-input-wrap input{width:100%;height:32px;background:#111827;border:1px solid rgba(255,255,255,.14);color:#e2e8f0;padding:0 8px;border-radius:6px;font-size:.7rem}
  .dp-actions{display:flex;justify-content:flex-end;gap:8px;margin-top:12px}
  .dp-btn-clear,.dp-btn-apply{height:32px;min-width:86px;padding:0 12px;border-radius:7px;font-size:.68rem;font-weight:900;letter-spacing:.5px;border:1px solid transparent;cursor:pointer}
  .dp-btn-clear{background:#1f2937;border-color:rgba(255,255,255,.16);color:#cbd5e1}
  .dp-btn-apply{background:linear-gradient(90deg,#2563eb,#7c3aed);color:#fff}
  @@media(max-width:900px){.date-filter-wrap{min-width:100%;max-width:none}.date-popup{left:0;right:0;width:100%}.dp-preset-grid{grid-template-columns:repeat(2,1fr)}.combined-filter-box{grid-template-columns:1fr}}
</style>

<div class="refresh-badge" id="refreshBadge"><i class="bi bi-arrow-repeat"></i> AUTO-REFRESH ACTIVE</div>

<div class="ca-page">
<div class="ca-header">
    <div>
        <div class="ca-title">Chart Analysis</div>
        <div class="ca-sub">Production Parameter vs SPS Standard</div>
    </div>
    <div class="d-flex gap-2">
        <button class="tv-toggle-btn nav-btn" id="tvNavBtn" onclick="openQuickNav()" style="display:none">
            <i class="bi bi-grid-fill"></i> QUICK NAV
        </button>
        <button class="tv-toggle-btn" id="refreshToggle" onclick="toggleAutoRefresh()" title="Auto update data every 5 minutes">
            <i class="bi bi-clock-history"></i> AUTO-REFRESH: OFF
        </button>
        <button class="tv-toggle-btn" id="tvModeBtn" onclick="toggleTVMode()">
            <i class="bi bi-tv"></i> ENTER TV MODE
        </button>
    </div>
</div>

<div class="search-panel">
<!-- Autocomplete Search Box: Item Planning dari Dimension History -->
<div class="s-box" id="acWrapper">
  <i class="bi bi-upc-scan"></i>
  <div class="ac-wrap">
    <input id="docSearch" class="ac-input" placeholder="CARI ITEM PLANNING (TA2634, NA1470, ALO310...)" autocomplete="off" spellcheck="false" />
    <div id="acDropdown" class="ac-dropdown"></div>
  </div>
  <button class="ac-clear" id="acClear" title="Clear" style="display:none"><i class="bi bi-x-circle-fill"></i></button>
</div>
<!-- Dropdown: Production Report berdasarkan Item yang dipilih -->
<div class="s-box"><i class="bi bi-cpu"></i><select id="docSelect"><option value="">-- PILIH DOCUMENT --</option></select></div>
<button class="btn-load" onclick="loadChart()"><i class="bi bi-lightning-charge-fill"></i> LOAD</button>

<!-- Sub Filters -->
<div class="filter-row">
  <div class="date-filter-wrap" id="dateFilterWrap">
    <button class="btn-date-popup" type="button" onclick="toggleDatePopup()">
      <i class="bi bi-calendar-range" style="color:#38bdf8;"></i>
      FILTER TANGGAL
      <span class="date-pill" id="dateRangeLabel">ALL</span>
    </button>
    <div class="date-popup" id="datePopup">
      <div class="dp-title">Tanggal</div>

      <div class="dp-sec-title">Preset Cepat</div>
      <div class="dp-preset-grid">
        <button type="button" class="dp-preset-btn" onclick="setDatePreset('today')">Hari Ini</button>
        <button type="button" class="dp-preset-btn" onclick="setDatePreset('week')">Minggu Ini</button>
        <button type="button" class="dp-preset-btn" onclick="setDatePreset('month')">Bulan Ini</button>
        <button type="button" class="dp-preset-btn" onclick="setDatePreset('year')">Tahun Ini</button>
      </div>

      <div class="dp-sec-title">Rentang Tanggal</div>
      <div class="dp-range">
        <div class="dp-input-wrap">
          <label>Dari</label>
          <input type="date" id="filterStartDate">
        </div>
        <div class="dp-input-wrap">
          <label>Sampai</label>
          <input type="date" id="filterEndDate">
        </div>
      </div>

      <div class="dp-actions">
        <button type="button" class="dp-btn-clear" onclick="clearDateFilter()">Clear</button>
        <button type="button" class="dp-btn-apply" onclick="applyDateFilter()">Apply</button>
      </div>
    </div>
  </div>
  <div class="combined-filter-box">
    <div class="mini-filter">
      <i class="bi bi-clock"></i>
      <select id="filterShift" onchange="onSubFilterChanged()">
        <option value="">SHIFT ALL</option>
        <option value="Shift 1">SHIFT 1</option>
        <option value="Shift 2">SHIFT 2</option>
        <option value="Shift 3">SHIFT 3</option>
      </select>
    </div>
    <div class="mini-filter">
      <i class="bi bi-person-badge"></i>
      <select id="filterPic" onchange="onSubFilterChanged()">
        <option value="">PIC / OPERATOR ALL</option>
      </select>
    </div>
  </div>
  <button class="btn-reset-f" onclick="resetFilters()" title="Reset Filters"><i class="bi bi-arrow-counterclockwise"></i></button>
</div>
</div>

<div id="noData"><i class="bi bi-bar-chart-line" style="font-size:3rem;display:block;margin-bottom:10px"></i>PILIH DOCUMENT UNTUK MEMUAT DATA</div>

<div id="chartMainContent" style="display:none">
<div class="info-cards" id="infoCards"></div>

<div class="tab-bar">
<button class="tab-btn" onclick="switchTab('temp',this)" style="display:none">Temperature</button>
<button class="tab-btn" onclick="switchTab('speed',this)" style="display:none">Speed / Pressure</button>
<button class="tab-btn active" onclick="switchTab('dim',this)">Dimension</button>
<button class="tab-btn" onclick="switchTab('table',this)" style="display:none">Detail Table</button>
</div>

<div id="pane-temp" class="tab-pane">
<div class="chart-card"><h3>Inner (Material 1) — Head / Cylinder / Screw Temperature</h3><button class="btn-reset-zoom" onclick="resetZoom('chartTempInner')"><i class="bi bi-arrow-counterclockwise"></i>RESET ZOOM</button><div class="chart-wrap"><canvas id="chartTempInner"></canvas></div>
<div class="legend-box"><span class="leg-actual">Actual (solid)</span><span class="leg-upper">Batas Atas (dashed)</span><span class="leg-lower">Batas Bawah (dashed)</span></div></div>
<div class="chart-card"><h3>Outer (Material 2) — Head / Cylinder / Screw Temperature</h3><button class="btn-reset-zoom" onclick="resetZoom('chartTempOuter')"><i class="bi bi-arrow-counterclockwise"></i>RESET ZOOM</button><div class="chart-wrap"><canvas id="chartTempOuter"></canvas></div></div>
</div>

<div id="pane-speed" class="tab-pane">
<div class="chart-card"><h3>Screw Speed &amp; Pressure — Inner vs Outer</h3><button class="btn-reset-zoom" onclick="resetZoom('chartSpeed')"><i class="bi bi-arrow-counterclockwise"></i>RESET ZOOM</button><div class="chart-wrap"><canvas id="chartSpeed"></canvas></div></div>
<div class="chart-card"><h3>Hose Speed &amp; Machine Parameters</h3><button class="btn-reset-zoom" onclick="resetZoom('chartMachine')"><i class="bi bi-arrow-counterclockwise"></i>RESET ZOOM</button><div class="chart-wrap"><canvas id="chartMachine"></canvas></div></div>
</div>

<div id="pane-dim" class="tab-pane active">
<div class="chart-card"><h3>Inner Diameter — SPC Chart</h3><button class="btn-reset-zoom" onclick="resetZoom('chartDimInner')"><i class="bi bi-arrow-counterclockwise"></i>RESET ZOOM</button><div class="chart-wrap"><canvas id="chartDimInner"></canvas></div></div>
<div class="chart-card"><h3>Total Thickness — SPC Chart</h3><button class="btn-reset-zoom" onclick="resetZoom('chartDimTotal')"><i class="bi bi-arrow-counterclockwise"></i>RESET ZOOM</button><div class="chart-wrap"><canvas id="chartDimTotal"></canvas></div></div>
</div>

<div id="pane-table" class="tab-pane">
<div id="alertZone" class="alert-zone" style="display:none"><h3><i class="bi bi-exclamation-triangle-fill"></i> OUT-OF-SPEC ALERTS</h3><div id="alertList"></div></div>
<div class="tbl-wrap"><table class="cmp-table"><thead><tr><th>Parameter</th><th>Standard</th><th>Batas Bawah</th><th>Batas Atas</th><th>Actual (Initial)</th><th>Status</th></tr></thead><tbody id="cmpBody"></tbody></table></div>
</div>
</div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<script src="https://cdn.jsdelivr.net/npm/hammerjs@2.0.8"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-zoom@2.0.1/dist/chartjs-plugin-zoom.min.js"></script>
<script>
let DATA=null, CHARTS={};
const P=v=>{if(!v)return null;let s=String(v);if(s.includes('~')){let p=s.split('~').map(Number);return(p[0]+p[1])/2}return parseFloat(s)||null};
const RANGE=v=>{if(!v)return null;let s=String(v);if(s.includes('~'))return s.split('~').map(Number);return null};
const toYMD=d=>{const x=new Date(d);x.setMinutes(x.getMinutes()-x.getTimezoneOffset());return x.toISOString().slice(0,10)};

// ── Autocomplete State (SPS Item List → Production Report) ──
let AC_IDX=-1, AC_DEBOUNCE=null, AC_SELECTED=null, AC_SELECTED_ITEM=null;
let REFRESH_TIMER = null;

// TV Mode State
function toggleTVMode() {
    const isTV = document.body.classList.toggle('monitoring-mode');
    const btn = document.getElementById('tvModeBtn');
    const navBtn = document.getElementById('tvNavBtn');
    
    if (isTV) {
