async function fetchAllSpsItems(){
  renderAcItems(null,true);
  try{
    // Ambil filter values saat ini
    const startDate=document.getElementById('filterStartDate').value;
    const endDate=document.getElementById('filterEndDate').value;
    const shift=document.getElementById('filterShift').value;
    const pic=document.getElementById('filterPic').value;
    
    const params=new URLSearchParams({
      query: '',
      startDate: startDate,
      endDate: endDate,
      shift: shift,
      pic: pic
    });
    console.log('[ChartAnalysis] Fetching items with params:', Object.fromEntries(params));
    const r=await fetch(`/ProductionReport/SearchSpsItems?${params.toString()}`);
    console.log('[ChartAnalysis] Response status:', r.status);
    const d=await r.json();
