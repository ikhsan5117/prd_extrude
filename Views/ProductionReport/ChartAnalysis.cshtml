// Populate dropdown kanan dengan daftar dokumen
function populateDocSelect(docs,autoSelect=false){
  const sel=document.getElementById('docSelect');
  if(!docs||docs.length===0){
    sel.innerHTML='<option value="">-- TIDAK ADA DOKUMEN --</option>';
    AC_SELECTED=null;
    return;
  }
  sel.innerHTML='<option value="">-- PILIH DOCUMENT --</option>';
  docs.forEach(x=>{
    const cnt=x.readingsCount>0?` [${x.readingsCount} data]`:' [no data]';
    sel.innerHTML+=`<option value="${x.documentNumber}">${x.documentNumber} | ${x.hoseType||'-'} | ${x.shift||'-'} | ${x.date||'-'}${cnt}</option>`;
  });
  if(autoSelect){
    const first=docs.find(x=>x.readingsCount>0)||docs[0];
    if(first){
      sel.value=first.documentNumber;
      AC_SELECTED=first.documentNumber;
    }
  }else{
    sel.value='';
    AC_SELECTED=null;
  }
}

// Set value autocomplete setelah item SPS dipilih
