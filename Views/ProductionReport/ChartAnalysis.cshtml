async function loadChart(){
  const selVal=document.getElementById('docSelect').value;
  const startDate=document.getElementById('filterStartDate').value;
  const endDate=document.getElementById('filterEndDate').value;
  const shift=document.getElementById('filterShift').value;
  const pic=document.getElementById('filterPic').value;
  // Prioritaskan AC_SELECTED (dari autocomplete), fallback ke select dropdown
  const doc=AC_SELECTED||selVal;
  if(!doc){showMsg('warning','Pilih Document','Pilih atau cari No. Document terlebih dahulu');return;}
  
  const nd=document.getElementById('noData');
  const mc=document.getElementById('chartMainContent');
  nd.innerHTML='<i class="bi bi-hourglass-split" style="font-size:3rem;display:block;margin-bottom:10px;animation:spin 1s linear infinite"></i>MEMUAT DATA...';
  nd.style.display='block';
  mc.style.display='none';
  
  try{
    console.log('[ChartAnalysis] Loading doc:', doc, 'with filters:', { startDate, endDate, shift, pic });
    const p=new URLSearchParams({ documentNumber: doc });
    if(startDate)p.set('startDate',startDate);
    if(endDate)p.set('endDate',endDate);
    if(shift)p.set('shift',shift);
    if(pic)p.set('pic',pic);
    
    // Pass the searched itemCode to the backend for strict SPC trend filtering
    if(window.AC_SELECTED_ITEM && window.AC_SELECTED_ITEM.itemCode){
      p.set('itemCode', window.AC_SELECTED_ITEM.itemCode);
    }
    
    const r=await fetch('/ProductionReport/GetChartData?'+p.toString());
    if(!r.ok){showMsg('error','HTTP Error','Status: '+r.status);nd.innerHTML='<i class="bi bi-bar-chart-line" style="font-size:3rem;display:block;margin-bottom:10px"></i>GAGAL MEMUAT DATA';return;}
    DATA=await r.json();
    console.log('[ChartAnalysis] Response:', DATA);
    if(!DATA.success){showMsg('error','Tidak Ditemukan',DATA.message||'Document tidak ditemukan');nd.innerHTML='<i class="bi bi-x-circle" style="font-size:3rem;display:block;margin-bottom:10px;color:#ff4d4d"></i>'+( DATA.message||'DOCUMENT TIDAK DITEMUKAN');return;}
    nd.style.display='none';
    mc.style.display='block';
    renderInfo();renderCharts();renderTable();

    // ── Popup peringatan jika SPS tidak ditemukan ──
    if(!DATA.spsFound){
      mc.style.display='none';
      nd.style.display='block';
      nd.innerHTML='<i class="bi bi-exclamation-triangle-fill" style="font-size:3rem;display:block;margin-bottom:10px;color:#f59e0b"></i>SPS TIDAK DITEMUKAN<br><small style="font-size:.8rem;color:#8b949e">Analisis dibatalkan karena tidak ada batas standar (SPS)</small>';

      const rp=DATA.report||{};
      Swal.fire({
        icon:'warning',
        title:'⚠️ SPS Tidak Ditemukan',
        html:`
          <div style="text-align:left;font-size:.85rem;line-height:1.8;">
            <p>Standard Parameter Setting (SPS) <b>tidak ditemukan</b> untuk dokumen ini.</p>
            <table style="width:100%;border-collapse:collapse;margin:10px 0;font-size:.8rem;">
              <tr><td style="color:#94a3b8;padding:3px 8px 3px 0">Document</td><td style="font-weight:900;color:#38bdf8">${rp.documentNumber||'—'}</td></tr>
              <tr><td style="color:#94a3b8;padding:3px 8px 3px 0">Hose Type</td><td style="font-weight:900;color:#fbbf24">${rp.hoseType||'—'}</td></tr>
              <tr><td style="color:#94a3b8;padding:3px 8px 3px 0">VIN / Item</td><td style="font-weight:900;color:#fff">${rp.vinCode||'—'}</td></tr>
            </table>
            <p style="color:#94a3b8;font-size:.78rem;">⚡ Analisis tidak dapat dilanjutkan tanpa batas standar. Pastikan data SPS sudah diinput di <b>SPS Master</b>.</p>
          </div>`,
        background:'#0d1117',
        color:'#e6edf3',
        confirmButtonText:'Tutup',
        confirmButtonColor:'#f59e0b',
        showCloseButton:true
      });
      return;
    }

    if((DATA.readings||[]).length===0){showMsg('info','Data Tersedia','Report ditemukan tapi belum ada data readings (interval). Tabel comparison tetap ditampilkan dari data initial.');}
  }catch(e){
    console.error('[ChartAnalysis] Error:', e);
    showMsg('error','Gagal Memuat',e.message||'Network error');
    nd.innerHTML='<i class="bi bi-wifi-off" style="font-size:3rem;display:block;margin-bottom:10px;color:#ff4d4d"></i>ERROR: '+e.message;
  }
}

