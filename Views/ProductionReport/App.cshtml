@model VelastoProductionSystem.Models.ProductionReport

@{
    Layout = "_Layout";
    ViewData["Title"] = "Extruder Production Report";
}

@Html.AntiForgeryToken()

@section Styles {
    <style>
        :root {
            --primary-bg: #0f172a;
            --secondary-bg: #1e293b;
            --tertiary-bg: #334155;
            --accent-blue: #3b82f6;
            --accent-light: #60a5fa;
            --text-primary: #e2e8f0;
            --text-secondary: #94a3b8;
            --border-color: #3b82f6;
            --success-green: #10b981;
            --warning-yellow: #f59e0b;
            --danger-red: #ef4444;
        }

        /* Adjustments for Layout Integration */
        .app-container {
            width: 100%;
            max-width: 1400px;
            margin: 0 auto;
            padding: 20px;
        }
        
        .app-header, .content-card {
            backdrop-filter: blur(10px);
        }

        /* Header Styles */
        .app-header {
            background: linear-gradient(135deg, rgba(15, 23, 42, 0.8) 0%, rgba(30, 41, 59, 0.9) 50%, rgba(51, 65, 85, 0.8) 100%);
            border: 2px solid var(--accent-blue);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
            box-shadow: 0 8px 32px rgba(59, 130, 246, 0.2);
        }

        .header-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .header-logo {
            display: flex;
            align-items: center;
        }

        .header-logo-v {
            width: 50px;
            height: 50px;
            background: var(--accent-blue);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 12px;
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
        }

        .header-logo-v span {
            font-weight: 900;
            font-size: 24px;
            color: white;
        }

        .header-logo-text .velasto {
            font-weight: 900;
            font-size: 18px;
            color: var(--accent-light);
            letter-spacing: 1px;
        }

        .header-logo-text .indonesia {
            font-size: 10px;
            color: var(--text-secondary);
            border-bottom: 1px solid var(--accent-blue);
            padding-bottom: 2px;
            margin-top: 2px;
        }

        .header-title {
            text-align: center;
            flex: 1;
        }

        .header-title h1 {
            font-size: 20px;
            font-weight: 900;
            margin: 0;
            color: #f1f5f9;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .header-title h2 {
            font-size: 14px;
            font-weight: 500;
            margin: 4px 0 0 0;
            color: var(--accent-blue);
        }

        .signature-section {
            display: flex;
            gap: 10px;
        }

        .signature-table {
            width: 200px;
            border: 1px solid var(--accent-blue);
            border-collapse: collapse;
            font-size: 10px;
            background: rgba(59, 130, 246, 0.1);
        }

        .signature-table th {
            border: 1px solid var(--accent-blue);
            padding: 6px;
            background: var(--accent-blue);
            color: white;
            font-weight: bold;
            text-align: center;
        }

        .signature-table td {
            border: 1px solid var(--accent-blue);
            height: 45px;
            text-align: center;
            color: var(--accent-light);
            font-weight: bold;
            background: rgba(15, 23, 42, 0.5);
        }

        .header-info-row {
            display: flex;
            justify-content: space-between;
            font-size: 11px;
            padding: 10px 0;
            border-top: 1px solid var(--accent-blue);
            border-bottom: 1px solid var(--accent-blue);
            flex-wrap: wrap;
            gap: 10px;
        }

        .header-info-row div {
            min-width: 120px;
        }

        .header-info-row span {
            color: var(--accent-light);
            font-weight: bold;
        }

        .product-info-row {
            display: flex;
            justify-content: space-between;
            font-size: 11px;
            padding-top: 10px;
            flex-wrap: wrap;
            gap: 10px;
        }

        .product-info-row div {
            min-width: 120px;
        }

        .product-info-row span {
            color: var(--accent-light);
            font-weight: bold;
        }

        /* Content Sections */
        .main-content {
            display: flex;
            flex-direction: column;
            gap: 25px;
        }

        .content-card {
            background: rgba(30, 41, 59, 0.5);
            border: 1px solid rgba(59, 130, 246, 0.2);
            border-radius: 12px;
            padding: 25px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
            position: relative;
            overflow: hidden;
        }

        .content-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
            background: var(--accent-blue);
            opacity: 0.6;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            border-bottom: 1px solid rgba(59, 130, 246, 0.1);
            padding-bottom: 15px;
        }

        .card-title {
            font-size: 18px;
            font-weight: 700;
            margin: 0;
            color: var(--accent-light);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* Data Tables */
        .data-table-container {
            overflow-x: auto;
            border-radius: 8px;
            border: 1px solid rgba(59, 130, 246, 0.1);
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        .data-table th, .data-table td {
            border: 1px solid rgba(59, 130, 246, 0.2);
            padding: 12px 10px;
            text-align: center;
        }

        .data-table th {
            background: rgba(30, 41, 59, 0.8);
            color: var(--accent-light);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 11px;
            letter-spacing: 0.5px;
        }

        .point-name {
            background: rgba(30, 41, 59, 0.9);
            color: var(--text-primary);
            font-weight: 700;
            text-align: left !important;
            padding-left: 15px !important;
        }

        .std-dimension {
            background: rgba(59, 130, 246, 0.05);
            color: var(--warning-yellow);
            font-weight: 700;
        }

        /* Form Inputs */
        .simple-production-data {
            display: flex;
            flex-direction: column;
            gap: 15px;
            padding: 20px;
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.05) 0%, rgba(16, 185, 129, 0.05) 100%);
            border-radius: 12px;
            border: 1px solid rgba(59, 130, 246, 0.2);
        }

        .data-row {
            display: flex;
            gap: 25px;
            align-items: stretch;
            margin-bottom: 10px;
        }

        .data-item {
            display: flex;
            flex-direction: column;
            gap: 8px;
            flex: 1;
            min-width: 0;
        }

        .data-item.full-width {
            flex: 1;
        }

        .data-item .label {
            font-size: 11px;
            font-weight: 600;
            color: var(--accent-blue);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 6px 10px;
            background: rgba(59, 130, 246, 0.1);
            border: 1px solid rgba(59, 130, 246, 0.2);
            border-radius: 6px;
        }

        .data-item .value {
            font-size: 12px;
            font-weight: 600;
            color: #e2e8f0;
            padding: 8px 12px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 6px;
            min-height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .simple-input {
            font-size: 12px;
            font-weight: 600;
            color: #e2e8f0;
            padding: 8px 12px;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(59, 130, 246, 0.3);
            border-radius: 6px;
            transition: all 0.3s ease;
            width: 100%;
        }

        .simple-input:focus {
            outline: none;
            border-color: var(--accent-blue);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
            background: rgba(255, 255, 255, 0.12);
        }

        /* QTY Selector Toggle */
        .qty-toggle-container {
            display: flex;
            flex-direction: column;
            gap: 10px;
            width: 100%;
        }

        .qty-toggle-buttons {
            display: flex;
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(59, 130, 246, 0.3);
            border-radius: 8px;
            padding: 4px;
            gap: 4px;
        }

        .qty-toggle-btn {
            flex: 1;
            padding: 8px;
            border: 1px solid transparent;
            border-radius: 6px;
            background: transparent;
            color: var(--text-secondary);
            font-size: 11px;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            transition: all 0.3s ease;
        }

        .qty-toggle-btn.active {
            background: rgba(59, 130, 246, 0.2);
            border-color: var(--accent-light);
            color: var(--accent-light);
        }

        .qty-toggle-btn.ok-btn.active {
            background: rgba(16, 185, 129, 0.2);
            border-color: var(--success-green);
            color: var(--success-green);
        }

        .qty-toggle-btn.ng-btn.active {
            background: rgba(239, 68, 68, 0.2);
            border-color: var(--danger-red);
            color: var(--danger-red);
        }

        .qty-input-section {
            display: none;
        }

        .qty-input-section.active {
            display: block;
        }

        .qty-main-input {
            width: 100%;
            font-size: 14px;
            font-weight: 600;
            color: var(--text-primary);
            padding: 8px 12px;
            background: rgba(15, 23, 42, 0.5);
            border: 1px solid rgba(59, 130, 246, 0.3);
            border-radius: 3px;
            text-align: center;
        }

        .ng-inputs {
            display: flex;
            gap: 8px;
        }

        .ng-input-group {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .ng-input-group label {
            font-size: 9px;
            font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase;
            text-align: center;
        }

        .ng-input {
            width: 100%;
            font-size: 13px;
            font-weight: 600;
            color: var(--text-primary);
            padding: 6px 4px;
            background: rgba(15, 23, 42, 0.5);
            border: 1px solid rgba(59, 130, 246, 0.3);
            border-radius: 3px;
            text-align: center;
        }

        /* Action Buttons */
        .action-buttons {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin-top: 10px;
            flex-wrap: wrap;
        }

        .btn-app {
            padding: 12px 25px;
            border-radius: 8px;
            font-weight: 700;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
            border: none;
        }

        .btn-primary { background: var(--accent-blue); color: white; }
        .btn-success { background: var(--success-green); color: white; }
        .btn-warning { background: var(--warning-yellow); color: white; }

        .btn-app:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.4);
        }

        /* Responsive Tablet */
        @@media (max-width: 1366px) {
            .app-container { padding: 10px 0; }
            .data-table { font-size: 11px; }
            .data-table th { font-size: 9px; padding: 6px 2px; }
            .data-table td { font-size: 10px; padding: 4px 2px; }
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .fade-in {
            animation: fadeIn 0.6s ease-out;
        }
    </style>
}

<div class="app-container">
    <div class="app-header fade-in">
        <!-- Header Top -->
        <div class="header-top">
            <div class="header-logo">
                <div class="header-logo-v"><span>V</span></div>
                <div class="header-logo-text">
                    <div class="velasto">VELASTO</div>
                    <div class="indonesia">INDONESIA</div>
                </div>
            </div>
            <div class="header-title">
                <h1>EXTRUDER PRODUCTION REPORT</h1>
                <h2>( DIMENSION )</h2>
            </div>
            <div class="signature-section">
                <table class="signature-table">
                    <thead>
                        <tr>
                            <th>APPROVED</th>
                            <th>CHECKED</th>
                            <th>PREPARED</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>SPV</td>
                            <td>LDR</td>
                            <td>OPR</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
                
        <!-- Document Info -->
        <div class="header-info-row">
            <div><span>NO DOC :</span> @Model.DocumentNumber</div>
            <div><span>REVISI :</span> @Model.RevisionNumber</div>
            <div><span>DATE :</span> @Model.ProductionDate.ToString("dd/MMM/yyyy")</div>
            <div><span>SHIFT :</span> @Model.Shift</div>
        </div>
        
        <!-- Product Info -->
        <div class="product-info-row">
            <div><span>CUSTOMER :</span> @Model.CustomerName</div>
            <div><span>TYPE :</span> @Model.HoseType</div>
            <div><span>HOSE :</span> @Model.Dimension</div>
            <div><span>WIRE :</span> @Model.Yarn</div>
            <div><span>BY PASS :</span> 2.5 mm</div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <!-- Dimension Data Card -->
        <div class="content-card fade-in">
            <div class="card-header">
                <h3 class="card-title">Dimension Measurements</h3>
                <div>
                    <span class="status-indicator status-ok"></span>
                    <span style="font-size: 12px; color: var(--text-secondary);">System Active</span>
                </div>
            </div>
            
            <div class="data-table-container">
                <table class="data-table">
                    <thead>
                        <tr style="background: rgba(59, 130, 246, 0.15); color: #60a5fa; font-size: 10px;">
                            <th colspan="4" class="py-1 border-bottom border-primary border-opacity-25 tracking-widest fw-black text-center text-uppercase">PUKUL / JAM</th>
                            @for(int i=0; i<6; i++) {
                                <th class="p-0 border border-primary border-opacity-25" style="height: 25px;">
                                    <input type="text" class="w-100 h-100 border-0 text-center bg-transparent text-info fw-bold" style="font-size: 10px;" placeholder="00:00" />
                                </th>
                            }
                        </tr>
                        <tr style="background: rgba(30, 41, 59, 0.7); color: #94a3b8; font-size: 9px;">
                            <th class="p-2 border border-primary border-opacity-25 align-middle">POINT</th>
                            <th class="p-2 border border-primary border-opacity-25 align-middle">FREKUENSI</th>
                            <th class="p-2 border border-primary border-opacity-25 align-middle">STD DIMENSI</th>
                            <th class="p-2 border border-primary border-opacity-25 align-middle" style="width: 70px;">SCALE</th>
                            <th class="p-1 border border-primary border-opacity-25" style="width: 75px;">INITIAL</th>
                            @for(int i=1; i<=5; i++) {
                                <th class="p-1 border border-primary border-opacity-25">@i</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var stdVal = Model.StandardParameterSetting;
                            var master = (VelastoProductionSystem.Models.MasterlistSpsDoubleLayer)ViewBag.Masterlist;

                            // Helper to parse string to decimal
                            decimal D(string s, decimal def) => decimal.TryParse(s, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out decimal v) ? v : def;
                            
                            // Override standards if masterlist is present and std is null/zero
                            decimal idNom = stdVal?.InnerDie > 0 ? stdVal.InnerDie : (master != null ? D(master.Dimensi, 11.0m) : 11.0m);
                            decimal idTol = stdVal?.ToleranceDie > 0 ? stdVal.ToleranceDie : (master != null ? D(master.ToleranceInner, 0.2m) : 0.2m);
                            decimal tubeNom = stdVal?.TubeDie > 0 ? stdVal.TubeDie : (master != null ? D(master.TebalInner, 1.8m) : 1.8m);
                            decimal tubeTol = stdVal?.Tol_TubeDie > 0 ? stdVal.Tol_TubeDie : 0.2m;
                            decimal coverNom = stdVal?.CoverDie > 0 ? stdVal.CoverDie : (master != null ? D(master.TebalTotal, 3.3m) : 3.3m);
                            decimal coverTol = stdVal?.Tol_CoverDie > 0 ? stdVal.Tol_CoverDie : (master != null ? D(master.ToleranceOuter, 0.2m) : 0.2m);

                            var sections = new[] {
                                new { Label = "Inner Diameter", Nom = idNom, Tol = idTol },
                                new { Label = "In Thick (X)", Nom = tubeNom, Tol = tubeTol },
                                new { Label = "In Thick (Y)", Nom = tubeNom, Tol = tubeTol },
                                new { Label = "Total Thick (X)", Nom = coverNom, Tol = coverTol },
                                new { Label = "Total Thick (Y)", Nom = coverNom, Tol = coverTol }
                            };
                        }

                        @foreach(var sec in sections) {
                            for(int rIdx=0; rIdx<5; rIdx++) {
                                decimal scaleValue = sec.Nom + (sec.Tol - (sec.Tol * 0.5m * rIdx));
                                <tr style="height: 22px; border-bottom: 1px solid rgba(59, 130, 246, 0.1);">
                                    @if(rIdx == 0) {
                                        <td rowspan="5" class="point-name align-middle p-1" style="font-size: 10px;">@sec.Label</td>
                                        <td rowspan="5" class="align-middle border-end border-primary border-opacity-25" style="font-size: 8px;">30m Sekali</td>
                                        <td rowspan="5" class="std-dimension align-middle border-end border-primary border-opacity-25" style="font-size: 10px;">@sec.Nom.ToString("0.0") ± @sec.Tol.ToString("0.0")</td>
                                    }
                                    <td class="border-end border-primary border-opacity-25" style="font-size: 9px; color: #94a3b8; background: rgba(255,255,255,0.02);">@scaleValue.ToString("0.00")</td>
                                    @for(int h=0; h<6; h++) {
                                        <td style="padding: 0;"><input type="text" class="w-100 h-100 border-0 text-center" style="background: transparent; color: white; font-size: 11px;" placeholder="-" /></td>
                                    }
                                </tr>
                            }
                        }

                        <!-- Spiral & Visual -->
                        <tr style="height: 40px;">
                            <td class="point-name align-middle">Spiral Pitch</td>
                            <td class="align-middle">30m Sekali</td>
                            <td class="std-dimension align-middle">@(stdVal?.SpiralPitch ?? 38) ± @(stdVal?.Tol_SpiralPitch ?? 5)</td>
                            <td style="background: rgba(255,255,255,0.05); font-size: 10px;">NOM</td>
                            @for(int h=0; h<6; h++) {
                                <td style="padding: 0;"><input type="text" class="w-100 h-100 border-0 text-center" style="background: transparent; color: white; font-size: 12px; font-weight: bold;" placeholder="-" /></td>
                            }
                        </tr>
                        <tr style="height: 45px;">
                            <td class="point-name align-middle">Visual Check</td>
                            <td class="align-middle">30m Sekali</td>
                            <td colspan="2" class="align-middle" style="font-size: 9px; color: #94a3b8; text-align: left; padding-left: 10px;">No Burry, No Line, No Bubble, No Scratch</td>
                            @for(int h=0; h<6; h++) {
                                <td style="padding: 0;"><input type="text" class="w-100 h-100 border-0 text-center" style="background: transparent; color: white; font-size: 12px; font-weight: bold;" placeholder="-" /></td>
                            }
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        
        <!-- Production Data Card -->
        <div class="content-card fade-in">
            <div class="card-header">
                <h3 class="card-title">Production Data</h3>
            </div>
            
            <div class="simple-production-data">
                <div class="data-row">
                    <div class="data-item">
                        <span class="label">PART NUMBER</span>
                        <span class="value">@(Model.StandardParameterSetting?.ProductCode ?? "-")</span>
                    </div>
                    <div class="data-item">
                        <span class="label">VIN KODE</span>
                        <input type="text" value="@Model.VinCode" placeholder="Enter VIN Code" class="simple-input" />
                    </div>
                </div>
                
                <div class="data-row">
                    <div class="data-item">
                        <span class="label">STD PNJG</span>
                        <span class="value">@Model.StandardLength</span>
                    </div>
                    <div class="data-item">
                        <span class="label">ACT PNJG</span>
                        <input type="text" value="@Model.ActualLength" placeholder="Enter Actual Length" class="simple-input" />
                    </div>
                </div>
                
                <div class="data-row">
                    <div class="data-item">
                        <span class="label">QTY TARGET</span>
                        <span class="value">@Model.QtyTarget</span>
                    </div>
                    <div class="data-item">
                        <span class="label">QTY ACTUAL</span>
                        <div class="qty-toggle-container">
                            <div class="qty-toggle-buttons">
                                <button type="button" class="qty-toggle-btn ok-btn active" data-type="ok">
                                    <i class="bi bi-check-circle"></i> OK
                                </button>
                                <button type="button" class="qty-toggle-btn ng-btn" data-type="ng">
                                    <i class="bi bi-x-circle"></i> NG
                                </button>
                            </div>
                            
                            <div class="qty-input-section ok-section active">
                                <input type="text" value="@Model.QtyOk" placeholder="0" class="qty-main-input" data-field="QtyOk" />
                            </div>
                            
                            <div class="qty-input-section ng-section">
                                <div class="ng-inputs">
                                    <div class="ng-input-group">
                                        <label>DIMENSI</label>
                                        <input type="text" value="@Model.NgDimension" placeholder="0" class="ng-input" data-field="NgDimension" />
                                    </div>
                                    <div class="ng-input-group">
                                        <label>VISUAL</label>
                                        <input type="text" value="@Model.NgVisual" placeholder="0" class="ng-input" data-field="NgVisual" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="data-row">
                    <div class="data-item full-width">
                        <span class="label">REMARK</span>
                        <input type="text" value="@Model.Remark" placeholder="Enter remarks or notes..." class="simple-input full-width" />
                    </div>
                </div>
            </div>
        </div>

        
        <!-- Action Buttons -->
        <div class="action-buttons">
            <button class="btn-app btn-primary" onclick="saveData()">
                <i class="bi bi-save"></i> Save Data
            </button>
            <button class="btn-app btn-success" onclick="submitReport()">
                <i class="bi bi-check-circle"></i> Submit Report
            </button>
            <button class="btn-app btn-warning" onclick="exportData()">
                <i class="bi bi-download"></i> Export
            </button>
            <button class="btn-app btn-primary" onclick="window.print()">
                <i class="bi bi-printer"></i> Print
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const reportId = @Model.Id;
        let isDirty = false;

        document.addEventListener('DOMContentLoaded', function() {
            // QTY Toggle
            const toggleButtons = document.querySelectorAll('.qty-toggle-btn');
            const okSection = document.querySelector('.ok-section');
            const ngSection = document.querySelector('.ng-section');

            toggleButtons.forEach(button => {
                button.addEventListener('click', function() {
                    toggleButtons.forEach(btn => btn.classList.remove('active'));
                    this.classList.add('active');
                    
                    okSection.classList.toggle('active', this.dataset.type === 'ok');
                    ngSection.classList.toggle('active', this.dataset.type === 'ng');
                });
            });

            // Input listeners
            document.querySelectorAll('input').forEach(input => {
                input.addEventListener('input', () => isDirty = true);
            });
        });

        async function saveData() {
            showNotification('Saving data...', 'success');
            // Mock backend call (Implement actual logic here)
            isDirty = false;
        }

        async function submitReport() {
            if(confirm('Submit this report?')) {
                showNotification('Report submitted!', 'success');
                window.location.href = '/ProductionReport/Index';
            }
        }

        function exportData() {
            window.open(`/ProductionReport/ExportAppData/${reportId}`, '_blank');
        }

        function showNotification(msg, type) {
            const toast = document.createElement('div');
            toast.style.cssText = `position:fixed; top:20px; right:20px; background:${type==='success'?'#10b981':'#ef4444'}; color:white; padding:15px; border-radius:8px; z-index:9999; animation:fadeIn 0.3s;`;
            toast.textContent = msg;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }
    </script>
}
