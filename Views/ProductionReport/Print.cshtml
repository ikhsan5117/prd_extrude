@inject VelastoProductionSystem.Data.ApplicationDbContext _context
@model VelastoProductionSystem.Models.ProductionReport

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Extruder Production Report - @Model.DocumentNumber</title>
    <style>
        body { font-family: 'Arial', sans-serif; color: #000; background: #fff; margin: 0; padding: 20px; font-size: 9pt; }
        @@page { size: A4 landscape; margin: 10mm; }
        
        .print-container { width: 100%; max-width: 100%; border: 1px solid #000; padding: 15px; }
        
        .header-section { display: flex; align-items: flex-start; margin-bottom: 10px; border-bottom: 1px solid #000; padding-bottom: 10px; }
        .header-left { flex: 1; }
        .header-center { flex: 1; text-align: center; }
        .header-right { flex: 1; display: flex; justify-content: flex-end; }
        
        .meta-table { font-size: 8pt; border-collapse: collapse; }
        .meta-table td { padding: 1px 5px; vertical-align: top; }
        .meta-table .label { font-weight: bold; width: 80px; }
        
        .report-title { font-size: 14pt; font-weight: bold; text-transform: uppercase; margin: 0; }
        .report-subtitle { font-size: 11pt; font-weight: normal; margin: 0; }
        
        .signature-table { border-collapse: collapse; width: 240px; }
        .signature-table th, .signature-table td { border: 1px solid #000; text-align: center; vertical-align: middle; }
        .signature-table th { font-size: 7pt; height: 15px; background: #eee; }
        .signature-table td { height: 60px; font-weight: bold; }

        .data-table { width: 100%; border-collapse: collapse; border: 1.5px solid #000; margin-top: 5px; }
        .data-table th, .data-table td { border: 1.5px solid #000; padding: 3px; font-size: 7.5pt; text-align: center; vertical-align: middle; }
        .data-table thead th { background: #f2f2f2; font-weight: bold; }
        
        .tipe-row { text-align: left; background: #fafafa; font-weight: bold; }
        .tipe-row span { font-weight: normal; margin-right: 5px; }
        
        .point-name { text-align: left; padding-left: 5px; font-weight: bold; }
        .scale-val { font-size: 7pt; color: #666; }
        
        .sub-header th { font-size: 7pt; background: #fff !important; }
        
        .footer-grid { display: flex; margin-top: 10px; gap: 10px; }
        .footer-box { border: 1px solid #000; flex: 1; min-height: 80px; position: relative; }
        .footer-box.small-box { flex: 0 0 30%; }
        .footer-label { position: absolute; top: 0; left: 0; background: #fff; padding: 0 5px; font-weight: bold; font-size: 8pt; margin-top: -8px; margin-left: 10px; }
        .footer-content { padding: 10px; font-size: 8pt; }

        .no-print-btn { display: inline-block; padding: 10px 20px; background: #007bff; color: #fff; text-decoration: none; border-radius: 5px; margin-bottom: 20px; cursor: pointer; border: none; }
        @@media print { .no-print-btn { display: none; } .print-container { border: none; } }
    </style>
</head>
<body>
    <button class="no-print-btn" onclick="window.print()">Print This Report</button>
    <button class="no-print-btn" onclick="window.close()" style="background:#6c757d; margin-left: 10px;">Close Window</button>

    <div class="print-container">
        <div class="header-section" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #334155 100%); color: #e2e8f0; padding: 15px; border: 2px solid #3b82f6; border-radius: 8px; margin-bottom: 15px;">
            <!-- Baris 1: Logo, Judul, dan TTD -->
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                <!-- Logo Kiri -->
                <div style="display: flex; align-items: center;">
                    <div style="width: 40px; height: 40px; background: #3b82f6; border-radius: 8px; display: flex; align-items: center; justify-content: center; margin-right: 10px;">
                        <span style="font-weight: 900; font-size: 20px; color: white;">V</span>
                    </div>
                    <div>
                        <div style="font-weight: 900; font-size: 16px; color: #60a5fa;">VELASTO</div>
                        <div style="font-size: 9px; color: #94a3b8; border-bottom: 1px solid #3b82f6; padding-bottom: 1px;">INDONESIA</div>
                    </div>
                </div>
                
                <!-- Judul Tengah -->
                <div style="text-align: center;">
                    <h1 style="font-size: 18px; font-weight: 900; margin: 0; color: #f1f5f9; text-transform: uppercase;">EXTRUDER PRODUCTION REPORT</h1>
                    <h2 style="font-size: 12px; font-weight: 500; margin: 2px 0 0 0; color: #3b82f6;">(Dimension)</h2>
                </div>
                
                <!-- TTD Kanan -->
                <table style="width: 180px; border: 1px solid #3b82f6; border-collapse: collapse; font-size: 8px;">
                    <thead>
                        <tr>
                            <th style="border: 1px solid #3b82f6; padding: 4px; background: #3b82f6; color: white; font-weight: bold;">PREPARED</th>
                            <th style="border: 1px solid #3b82f6; padding: 4px; background: #3b82f6; color: white; font-weight: bold;">CHECKED</th>
                            <th style="border: 1px solid #3b82f6; padding: 4px; background: #3b82f6; color: white; font-weight: bold;">APPROVED</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td style="border: 1px solid #3b82f6; height: 35px; text-align: center; color: #60a5fa; font-weight: bold;">Operator 1</td>
                            <td style="border: 1px solid #3b82f6; height: 35px;"></td>
                            <td style="border: 1px solid #3b82f6; height: 35px;"></td>
                        </tr>
                    </tbody>
                </table>
            </div>
            
            <!-- Baris 2: Informasi Dokumen -->
            <div style="display: flex; justify-content: space-between; font-size: 9px; padding: 8px 0; border-top: 1px solid #3b82f6; border-bottom: 1px solid #3b82f6;">
                <div>
                    <span style="color: #60a5fa; font-weight: bold;">NO DOC :</span> SOP/PROD/HOSE/SPS/24/10/05
                </div>
                <div>
                    <span style="color: #60a5fa; font-weight: bold;">REVISI :</span> 0
                </div>
                <div>
                    <span style="color: #60a5fa; font-weight: bold;">DATE :</span> 17/Mar/2026
                </div>
                <div>
                    <span style="color: #60a5fa; font-weight: bold;">SHIFT :</span> 2
                </div>
            </div>
            
            <!-- Baris 3: Customer dan Product Info -->
            <div style="display: flex; justify-content: space-between; font-size: 9px; padding-top: 8px;">
                <div>
                    <span style="color: #60a5fa; font-weight: bold;">CUSTOMER :</span> PT. TMMIN
                </div>
                <div>
                    <span style="color: #60a5fa; font-weight: bold;">TYPE :</span> TSHSS01G-1C
                </div>
                <div>
                    <span style="color: #60a5fa; font-weight: bold;">HOSE :</span> 11 mm x 18 mm
                </div>
                <div>
                    <span style="color: #60a5fa; font-weight: bold;">WIRE :</span> 0.30 mm x 7 x 7
                </div>
                <div>
                    <span style="color: #60a5fa; font-weight: bold;">BY PASS :</span> 2.5 mm
                </div>
            </div>
        </div>

        <table class="data-table">
            <thead>
                <tr>
                    <th colspan="16" class="tipe-row"><span>Tipe :</span> @Model.HoseType ; @Model.Dimension</th>
                </tr>
                <tr>
                    <th rowspan="2" width="100">POINT</th>
                    <th rowspan="2" width="80">FREKUENSI</th>
                    <th rowspan="2" width="100">STD DIMENSI</th>
                    <th rowspan="2" width="40">Scale</th>
                    <th colspan="6">PUKUL / JAM</th>
                    <th rowspan="2" width="100">PART NUMBER</th>
                    <th rowspan="2" width="80">VIN KODE</th>
                    <th rowspan="2" width="60">STD PNJG</th>
                    <th rowspan="2" width="60">ACT PNJG</th>
                    <th rowspan="2" width="40">QTY TGT</th>
                    <th colspan="3">QTY ACTUAL</th>
                    <th rowspan="2">REMARK</th>
                </tr>
                <tr class="sub-header">
                    <th width="50">INIT</th><th width="40">1</th><th width="40">2</th><th width="40">3</th><th width="40">4</th><th width="40">5</th>
                    <th width="30">OK</th><th width="30">NG-D</th><th width="30">NG-V</th>
                </tr>
            </thead>
            <tbody>
                @{
                    // FIXED: Changed from MasterlistSpsDoubleLayers to SpsNoDocs
                    var master = _context.SpsNoDocs.FirstOrDefault(m => m.HoseType == Model.HoseType);
                    
                    // Helper to parse string to decimal
                    decimal D(string? s, decimal def) => decimal.TryParse(s ?? "0", System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out decimal v) ? v : def;
                    
                    // SpsNoDoc field names are the same as before (PascalCase)
                    decimal idNom = master != null ? D(master.Dimensi, 11.0m) : 11.0m;
                    decimal idTol = master != null ? D(master.ToleranceInner, 0.2m) : 0.2m;
                    decimal tubeNom = master != null ? D(master.TebalInner, 1.8m) : 1.8m;
                    decimal tubeTol = 0.2m;
                    decimal coverNom = master != null ? D(master.TebalTotal, 3.3m) : 3.3m;
                    decimal coverTol = master != null ? D(master.ToleranceOuter, 0.2m) : 0.2m;

                    var pGroups = new[] {
                        new { Name = "Inner Diameter", Std = $"{idNom:0.0} ± {idTol:0.0}", Values = new[] { (idNom+idTol*1.0m).ToString("0.00"), (idNom+idTol*0.5m).ToString("0.00"), idNom.ToString("0.00"), (idNom-idTol*0.5m).ToString("0.00"), (idNom-idTol*1.0m).ToString("0.00") } },
                        new { Name = "Inner Thickness (x)", Std = $"{tubeNom:0.0} ± {tubeTol:0.0}", Values = new[] { (tubeNom+tubeTol*1.0m).ToString("0.00"), (tubeNom+tubeTol*0.5m).ToString("0.00"), tubeNom.ToString("0.00"), (tubeNom-tubeTol*0.5m).ToString("0.00"), (tubeNom-tubeTol*1.0m).ToString("0.00") } },
                        new { Name = "Inner Thickness (y)", Std = $"{tubeNom:0.0} ± {tubeTol:0.0}", Values = new[] { (tubeNom+tubeTol*1.0m).ToString("0.00"), (tubeNom+tubeTol*0.5m).ToString("0.00"), tubeNom.ToString("0.00"), (tubeNom-tubeTol*0.5m).ToString("0.00"), (tubeNom-tubeTol*1.0m).ToString("0.00") } },
                        new { Name = "Total Thickness (x)", Std = $"{coverNom:0.0} ± {coverTol:0.0}", Values = new[] { (coverNom+coverTol*1.0m).ToString("0.00"), (coverNom+coverTol*0.5m).ToString("0.00"), coverNom.ToString("0.00"), (coverNom-coverTol*0.5m).ToString("0.00"), (coverNom-coverTol*1.0m).ToString("0.00") } },
                        new { Name = "Total Thickness (y)", Std = $"{coverNom:0.0} ± {coverTol:0.0}", Values = new[] { (coverNom+coverTol*1.0m).ToString("0.00"), (coverNom+coverTol*0.5m).ToString("0.00"), coverNom.ToString("0.00"), (coverNom-coverTol*0.5m).ToString("0.00"), (coverNom-coverTol*1.0m).ToString("0.00") } }
                    };
                }

                @foreach (var g in pGroups)
                {
                    for (int i = 0; i < 5; i++)
                    {
                        <tr>
                            @if (i == 0)
                            {
                                <td rowspan="5" class="point-name">@g.Name</td>
                                <td rowspan="5">30m Sekali</td>
                                <td rowspan="5" style="font-weight: bold;">@g.Std</td>
                            }
                            <td class="scale-val">@g.Values[i]</td>
                            <td></td><td></td><td></td><td></td><td></td><td></td>
                            
                            @if (i == 0 && g.Name == "Inner Diameter")
                            {
                                <td rowspan="27">@(Model.HoseType ?? "-")</td>
                                <td rowspan="27">@Model.VinCode</td>
                                <td rowspan="27">@(master?.Dimensi ?? Model.StandardLength)</td>
                                <td rowspan="27" style="font-weight: bold;">@Model.ActualLength</td>
                                <td rowspan="27">@Model.QtyTarget</td>
                                <td rowspan="27" style="font-weight: bold;">@Model.QtyOk</td>
                                <td rowspan="27">@Model.NgDimension</td>
                                <td rowspan="27">@Model.NgVisual</td>
                                <td rowspan="27" style="text-align: left; vertical-align: top; padding: 5px;">@Model.Remark</td>
                            }
                        </tr>
                    }
                }
                <tr>
                    <td class="point-name">Spiral Pitch</td>
                    <td>30m Sekali</td>
                    <td style="font-weight: bold;">@(master?.ToleranceSpiralPitch ?? "38 ± 5")</td>
                    <td></td><td></td><td></td><td></td><td></td><td></td><td></td>
                </tr>
                <tr>
                    <td class="point-name">Visual Check</td>
                    <td>30m Sekali</td>
                    <td style="font-size: 6pt;">No Burry, No Line, No Bubble, No Scratch</td>
                    <td></td><td></td><td></td><td></td><td></td><td></td><td></td>
                </tr>
            </tbody>
        </table>

        <div class="footer-grid">
            <div class="footer-box">
                <span class="footer-label">Note :</span>
                <div class="footer-content">@Model.Remark</div>
            </div>
            <div class="footer-box small-box">
                <span class="footer-label">Attention :</span>
                <div class="footer-content" style="font-size: 7pt; line-height: 1.2;">
                    1. Setiap operator wajib menggunakan APD Sepatu safety & Sarung tangan)<br/>
                    2. Periksa Dies Sebelum dan sesudah proses<br/>
                    3. Pastikan semua parameter sesuai dengan SPS
                </div>
            </div>
        </div>
    </div>
</body>
</html>
