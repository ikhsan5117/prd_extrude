@model IEnumerable<VelastoProductionSystem.Models.ProductionReport>

@{
    ViewData["Title"] = "Production Report";
}

<div class="production-dashboard-sapphire fade-in">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4 header-sapphire-glass p-3 px-4">
                <div class="d-flex align-items-center">
                    <div class="hud-icon-box bg-primary bg-opacity-10 me-3">
                        <i class="bi bi-clipboard-data text-primary fs-3"></i>
                    </div>
                    <div>
                        <h2 class="text-white fw-black mb-0 tracking-tighter">PRODUCTION MONITOR</h2>
                        <div class="text-primary-50 super-small fw-bold letter-spacing-2">ACTIVE REPORTS FEED</div>
                    </div>
                </div>
                <a asp-action="Create" class="btn btn-velasto-glow-blue btn-lg rounded-pill px-4">
                    <i class="bi bi-plus-circle-fill me-2"></i> CREATE NEW REPORT
                </a>
            </div>

            <div class="hud-table-wrapper">
                <div class="table-scroll-container">
                    <table class="table table-dark mb-0 sapphire-table">
                        <thead>
                            <tr class="header-row">
                                <th class="ps-4">PRODUCTION DATE</th>
                                <th>DOC NUMBER</th>
                                <th>SHIFT</th>
                                <th>SPECIFICATION</th>
                                <th>MATERIAL (IN/OUT)</th>
                                <th class="text-center">PROGRESS</th>
                                <th class="text-center">STATUS</th>
                                <th class="text-center pe-4">COMMAND</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr class="align-middle">
                                    <td class="ps-4 fw-bold text-nowrap">@item.ProductionDate.ToString("dd MMM yyyy")</td>
                                    <td><code class="text-primary-50">@item.DocumentNumber</code></td>
                                    <td><span class="badge shift-badge @(item.Shift == "Shift 1" ? "bg-info" : "bg-warning")">@item.Shift</span></td>
                                    <td>
                                        <div class="hose-type-tag">@item.HoseType</div>
                                        <div class="super-small text-white-50 mt-1">
                                            <span class="text-info fw-bold">DIM:</span> @item.Dimension<br/>
                                            <span class="text-info fw-bold">YARN:</span> @item.Yarn
                                        </div>
                                    </td>
                                    <td>
                                        <div class="extra-small text-white-50">
                                            <i class="bi bi-circle-fill text-info me-1" style="font-size: 6px;"></i>IN: <span class="text-white">@item.InnerMaterial</span><br/>
                                            <i class="bi bi-circle-fill text-warning me-1" style="font-size: 6px;"></i>OUT: <span class="text-white">@item.OuterMaterial</span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <div class="fw-black text-primary" style="font-size: 1.1rem;">@item.QtyOk <span class="text-white-50 small fw-normal">/ @item.QtyTarget</span></div>
                                        <div class="progress mt-1" style="height: 4px; background: rgba(255,255,255,0.05);">
                                            @if (item.QtyTarget > 0)
                                            {
                                                <div class="progress-bar bg-primary" style="width: @(Math.Min(100, (item.QtyOk * 100) / item.QtyTarget))%"></div>
                                            }
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="status-pill @(item.Status == "COMPLETED" ? "completed" : "active")">
                                            <i class="bi @(item.Status == "COMPLETED" ? "bi-check-circle-fill" : "bi-broadcast pulse-blue") me-1"></i>
                                            @item.Status
                                        </span>
                                    </td>
                                    <td class="text-center pe-4">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-action-glass btn-blue" title="Open HUD">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="App" asp-route-id="@item.Id" class="btn btn-action-glass btn-success" title="Open Tablet App">
                                                <i class="bi bi-tablet"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-action-glass btn-orange" title="Edit">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>
                                            <button type="button" class="btn btn-action-glass btn-red delete-btn" 
                                                    data-id="@item.Id" 
                                                    data-doc="@item.DocumentNumber" 
                                                    title="Delete">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    
                    @if (!Model.Any())
                    {
                        <div class="text-center py-5 bg-dark bg-opacity-20">
                            <i class="bi bi-cpu-fill text-white-50 opacity-10" style="font-size: 5rem;"></i>
                            <p class="text-white-50 fw-bold mt-3 tracking-widest">NO DATA DETECTED IN STREAM</p>
                            <a asp-action="Create" class="btn btn-outline-glass rounded-pill px-5 mt-2">
                                INITIALIZE FIRST REPORT
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<form id="deleteForm" asp-action="Delete" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteId" />
</form>

<style>
    .production-dashboard-sapphire {
        min-height: 100vh;
        padding: 2.5rem;
        background-color: #020617;
        background-image: 
            radial-gradient(at 0% 0%, rgba(30, 58, 138, 0.15) 0, transparent 50%), 
            radial-gradient(at 100% 0%, rgba(37, 99, 235, 0.1) 0, transparent 50%);
        position: relative;
    }

    .header-sapphire-glass {
        background: rgba(30, 58, 138, 0.15);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(59, 130, 246, 0.2);
        border-radius: 24px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.4);
    }

    .hud-icon-box {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(59, 130, 246, 0.1);
        border: 1px solid rgba(59, 130, 246, 0.2);
    }

    .btn-velasto-glow-blue {
        background: #2563eb;
        color: white;
        border: 1px solid #60a5fa;
        box-shadow: 0 0 15px rgba(37, 99, 235, 0.4);
        font-weight: 800;
        transition: all 0.3s;
    }
    .btn-velasto-glow-blue:hover { transform: scale(1.02); box-shadow: 0 0 25px rgba(37, 99, 235, 0.6); color: white; }

    .hud-container {
        background: rgba(15, 23, 42, 0.7);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(59, 130, 246, 0.15);
        border-radius: 0px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6);
    }

    /* Sharp HUD Table Wrapper */
    .hud-table-wrapper {
        background: rgba(8, 14, 30, 0.95);
        border: 1px solid rgba(59, 130, 246, 0.35);
        border-radius: 0;
        box-shadow: 0 0 40px rgba(0,0,0,0.7), inset 0 0 60px rgba(30,58,138,0.05);
        overflow: hidden;
    }

    /* Dual scroll container */
    .table-scroll-container {
        overflow-x: auto;
        overflow-y: auto;
        max-height: 70vh;
    }
    .table-scroll-container::-webkit-scrollbar { width: 6px; height: 6px; }
    .table-scroll-container::-webkit-scrollbar-track { background: rgba(15,23,42,0.8); }
    .table-scroll-container::-webkit-scrollbar-thumb { background: rgba(59,130,246,0.5); border-radius: 0; }
    .table-scroll-container::-webkit-scrollbar-thumb:hover { background: #3b82f6; }
    .table-scroll-container::-webkit-scrollbar-corner { background: rgba(15,23,42,0.8); }

    /* Sharp Grid Table */
    .sapphire-table { 
        color: rgba(255,255,255,0.85);
        border-collapse: collapse;
        min-width: 900px;
    }
    .sapphire-table thead tr.header-row {
        background: linear-gradient(90deg, rgba(30, 58, 138, 0.5), rgba(37, 99, 235, 0.3));
        border-bottom: 2px solid rgba(59, 130, 246, 0.5);
        position: sticky;
        top: 0;
        z-index: 5;
    }
    .sapphire-table th { 
        font-size: 10px; 
        font-weight: 900; 
        letter-spacing: 2px; 
        color: #60a5fa; 
        padding: 14px 14px;
        text-transform: uppercase;
        white-space: nowrap;
        border-right: 1px solid rgba(59, 130, 246, 0.25) !important;
        border-bottom: 2px solid rgba(59, 130, 246, 0.4) !important;
        text-shadow: 0 0 10px rgba(96,165,250,0.4);
    }
    .sapphire-table th:last-child { border-right: none !important; }
    .sapphire-table td { 
        padding: 14px 14px; 
        border-bottom: 1px solid rgba(59, 130, 246, 0.12) !important;
        border-right: 1px solid rgba(59, 130, 246, 0.1) !important;
        vertical-align: middle;
    }
    .sapphire-table td:last-child { border-right: none !important; }
    .sapphire-table tbody tr { transition: background 0.15s; }
    .sapphire-table tbody tr:hover td { background: rgba(59, 130, 246, 0.08); }
    .sapphire-table tbody tr:nth-child(even) td { background: rgba(15, 23, 42, 0.3); }
    .sapphire-table tbody tr:nth-child(even):hover td { background: rgba(59, 130, 246, 0.08); }

    /* Sharp Hose Type Tag */
    .hose-type-tag {
        display: inline-block;
        background: rgba(37, 99, 235, 0.2);
        border: 1px solid rgba(59, 130, 246, 0.45);
        border-left: 3px solid #3b82f6;
        color: white;
        font-weight: 800;
        padding: 3px 10px;
        border-radius: 0;
        font-size: 12px;
        letter-spacing: 0.5px;
    }

    .shift-badge { padding: 4px 10px; border-radius: 0; font-weight: 900; font-size: 10px; letter-spacing: 1px; }

    .status-pill {
        display: inline-flex;
        align-items: center;
        padding: 4px 12px;
        border-radius: 0;
        font-size: 10px;
        font-weight: 900;
        letter-spacing: 1.5px;
        white-space: nowrap;
    }
    .status-pill.active { background: rgba(59, 130, 246, 0.1); color: #60a5fa; border: 1px solid rgba(59, 130, 246, 0.4); border-left: 3px solid #3b82f6; }
    .status-pill.completed { background: rgba(16, 185, 129, 0.1); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.4); border-left: 3px solid #10b981; }

    .btn-action-glass {
        width: 34px;
        height: 34px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 0;
        transition: all 0.2s;
        border: 1px solid rgba(255,255,255,0.1);
    }
    .btn-action-glass.btn-blue { color: #60a5fa; background: rgba(37, 99, 235, 0.1); border-color: rgba(59,130,246,0.3); }
    .btn-action-glass.btn-success { color: #10b981; background: rgba(16, 185, 129, 0.1); border-color: rgba(16,185,129,0.3); }
    .btn-action-glass.btn-orange { color: #fbbf24; background: rgba(245, 158, 11, 0.1); border-color: rgba(251,191,36,0.3); }
    .btn-action-glass.btn-red { color: #ef4444; background: rgba(220, 38, 38, 0.1); border-color: rgba(239,68,68,0.3); }
    .btn-action-glass:hover { transform: scale(1.1); color: white; background: rgba(255,255,255,0.15); border-color: rgba(255,255,255,0.4); }

    .btn-outline-glass {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.8);
        transition: all 0.3s;
    }
    .btn-outline-glass:hover { background: rgba(255, 255, 255, 0.1); border-color: white; color: white; }

    .pulse-blue { width: 8px; height: 8px; background: #3b82f6; border-radius: 50%; display: inline-block; animation: i-pulse 2.5s infinite; filter: blur(1px); }
    @@keyframes i-pulse { 0% { opacity: 1; transform: scale(1); box-shadow: 0 0 0 0 rgba(59,130,246,0.7); } 50% { opacity: 0.5; transform: scale(0.8); } 100% { opacity: 1; transform: scale(1); box-shadow: 0 0 0 10px rgba(59,130,246,0); } }
    
    .super-small { font-size: 9px; }
    .fw-black { font-weight: 900; }
    .tracking-tighter { letter-spacing: -0.5px; }
    .letter-spacing-2 { letter-spacing: 2px; }
</style>

@section Scripts {
    <script src="~/lib/offline-cdn/sweetalert2.all.min.js"></script>
    <script>
        $(document).ready(function() {
            // Success/Error notifications from TempData
            @if (TempData["SuccessMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Berhasil!',
                    text: '@TempData["SuccessMessage"]',
                    background: '#0f172a',
                    color: '#fff',
                    timer: 3000,
                    showConfirmButton: false
                });
                </text>
            }

            function bindEvents() {
                $('.delete-btn').off('click').on('click', function() {
                    const id = $(this).data('id');
                    const docNumber = $(this).data('doc');

                    Swal.fire({
                        title: 'Hapus Laporan?',
                        text: `Apakah Anda yakin ingin menghapus "${docNumber}"?`,
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#ef4444',
                        cancelButtonColor: '#334155',
                        confirmButtonText: 'Ya, Hapus!',
                        cancelButtonText: 'Batal',
                        background: '#0f172a',
                        color: '#fff'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            $('#deleteId').val(id);
                            $('#deleteForm').submit();
                        }
                    });
                });
            }

            window.bindMonitorEvents = bindEvents;
            bindEvents();
        });

        // SignalR Live Sync for Monitor Page
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hub/dashboard")
            .withAutomaticReconnect()
            .build();

        async function startSignalR() {
            try {
                await connection.start();
                console.log("SignalR Connected to Monitor Hub.");
            } catch (err) {
                console.log("SignalR Connection Error: ", err);
                setTimeout(startSignalR, 5000);
            }
        }

        connection.on("ReceiveUpdate", function () {
            console.log("Real-time Update Received in Monitor!");
            
            // Show notification
            Swal.fire({
                title: 'Data Update!',
                text: 'Perubahan data terdeteksi. Memperbarui daftar...',
                icon: 'info',
                background: '#0f172a',
                color: '#fff',
                timer: 2000,
                showConfirmButton: false,
                toast: true,
                position: 'top-end'
            });

            refreshTable();
        });

        async function refreshTable() {
            const url = window.location.href;
            try {
                const response = await fetch(url);
                const html = await response.text();
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');
                
                // Update table body
                const newTbody = doc.querySelector('.sapphire-table tbody');
                const oldTbody = document.querySelector('.sapphire-table tbody');
                if (newTbody && oldTbody) {
                    oldTbody.innerHTML = newTbody.innerHTML;
                    // Note: bindEvents is already defined in the $(document).ready block, 
                    // but we need it to be accessible here. Moving it to global scope or 
                    // making it accessible.
                    if (typeof window.bindMonitorEvents === 'function') {
                        window.bindMonitorEvents();
                    }
                }
                console.log("Monitor table updated via partial sync.");
            } catch (err) {
                console.warn("Partial refresh failed, falling back to full reload:", err);
                window.location.reload();
            }
        }

        startSignalR();
    </script>
    <script src="~/lib/offline-cdn/signalr.min.js"></script>
}

