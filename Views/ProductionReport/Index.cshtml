@model IEnumerable<VelastoProductionSystem.Models.ProductionReport>

@{
    ViewData["Title"] = "Production Report";
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2><i class="bi bi-clipboard-data"></i> Production Report</h2>
            <a asp-action="Create" class="btn btn-velasto">
                <i class="bi bi-plus-circle"></i> Buat Report Baru
            </a>
        </div>

        <div class="card">
            <div class="card-header">
                <i class="bi bi-list-ul"></i> Daftar Laporan Produksi
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Tanggal</th>
                                <th>No. Dokumen</th>
                                <th>Shift</th>
                                <th>Customer</th>
                                <th>Hose Type</th>
                                <th>Dimensi</th>
                                <th class="text-center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.ProductionDate.ToString("dd/MM/yyyy")</td>
                                    <td>@item.DocumentNumber</td>
                                    <td><span class="badge bg-primary">@item.Shift</span></td>
                                    <td>@item.CustomerName</td>
                                    <td>@item.HoseType</td>
                                    <td>@item.Dimension</td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info" title="Detail">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Hapus">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    
                    @if (!Model.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-inbox" style="font-size: 3rem; color: #ccc;"></i>
                            <p class="text-muted mt-3">Belum ada laporan produksi.</p>
                            <a asp-action="Create" class="btn btn-velasto">
                                <i class="bi bi-plus-circle"></i> Buat Laporan Pertama
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
