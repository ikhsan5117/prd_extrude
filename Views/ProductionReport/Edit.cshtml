    .hud-pill-group.sm { border-radius: 6px; padding: 4px; }
    .hud-pill-group.sm .hud-pill-item { padding: 8px 2px; font-size: 0.7rem; border-radius: 4px; }
    .die-card { transition: all 0.3s cubic-bezier(0.4,0,0.2,1); position: relative; overflow: hidden; }
    .die-card:hover { background: rgba(14,165,233,0.08) !important; border-color: rgba(14,165,233,0.4) !important; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(0,0,0,0.3); }
    .die-card::before { content: ''; position: absolute; top: 0; left: 0; width: 3px; height: 100%; background: rgba(255,255,255,0.05); transition: all 0.3s; }
    .die-card:hover::before { background: var(--hud-primary); box-shadow: 0 0 10px var(--hud-primary); }
    .btn-hud-primary { background: var(--hud-primary); color: white; border: none; border-radius: 6px; }
    .btn-hud-primary:hover { transform: translateY(-3px); box-shadow: 0 10px 25px rgba(14,165,233,0.5); color: white; }
    .btn-hud-outline { background: transparent; border: 1px solid rgba(14,165,233,0.3); color: #94a3b8; border-radius: 6px; }
    .text-primary-glow { color: var(--hud-glow); text-shadow: 0 0 10px rgba(56,189,248,0.4); }
    .text-info-glow { color: #38bdf8; text-shadow: 0 0 10px rgba(56,189,248,0.4); }
    .super-small { font-size: 0.7rem; }
    .tracking-widest { letter-spacing: 2.5px; }
    .shadow-hud-blue { box-shadow: 0 0 40px rgba(14,165,233,0.06); }
    .shadow-hud-red { box-shadow: 0 0 30px rgba(239,68,68,0.1); }
