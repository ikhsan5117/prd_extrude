@model VelastoProductionSystem.Models.ProductionReport

@{
    ViewData["Title"] = "Edit Production Report";
}

<div class="production-dashboard-sapphire fade-in">
    <div class="col-md-11 mx-auto">
        <form asp-action="Edit" id="mainForm">
            <input type="hidden" asp-for="Id" />
            
            <div class="d-flex justify-content-between align-items-center mb-4 header-sapphire-glass p-3 px-4">
                <div class="d-flex align-items-center">
                    <div class="hud-icon-box bg-warning bg-opacity-10 me-3">
                        <i class="bi bi-pencil-square text-warning fs-3"></i>
                    </div>
                    <div>
                        <h2 class="text-white fw-black mb-0 tracking-tighter">DATA CORRECTION</h2>
                        <div class="text-warning-50 super-small fw-bold letter-spacing-2">EDITING REPORT #@Model.DocumentNumber</div>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-glass rounded-pill px-4">CANCEL</a>
                    <button type="submit" class="btn btn-velasto-glow-blue rounded-pill px-4">SAVE CHANGES</button>
                </div>
            </div>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger bg-danger bg-opacity-10 border border-danger border-opacity-20 text-danger rounded-4 mb-4"></div>

            <!-- MAIN EDIT HUD -->
            <div class="hud-container p-4 mb-4">
                <div class="row g-4">
                    <!-- DOC INFO COLUMN -->
                    <div class="col-lg-4 border-end border-white border-opacity-10 pe-4">
                        <div class="section-tag mb-3">DOCUMENT IDENTIFICATION</div>
                        <div class="d-flex flex-column gap-3">
                            <div class="hud-input-group">
                                <label class="hud-label text-primary-50">Document Number</label>
                                <input asp-for="DocumentNumber" class="hud-input-sm w-100" />
                            </div>
                            <div class="hud-input-group">
                                <label class="hud-label text-primary-50">Production Date</label>
                                <input asp-for="ProductionDate" type="date" class="hud-input-sm w-100" />
                            </div>
                            <div class="row g-2">
                                <div class="col-6">
                                    <div class="hud-input-group">
                                        <label class="hud-label text-primary-50">Shift</label>
                                        <select asp-for="Shift" class="hud-input-sm w-100">
                                            <option value="Shift 1">Shift 1</option>
                                            <option value="Shift 2">Shift 2</option>
                                            <option value="Shift 3">Shift 3</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="hud-input-group">
                                        <label class="hud-label text-primary-50">Revision</label>
                                        <input asp-for="RevisionNumber" class="hud-input-sm w-100" />
                                    </div>
                                </div>
                            </div>
                            <div class="hud-input-group">
                                <label class="hud-label text-primary-50">Customer</label>
                                <input asp-for="CustomerName" class="hud-input-sm w-100" />
                            </div>
                        </div>
                    </div>

                    <!-- SPEC & MATERIAL COLUMN -->
                    <div class="col-lg-8 ps-4">
                        <div class="section-tag mb-3">PRODUCTION SPECIFICATIONS</div>
                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="hud-input-group border-info border-opacity-20 mb-3">
                                    <label class="hud-label text-info">Hose Type</label>
                                    <input asp-for="HoseType" class="hud-input-lg w-100 text-info" />
                                </div>
                                <div class="hud-input-group">
                                    <label class="hud-label text-primary-50">Standard Parameter Reference</label>
                                    <select asp-for="StandardParameterSettingId" class="hud-input-sm w-100 text-warning" asp-items="ViewBag.StandardParameterSettings">
                                        <option value="">-- NO REFERENCE --</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="hud-input-group mb-3">
                                    <label class="hud-label text-primary-50">Inner Material Actual</label>
                                    <div class="d-flex gap-2">
                                        <input asp-for="InnerMaterialActual" class="hud-input-sm flex-grow-1" placeholder="Material" />
                                        <input asp-for="InnerMaterialLotNo" class="hud-input-sm w-25" placeholder="Lot" />
                                    </div>
                                </div>
                                <div class="hud-input-group">
                                    <label class="hud-label text-primary-50">Outer Material Actual</label>
                                    <div class="d-flex gap-2">
                                        <input asp-for="OuterMaterialActual" class="hud-input-sm flex-grow-1" placeholder="Material" />
                                        <input asp-for="OuterMaterialLotNo" class="hud-input-sm w-25" placeholder="Lot" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- DIE VERIFICATION HUD -->
                        <div class="mt-4 pt-3 border-top border-white border-opacity-10">
                            <div class="row g-2">
                                @foreach(var die in new[] { ("NippleDieOK", "Nipple"), ("TubeDieOK", "Tube"), ("MiddleDieOK", "Middle"), ("CoverDieOK", "Cover"), ("SpacerDieOK", "Spacer") })
                                {
                                    <div class="col">
                                        <div class="die-toggle-hud @(typeof(VelastoProductionSystem.Models.ProductionReport).GetProperty(die.Item1)?.GetValue(Model) as bool? == true ? "active" : "")">
                                            <input class="die-checkbox" type="checkbox" name="@die.Item1" value="true" @(typeof(VelastoProductionSystem.Models.ProductionReport).GetProperty(die.Item1)?.GetValue(Model) as bool? == true ? "checked" : "") id="@die.Item1">
                                            <label for="@die.Item1" class="die-label">@die.Item2</label>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- RESULT RECAP HUD -->
            <div class="hud-container p-4 mb-4 border-info border-opacity-20">
                <div class="section-tag mb-3">FINAL OUTPUT DATA</div>
                <div class="row g-4 align-items-end">
                    <div class="col-md-3">
                        <div class="hud-input-group border-info border-opacity-25 p-3">
                            <label class="hud-label text-info">VIN CODE</label>
                            <input asp-for="VinCode" class="hud-input-lg w-100 fw-black fs-4" style="color: #60a5fa;" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="hud-input-group">
                            <label class="hud-label">Qty Target</label>
                            <input asp-for="QtyTarget" class="hud-input-sm w-100 text-center text-white" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="hud-input-group border-success border-opacity-25">
                            <label class="hud-label text-success">Qty OK</label>
                            <input asp-for="QtyOk" class="hud-input-sm w-100 text-center text-success fw-bold" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="hud-input-group border-danger border-opacity-25">
                            <label class="hud-label text-danger">NG DIM / VIS</label>
                            <div class="d-flex gap-1">
                                <input asp-for="NgDimension" class="hud-input-sm w-50 text-center text-danger" />
                                <input asp-for="NgVisual" class="hud-input-sm w-50 text-center text-danger" />
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="hud-input-group">
                            <label class="hud-label">Dandori Start/End</label>
                            <div class="d-flex gap-1">
                                <input asp-for="DandoriStartTime" type="time" class="hud-input-sm w-50" />
                                <input asp-for="DandoriEndTime" type="time" class="hud-input-sm w-50" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- RESULTS -->
            <div class="card mb-4 tactical-glass border-0 shadow-lg">
                <div class="tactical-header-bar result">
                    <i class="bi bi-bullseye"></i>
                    <span>PRODUCTION SUMMARY (ACTUAL)</span>
                </div>
                <div class="card-body p-4 pt-0">
                    <div class="row g-4 pt-2">
                        <div class="col-md-4 border-end border-white border-opacity-10">
                            <div class="info-chip-tactical mb-3">
                                <label class="data-label-tactical">VIN KODE</label>
                                <input asp-for="VinCode" class="form-control fs-4 fw-bold text-white" />
                            </div>
                            <div class="row g-2">
                                <div class="col-12"><label class="extra-small text-white-50">Std. Panjang (mm)</label><input asp-for="StandardLength" class="form-control bg-dark border-secondary text-white" /></div>
                                <div class="col-12"><label class="extra-small text-white-50">Actual Panjang (mm)</label><input asp-for="ActualLength" class="form-control bg-dark border-warning text-warning" /></div>
                            </div>
                        </div>

                        <div class="col-md-8">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <div class="stat-card-tactical primary">
                                        <label class="stat-label-tactical">Qty Target</label>
                                        <input asp-for="QtyTarget" class="w-100 text-center bg-transparent border-0 text-primary fw-bold fs-3" style="outline:none;" />
                                        <div class="stat-unit-tactical">pcs</div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="stat-card-tactical success">
                                        <label class="stat-label-tactical">Qty Actual (OK)</label>
                                        <input asp-for="QtyOk" class="w-100 text-center bg-transparent border-0 text-success fw-bold fs-3" style="outline:none;" />
                                        <div class="stat-unit-tactical">pcs</div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="stat-card-tactical danger p-2">
                                        <label class="stat-label-tactical mb-2">Quantities (NG)</label>
                                        <div class="d-flex flex-column gap-2">
                                            <div class="input-group input-group-sm">
                                                <span class="input-group-text bg-dark border-danger text-danger extra-small">DIM</span>
                                                <input asp-for="NgDimension" class="form-control bg-dark border-danger text-danger text-end fw-bold" />
                                            </div>
                                            <div class="input-group input-group-sm">
                                                <span class="input-group-text bg-dark border-danger text-danger extra-small">VIS</span>
                                                <input asp-for="NgVisual" class="form-control bg-dark border-danger text-danger text-end fw-bold" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12 mt-3">
                                    <div class="info-chip-tactical">
                                        <label class="data-label-tactical">REMARKS / NOTES</label>
                                        <textarea asp-for="Remark" class="form-control bg-transparent border-0 text-white p-0 fs-7" rows="2"></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <style>
        .production-dashboard-sapphire {
            min-height: 100vh;
            padding: 2.5rem;
            background-color: #020617;
            background-image: 
                radial-gradient(at 0% 0%, rgba(30, 58, 138, 0.15) 0, transparent 50%), 
                radial-gradient(at 100% 0%, rgba(37, 99, 235, 0.1) 0, transparent 50%);
            position: relative;
        }

        .header-sapphire-glass {
            background: rgba(30, 58, 138, 0.15);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(59, 130, 246, 0.2);
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

        .hud-icon-box {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(59, 130, 246, 0.1);
            border: 1px solid rgba(59, 130, 246, 0.2);
        }

        .hud-container {
            background: rgba(15, 23, 42, 0.7);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(59, 130, 246, 0.15);
            border-radius: 20px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6);
            overflow: hidden;
        }

        .section-tag { background: rgba(59, 130, 246, 0.15); border-left: 3px solid #3b82f6; color: #60a5fa; font-size: 10px; font-weight: 900; padding: 4px 10px; letter-spacing: 2px; text-transform: uppercase; display: inline-block; }

        .hud-input-group { background: rgba(255,255,255,0.02); padding: 12px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.05); }
        .hud-label { display: block; font-size: 10px; font-weight: 800; text-transform: uppercase; margin-bottom: 6px; letter-spacing: 0.5px; opacity: 0.8; }
        .hud-input-sm { background: #1e293b; border: 1px solid rgba(59, 130, 246, 0.2); border-radius: 6px; color: #fff; padding: 8px 12px; font-size: 14px; font-weight: 600; outline: none; transition: all 0.3s; }
        .hud-input-sm:focus { border-color: #3b82f6; box-shadow: 0 0 10px rgba(59, 130, 246, 0.3); }
        .hud-input-lg { background: #1e293b; border: 1px solid rgba(59, 130, 246, 0.3); border-radius: 8px; color: #60a5fa; padding: 12px; font-size: 18px; font-weight: 900; text-align: center; outline: none; }

        .die-toggle-hud { background: rgba(30, 41, 59, 0.4); border: 1px solid rgba(255, 255, 255, 0.05); padding: 10px; display: flex; align-items: center; gap: 10px; border-radius: 8px; transition: all 0.3s; cursor: pointer; }
        .die-toggle-hud.active { background: rgba(16, 185, 129, 0.1); border-color: rgba(16, 185, 129, 0.3); }
        .die-toggle-hud.active .die-label { color: #10b981; }
        .die-checkbox { width: 18px; height: 18px; cursor: pointer; }
        .die-label { color: rgba(255,255,255,0.6); font-size: 11px; font-weight: 800; text-transform: uppercase; margin: 0; cursor: pointer; }

        .btn-velasto-glow-blue {
            background: #2563eb;
            color: white;
            border: 1px solid #60a5fa;
            box-shadow: 0 0 15px rgba(37, 99, 235, 0.4);
            font-weight: 800;
            transition: all 0.3s;
        }
        .btn-velasto-glow-blue:hover { transform: scale(1.02); box-shadow: 0 0 25px rgba(37, 99, 235, 0.6); color: white; }

        .btn-outline-glass {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: rgba(255, 255, 255, 0.8);
            transition: all 0.3s;
        }
        .btn-outline-glass:hover { background: rgba(255, 255, 255, 0.1); border-color: white; color: white; }

        .super-small { font-size: 9px; }
        .fw-black { font-weight: 900; }
        .tracking-tighter { letter-spacing: -0.5px; }
        .letter-spacing-2 { letter-spacing: 2px; }
        input[type="date"], select { color-scheme: dark; }
    </style>
}
