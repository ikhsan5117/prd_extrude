@model VelastoProductionSystem.Models.ProductionReport

@{
    ViewData["Title"] = "Edit Production Report";
}

@section Styles {
    <style>
        /* --- Planning Search Styles (HUD) --- */
        .planning-results {
            position: absolute; top: calc(100% + 5px); left: 0; right: 0; 
            background: rgba(15, 23, 42, 0.95);
            backdrop-filter: blur(20px);
            border: 1px solid #0ea5e9; 
            border-radius: 12px; 
            z-index: 10000;
            max-height: 450px; overflow-y: auto; 
            box-shadow: 0 25px 60px rgba(0,0,0,0.9), 0 0 30px rgba(14, 165, 233, 0.1);
            animation: dropdownFade 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            padding: 8px;
        }

        @@keyframes dropdownFade {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .custom-tactical-scroll::-webkit-scrollbar { width: 6px; }
        .custom-tactical-scroll::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); border-radius: 10px; }
        .custom-tactical-scroll::-webkit-scrollbar-thumb { 
            background: rgba(14, 165, 233, 0.3); border-radius: 10px; 
            border: 1px solid rgba(255,255,255,0.05);
        }
        .custom-tactical-scroll::-webkit-scrollbar-thumb:hover { background: #0ea5e9; }

        .planning-result-item {
            padding: 12px 15px;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            border: 1px solid transparent;
            margin-bottom: 4px;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .planning-result-item:hover, .planning-result-highlight {
            background: rgba(14, 165, 233, 0.1);
            border-color: rgba(14, 165, 233, 0.3);
            transform: translateX(5px);
        }

        .planning-result-highlight {
            background: rgba(14, 165, 233, 0.15) !important;
            border-color: #0ea5e9 !important;
            box-shadow: inset 4px 0 0 #0ea5e9;
        }

        .planning-result-code {
            font-family: 'JetBrains Mono', 'Fira Code', monospace;
            font-size: 13px;
            font-weight: 800;
            color: #38bdf8;
            letter-spacing: 0.5px;
        }

        .planning-result-name {
            font-size: 11px;
            font-weight: 600;
            color: #f1f5f9;
            opacity: 0.9;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .planning-result-meta {
            font-size: 9px;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            gap: 6px;
            margin-top: 2px;
        }

        .machine-badge-mini {
            font-size: 9px; 
            font-weight: 900; 
            color: #000;
            background: #f59e0b; 
            padding: 2px 8px; 
            border-radius: 50px; 
            white-space: nowrap;
            display: flex;
            align-items: center;
            gap: 4px;
        }
        
        .blink-once { animation: blink 0.8s ease-out; }
        @@keyframes blink { 0% { background: rgba(56, 189, 248, 0.4); } 100% { background: transparent; } }
    </style>
}

<div class="production-blueprint no-print-bg pb-5">
    <div class="container-fluid p-1 p-md-2">

        <!-- HEADER HUD -->
        <div class="mb-5 py-2">
            <div class="text-center">
                <h1 class="m-0 fw-black text-white letter-spacing-2" style="font-size: 1.6rem;">EDIT PRODUCTION REPORT</h1>
                <div class="text-warning fw-bold tracking-widest" style="font-size: 0.95rem;">(PARAMETER CORRECTION)</div>
            </div>
        </div>

        <form asp-action="Edit" id="editForm">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" id="MachineName" name="MachineName" value="@(Model?.MachineName ?? Context.Session.GetString("MachineName"))" />
            @* Preserve immutable fields *@
            <input type="hidden" asp-for="CreatedDate" />
            <input type="hidden" asp-for="Status" />
            <input type="hidden" id="SpsId" name="SpsId" value="@Model?.SpsId" />
            <input type="hidden" asp-for="ItemCode" id="ItemCode" />
            <div asp-validation-summary="ModelOnly" class="alert mb-4" style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#f87171;border-radius:10px;"></div>

            <!-- SECTION 1: COMMAND CONSOLE (HEADER) -->
            <div class="hud-card mb-4 shadow-hud-blue border-white border-opacity-10 overflow-hidden">
                <div class="hud-card-header d-flex justify-content-between align-items-center py-2 px-3">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-terminal-fill hud-card-icon fs-6"></i>
                        <span class="hud-card-title small tracking-widest font-monospace">PRODUCTION COMMAND CONSOLE</span>
                    </div>
                    <div class="d-flex gap-3 super-small font-black opacity-40 text-uppercase letter-spacing-2">
                        <span><i class="bi bi-file-text me-1"></i>DOC: <input asp-for="DocumentNumber" id="DocNo" class="bg-transparent border-0 text-white-50 w-auto" placeholder="AUTO" /></span>
                        <span><i class="bi bi-activity me-1"></i>REV: <input asp-for="RevisionNumber" id="RevNo" class="bg-transparent border-0 text-white-50 w-auto" placeholder="0" /></span>
                    </div>
                </div>

                <!-- SPS PROTOCOL SYNC ROW -->
                <div class="p-3 bg-black bg-opacity-20 border-bottom border-white border-opacity-5">
                    <div class="row g-3 align-items-center">
                        <div class="col-md-7">
                            <div class="hud-pill p-0 d-flex flex-row border border-info border-opacity-50" style="min-height:60px;position:relative;background:#0f172a;border-radius:8px;">
                                <div class="flex-grow-1 p-2 px-3 d-flex flex-column justify-content-center">
                                    <div class="d-flex align-items-center gap-2 mb-0">
                                        <label class="mb-0 text-info font-black" style="font-size:0.65rem;letter-spacing:1px;"><i class="bi bi-list-check me-2"></i>PLANNING MASTER</label>
                                        @{
                                            var sessionMachine = Context.Session.GetString("MachineName");
                                            var sessionIsAdmin = Context.Session.GetString("IsAdmin") == "true";
                                        }
                                        @if (!sessionIsAdmin && !string.IsNullOrEmpty(sessionMachine))
                                        {
                                            <span class="ms-1" style="font-size:9px; font-weight:900; color:#f59e0b; background:rgba(245,158,11,0.15); padding:2px 8px; border-radius:20px; border:1px solid rgba(245,158,11,0.3); white-space:nowrap;">
                                                <i class="bi bi-cpu-fill me-1"></i>@sessionMachine
                                            </span>
                                        }
                                        else if (sessionIsAdmin)
                                        {
                                            <span class="ms-1" style="font-size:9px; font-weight:900; color:#10b981; background:rgba(16,185,129,0.1); padding:2px 8px; border-radius:20px; border:1px solid rgba(16,185,129,0.3); white-space:nowrap;">
                                                <i class="bi bi-shield-fill me-1"></i>ALL MACHINES
                                            </span>
                                        }
                                    </div>
                                    <input id="planningSearch" type="text" class="hud-input bg-transparent border-0 py-1 font-monospace text-white fw-bold" style="font-size:1rem;outline:none;" 
                                           placeholder="KETIK ITEM CODE..." 
                                           value="@(string.IsNullOrEmpty(Model?.ItemCode) || Model?.ItemCode == "---" ? (Model?.HoseType ?? "") : $"[{Model?.ItemCode}] {Model?.HoseType}")"
                                           oninput="filterPlanningResults(this.value)" 
                                           onfocus="openPlanningDropdown()" autocomplete="off" />
                                    <div id="planningResults" class="planning-results d-none custom-tactical-scroll"></div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-5" style="position:relative;">
                            <div class="hud-pill p-0 d-flex flex-row overflow-hidden border border-info border-opacity-50" style="min-height:60px;background:#0f172a;border-radius:8px;">
                                <div class="flex-grow-1 p-2 px-3 d-flex flex-column justify-content-center">
                                    <label class="mb-0 text-info font-black" style="font-size:0.65rem;letter-spacing:1px;"><i class="bi bi-keyboard me-2"></i>MANUAL PROTOCOL</label>
                                    <input id="manualItemSearch" type="text" class="hud-input bg-transparent border-0 py-1 font-monospace text-white fw-bold" style="font-size:1rem;outline:none;" placeholder="SEARCH SPS MASTERLIST..." oninput="handleSpsAutocomplete(this.value)" onkeydown="handleSpsKeydown(event)" onfocus="if(this.value) handleSpsAutocomplete(this.value)" onblur="setTimeout(() => closeSpsAutocomplete(), 200)" autocomplete="off" />
                                </div>
                                <button type="button" onclick="let v=document.getElementById('manualItemSearch').value; if(v) fetchSpsByItem(v);" class="btn border-0 rounded-0 px-3 d-flex align-items-center justify-content-center border-start border-info border-opacity-20" style="min-width:60px;background:rgba(14,165,233,0.1);color:#0ea5e9;" title="Search">
                                    <i class="bi bi-search fs-4"></i>
                                </button>
                            </div>
                            <!-- Autocomplete Dropdown -->
                            <div id="spsAutocompleteResults" class="d-none" style="position:absolute;top:68px;left:0;right:0;background:#0f172a;border:2px solid #0ea5e9;border-radius:8px;max-height:300px;overflow-y:auto;z-index:9999;box-shadow:0 10px 30px rgba(0,0,0,0.8);">
                                <!-- Results will be injected here -->
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 4-PILL ROW -->
                <div class="p-2 bg-black bg-opacity-10">
                    <div class="row g-2">
                        <div class="col-6">
                            <div class="hud-pill-integrated border border-info border-opacity-20" style="background:rgba(15,23,42,0.8);">
                                <label><i class="bi bi-calendar-check me-2 text-info"></i>SYSTEM DATE</label>
                                <input type="date" asp-for="ProductionDate" id="ProductionDate" class="hud-input font-monospace text-primary-glow" required />
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="hud-pill-integrated border border-info border-opacity-20" style="background:rgba(15,23,42,0.8);">
                                <label><i class="bi bi-clock-history me-2 text-info"></i>SHIFT MONITORING</label>
                                <select asp-for="Shift" id="Shift" class="hud-input font-black bg-transparent border-0 text-white" style="-webkit-appearance:none;">
                                    <option value="I" class="bg-dark">SHIFT I (SIANG)</option>
                                    <option value="II" class="bg-dark">SHIFT II (SORE)</option>
                                    <option value="III" class="bg-dark">SHIFT III (MALAM)</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="hud-pill-integrated border border-info border-opacity-20" style="background:rgba(15,23,42,0.8);">
                                <label><i class="bi bi-building me-2 text-info"></i>CUSTOMER ENTITY</label>
                                <input asp-for="CustomerName" id="CustomerName" class="hud-input small text-white font-black" placeholder="PT. ADM" />
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="hud-pill-integrated border border-info border-opacity-20" style="background:rgba(15,23,42,0.8);">
                                <label><i class="bi bi-cpu me-2 text-info"></i>HOSE SPECIFICATION TYPE</label>
                                <input asp-for="HoseType" id="HoseType" class="hud-input small font-monospace text-white" placeholder="Extrusion Spec Name..." />
                            </div>
                        </div>
                    </div>
                </div>

            </div>


            <!-- SECTION 2: MATERIAL & MESH CHECKING -->
            <div class="row g-4 mb-4 align-items-start">
                <!-- CARD: MATERIAL & LOT TRACKING -->
                <div class="col-lg-7">
                    <div class="hud-card h-100 shadow-hud-blue border-white border-opacity-10 overflow-hidden">
                        <div class="hud-card-header">
                            <i class="bi bi-box-seam hud-card-icon"></i>
                            <span class="hud-card-title">MATERIAL & LOT TRACKING</span>
                        </div>
                        <div class="p-3 bg-black bg-opacity-20 d-flex flex-column gap-3">
                            <!-- INNER COMPOUND -->
                            <div class="hud-pill-integrated border border-info border-opacity-20 p-3 shadow-sm" style="background: rgba(15, 23, 42, 0.8);">
                                <div class="d-flex justify-content-between mb-2 pb-2 border-bottom border-white border-opacity-10">
                                    <div class="label-stack"><span class="label-sub text-info">INNER (MATERIAL)</span><span class="label-main">COMPOUND</span></div>
                                    <button type="button" onclick="addMaterialRow('inner')" class="btn btn-sm btn-outline-info border-0 rounded-circle p-1" style="width: 28px; height: 28px; background: rgba(14, 165, 233, 0.1);">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                </div>
                                <div class="row g-2 align-items-end mb-2">
                                    <div class="col-4">
                                        <label class="super-small text-white-50 mb-1">STANDARD</label>
                                        <input asp-for="InnerMaterial" id="InnerMaterial" class="hud-input font-monospace text-white opacity-50 w-100" readonly />
                                    </div>
                                    <div class="col-8">
                                        <label class="super-small text-info mb-1">ACTUAL BATCH NAME</label>
                                        <input asp-for="InnerMaterialActual" id="InnerMaterialActual" class="hud-input font-monospace text-white w-100" placeholder="Input Actual..." />
                                    </div>
                                </div>
                                
                                <!-- Dynamic List for Inner -->
                                <div id="inner-lot-list" class="d-flex flex-column gap-2 mt-2">
                                    <!-- Rows will be added here -->
                                </div>
                            </div>

                            <!-- MIDDLE COMPOUND (CHS 3 LAYER ONLY - hidden by default) -->
                            <div id="middleMaterialCard" class="hud-pill-integrated border p-3 shadow-sm" 
                                 style="display:none; background: rgba(15, 23, 42, 0.8); border-color: rgba(167,139,250,0.35) !important;">
                                <div class="d-flex justify-content-between mb-2 pb-2 border-bottom border-white border-opacity-10">
                                    <div class="label-stack">
                                        <span class="label-sub" style="color:#a78bfa;">MIDDLE (MATERIAL)</span>
                                        <span class="label-main" style="color:#c4b5fd;">COMPOUND 3L</span>
                                    </div>
                                    <button type="button" onclick="addMaterialRow('middle')" class="btn btn-sm border-0 rounded-circle p-1" style="width: 28px; height: 28px; background: rgba(167,139,250,0.15); color:#a78bfa;">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                </div>
                                <div class="row g-2 align-items-end mb-2">
                                    <div class="col-4">
                                        <label class="super-small text-white-50 mb-1">STANDARD</label>
                                        <input id="MiddleMaterial" name="MiddleMaterial" class="hud-input font-monospace w-100" style="color:rgba(196,181,253,0.6);" readonly />
                                    </div>
                                    <div class="col-8">
                                        <label class="super-small mb-1" style="color:#a78bfa;">ACTUAL BATCH NAME</label>
                                        <input id="MiddleMaterialActual" name="MiddleMaterialActual" class="hud-input font-monospace text-white w-100" placeholder="Input Actual..." />
                                    </div>
                                </div>
                                <!-- Dynamic List for Middle -->
                                <div id="middle-lot-list" class="d-flex flex-column gap-2 mt-2">
                                    <!-- Rows will be added here -->
                                </div>
                            </div>

                            <!-- OUTER COMPOUND -->
                            <div class="hud-pill-integrated border border-warning border-opacity-20 p-3 shadow-sm" style="background: rgba(15, 23, 42, 0.8);">
                                <div class="d-flex justify-content-between mb-2 pb-2 border-bottom border-white border-opacity-10">
                                    <div class="label-stack"><span class="label-sub text-warning">OUTER (MATERIAL)</span><span class="label-main">COMPOUND</span></div>
                                    <button type="button" onclick="addMaterialRow('outer')" class="btn btn-sm btn-outline-warning border-0 rounded-circle p-1" style="width: 28px; height: 28px; background: rgba(245, 158, 11, 0.1);">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                </div>
                                <div class="row g-2 align-items-end mb-2">
                                    <div class="col-4">
                                        <label class="super-small text-white-50 mb-1">STANDARD</label>
                                        <input asp-for="OuterMaterial" id="OuterMaterial" class="hud-input font-monospace text-white opacity-50 w-100" readonly />
                                    </div>
                                    <div class="col-8">
                                        <label class="super-small text-warning mb-1">ACTUAL BATCH NAME</label>
                                        <input asp-for="OuterMaterialActual" id="OuterMaterialActual" class="hud-input font-monospace text-white w-100" placeholder="Input Actual..." />
                                    </div>
                                </div>

                                <!-- Dynamic List for Outer -->
                                <div id="outer-lot-list" class="d-flex flex-column gap-2 mt-2">
                                    <!-- Rows will be added here -->
                                </div>
                            </div>

                            <!-- YARN SUPPORT -->
                            <div class="hud-pill-integrated border border-success border-opacity-20 p-3 shadow-sm" style="background: rgba(15, 23, 42, 0.8);">
                                <div class="d-flex justify-content-between mb-2 pb-2 border-bottom border-white border-opacity-10">
                                    <div class="label-stack"><span class="label-sub text-success">YARN (SUPPORT)</span><span class="label-main">POLYESTER</span></div>
                                    <button type="button" onclick="addMaterialRow('yarn')" class="btn btn-sm btn-outline-success border-0 rounded-circle p-1" style="width: 28px; height: 28px; background: rgba(16, 185, 129, 0.1);">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                </div>
                                <div class="row g-2 align-items-end mb-2">
                                    <div class="col-4">
                                        <label class="super-small text-white-50 mb-1">STANDARD</label>
                                        <input asp-for="Yarn" id="Yarn" class="hud-input font-monospace text-white opacity-50 w-100" readonly />
                                    </div>
                                    <div class="col-8">
                                        <label class="super-small text-success mb-1">ACTUAL BATCH NAME</label>
                                        <input asp-for="YarnActual" id="YarnActual" class="hud-input font-monospace text-white w-100" placeholder="Input Actual..." />
                                    </div>
                                </div>

                                <!-- Dynamic List for Yarn -->
                                <div id="yarn-lot-list" class="d-flex flex-column gap-2 mt-2">
                                    <!-- Rows will be added here -->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- CARD: MESH & EMBOSS -->
                <div class="col-lg-5">
                    <div class="hud-card shadow-hud-blue border-white border-opacity-10 overflow-hidden">
                        <div class="hud-card-header">
                            <i class="bi bi-patch-check hud-card-icon"></i>
                            <span class="hud-card-title">MESH & EMBOSS QUALITY</span>
                        </div>
                        <div class="p-3 bg-slate-800 bg-opacity-40 flex-grow-1" style="background: rgba(30, 41, 59, 0.4);">
                            <!-- CATEGORY: TIPE MESH (BEFORE) -->
                            <div class="mb-4 pb-3">
                                <div class="label-stack mb-2">
                                    <div class="d-flex justify-content-between align-items-center w-100">
                                         <div>
                                             <span class="label-sub text-info-glow fw-bold"><i class="bi bi-layers me-1"></i>TIPE MESH</span>
                                             <span class="label-main small text-white fw-900">INNER & OUTER SELECTION (BEFORE)</span>
                                         </div>
                                     </div>
                                 </div>
                                
                                <div class="row g-2">
                                    <!-- INNER GROUP -->
                                    <div class="col-6">
                                        <div class="p-2 rounded-3 bg-slate-900 bg-opacity-60 border border-white border-opacity-20 text-center">
                                            <span class="label-main small text-white fw-900 opacity-75 d-block mb-3 border-bottom border-white border-opacity-10 pb-1">INNER LAYER</span>
                                             <div class="d-flex justify-content-center gap-4 py-1">
                                                 <div class="d-flex flex-column align-items-center gap-1">
                                                     <div class="hud-check-box sm"><input type="checkbox" asp-for="MeshInner10Before"><span></span></div>
                                                     <span id="label_MeshInner1" class="super-small text-white fw-bold">--</span>
                                                 </div>
                                                 <div class="d-flex flex-column align-items-center gap-1">
                                                     <div class="hud-check-box sm"><input type="checkbox" asp-for="MeshInner40Before"><span></span></div>
                                                     <span id="label_MeshInner2" class="super-small text-white fw-bold">--</span>
                                                 </div>
                                             </div>
                                        </div>
                                    </div>
                                    <!-- OUTER GROUP -->
                                    <div class="col-6">
                                        <div class="p-2 rounded-3 bg-slate-900 bg-opacity-60 border border-white border-opacity-20 text-center">
                                            <span class="label-main small text-white fw-900 opacity-75 d-block mb-3">OUTER LAYER</span>
                                             <div class="d-flex justify-content-center gap-4 py-1">
                                                 <div class="d-flex flex-column align-items-center gap-1">
                                                     <div class="hud-check-box sm"><input type="checkbox" asp-for="MeshOuter10Before"><span></span></div>
                                                     <span id="label_MeshOuter1" class="super-small text-white fw-bold">--</span>
                                                 </div>
                                                 <div class="d-flex flex-column align-items-center gap-1">
                                                     <div class="hud-check-box sm"><input type="checkbox" asp-for="MeshOuter40Before"><span></span></div>
                                                     <span id="label_MeshOuter2" class="super-small text-white fw-bold">--</span>
                                                 </div>
                                             </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- CATEGORY: MESH CHECK (AFTER) -->
                            <div class="mb-4 border-bottom border-white border-opacity-20 pb-4">
                                <div class="label-stack mb-2"><span class="label-sub text-info-glow fw-bold"><i class="bi bi-shield-check me-1"></i>MESH CHECK</span><span class="label-main small text-white fw-900">QUALITY VERIFICATION (AFTER)</span></div>
                                <div class="d-flex flex-column gap-3 mt-2">
                                    <div class="d-flex align-items-center justify-content-between p-2 rounded-3 bg-slate-900 bg-opacity-50 border border-white border-opacity-20">
                                        <span class="label-main text-white fw-black" style="font-size: 0.8rem; min-width:80px">INNER</span>
                                        <div class="hud-pill-group"><label class="hud-pill-item">OK<input type="radio" asp-for="MeshInnerCheck" value="OK"></label><label class="hud-pill-item red">BOLONG<input type="radio" asp-for="MeshInnerCheck" value="BOLONG"></label><label class="hud-pill-item orange">ASING<input type="radio" asp-for="MeshInnerCheck" value="ASING"></label></div>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between p-2 rounded-3 bg-slate-900 bg-opacity-50 border border-white border-opacity-20">
                                        <span class="label-main text-white fw-black" style="font-size: 0.8rem; min-width:80px">OUTER</span>
                                        <div class="hud-pill-group"><label class="hud-pill-item">OK<input type="radio" asp-for="MeshOuterCheck" value="OK"></label><label class="hud-pill-item red">BOLONG<input type="radio" asp-for="MeshOuterCheck" value="BOLONG"></label><label class="hud-pill-item orange">ASING<input type="radio" asp-for="MeshOuterCheck" value="ASING"></label></div>
                                    </div>
                                </div>
                            </div>

                            <!-- CATEGORY: EMBOSSING & QC -->
                            <div class="p-3 bg-slate-900 bg-opacity-70 border border-white border-opacity-20 rounded-4">
                                <div class="label-stack mb-3"><span class="label-sub text-info-glow fw-bold">FINAL SECURITY</span><span class="label-main small text-white fw-900">MARKING & QC ANALYTICS</span></div>
                                <div class="row g-2 mb-3">
                                    <div class="col-7">
                                        <div class="p-2 px-3 rounded-3 border border-white border-opacity-30 bg-black bg-opacity-40 shadow-sm h-100">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <label class="super-small text-info-glow fw-black mb-0"><i class="bi bi-fonts me-1"></i>MARK CONTENT DATA</label>
                                                <span id="std_Marking" class="super-small text-info-glow opacity-75 font-monospace">STD: --</span>
                                            </div>
                                            <input asp-for="EmbossMarkContent" class="hud-input w-100 border-0 bg-transparent text-white fw-bold font-monospace mt-1" style="font-size: 1rem;" placeholder="[ ENTER SEQUENCE ]" />
                                        </div>
                                    </div>
                                    <div class="col-5">
                                        <div class="p-2 px-3 rounded-3 border border-white border-opacity-30 bg-black bg-opacity-40 shadow-sm h-100">
                                            <label class="super-small text-info-glow fw-black mb-1"><i class="bi bi-calendar-event me-1"></i>VERIFICATION DATE</label>
                                            <input type="date" asp-for="EmbossMarkDate" class="hud-input w-100 border-0 bg-transparent text-white fw-bold font-monospace mt-1" style="font-size: 1rem; color-scheme: dark;" />
                                        </div>
                                    </div>
                                </div>

                                <div class="d-flex flex-column gap-3">
                                    @{
                                        var qcMetricsLight = new[] { 
                                            new { Label = "CONDITION", Sub = "Q.01", Field = "QcCond", Opt1 = "BERSIH", Opt2 = "KOTOR" },
                                            new { Label = "SURFACE", Sub = "Q.02", Field = "QcSurf", Opt1 = "OK", Opt2 = "SCRATCH" },
                                            new { Label = "QUALITY RES", Sub = "Q.03", Field = "QcRes", Opt1 = "READ", Opt2 = "UNREAD" }
                                        };
                                    }

                                    @foreach(var qc in qcMetricsLight) {
                                        <div class="d-flex align-items-center justify-content-between p-2 px-3 rounded-3 bg-black bg-opacity-30 border border-white border-opacity-20">
                                            <div class="label-stack">
                                                <span class="label-sub text-info-glow opacity-75" style="font-size: 0.6rem">@qc.Sub</span>
                                                <span class="label-main text-white fw-black" style="font-size: 0.85rem">@qc.Label</span>
                                            </div>
                                            <div class="hud-pill-group" style="width: 170px; height: 38px;">
                                                <label class="hud-pill-item">@qc.Opt1<input type="radio" name="@qc.Field" value="@qc.Opt1"></label>
                                                <label class="hud-pill-item red">@qc.Opt2<input type="radio" name="@qc.Field" value="@qc.Opt2"></label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- SECTION 3: DIES DIMENSION - REDESIGNED AS CARDS -->
            <div class="row g-4 mb-4">
                <div class="col-12">
            <div class="hud-card mb-4 shadow-hud-blue border-white border-opacity-10 overflow-hidden">
                <div class="hud-card-header d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-rulers hud-card-icon"></i>
                        <span class="hud-card-title">DIES DIMENSION MEASUREMENTS</span>
                    </div>
                </div>
                
                <div class="p-3">
                    <div class="row g-3">
                        @{
                            var diesList = new[] { 
                                new { Name = "Nipple", Field = "NippleDieOK", SpecKey = "NippleDie", InitName = "NippleDieInitial", FinalName = "NippleDieFinal", OK = Model!.NippleDieOK, InitVal = Model!.NippleDieInitial, FinalVal = Model!.NippleDieFinal },
                                new { Name = "Tube Die", Field = "TubeDieOK", SpecKey = "TubeDie", InitName = "TubeDieInitial", FinalName = "TubeDieFinal", OK = Model!.TubeDieOK, InitVal = Model!.TubeDieInitial, FinalVal = Model!.TubeDieFinal },
                                new { Name = "Middle Die", Field = "MiddleDieOK", SpecKey = "MiddleDie", InitName = "MiddleDieInitial", FinalName = "MiddleDieFinal", OK = Model!.MiddleDieOK, InitVal = Model!.MiddleDieInitial, FinalVal = Model!.MiddleDieFinal },
                                new { Name = "Cover Die", Field = "CoverDieOK", SpecKey = "CoverDie", InitName = "CoverDieInitial", FinalName = "CoverDieFinal", OK = Model!.CoverDieOK, InitVal = Model!.CoverDieInitial, FinalVal = Model!.CoverDieFinal },
                                new { Name = "Spacer", Field = "SpacerDieOK", SpecKey = "SpacerDie", InitName = "SpacerDieInitial", FinalName = "SpacerDieFinal", OK = Model!.SpacerDieOK, InitVal = Model!.SpacerDieInitial, FinalVal = Model!.SpacerDieFinal },
                                new { Name = "A Distance", Field = "ToleranceDieOK", SpecKey = "ToleranceDie", InitName = "ToleranceInitial", FinalName = "ToleranceFinal", OK = Model!.ToleranceDieOK, InitVal = Model!.ToleranceInitial, FinalVal = Model!.ToleranceFinal }
                            };
                        }

                        @foreach(var die in diesList) {
                            var isMiddleDie = die.Name == "Middle Die";
                            <div class="col-md-6 col-xl-4 @(isMiddleDie && string.IsNullOrEmpty(die.SpecKey) ? "d-none" : "")" id="die_card_@die.SpecKey">
                                <div class="die-card p-3 rounded-3 border border-white border-opacity-10 bg-black bg-opacity-30 h-100 d-flex flex-column">

                                    <!-- TOP: Instrument name + OK/NG -->
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <div class="label-stack">
                                            <span class="label-sub">INSTRUMENT</span>
                                            <span class="label-main fs-6">@die.Name</span>
                                        </div>
                                        <div class="hud-pill-group sm" style="width: 100px;">
                                            <label class="hud-pill-item">OK<input type="radio" name="@die.Field" value="true" @(die.OK == true ? "checked" : "")></label>
                                            <label class="hud-pill-item red">NG<input type="radio" name="@die.Field" value="false" @(die.OK == false ? "checked" : "")></label>
                                        </div>
                                    </div>

                                    <!-- MIDDLE: Standard min / std / max individual boxes -->
                                    <div class="mb-3">
                                        <div class="text-center mb-1">
                                            <span style="font-size: 0.48rem; font-weight: 900; letter-spacing: 2px; color: #94a3b8; text-transform: uppercase;">STANDARD</span>
                                        </div>
                                        <div class="d-flex justify-content-center gap-2">
                                            <div class="text-center px-2 py-1 rounded-2" style="border: 1px solid rgba(56,189,248,0.25); min-width: 60px;">
                                                <div style="font-size: 0.42rem; font-weight: 700; letter-spacing: 1px; color: #94a3b8; text-transform: uppercase; margin-bottom: 2px;">min</div>
                                                <div id="spec_min_@die.SpecKey" class="font-monospace fw-bold" style="font-size: 0.8rem; color: #38bdf8;">--</div>
                                            </div>
                                            <div class="text-center px-2 py-1 rounded-2" style="border: 1px solid rgba(125,211,252,0.5); min-width: 60px; background: rgba(56,189,248,0.06);">
                                                <div style="font-size: 0.42rem; font-weight: 700; letter-spacing: 1px; color: #38bdf8; text-transform: uppercase; margin-bottom: 2px;">std</div>
                                                <div id="spec_std_@die.SpecKey" class="font-monospace fw-bold" style="font-size: 0.9rem; color: #7dd3fc;">--</div>
                                            </div>
                                            <div class="text-center px-2 py-1 rounded-2" style="border: 1px solid rgba(56,189,248,0.25); min-width: 60px;">
                                                <div style="font-size: 0.42rem; font-weight: 700; letter-spacing: 1px; color: #94a3b8; text-transform: uppercase; margin-bottom: 2px;">max</div>
                                                <div id="spec_max_@die.SpecKey" class="font-monospace fw-bold" style="font-size: 0.8rem; color: #38bdf8;">--</div>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- Hidden full spec value for JS validation -->
                                    <div id="spec_@die.SpecKey" style="display:none;">--</div>

                                    <!-- BOTTOM: Before + After centered -->
                                    <div class="d-flex justify-content-center gap-3 mt-auto">
                                        <div class="text-center" style="width: 130px;">
                                            <label class="lbl-small mb-1 text-warning d-block" style="font-size: 0.55rem;">BEFORE</label>
                                            <input name="@die.InitName" value="@die.InitVal" class="hud-input-underlined py-1 text-center font-monospace text-warning border-0 bg-white bg-opacity-5 rounded-2 w-100" placeholder="---" style="font-size: 0.9rem; min-height: 35px;" />
                                        </div>
                                        <div class="text-center" style="width: 130px;">
                                            <label class="lbl-small mb-1 text-warning d-block" style="font-size: 0.55rem;">AFTER</label>
                                            <input name="@die.FinalName" value="@die.FinalVal" class="hud-input-underlined py-1 text-center font-monospace text-warning border-0 bg-white bg-opacity-5 rounded-2 w-100" placeholder="---" style="font-size: 0.9rem; min-height: 35px;" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

            <!-- SECTION: DYNAMIC PRODUCTION READINGS TABS (CENTERED) -->
            <div class="d-flex flex-column align-items-center mb-5 mt-2">
                <div class="text-info-glow opacity-40 super-small fw-black tracking-widest mb-3" style="font-size: 0.6rem;">DYNAMIC MEASUREMENT CONTROL</div>
                <div class="d-flex align-items-center gap-4">
                    <div id="readingsTabs" class="d-flex gap-2">
                        <!-- P-1, P-2, etc. will be injected here -->
                    </div>
                    <div class="add-check-trigger d-flex align-items-center gap-2 cursor-pointer no-select" onclick="addReadingPoint()">
                        <i class="bi bi-plus fs-2 text-white"></i>
                        <span class="text-white fw-900 tracking-widest" style="font-size: 1.1rem;">ADD CHECK</span>
                    </div>
                </div>
            </div>

            <!-- SECTION: SMART PARAMETER CARDS (ACTIVE RECORD VIEW) -->
            <div class="row g-4 mb-5" id="parameterCardsContainer">
                @{
                    var monSections = new[] {
                        new { 
                            Title = "SECTION 01: INNER (TUBE 1)", Icon="bi-gear-fill", Color = "#3b82f6", ID="inner",
                            Rows = new[,] { { "Head Temp.", "°C", "HeadTempInner" }, { "Cylinder 1", "°C", "Cylinder1TempInner" }, { "Cylinder 2", "°C", "Cylinder2TempInner" }, { "Cylinder 3", "°C", "Cylinder3TempInner" }, { "Screw Temp.", "°C", "ScrewTempInner" }, { "Screw Speed", "rpm", "ScrewSpeedInner" }, { "Feed Roll Ratio", "%", "FeedRollRatioInner" }, { "Pressure", "MPa", "PressureInner" } }
                        },
                        new { 
                            Title = "SECTION 02: OUTER (COVER)", Icon="bi-shield-shaded", Color = "#f59e0b", ID="outer",
                            Rows = new[,] { { "Head Temp.", "°C", "HeadTempOuter" }, { "Cylinder 1", "°C", "Cylinder1TempOuter" }, { "Cylinder 2", "°C", "Cylinder2TempOuter" }, { "Cylinder 3", "°C", "Cylinder3TempOuter" }, { "Screw Temp.", "°C", "ScrewTempOuter" }, { "Screw Speed", "rpm", "ScrewSpeedOuter" }, { "Feed Roll Ratio", "%", "FeedRollRatioOuter" }, { "Pressure", "MPa", "PressureOuter" } }
                        },
                        new { 
                            Title = "SECTION 03: SPIRAL MECHANISM", Icon="bi-sync", Color = "#10b981", ID="spiral",
                            Rows = new[,] { { "Spiral Speed", "rpm", "SpiralSpeed" }, { "Spiral Pitch (Set)", "mm", "SpiralPitchSetting" }, { "Spiral Pitch (Disp)", "mm", "SpiralPitchDisplay" } } 
                        },
                        new { 
                            Title = "SECTION 04: INFRA & UTILITY", Icon="bi-water", Color = "#0ea5e9", ID="other",
                            Rows = new[,] { { "Preset Value", "Ø mm", "PresetValue" }, { "Control Value", "Ø mm", "ControlValue" }, { "Hose Speed", "m/min", "HoseSpeed" }, { "Take-up Speed", "", "TakeupConveyorSpeed" }, { "Cool Speed", "", "CoolConveyorSpeed" }, { "Conveyor Ratio", "", "ConveyorRatio" }, { "Surface Condition", "", "UnsmoothSurface" }, { "Chiller Temp", "°C", "ChillerWaterTemp" }, { "Caterpillar Gap", "mm", "CaterpillarGap" } } 
                        }
                    };
                }

                @foreach (var mSec in monSections) {
                    <div class="col-12 col-xxl-6">
                        <div class="hud-card h-100 shadow-hud mb-1 overflow-hidden" 
                             style="border: 1px solid @(mSec.Color)44; background: rgba(15, 23, 42, 0.6); box-shadow: 0 0 20px @(mSec.Color)11;">
                            
                            <div class="hud-card-header d-flex justify-content-between align-items-center py-3 px-4" 
                                 style="background: linear-gradient(90deg, @(mSec.Color)33 0%, transparent 100%); border-bottom: 2px solid @(mSec.Color)66;">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="p-2 rounded-3" style="background: @(mSec.Color)22; border: 1px solid @(mSec.Color)44;">
                                        <i class="bi @mSec.Icon fs-4" style="color: @mSec.Color"></i>
                                    </div>
                                    <span class="hud-card-title tracking-widest text-white fw-900" style="font-size: 1.1rem; text-shadow: 0 0 10px @(mSec.Color)66;">@mSec.Title</span>
                                </div>
                            </div>
                            
                            <div class="p-4 bg-black bg-opacity-20">
                                <div class="row g-4">
                                    @for (int r = 0; r < mSec.Rows.GetLength(0); r++) {
                                        var key = mSec.Rows[r, 2];
                                        <div class="col-6">
                                            <div class="param-tile-modern rounded-3 p-3 text-center h-100 d-flex flex-column justify-content-between"
                                                 style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); transition: all 0.3s; position: relative; overflow: hidden;">
                                                
                                                <div class="d-flex justify-content-between align-items-start mb-2">
                                                    <span class="text-white opacity-60 super-small fw-black tracking-widest">@(mSec.Rows[r, 0].ToUpper())</span>
                                                    <span class="badge rounded-pill super-small" style="background: @(mSec.Color)22; color: @mSec.Color; border: 1px solid @(mSec.Color)44;">@mSec.Rows[r, 1]</span>
                                                </div>
                                                
                                                <div class="std-zone py-2 mb-2 rounded-2" style="background: rgba(0,0,0,0.3); border: 1px dashed rgba(255,255,255,0.1);">
                                                    <div class="d-flex justify-content-center gap-1">
                                                        <div class="text-center px-1" style="border-right: 1px solid rgba(255,255,255,0.1); width: 33%;">
                                                            <div style="font-size: 0.4rem; color: #94a3b8; text-transform: uppercase;">min</div>
                                                            <div id="spec_min_@key" class="font-monospace fw-bold" style="font-size: 0.75rem; color: @mSec.Color;">--</div>
                                                        </div>
                                                        <div class="text-center px-1" style="border-right: 1px solid rgba(255,255,255,0.1); width: 33%;">
                                                            <div style="font-size: 0.45rem; color: #fff; text-transform: uppercase;">std</div>
                                                            <div id="spec_std_@key" class="font-monospace fw-bold" style="font-size: 0.85rem; color: @mSec.Color;">--</div>
                                                        </div>
                                                        <div class="text-center px-1" style="width: 33%;">
                                                            <div style="font-size: 0.4rem; color: #94a3b8; text-transform: uppercase;">max</div>
                                                            <div id="spec_max_@key" class="font-monospace fw-bold" style="font-size: 0.75rem; color: @mSec.Color;">--</div>
                                                        </div>
                                                    </div>
                                                    <div id="spec_@key" style="display:none;">--</div>
                                                </div>
                                                
                                                <div class="input-zone">
                                                    <input id="input_@key"
                                                           onchange="updateReadingData('@key', this.value)"
                                                           class="vibrant-hud-input w-100" 
                                                           placeholder="0.00" 
                                                           style="--theme-color: @mSec.Color;" />
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- SECTION 4: WASTE & SIGN-OFF -->
            <div class="row g-3 mb-4 align-items-start">
                <!-- WASTE / DANDORI -->
                <div class="col-lg-7">
                    <div class="hud-card shadow-hud-blue border-white border-opacity-10 p-3 bg-black bg-opacity-40">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-trash text-info fs-5 me-2"></i>
                            <div class="text-info-glow tracking-widest fw-black">WASTE PERFORMANCE (KG)</div>
                        </div>
                        <div class="row g-3">
                            <!-- DANDORI AWAL -->
                            <div class="col-md-6">
                                <div class="border border-white border-opacity-10 rounded-2 p-2 bg-black bg-opacity-20">
                                    <div class="text-white opacity-50 super-small fw-bold tracking-widest mb-2 border-bottom border-info border-opacity-25 pb-1">DANDORI AWAL (CLEANING)</div>
                                    <div class="d-flex flex-column gap-2 mt-2">
                                        <div class="hud-pill-integrated border-white border-opacity-5 bg-black bg-opacity-40 p-2 rounded-1">
                                            <div class="mb-1"><label class="text-info super-small fw-bold"><i class="bi bi-circle-fill me-1" style="font-size:0.5rem"></i>INNER TUBE</label></div>
                                            <div class="d-flex gap-2 bg-dark bg-opacity-50 rounded border border-white border-opacity-10 p-1">
                                                <div class="flex-grow-1 position-relative">
                                                    <span class="position-absolute top-50 start-0 translate-middle-y ms-2 super-small opacity-50">AWAL</span>
                                                    <input asp-for="DAI_Awal" class="hud-input text-end text-primary-glow fw-bold font-monospace pe-2 h-100" placeholder="-" />
                                                </div>
                                                <div class="border-start border-white border-opacity-10"></div>
                                                <div class="flex-grow-1 position-relative">
                                                    <span class="position-absolute top-50 start-0 translate-middle-y ms-2 super-small opacity-50">AKHIR</span>
                                                    <input asp-for="DAI_Akhir" class="hud-input text-end text-primary-glow fw-bold font-monospace pe-2 h-100" placeholder="-" />
                                                </div>
                                            </div>
                                        </div>
                                        <div class="hud-pill-integrated border-white border-opacity-5 bg-black bg-opacity-40 p-2 rounded-1">
                                            <div class="mb-1"><label class="text-warning super-small fw-bold"><i class="bi bi-circle-fill me-1" style="font-size:0.5rem"></i>COVER</label></div>
                                            <div class="d-flex gap-2 bg-dark bg-opacity-50 rounded border border-white border-opacity-10 p-1">
                                                <div class="flex-grow-1 position-relative">
                                                    <span class="position-absolute top-50 start-0 translate-middle-y ms-2 super-small opacity-50">AWAL</span>
                                                    <input asp-for="DAC_Awal" class="hud-input text-end text-warning fw-bold font-monospace pe-2 h-100" style="text-shadow:0 0 8px rgba(250,204,21,0.4);" placeholder="-" />
                                                </div>
                                                <div class="border-start border-white border-opacity-10"></div>
                                                <div class="flex-grow-1 position-relative">
                                                    <span class="position-absolute top-50 start-0 translate-middle-y ms-2 super-small opacity-50">AKHIR</span>
                                                    <input asp-for="DAC_Akhir" class="hud-input text-end text-warning fw-bold font-monospace pe-2 h-100" style="text-shadow:0 0 8px rgba(250,204,21,0.4);" placeholder="-" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- DANDORI AKHIR -->
                            <div class="col-md-6">
                                <div class="border border-white border-opacity-10 rounded-2 p-2 bg-black bg-opacity-20">
                                    <div class="text-white opacity-50 super-small fw-bold tracking-widest mb-2 border-bottom border-warning border-opacity-25 pb-1">DANDORI AKHIR (REMAIN)</div>
                                    <div class="d-flex flex-column gap-2 mt-2">
                                        <div class="hud-pill-integrated border-white border-opacity-5 bg-black bg-opacity-40 p-2 rounded-1">
                                            <div class="mb-1"><label class="text-info super-small fw-bold"><i class="bi bi-circle-fill me-1" style="font-size:0.5rem"></i>INNER TUBE</label></div>
                                            <div class="d-flex gap-2 bg-dark bg-opacity-50 rounded border border-white border-opacity-10 p-1">
                                                <div class="flex-grow-1 position-relative">
                                                    <span class="position-absolute top-50 start-0 translate-middle-y ms-2 super-small opacity-50">AWAL</span>
                                                    <input asp-for="DRAI_Awal" class="hud-input text-end text-primary-glow fw-bold font-monospace pe-2 h-100" placeholder="-" />
                                                </div>
                                                <div class="border-start border-white border-opacity-10"></div>
                                                <div class="flex-grow-1 position-relative">
                                                    <span class="position-absolute top-50 start-0 translate-middle-y ms-2 super-small opacity-50">AKHIR</span>
                                                    <input asp-for="DRAI_Akhir" class="hud-input text-end text-primary-glow fw-bold font-monospace pe-2 h-100" placeholder="-" />
                                                </div>
                                            </div>
                                        </div>
                                        <div class="hud-pill-integrated border-white border-opacity-5 bg-black bg-opacity-40 p-2 rounded-1">
                                            <div class="mb-1"><label class="text-warning super-small fw-bold"><i class="bi bi-circle-fill me-1" style="font-size:0.5rem"></i>COVER</label></div>
                                            <div class="d-flex gap-2 bg-dark bg-opacity-50 rounded border border-white border-opacity-10 p-1">
                                                <div class="flex-grow-1 position-relative">
                                                    <span class="position-absolute top-50 start-0 translate-middle-y ms-2 super-small opacity-50">AWAL</span>
                                                    <input asp-for="DRAC_Awal" class="hud-input text-end text-warning fw-bold font-monospace pe-2 h-100" style="text-shadow:0 0 8px rgba(250,204,21,0.4);" placeholder="-" />
                                                </div>
                                                <div class="border-start border-white border-opacity-10"></div>
                                                <div class="flex-grow-1 position-relative">
                                                    <span class="position-absolute top-50 start-0 translate-middle-y ms-2 super-small opacity-50">AKHIR</span>
                                                    <input asp-for="DRAC_Akhir" class="hud-input text-end text-warning fw-bold font-monospace pe-2 h-100" style="text-shadow:0 0 8px rgba(250,204,21,0.4);" placeholder="-" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- RIGHT COLUMN: PROTOCOL + COMMANDS -->
                <div class="col-lg-5">
                    <div class="d-flex flex-column h-100 gap-3">

                        <!-- SYSTEM PROTOCOL ALERT -->
                        <div class="hud-card border-danger border-opacity-40 bg-danger bg-opacity-10 shadow-hud-red p-3 d-flex align-items-center gap-3">
                            <div class="hud-status-led led-red blink"></div>
                            <div>
                                <div class="text-danger fw-900 super-small tracking-widest mb-1"><i class="bi bi-shield-lock-fill me-1"></i>SYSTEM PROTOCOL</div>
                                <p class="text-white font-monospace super-small m-0 opacity-90 fw-bold">VERIFIKASI PARAMETER: AWAL / TENGAH / AKHIR PROSES.</p>
                            </div>
                        </div>

                        <!-- FINAL COMMANDS -->
                        <div class="hud-card p-3 flex-grow-1 d-flex flex-column bg-black bg-opacity-40 border-white border-opacity-10 shadow-hud-blue">
                            <div class="text-info-glow super-small fw-black mb-3 tracking-widest ps-1"><i class="bi bi-terminal-fill me-2"></i>FINAL COMMANDS</div>
                            
                            <div class="hud-pill-integrated border-white border-opacity-5 mb-3">
                                <label>OPERATOR (AUTHORIZED BY)</label>
                                <input asp-for="CreatedBy" id="CreatedBy" class="hud-input text-primary-glow font-black h-auto py-1" placeholder="ENTER NAME..." />
                            </div>

                            <div class="mt-auto d-flex gap-2">
                                <a asp-action="ParameterHistory" class="btn btn-hud-outline flex-grow-1 py-3 fw-bold small d-flex align-items-center justify-content-center gap-2" style="border-width:1px;">
                                    <i class="bi bi-x-lg"></i> CANCEL
                                </a>
                                <button type="button" class="btn btn-hud-primary flex-grow-3 py-3 fw-900 tracking-widest shadow-glow-primary border-0 rounded-1 d-flex align-items-center justify-content-center gap-2" style="font-size:1.1rem;" onclick="submitUpdateReport()">
                                    <i class="bi bi-cloud-arrow-up-fill fs-5"></i> UPDATE RECORD
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            </form>
    </div>
</div>

<style>
