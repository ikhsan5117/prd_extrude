    .reading-tab:hover:not(.active-tab) { border-color: rgba(14, 165, 233, 0.6); background: rgba(14, 165, 233, 0.1); transform: translateY(-2px); }

    .no-select { user-select: none; }
    .add-check-trigger { opacity: 0.6; transition: all 0.3s; padding: 8px 15px; border-radius: 8px; }
    .add-check-trigger:hover { opacity: 1; background: rgba(255,255,255,0.05); transform: translateX(5px); }

    .compact-hud td { padding: 4px 1px !important; }
    .compact-hud th { padding: 6px 1px !important; }
    .instrument-style { font-family: 'JetBrains Mono','Roboto Mono',monospace; }
    .group-lane { background: rgba(14,165,233,0.03); }
    .font-black { font-weight: 900 !important; font-size: 0.6rem !important; }
    .hud-check-box { position: relative; width: 32px; height: 32px; margin: 0 auto; cursor: pointer; }
    .hud-check-box input { position: absolute; opacity: 0; width: 100%; height: 100%; cursor: pointer; z-index: 2; margin: 0; }
    .hud-check-box span { position: absolute; top: 0; left: 0; height: 32px; width: 32px; background-color: rgba(15,23,42,0.6); border: 2px solid rgba(14,165,233,0.2); border-radius: 8px; transition: all 0.3s cubic-bezier(0.4,0,0.2,1); z-index: 1; }
    .hud-check-box:hover input ~ span { border-color: #0ea5e9; background: rgba(14,165,233,0.1); }
    .hud-check-box input:checked ~ span { background-color: #0ea5e9; border-color: white; box-shadow: 0 0 20px rgba(14,165,233,0.6); }
    .hud-check-box span:after { content: ""; position: absolute; display: none; left: 11px; top: 5px; width: 8px; height: 16px; border: solid white; border-width: 0 4px 4px 0; transform: rotate(45deg); }
    .hud-check-box input:checked ~ span:after { display: block; }
    .hud-pill-group { display: inline-flex; background: rgba(15,23,42,0.6); padding: 4px; border-radius: 8px; border: 1px solid rgba(14,165,233,0.2); width: 100%; gap: 4px; }
    .hud-pill-item { flex: 1; padding: 8px 4px; font-size: 0.75rem; font-weight: 900; color: rgba(255,255,255,0.3); border-radius: 6px; cursor: pointer; transition: all 0.2s cubic-bezier(0.4,0,0.2,1); text-transform: uppercase; text-align: center; border: 1px solid transparent; }
    .hud-pill-item input { display: none; }
    .hud-pill-item:has(input:checked) { background: #10b981; color: white; box-shadow: 0 0 15px rgba(16,185,129,0.5); border-color: rgba(255,255,255,0.2); }
