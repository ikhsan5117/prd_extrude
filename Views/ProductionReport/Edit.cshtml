                                                </div>
                                                <div class="border-start border-white border-opacity-10"></div>
                                                <div class="flex-grow-1 position-relative">
                                                    <span class="position-absolute top-50 start-0 translate-middle-y ms-2 super-small opacity-50">AKHIR</span>
                                                    <input asp-for="DAI_Akhir" class="hud-input text-end text-primary-glow fw-bold font-monospace pe-2 h-100" placeholder="-" />
                                                </div>
                                            </div>
                                        </div>
                                        <div class="hud-pill-integrated border-white border-opacity-5 bg-black bg-opacity-40 p-2 rounded-1">
                                            <div class="mb-1"><label class="text-warning super-small fw-bold"><i class="bi bi-circle-fill me-1" style="font-size:0.5rem"></i>COVER</label></div>
                                            <div class="d-flex gap-2 bg-dark bg-opacity-50 rounded border border-white border-opacity-10 p-1">
                                                <div class="flex-grow-1 position-relative">
                                                    <span class="position-absolute top-50 start-0 translate-middle-y ms-2 super-small opacity-50">AWAL</span>
                                                    <input asp-for="DAC_Awal" class="hud-input text-end text-warning fw-bold font-monospace pe-2 h-100" style="text-shadow:0 0 8px rgba(250,204,21,0.4);" placeholder="-" />
                                                </div>
                                                <div class="border-start border-white border-opacity-10"></div>
                                                <div class="flex-grow-1 position-relative">
                                                    <span class="position-absolute top-50 start-0 translate-middle-y ms-2 super-small opacity-50">AKHIR</span>
                                                    <input asp-for="DAC_Akhir" class="hud-input text-end text-warning fw-bold font-monospace pe-2 h-100" style="text-shadow:0 0 8px rgba(250,204,21,0.4);" placeholder="-" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- DANDORI AKHIR -->
                            <div class="col-md-6">
                                <div class="border border-white border-opacity-10 rounded-2 p-2 bg-black bg-opacity-20">
                                    <div class="text-white opacity-50 super-small fw-bold tracking-widest mb-2 border-bottom border-warning border-opacity-25 pb-1">DANDORI AKHIR (REMAIN)</div>
                                    <div class="d-flex flex-column gap-2 mt-2">
                                        <div class="hud-pill-integrated border-white border-opacity-5 bg-black bg-opacity-40 p-2 rounded-1">
                                            <div class="mb-1"><label class="text-info super-small fw-bold"><i class="bi bi-circle-fill me-1" style="font-size:0.5rem"></i>INNER TUBE</label></div>
                                            <div class="d-flex gap-2 bg-dark bg-opacity-50 rounded border border-white border-opacity-10 p-1">
                                                <div class="flex-grow-1 position-relative">
                                                    <span class="position-absolute top-50 start-0 translate-middle-y ms-2 super-small opacity-50">AWAL</span>
                                                    <input asp-for="DRAI_Awal" class="hud-input text-end text-primary-glow fw-bold font-monospace pe-2 h-100" placeholder="-" />
                                                </div>
                                                <div class="border-start border-white border-opacity-10"></div>
                                                <div class="flex-grow-1 position-relative">
                                                    <span class="position-absolute top-50 start-0 translate-middle-y ms-2 super-small opacity-50">AKHIR</span>
                                                    <input asp-for="DRAI_Akhir" class="hud-input text-end text-primary-glow fw-bold font-monospace pe-2 h-100" placeholder="-" />
                                                </div>
                                            </div>
                                        </div>
                                        <div class="hud-pill-integrated border-white border-opacity-5 bg-black bg-opacity-40 p-2 rounded-1">
                                            <div class="mb-1"><label class="text-warning super-small fw-bold"><i class="bi bi-circle-fill me-1" style="font-size:0.5rem"></i>COVER</label></div>
                                            <div class="d-flex gap-2 bg-dark bg-opacity-50 rounded border border-white border-opacity-10 p-1">
                                                <div class="flex-grow-1 position-relative">
                                                    <span class="position-absolute top-50 start-0 translate-middle-y ms-2 super-small opacity-50">AWAL</span>
                                                    <input asp-for="DRAC_Awal" class="hud-input text-end text-warning fw-bold font-monospace pe-2 h-100" style="text-shadow:0 0 8px rgba(250,204,21,0.4);" placeholder="-" />
                                                </div>
                                                <div class="border-start border-white border-opacity-10"></div>
                                                <div class="flex-grow-1 position-relative">
                                                    <span class="position-absolute top-50 start-0 translate-middle-y ms-2 super-small opacity-50">AKHIR</span>
                                                    <input asp-for="DRAC_Akhir" class="hud-input text-end text-warning fw-bold font-monospace pe-2 h-100" style="text-shadow:0 0 8px rgba(250,204,21,0.4);" placeholder="-" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- RIGHT COLUMN: PROTOCOL + COMMANDS -->
                <div class="col-lg-5">
                    <div class="d-flex flex-column h-100 gap-3">

                        <!-- SYSTEM PROTOCOL ALERT -->
                        <div class="hud-card border-danger border-opacity-40 bg-danger bg-opacity-10 shadow-hud-red p-3 d-flex align-items-center gap-3">
                            <div class="hud-status-led led-red blink"></div>
                            <div>
                                <div class="text-danger fw-900 super-small tracking-widest mb-1"><i class="bi bi-shield-lock-fill me-1"></i>SYSTEM PROTOCOL</div>
                                <p class="text-white font-monospace super-small m-0 opacity-90 fw-bold">VERIFIKASI PARAMETER: AWAL / TENGAH / AKHIR PROSES.</p>
                            </div>
                        </div>

                        <!-- FINAL COMMANDS -->
                        <div class="hud-card p-3 flex-grow-1 d-flex flex-column bg-black bg-opacity-40 border-white border-opacity-10 shadow-hud-blue">
                            <div class="text-info-glow super-small fw-black mb-3 tracking-widest ps-1"><i class="bi bi-terminal-fill me-2"></i>FINAL COMMANDS</div>
                            
                            <div class="hud-pill-integrated border-white border-opacity-5 mb-3">
                                <label>OPERATOR (AUTHORIZED BY)</label>
                                <input asp-for="CreatedBy" id="CreatedBy" class="hud-input text-primary-glow font-black h-auto py-1" placeholder="ENTER NAME..." />
                            </div>

                            <div class="mt-auto d-flex gap-2">
                                <a asp-action="ParameterHistory" class="btn btn-hud-outline flex-grow-1 py-3 fw-bold small d-flex align-items-center justify-content-center gap-2" style="border-width:1px;">
                                    <i class="bi bi-x-lg"></i> CANCEL
                                </a>
                                <button type="button" class="btn btn-hud-primary flex-grow-3 py-3 fw-900 tracking-widest shadow-glow-primary border-0 rounded-1 d-flex align-items-center justify-content-center gap-2" style="font-size:1.1rem;" onclick="submitUpdateReport()">
                                    <i class="bi bi-cloud-arrow-up-fill fs-5"></i> UPDATE RECORD
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            </form>
    </div>
</div>

<style>
    :root {
        --hud-primary: #0ea5e9;
        --hud-glow: #38bdf8;
        --hud-dark: #020617;
        --hud-card: rgba(15, 23, 42, 0.85);
        --hud-border: rgba(14, 165, 233, 0.3);
    }
    .production-blueprint { min-height: 100vh; background: var(--hud-dark); color: #f1f5f9; font-family: 'Inter', sans-serif; }
    .hud-pill { background: rgba(30,41,59,0.6); border: 1px solid var(--hud-border); border-radius: 8px; padding: 6px 16px; display: flex; flex-direction: column; transition: all 0.3s; }
    .hud-pill:focus-within { border-color: var(--hud-glow); box-shadow: 0 0 15px rgba(14,165,233,0.3); }
    .hud-pill label { font-size: 0.65rem; font-weight: 800; color: var(--hud-primary); letter-spacing: 1px; margin-bottom: 2px; }
    .hud-input { background: transparent; border: none; color: white; font-size: 0.95rem; padding: 0; outline: none; width: 100%; }
    .hud-card { background: var(--hud-card); border: 1px solid var(--hud-border); border-radius: 10px; overflow: hidden; backdrop-filter: blur(15px); }
    .hud-card-header { background: linear-gradient(90deg, rgba(14,165,233,0.15) 0%, transparent 100%); border-bottom: 1px solid rgba(14,165,233,0.3); padding: 10px 20px; display: flex; align-items: center; gap: 12px; }
    .hud-card-title { font-size: 0.85rem; font-weight: 900; letter-spacing: 2px; color: #0ea5e9; text-transform: uppercase; }
    .hud-card-icon { color: #0ea5e9; font-size: 1.1rem; }
    .die-card { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); position: relative; overflow: hidden; }
    .die-card:hover { background: rgba(14, 165, 233, 0.08) !important; border-color: rgba(14, 165, 233, 0.4) !important; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(0,0,0,0.3); }
    .die-card::before { content: ''; position: absolute; top: 0; left: 0; width: 3px; height: 100%; background: rgba(255,255,255,0.05); transition: all 0.3s; }
    .die-card:hover::before { background: var(--hud-primary); box-shadow: 0 0 10px var(--hud-primary); }

    .param-tile-modern { background: rgba(15, 23, 42, 0.4); border: 1px solid rgba(14, 165, 233, 0.2); }
    .hud-pill-integrated { background: rgba(30,41,59,0.4); border: 1px solid rgba(14,165,233,0.2); border-radius: 6px; padding: 8px 12px; display: flex; flex-direction: column; transition: all 0.3s; }
    .hud-pill-integrated:focus-within { border-color: #0ea5e9; background: rgba(14,165,233,0.1); box-shadow: 0 0 15px rgba(14,165,233,0.2); }
    .hud-pill-integrated label { font-size: 0.6rem; font-weight: 800; color: #38bdf8; letter-spacing: 1px; margin-bottom: 4px; text-transform: uppercase; }
    .hud-pill-integrated .hud-input { font-size: 0.85rem; background: transparent; border: none; color: white; padding: 0; width: 100%; outline: none; }
    .table-hud-unified { width: 100%; border-collapse: collapse; }
    .table-hud-unified th { padding: 12px; font-size: 0.65rem; font-weight: 800; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .table-hud-unified td { padding: 12px; vertical-align: middle; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .label-stack { display: flex; flex-direction: column; gap: 2px; }
    .label-main { font-size: 0.85rem; font-weight: 900; color: white; line-height: 1; }
    .label-sub { font-size: 0.6rem; font-weight: 700; color: #60a5fa; text-transform: uppercase; opacity: 0.8; }
    .hud-th-scan { background: rgba(14,165,233,0.05); color: #0ea5e9 !important; font-weight: 900 !important; }
    .hud-td-scan { background: rgba(0,0,0,0.2); padding: 8px 12px !important; }
    .hud-scan-group { display: flex; align-items: center; background: rgba(15,23,42,0.6); border: 1px solid rgba(14,165,233,0.2); border-radius: 6px; padding: 2px 4px; transition: all 0.3s; }
    .hud-scan-group:focus-within { border-color: #0ea5e9; box-shadow: 0 0 15px rgba(14,165,233,0.2); background: rgba(14,165,233,0.05); }
    .hud-input-scan { background: transparent; border: none; color: #0ea5e9; font-weight: 900; font-size: 0.85rem; padding: 8px; width: 100%; outline: none; letter-spacing: 1px; }
    .hud-scan-btn { background: rgba(14,165,233,0.1); border: none; color: #0ea5e9; padding: 6px 10px; border-radius: 4px; cursor: pointer; transition: all 0.2s; }
    .hud-scan-btn:hover { background: #0ea5e9; color: white; }
    .hud-input-underlined { background: transparent; border: none; border-bottom: 2px solid rgba(255,255,255,0.05); color: white; font-weight: 900; width: 100%; padding: 8px 0; text-align: center; transition: all 0.3s; font-size: 1.1rem; min-height: 46px; font-family: 'JetBrains Mono', monospace; }
    .hud-input-underlined:focus { outline: none; border-bottom-color: #3b82f6; background: rgba(59,130,246,0.05); }

    .vibrant-hud-input { background: rgba(255,255,255,0.05); border: 2px solid rgba(255,255,255,0.1); border-radius: 8px; color: white; text-align: center; font-family: 'JetBrains Mono', monospace; font-weight: 900; font-size: 1.8rem; height: 65px; width: 100%; outline: none; transition: all 0.3s; }
    .vibrant-hud-input:focus { background: rgba(255,255,255,0.1); border-color: var(--theme-color); box-shadow: 0 0 20px var(--theme-color); transform: translateY(-2px); }
    .param-tile-modern:hover { background: rgba(255,255,255,0.07) !important; border-color: rgba(255,255,255,0.2) !important; transform: translateY(-5px); }
    
    .active-tab { background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%) !important; color: white !important; box-shadow: 0 0 25px rgba(14, 165, 233, 0.6) !important; border-color: #7dd3fc !important; transform: translateY(-3px); }
