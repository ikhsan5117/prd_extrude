@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/html5-qrcode"></script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        let html5QrCode;
        
        // === MATERIAL LOT TRACKING STATE ===
        const materialState = {
            inner: [],
            middle: [],
            outer: [],
            yarn: []
        };

        function addMaterialRow(layer) {
            const listContainer = document.getElementById(`${layer}-lot-list`);
            const index = materialState[layer].length;
            
            if (index >= 10) {
                Swal.fire('PROCESS LIMIT', 'System supports a maximum of 10 batch lots per production cycle.', 'warning');
                return;
            }

            const rowId = `lot-${layer}-${Date.now()}`;
            const isYarn = (layer === 'yarn');
            const themeColor = layer === 'inner' ? 'info' : (layer === 'outer' ? 'warning' : (layer === 'middle' ? 'purple' : 'success'));
            const themeRgb = layer === 'inner' ? '14, 165, 233' : (layer === 'outer' ? '245, 158, 11' : (layer === 'middle' ? '167, 139, 250' : '16, 185, 129'));
            const themeHex = layer === 'inner' ? '#38bdf8' : (layer === 'outer' ? '#f59e0b' : (layer === 'middle' ? '#c4b5fd' : '#10b981'));
            
            const div = document.createElement('div');
            div.id = rowId;
            div.className = `row g-1 align-items-center mb-2`;
            div.innerHTML = `
                <div class="${isYarn ? 'col-10' : 'col-6'}">
                    <div class="hud-scan-group p-1" style="border-color: rgba(${themeRgb}, 0.25); background: rgba(15, 23, 42, 0.6); border-radius: 6px;">
                        <input type="text" class="hud-input-scan fw-bold w-100" style="font-size: 0.75rem; color: ${themeHex}; padding: 6px;" placeholder="LOT #${index + 1}..." data-layer="${layer}" data-type="lot" />
                        <button type="button" class="hud-scan-btn ms-1" style="color: ${themeHex};" onclick="openScannerForDynamicRow('${rowId}')"><i class="bi bi-upc-scan fs-6"></i></button>
                    </div>
                </div>
                ${!isYarn ? `
                <div class="col-4">
                    <div class="d-flex flex-column" style="background: rgba(15, 23, 42, 0.6); border: 1px solid rgba(${themeRgb}, 0.3); border-radius: 6px; padding: 2px 8px;">
                        <label class="font-black opacity-50 mb-0" style="font-size: 0.55rem; letter-spacing: 0.5px; color: ${themeHex};">SG VALUE</label>
                        <div class="d-flex align-items-center">
                            <span class="fw-900 me-1" style="font-size: 0.65rem; opacity: 0.6; color: ${themeHex};">🧪</span>
                            <input type="number" step="0.0001" class="hud-input font-monospace fw-black p-0 border-0 bg-transparent text-end flex-grow-1" style="font-size: 1rem; color: ${themeHex};" placeholder="0.0000" data-layer="${layer}" data-type="sg" />
                        </div>
                    </div>
                </div>
                ` : ''}
                <div class="col-2 text-center" style="min-width: 40px;">
                    <button type="button" onclick="removeMaterialRow('${layer}', '${rowId}')" class="btn btn-link text-danger p-0 border-0 shadow-none" title="REMOVE LOT">
                        <i class="bi bi-x-circle-fill fs-5"></i>
                    </button>
                </div>
            `;
            
            listContainer.appendChild(div);
            materialState[layer].push(rowId);
        }

        function removeMaterialRow(layer, rowId) {
            const el = document.getElementById(rowId);
            if (el) {
                el.style.opacity = '0';
                el.style.transform = 'translateX(20px)';
                el.style.transition = 'all 0.3s';
                setTimeout(() => {
                    el.remove();
                    materialState[layer] = materialState[layer].filter(id => id !== rowId);
                }, 300);
            }
        }

        function openScannerForDynamicRow(rowId) {
            const row = document.getElementById(rowId);
            if (!row) return;
            const input = row.querySelector('input[data-type="lot"]');
            if (!input) return;
            
            openScannerCustom((code) => {
                input.value = code;
                input.style.animation = 'pulse 0.5s';
            });
        }

        function openScannerCustom(callback) {
            Swal.fire({
                title: 'SCANNING LOT NUMBER',
                html: `
                    <div id="scanner-reader-container" style="width:100%;min-height:250px;background:#000;border-radius:8px;overflow:hidden;border:2px solid #0ea5e9;">
                        <div id="scanner-reader"></div>
                    </div>
                `,
                background: '#020617',
                color: '#0ea5e9',
                showConfirmButton: false,
                showCloseButton: true,
                width: '90%',
                didOpen: () => {
                    const customScanner = new Html5Qrcode("scanner-reader");
                    const config = { fps: 10, qrbox: { width: 220, height: 220 } };
                    
                    customScanner.start({ facingMode: "environment" }, config, (decodedText) => {
                        callback(decodedText);
                        customScanner.stop().then(() => {
                            Swal.close();
                            Swal.fire({ icon: 'success', title: 'SCANNED!', text: decodedText, toast: true, position: 'top-end', timer: 2000, showConfirmButton: false });
                        });
                    }).catch(err => {
                        document.getElementById('scanner-reader').innerHTML = `<div class="p-4 text-danger small">CAMERA ERROR: ${err}</div>`;
                    });
                },
                willClose: () => {
                    // Cleanup handled in callback
                }
            });
        }

        function getMaterialLotPayload() {
            const results = [];
            const layerIdMap = {
                inner: { std: 'InnerMaterial', actual: 'InnerMaterialActual' },
                outer: { std: 'OuterMaterial', actual: 'OuterMaterialActual' },
                middle: { std: 'MiddleMaterial', actual: 'MiddleMaterialActual' },
                yarn: { std: 'Yarn', actual: 'YarnActual' }
            };

            ['inner', 'outer', 'middle', 'yarn'].forEach(layer => {
                const container = document.getElementById(`${layer}-lot-list`);
                if (!container) return;
                const rows = container.querySelectorAll('.row');
                const ids = layerIdMap[layer];
                const stdMaterial = document.getElementById(ids.std)?.value || '';
                const actualMaterial = document.getElementById(ids.actual)?.value || '';
                
                rows.forEach(row => {
                    const lotInput = row.querySelector('input[data-type="lot"]');
                    const sgInput = row.querySelector('input[data-type="sg"]');
                    const lot = lotInput ? lotInput.value.trim() : '';
                    const sg = sgInput ? parseFloat(sgInput.value.replace(',', '.')) : null;
                    
                    if (lot || sg) {
                        results.push({
                            LayerType: layer.toUpperCase(),
                            LotNumber: lot,
                            SpecificGravity: sg,
                            StandardMaterial: stdMaterial,
                            ActualMaterial: actualMaterial
                        });
                    }
                });
            });

            return results;
        }

        async function openScanner(targetId) {
            Swal.fire({
                title: 'SCANNING MATERIAL LOT',
                html: `
                    <div id="reader-container" style="width:100%;min-height:250px;background:#000;border-radius:8px;overflow:hidden;border:2px solid #0ea5e9;">
                        <div id="reader"></div>
                    </div>
                    <div class="mt-3 small fw-bold" style="color:#0ea5e9;letter-spacing:2px;">POSITION BARCODE WITHIN FRAME</div>
                `,
                background: '#020617',
                color: '#0ea5e9',
                showConfirmButton: false,
                showCloseButton: true,
                width: '90%',
                didOpen: () => {
                    const config = { fps: 10, qrbox: { width: 250, height: 150 } };
                    html5QrCode = new Html5Qrcode("reader");
                    html5QrCode.start(
                        { facingMode: "environment" }, config,
                        (decodedText) => {
                            const el = document.getElementById(targetId);
                            if (el) { el.value = decodedText; el.dispatchEvent(new Event('input')); }
                            html5QrCode.stop().then(() => {
                                Swal.close();
                                if (window.navigator.vibrate) window.navigator.vibrate(100);
                                Swal.fire({ icon: 'success', title: 'SCANNED!', text: decodedText, toast: true, position: 'top-end', timer: 2500, showConfirmButton: false, background: '#0f172a', color: '#38bdf8' });
                            });
                        },
                        (err) => {}
                    ).catch(err => {
                        document.getElementById('reader').innerHTML = `<div class="p-4 text-danger small">CAMERA ERROR: ${err}</div>`;
                    });
                },
                willClose: () => {
                    if (html5QrCode && html5QrCode.isScanning) html5QrCode.stop();
                }
            });
        }

        // ══ SPS AUTOCOMPLETE FUNCTIONS ══
        let spsAutocompleteTimeout = null;
        let spsAutocompleteSelectedIndex = -1;
        let spsAutocompleteItems = [];

        async function handleSpsAutocomplete(query) {
            console.log('🔍 Autocomplete triggered, query:', query);
            clearTimeout(spsAutocompleteTimeout);
            
            if (!query || query.trim().length < 2) {
                console.log('⚠️ Query too short, closing dropdown');
                closeSpsAutocomplete();
                return;
            }
            
            spsAutocompleteTimeout = setTimeout(async () => {
                try {
                    console.log('📡 Fetching SPS items for:', query);
                    const res = await fetch(`/ProductionReport/SearchSpsItems?query=${encodeURIComponent(query)}`);
                    const data = await res.json();
                    console.log('✅ Received data:', data);
                    
                    if (data && data.length > 0) {
                        showSpsAutocomplete(data);
                    } else {
                        console.log('⚠️ No results found');
                        closeSpsAutocomplete();
                    }
                } catch (e) {
                    console.error('❌ Autocomplete error:', e);
                    closeSpsAutocomplete();
                }
            }, 300);
        }

        function showSpsAutocomplete(items) {
            console.log('📋 Showing autocomplete with items:', items);
            spsAutocompleteItems = items;
            spsAutocompleteSelectedIndex = -1;
            
            const dropdown = document.getElementById('spsAutocompleteResults');
            if (!dropdown) {
                console.error('❌ Dropdown element not found!');
                return;
            }
            
            dropdown.innerHTML = items.map((item, index) => `
                <div class="autocomplete-item" data-index="${index}" onclick="selectSpsItem('${item.itemCode}')" 
                     style="padding:12px 16px;cursor:pointer;border-bottom:1px solid rgba(255,255,255,0.05);transition:all 0.2s;">
                    <div style="color:#38bdf8;font-weight:700;font-family:monospace;font-size:0.95rem;">${item.itemCode}</div>
                    <div style="color:rgba(255,255,255,0.6);font-size:0.75rem;margin-top:2px;">${item.hoseType || 'No specification'}</div>
                </div>
            `).join('');
            
            dropdown.classList.remove('d-none');
            console.log('✅ Dropdown displayed with', items.length, 'items');
            
            // Add hover effects
            dropdown.querySelectorAll('.autocomplete-item').forEach(item => {
                item.addEventListener('mouseenter', function() {
                    dropdown.querySelectorAll('.autocomplete-item').forEach(i => i.style.background = 'transparent');
                    this.style.background = 'rgba(14,165,233,0.15)';
                });
                item.addEventListener('mouseleave', function() {
                    this.style.background = 'transparent';
                });
            });
        }

        function closeSpsAutocomplete() {
            document.getElementById('spsAutocompleteResults').classList.add('d-none');
            spsAutocompleteSelectedIndex = -1;
        }

        function handleSpsKeydown(event) {
            const dropdown = document.getElementById('spsAutocompleteResults');
            if (dropdown.classList.contains('d-none')) return;
            
            const items = dropdown.querySelectorAll('.autocomplete-item');
            
            if (event.key === 'ArrowDown') {
                event.preventDefault();
                spsAutocompleteSelectedIndex = Math.min(spsAutocompleteSelectedIndex + 1, items.length - 1);
                highlightSpsItem(items, spsAutocompleteSelectedIndex);
            } else if (event.key === 'ArrowUp') {
                event.preventDefault();
                spsAutocompleteSelectedIndex = Math.max(spsAutocompleteSelectedIndex - 1, -1);
                highlightSpsItem(items, spsAutocompleteSelectedIndex);
            } else if (event.key === 'Enter') {
                event.preventDefault();
                if (spsAutocompleteSelectedIndex >= 0 && spsAutocompleteItems[spsAutocompleteSelectedIndex]) {
                    selectSpsItem(spsAutocompleteItems[spsAutocompleteSelectedIndex].itemCode);
                } else {
                    const inputVal = document.getElementById('manualItemSearch').value;
                    if (inputVal) fetchSpsByItem(inputVal);
                }
            } else if (event.key === 'Escape') {
                closeSpsAutocomplete();
            }
        }

        function highlightSpsItem(items, index) {
            items.forEach((item, i) => {
                item.style.background = i === index ? 'rgba(14,165,233,0.25)' : 'transparent';
            });
            if (index >= 0 && items[index]) {
                items[index].scrollIntoView({ block: 'nearest' });
            }
        }

        function selectSpsItem(itemCode) {
            console.log('🎯 SPS item selected:', itemCode);
            document.getElementById('manualItemSearch').value = itemCode;
            closeSpsAutocomplete();
            fetchSpsByItem(itemCode);
        }

        async function fetchSpsByItem(code) {
            console.log('📡 Fetching full SPS data for:', code);
            Swal.fire({
                title: 'SEARCHING PROTOCOL...',
                text: `VALIDATING: ${code.trim().toUpperCase()}`,
                allowOutsideClick: false,
                background: '#020617', color: '#38bdf8',
                didOpen: () => { Swal.showLoading(); }
            });
            try {
                const machine = document.getElementById('MachineName')?.value || '';
                const res = await fetch(`/ProductionReport/GetSpsByItem?itemCode=${encodeURIComponent(code.trim())}&machineCode=${encodeURIComponent(machine)}`);
                if (!res.ok) throw new Error('NOT FOUND');
                const data = await res.json();
                console.log('✅ Full SPS data received:', data);
                if (data.success === false) throw new Error(data.message || 'NOT FOUND');
                Swal.close();
                applySpsToForm(data);
            } catch (e) {
                Swal.fire({
                    title: 'SYNC ERROR',
                    text: `Kode '${code}' tidak ditemukan di Database SPS!`,
                    icon: 'warning',
                    confirmButtonColor: '#0ea5e9',
                    background: '#0f172a', color: '#fff'
                });
            }
        }

        function applySpsToForm(sps, fromPlanning = false) {
            if (!sps) return;
            
            console.log('Applying SPS to form:', sps);
            
            // Update hidden SPS ID (Critical for database relationship)
            const spsIdEl = document.getElementById('SpsId');
            if (spsIdEl) {
                const spsId = sps.id || sps.Id || sps.spsId;
                spsIdEl.value = /^\d+$/.test(String(spsId ?? '').trim()) ? String(spsId).trim() : '';
                console.log('💾 SpsId set to:', spsIdEl.value || 'NULL');
                
                // Warn user if this is from Masterlist (no StandardParameterSettings record)
                if (!spsId && sps.source === 'Masterlist') {
                    console.warn('⚠️ This SPS is from Masterlist - SpsId will be NULL in database');
                }
            }

            // Update manual search display (show what was loaded)
            const manualSearchEl = document.getElementById('manualItemSearch');
            if (manualSearchEl) manualSearchEl.value = sps.itemList || sps.ItemList || '';
            
            // Sync ItemCode with SPS ItemList (Planning Master field)
            // This ensures ItemCode matches the SPS protocol being applied
            const itemCodeEl = document.getElementById('ItemCode');
            if (itemCodeEl) {
                itemCodeEl.value = sps.itemList || sps.ItemList || sps.productCode || sps.ProductCode || '';
            }

            // Populate header inputs
            const set = (id, val) => { const el = document.getElementById(id); if (el && val) el.value = val; };
            if (fromPlanning || !document.getElementById('DocNo').value) set('DocNo', sps.documentNumber || sps.DocumentNumber);
            if (fromPlanning || !document.getElementById('RevNo').value || document.getElementById('RevNo').value === '0') set('RevNo', sps.revisionNumber || sps.RevisionNumber);
            if (fromPlanning || !document.getElementById('HoseType').value) set('HoseType', sps.hoseType || sps.HoseType);
            if (fromPlanning || !document.getElementById('CustomerName').value) set('CustomerName', sps.customerName || sps.CustomerName);

            // Populate material standards (readonly column)
            // Explicitly set material names to form inputs to ensure they save to DB
            const innerMatEl = document.getElementById('InnerMaterial');
            if (innerMatEl) innerMatEl.value = sps.innerMaterial || sps.InnerMaterial || sps.innerTube || sps.InnerTube || '';
            
            const outerMatEl = document.getElementById('OuterMaterial');
            if (outerMatEl) outerMatEl.value = sps.outerMaterial || sps.OuterMaterial || sps.material || sps.Material || '';

            // Show/hide Middle material CARD based on LayerType
            const layerType = (sps.layerType || sps.LayerType || '').toLowerCase();
            const middleStd = sps.middleMaterial || sps.MiddleMaterial || sps.middleTube || sps.MiddleTube || '';
            const is3Layer = layerType.includes('3') || layerType.includes('triple') || layerType.includes('three') || middleStd !== '';
            
            const middleCard = document.getElementById('middleMaterialCard');
            const midEl = document.getElementById('MiddleMaterial');
            
            if (middleCard) {
                middleCard.style.display = is3Layer ? 'block' : 'none';
                if (is3Layer && midEl) {
                    midEl.value = middleStd;
                }
            }

            // Set Yarn/Benang field
            const yarnStd = sps.yarnType || sps.YarnType || sps.yarn || sps.Yarn || '';
            const yarnEl = document.getElementById('Yarn');
            if (yarnEl) yarnEl.value = yarnStd;

            // Populate parameter standards
            const setSpec = (id, val, minVal, maxVal, specId) => {
                const fmt = v => (v != null && v !== '' && v !== 0 && v !== '0') ? String(v) : '--';
                const stdStr = fmt(val);
                const minStr = fmt(minVal);
                const maxStr = fmt(maxVal);
                // Populate split min/std/max display for die cards
                const minEl = document.getElementById('spec_min_' + id);
                const stdEl = document.getElementById('spec_std_' + id);
                const maxEl = document.getElementById('spec_max_' + id);
                if (minEl) minEl.textContent = minStr;
                if (stdEl) stdEl.textContent = stdStr;
                if (maxEl) maxEl.textContent = maxStr;
                // Store pipe-range in hidden spec element for checkDieStatus validation
                const specKey = specId || id;
                const el = document.getElementById('spec_' + specKey);
                if (el) {
                    if (minStr !== '--' && maxStr !== '--') {
                        el.textContent = minStr + ' | ' + stdStr + ' | ' + maxStr;
                    } else {
                        el.textContent = stdStr;
                    }
                }
            };
            
            // Dies dimension standards
            setSpec('NippleDie',    sps.Nipple_Asli    || sps.nipple_Asli    || sps.Nipple    || sps.nipple,    sps.Nipple_Min    || sps.nipple_Min,    sps.Nipple_Max    || sps.nipple_Max,    'NippleDie');
            setSpec('TubeDie',      sps.TubeDie_Asli   || sps.tubeDie_Asli   || sps.TubeDie   || sps.tubeDie,   sps.TubeDie_Min   || sps.tubeDie_Min,   sps.TubeDie_Max   || sps.tubeDie_Max,   'TubeDie');
            setSpec('MiddleDie',    sps.MiddleDie_Asli  || sps.middleDie_Asli  || sps.MiddleDie  || sps.middleDie,  sps.MiddleDie_Min  || sps.middleDie_Min,  sps.MiddleDie_Max  || sps.middleDie_Max,  'MiddleDie');
            setSpec('CoverDie',     sps.CoverDie_Asli  || sps.coverDie_Asli  || sps.CoverDie  || sps.coverDie,  sps.CoverDie_Min  || sps.coverDie_Min,  sps.CoverDie_Max  || sps.coverDie_Max,  'CoverDie');
            setSpec('SpacerDie',    sps.SpacerDie_Asli || sps.spacerDie_Asli || sps.SpacerDie || sps.spacerDie, sps.SpacerDie_Min || sps.spacerDie_Min, sps.SpacerDie_Max || sps.spacerDie_Max, 'SpacerDie');
            setSpec('ToleranceDie', sps.ADistance_Asli || sps.aDistance_Asli || sps.ToleranceDie || sps.toleranceDie || '--', sps.ADistance_Min || sps.aDistance_Min, sps.ADistance_Max || sps.aDistance_Max, 'ToleranceDie');

            // AUTO-HIDE Middle Die Card if empty OR if it's a Double Layer machine
            const midVal = (sps.MiddleDie_Asli || sps.middleDie_Asli || sps.MiddleDie || sps.middleDie || '').toString().trim();
            
            // SUPER ROBUST Machine Detection
            const machineHidden = document.getElementById('MachineName')?.value || '';
            // Look for the machine name in the top navbar (it's in a div with text-warning fw-bold near 'Machine' label)
            const navbarMachine = Array.from(document.querySelectorAll('.navbar-right .text-warning.fw-bold'))
                                     .map(el => el.textContent.trim())
                                     .find(txt => txt.length > 0) || '';
            
            const isDoubleLayer = (machineHidden + navbarMachine).toUpperCase().includes('DL');
            const midCard = document.getElementById('die_card_MiddleDie');

            if (midCard) {
                if (isDoubleLayer || !midVal || midVal === '--' || midVal === '0' || midVal === '') {
                    midCard.classList.add('d-none');
                    midCard.style.setProperty('display', 'none', 'important');
                    console.log('🚫 FORCE HIDE Middle Die. Detected:', (machineHidden || navbarMachine), 'Value:', midVal);
                } else {
                    midCard.classList.remove('d-none');
                    midCard.style.display = 'block';
                    console.log('✅ SHOW Middle Die. Value:', midVal);
                }
            }

            // Map SPS fields to spec labels
            setSpec('HeadTempInner', sps.HeadTemp1_Asli || sps.headTemp1_Asli || sps.HeadTemp1 || sps.headTemp1, sps.HeadTemp1_Min || sps.headTemp1_Min, sps.HeadTemp1_Max || sps.headTemp1_Max);
            setSpec('Cylinder1TempInner', sps.Cylinder1_1_Asli || sps.cylinder1_1_Asli || sps.Cylinder1_1 || sps.cylinder1_1, sps.Cylinder1_1_Min || sps.cylinder1_1_Min, sps.Cylinder1_1_Max || sps.cylinder1_1_Max);
            setSpec('Cylinder2TempInner', sps.Cylinder2_1_Asli || sps.cylinder2_1_Asli || sps.Cylinder2_1 || sps.cylinder2_1, sps.Cylinder2_1_Min || sps.cylinder2_1_Min, sps.Cylinder2_1_Max || sps.cylinder2_1_Max);
            setSpec('Cylinder3TempInner', sps.Cylinder3_1_Asli || sps.cylinder3_1_Asli || sps.Cylinder3_1 || sps.cylinder3_1, sps.Cylinder3_1_Min || sps.cylinder3_1_Min, sps.Cylinder3_1_Max || sps.cylinder3_1_Max);
            setSpec('ScrewTempInner', sps.ScrewTemp1_Asli || sps.screwTemp1_Asli || sps.ScrewTemp1 || sps.screwTemp1, sps.ScrewTemp1_Min || sps.screwTemp1_Min, sps.ScrewTemp1_Max || sps.screwTemp1_Max);
            setSpec('ScrewSpeedInner', sps.ScrewSpeed1_Asli || sps.screwSpeed1_Asli || sps.ScrewSpeed1 || sps.screwSpeed1, sps.ScrewSpeed1_Min || sps.screwSpeed1_Min, sps.ScrewSpeed1_Max || sps.screwSpeed1_Max);
            setSpec('FeedRollRatioInner', sps.FeedRollRatio1_Asli || sps.feedRollRatio1_Asli || sps.FeedRollRatio1 || sps.feedRollRatio1 || sps.Feed1_Asli || sps.feed1_Asli || sps.Feed1 || sps.feed1, sps.FeedRollRatio1_Min || sps.feedRollRatio1_Min || sps.Feed1_Min || sps.feed1_Min, sps.FeedRollRatio1_Max || sps.feedRollRatio1_Max || sps.Feed1_Max || sps.feed1_Max);
            setSpec('PressureInner', sps.Pressure1_Asli || sps.pressure1_Asli || sps.Pressure1 || sps.pressure1, sps.Pressure1_Min || sps.pressure1_Min, sps.Pressure1_Max || sps.pressure1_Max);

            setSpec('HeadTempOuter', sps.HeadTemp2_Asli || sps.headTemp2_Asli || sps.HeadTemp2 || sps.headTemp2, sps.HeadTemp2_Min || sps.headTemp2_Min, sps.HeadTemp2_Max || sps.headTemp2_Max);
            setSpec('Cylinder1TempOuter', sps.Cylinder1_2_Asli || sps.cylinder1_2_Asli || sps.Cylinder1_2 || sps.cylinder1_2, sps.Cylinder1_2_Min || sps.cylinder1_2_Min, sps.Cylinder1_2_Max || sps.cylinder1_2_Max);
            setSpec('Cylinder2TempOuter', sps.Cylinder2_2_Asli || sps.cylinder2_2_Asli || sps.Cylinder2_2 || sps.cylinder2_2, sps.Cylinder2_2_Min || sps.cylinder2_2_Min, sps.Cylinder2_2_Max || sps.cylinder2_2_Max);
            setSpec('Cylinder3TempOuter', sps.Cylinder3_2_Asli || sps.cylinder3_2_Asli || sps.Cylinder3_2 || sps.cylinder3_2, sps.Cylinder3_2_Min || sps.cylinder3_2_Min, sps.Cylinder3_2_Max || sps.cylinder3_2_Max);
            setSpec('ScrewTempOuter', sps.ScrewTemp2_Asli || sps.screwTemp2_Asli || sps.ScrewTemp2 || sps.screwTemp2, sps.ScrewTemp2_Min || sps.screwTemp2_Min, sps.ScrewTemp2_Max || sps.screwTemp2_Max);
            setSpec('ScrewSpeedOuter', sps.ScrewSpeed2_Asli || sps.screwSpeed2_Asli || sps.ScrewSpeed2 || sps.screwSpeed2, sps.ScrewSpeed2_Min || sps.screwSpeed2_Min, sps.ScrewSpeed2_Max || sps.screwSpeed2_Max);
            setSpec('FeedRollRatioOuter', sps.FeedRollRatio2_Asli || sps.feedRollRatio2_Asli || sps.FeedRollRatio2 || sps.feedRollRatio2 || sps.Feed2_Asli || sps.feed2_Asli || sps.Feed2 || sps.feed2, sps.FeedRollRatio2_Min || sps.feedRollRatio2_Min || sps.Feed2_Min || sps.feed2_Min, sps.FeedRollRatio2_Max || sps.feedRollRatio2_Max || sps.Feed2_Max || sps.feed2_Max);
            setSpec('PressureOuter', sps.Pressure2_Asli || sps.pressure2_Asli || sps.Pressure2 || sps.pressure2, sps.Pressure2_Min || sps.pressure2_Min, sps.Pressure2_Max || sps.pressure2_Max);

            setSpec('SpiralSpeed', sps.SpiralSpeed_Asli || sps.spiralSpeed_Asli || sps.SpiralSpeed || sps.spiralSpeed, sps.SpiralSpeed_Min || sps.spiralSpeed_Min, sps.SpiralSpeed_Max || sps.spiralSpeed_Max);
            setSpec('SpiralPitchSetting', sps.SpiralPitchSetting_Asli || sps.spiralPitchSetting_Asli || sps.SpiralPitchSetting || sps.spiralPitchSetting, sps.SpiralPitchSetting_Min || sps.spiralPitchSetting_Min, sps.SpiralPitchSetting_Max || sps.spiralPitchSetting_Max);
            setSpec('SpiralPitchDisplay', sps.SpiralPitchDisplay_Asli || sps.spiralPitchDisplay_Asli || sps.SpiralPitchDisplay || sps.spiralPitchDisplay, sps.SpiralPitchDisplay_Min || sps.spiralPitchDisplay_Min, sps.SpiralPitchDisplay_Max || sps.spiralPitchDisplay_Max);

            setSpec('HoseSpeed', sps.HoseSpeed_Asli || sps.hoseSpeed_Asli || sps.HoseSpeed || sps.hoseSpeed, sps.HoseSpeed_Min || sps.hoseSpeed_Min, sps.HoseSpeed_Max || sps.hoseSpeed_Max);
            setSpec('ConveyorRatio', sps.ConveyorRatio_Asli || sps.conveyorRatio_Asli || sps.ConveyorRatio || sps.conveyorRatio, sps.ConveyorRatio_Min || sps.conveyorRatio_Min, sps.ConveyorRatio_Max || sps.conveyorRatio_Max);

            // Populate Emboss Marking Date if empty
            const dateEl = document.getElementById('EmbossMarkDate');
            if (dateEl && !dateEl.value) {
                dateEl.value = new Date().toISOString().split('T')[0];
            }

            // --- MESH MAPPING LOGIC ---
            const innerMesh = (sps.meshScreen || sps.MeshScreen || sps.meshScreen1 || sps.MeshScreen1 || '').toString();
            const outerMesh = (sps.meshScreen2 || sps.MeshScreen2 || '').toString();
            
            const stdMeshInnerEl = document.getElementById('std_MeshInner');
            const stdMeshOuterEl = document.getElementById('std_MeshOuter');
            if (stdMeshInnerEl) stdMeshInnerEl.innerText = innerMesh || '--';
            if (stdMeshOuterEl) stdMeshOuterEl.innerText = outerMesh || '--';

            // Auto-check checkboxes based on standard string
                                             // Update labels and auto-check checkboxes
                                             function parseAndApplyMesh(meshStr, layerType) {
                                                 if (!meshStr) return;
                                                 // Support splitting by comma, x, *, or ×
                                                 const parts = meshStr.split(/[,x*×]/).map(s => s.trim()).filter(s => s !== '');
                                                 
                                                 // Update Labels
                                                 const label1 = document.getElementById(`label_Mesh${layerType}1`);
                                                 const label2 = document.getElementById(`label_Mesh${layerType}2`);
                                                 if (label1 && parts[0]) label1.innerText = parts[0];
                                                 if (label2 && parts[1]) label2.innerText = parts[1];

                                                 // Auto-check
                                                 const check1 = document.getElementById(`Mesh${layerType}10Before`);
                                                 const check2 = document.getElementById(`Mesh${layerType}40Before`);
                                                 if (check1) check1.checked = !!parts[0];
                                                 if (check2) check2.checked = !!parts[1];
                                             }

                                             parseAndApplyMesh(innerMesh, 'Inner');
                                             parseAndApplyMesh(outerMesh, 'Outer');

            const markingStd = sps.markingStandard || sps.MarkingStandard || '';
            const stdMarkingEl = document.getElementById('std_Marking');
            if (stdMarkingEl) stdMarkingEl.innerText = 'STD: ' + (markingStd || '--');

            Swal.fire({
                icon: 'success', title: 'SPS SYNC SUCCESS',
                text: `Protokol ${sps.hoseType || sps.HoseType || ''} berhasil dimuat!`,
                toast: true, position: 'top-end', timer: 3000,
                showConfirmButton: false, background: '#0f172a', color: '#38bdf8'
            });
        }

        // ══ DYNAMIC READINGS LOGIC ══
        let pReadings = [];
        let activeTabIndex = 0;

        // Auto-reveal Middle row on page load if the model already has middle material data
        document.addEventListener('DOMContentLoaded', () => {
            const hasMiddle = @Html.Raw(
                (Model?.MiddleMaterial != null || Model?.MiddleMaterialActual != null || Model?.MiddleMaterialLotNo != null) ? "true" : "false"
            );
            if (hasMiddle) {
                const row = document.getElementById('middleMaterialRow');
                if (row) row.style.display = '';
            }
        });

        // Load existing readings from Model
        const initialReadings = @Html.Raw(Json.Serialize((Model?.ProductionReadings ?? new List<ProductionReading>()).OrderBy(r => r.ReadingTime).Select(r => new {
            HeadTempInner = r.HeadTempInner?.ToString(),
            Cylinder1TempInner = r.Cylinder1TempInner?.ToString(),
            Cylinder2TempInner = r.Cylinder2TempInner?.ToString(),
            Cylinder3TempInner = r.Cylinder3TempInner?.ToString(),
            ScrewTempInner = r.ScrewTempInner?.ToString(),
            ScrewSpeedInner = r.ScrewSpeedInner?.ToString(),
            FeedRollRatioInner = r.FeedRollRatioInner?.ToString(),
            PressureInner = r.PressureInner?.ToString(),
            HeadTempOuter = r.HeadTempOuter?.ToString(),
            Cylinder1TempOuter = r.Cylinder1TempOuter?.ToString(),
            Cylinder2TempOuter = r.Cylinder2TempOuter?.ToString(),
            Cylinder3TempOuter = r.Cylinder3TempOuter?.ToString(),
            ScrewTempOuter = r.ScrewTempOuter?.ToString(),
            ScrewSpeedOuter = r.ScrewSpeedOuter?.ToString(),
            FeedRollRatioOuter = r.FeedRollRatioOuter?.ToString(),
            PressureOuter = r.PressureOuter?.ToString(),
            SpiralSpeed = r.SpiralSpeed?.ToString(),
            SpiralPitchSetting = r.SpiralPitchSetting?.ToString(),
            SpiralPitchDisplay = r.SpiralPitchDisplay?.ToString(),
            PresetValue = r.PresetValue?.ToString(),
            ControlValue = r.ControlValue?.ToString(),
            HoseSpeed = r.HoseSpeed?.ToString(),
            TakeupConveyorSpeed = r.TakeupConveyorSpeed?.ToString(),
            CoolConveyorSpeed = r.CoolConveyorSpeed?.ToString(),
            ConveyorRatio = r.ConveyorRatio?.ToString(),
            UnsmoothSurface = r.UnsmoothSurface?.ToString(),
            ChillerWaterTemp = r.ChillerWaterTemp?.ToString(),
            CaterpillarGap = r.CaterpillarGap?.ToString(),
            ReadingTime = r.ReadingTime.ToString("yyyy-MM-ddTHH:mm:ss")
        }).ToList()));

        // Transform to match expected format { data: {...} }
        pReadings = initialReadings.length > 0 ? initialReadings.map(r => ({ data: r })) : [{ data: {} }];

        function renderTabs() {
            const container = document.getElementById('readingsTabs');
            container.innerHTML = '';
            pReadings.forEach((p, idx) => {
                const btn = document.createElement('div');
                btn.className = `reading-tab d-flex flex-column align-items-center justify-content-center ${idx === activeTabIndex ? 'active-tab shadow-glow-primary' : ''}`;
                btn.style.minWidth = "80px";
                btn.style.height = "55px";
                btn.style.borderRadius = "8px";
                btn.style.cursor = "pointer";
                btn.style.transition = "all 0.3s";
                
                let timeStr = "--:--";
                const rt = p.data ? (p.data.ReadingTime || p.data.readingTime) : null;
                if (rt) {
                    try {
                        const d = new Date(rt);
                        if (!isNaN(d.getTime())) {
                            timeStr = d.getHours().toString().padStart(2, '0') + ":" + d.getMinutes().toString().padStart(2, '0');
                        }
                    } catch(e) {}
                }
                
                btn.innerHTML = `
                    <div style="font-size:0.55rem; font-weight:bold; opacity:0.8; letter-spacing:1px; margin-bottom: 2px;">P-${idx + 1}</div>
                    <div style="font-size:1.1rem; font-weight:900; line-height:1;">${timeStr}</div>
                `;
                btn.onclick = () => switchTab(idx);
                container.appendChild(btn);
            });
        }

        function switchTab(idx) {
            activeTabIndex = idx;
            renderTabs();
            loadCurrentReadingToInputs();
        }

        function loadCurrentReadingToInputs() {
            const data = pReadings[activeTabIndex].data;
            const inputs = document.querySelectorAll('.vibrant-hud-input');
            inputs.forEach(input => {
                const key = input.id.replace('input_', '');
                let val = data[key];
                if (val === undefined) {
                    const camelKey = key.charAt(0).toLowerCase() + key.slice(1);
                    val = data[camelKey];
                }
                
                if (val !== undefined && val !== null && val !== '') {
                    // C# decimal serialization might keep trailing zeros (e.g. "6,1000" or "12.0000")
                    if (typeof val === 'string' && /^-?\d+([.,]\d+)?$/.test(val)) {
                        val = val.replace(/([.,]\d*?[1-9])0+$/, '$1').replace(/[.,]0+$/, '');
                    }
                }
                
                input.value = (val !== undefined && val !== null) ? val : '';
            });
        }

        function updateReadingData(key, val) {
            const data = pReadings[activeTabIndex].data;
            const camelKey = key.charAt(0).toLowerCase() + key.slice(1);
            if (data[camelKey] !== undefined) {
                data[camelKey] = val;
            } else {
                data[key] = val;
            }
        }

        function addReadingPoint() {
            const now = new Date();
            const timeFormatted = now.toISOString(); // yyyy-MM-ddTHH:mm:ss.sssZ
            pReadings.push({ data: { ReadingTime: timeFormatted } });
            switchTab(pReadings.length - 1);
            Swal.fire({ icon: 'info', title: 'NEW CHECK ADDED', text: `Point P-${pReadings.length} initialized at ${now.getHours().toString().padStart(2,'0')}:${now.getMinutes().toString().padStart(2,'0')}.`, toast: true, position: 'top-end', timer: 2000, showConfirmButton: false, background: '#0f172a', color: '#38bdf8' });
        }



        // === PLANNING SEARCH VARIABLES ===
        let planningItemsCache = [];
        let planningResultItems = [];
        let planningResultIndex = -1;
        let userHasSelectedData = false;

        // === PLANNING SEARCH FUNCTIONS ===
        async function refreshPlanningItems() {
            const dateInput = document.getElementById('ProductionDate');
            const shiftInput = document.getElementById('Shift');
            const planningInput = document.getElementById('planningSearch');
            
            if (!dateInput || !shiftInput || !planningInput) return;
            
            const date = dateInput.value;
            const shift = shiftInput.value;
            
            if (!date || !shift) return;

            planningInput.placeholder = 'LOADING PLANNING...';
            // planningInput.disabled = true; // Don't disable to keep user input focus

            try {
                const res = await fetch(`/ProductionReport/GetPlanningItems?date=${date}&shift=${encodeURIComponent(shift)}`);
                planningItemsCache = await res.json();
                planningResultItems = planningItemsCache;
                planningResultIndex = -1;

                if (planningItemsCache.length > 0) {
                    planningInput.placeholder = `SEARCH PLANNING (${planningItemsCache.length} ITEMS)`;
                    if (document.activeElement === planningInput) {
                        renderPlanningResults(planningResultItems, true);
                    }
                } else {
                    planningInput.placeholder = 'NO ITEMS IN PLAN FOR THIS DATE/SHIFT';
                }
            } catch (error) {
                console.error('Failed to refresh planning items:', error);
                planningInput.placeholder = 'ERROR LOADING PLANNING';
            }
        }

        function filterPlanningResults(query) {
            const sanitizedQuery = query.trim().toUpperCase();
            // If query starts with [ and ends with ] something, it's likely an existing selection, don't filter or show all
            if (sanitizedQuery.startsWith('[') && sanitizedQuery.includes(']')) {
                 // Keep showing but maybe don't filter
            }

            const results = sanitizedQuery.length === 0
                ? planningItemsCache
                : planningItemsCache.filter(item =>
                    (item.itemCode && item.itemCode.toUpperCase().includes(sanitizedQuery)) ||
                    (item.itemName && item.itemName.toUpperCase().includes(sanitizedQuery))
                );

            planningResultItems = results;
            planningResultIndex = -1;
            renderPlanningResults(results, sanitizedQuery.length === 0);
        }

        function renderPlanningResults(items, showAll = false) {
            const container = document.getElementById('planningResults');
            if (!container) return;
            container.innerHTML = '';

            if (items.length === 0) {
                container.innerHTML = `<div class="planning-result-item" style="text-align:center; opacity:0.5; pointer-events:none;">
                    <div class="planning-result-code">--- NO MATCHES FOUND ---</div>
                </div>`;
                container.classList.remove('d-none');
                return;
            }

            const header = document.createElement('div');
            header.style.cssText = 'padding:10px 15px;font-size:9px;font-weight:900;color:#0ea5e9;letter-spacing:2px;text-transform:uppercase;border-bottom:1px solid rgba(255,255,255,0.05);margin-bottom:8px;opacity:0.7;display:flex;align-items:center;justify-content:space-between;';
            header.innerHTML = `<span>PLANNING RESULTS (${items.length})</span> <i class="bi bi-funnel-fill"></i>`;
            container.appendChild(header);

            items.forEach((item, index) => {
                const hasSps = item.hasSps === true;
                const spsBadge = hasSps
                    ? `<span style="font-size:8px;font-weight:900;color:#10b981;background:rgba(16,185,129,0.15);padding:1px 6px;border-radius:20px;border:1px solid rgba(16,185,129,0.4);white-space:nowrap;"><i class="bi bi-check-circle-fill me-1"></i>SPS</span>`
                    : `<span style="font-size:8px;font-weight:900;color:#ef4444;background:rgba(239,68,68,0.12);padding:1px 6px;border-radius:20px;border:1px solid rgba(239,68,68,0.35);white-space:nowrap;"><i class="bi bi-x-circle-fill me-1"></i>NO SPS</span>`;

                const div = document.createElement('div');
                div.className = 'planning-result-item';
                if (hasSps) div.style.borderLeft = '3px solid #10b981';
                div.innerHTML = `
                    <div style="display:flex;justify-content:space-between;align-items:center;width:100%;gap:8px;">
                        <div class="planning-result-code">${item.itemCode}</div>
                        <div style="display:flex;gap:4px;align-items:center;">
                            ${item.machineName ? `<div class="machine-badge-mini">${item.machineName}</div>` : ''}
                            ${spsBadge}
                        </div>
                    </div>
                    <div class="planning-result-name">${item.itemName || 'NO DESCRIPTION'}</div>
                `;
                div.onclick = () => selectPlanningItem(item);
                container.appendChild(div);
            });

            container.classList.remove('d-none');
        }

        function selectPlanningItem(item) {
            userHasSelectedData = true;
            const planningInput = document.getElementById('planningSearch');
            if (planningInput) {
                planningInput.value = `[${item.itemCode}] ${item.itemName}`;
            }
            document.getElementById('planningResults')?.classList.add('d-none');

            // Update hidden item code
            const itemCodeField = document.getElementById('ItemCode');
            if (itemCodeField) {
                itemCodeField.value = item.itemCode;
            }

            // Update hose type in form
            const hoseInput = document.getElementById('HoseType');
            if (hoseInput) hoseInput.value = item.itemName || item.itemCode; 
            
            // Fetch full SPS details
            fetchSpsByItem(item.itemCode);
        }

        function openPlanningDropdown() {
            const results = document.getElementById('planningResults');
            if (results && planningItemsCache.length > 0) {
                results.classList.remove('d-none');
                renderPlanningResults(planningResultItems, true);
            } else {
                refreshPlanningItems();
            }
        }

        // Initialize on load
        window.addEventListener('DOMContentLoaded', () => {
            renderTabs();
            loadCurrentReadingToInputs();
            loadExistingMaterialLots();
            
            // Initialize Planning Items
            refreshPlanningItems();
            
            // Update Planning items when date or shift changes
            document.getElementById('ProductionDate')?.addEventListener('change', refreshPlanningItems);
            document.getElementById('Shift')?.addEventListener('change', refreshPlanningItems);

            // Close dropdowns on outside click
            document.addEventListener('click', (e) => {
                const planningContainer = document.querySelector('.planning-master-container');
                if (planningContainer && !planningContainer.contains(e.target)) {
                    document.getElementById('planningResults')?.classList.add('d-none');
                }
            });

            @if (ViewBag.Sps != null) {
                <text>
                applySpsToForm(@Html.Raw(Json.Serialize(ViewBag.Sps)));
                </text>
            }
            @if (ViewBag.Sps == null && !string.IsNullOrWhiteSpace(Model?.ItemCode)) {
                <text>
                console.log('🔄 Auto-loading SPS for ItemCode:', '@Model?.ItemCode');
                fetchSpsByItem('@Model?.ItemCode');
                </text>
            }
        });

        function loadExistingMaterialLots() {
            @if (Model?.MaterialLots != null && Model.MaterialLots.Any()) {
                <text>
                const existingLots = @Html.Raw(Json.Serialize(Model.MaterialLots.Select(m => new { m.LayerType, m.LotNumber, m.SGValue })));
                console.log('Loading existing material lots:', existingLots);
                
                // Check if there are any middle layer lots to show the card
                const hasMiddle = existingLots.some(lot => (lot.layerType || lot.LayerType || '').toLowerCase() === 'middle');
                if (hasMiddle) {
                    const middleCard = document.getElementById('middleMaterialCard');
                    if (middleCard) middleCard.style.display = 'block';
                }
                
                existingLots.forEach(lot => {
                    const layer = (lot.layerType || lot.LayerType || '').toLowerCase();
                    if (!layer) return;
                    
                    // Add new row
                    const listContainer = document.getElementById(`${layer}-lot-list`);
                    if (!listContainer) return;
                    
                    const index = materialState[layer].length;
                    const rowId = `lot-${layer}-${Date.now()}-${index}`;
                    const isYarn = (layer === 'yarn');
                    const themeColor = layer === 'inner' ? 'info' : (layer === 'outer' ? 'warning' : (layer === 'middle' ? 'purple' : 'success'));
                    const themeRgb = layer === 'inner' ? '14, 165, 233' : (layer === 'outer' ? '245, 158, 11' : (layer === 'middle' ? '167, 139, 250' : '16, 185, 129'));
                    const themeHex = layer === 'inner' ? '#38bdf8' : (layer === 'outer' ? '#f59e0b' : (layer === 'middle' ? '#c4b5fd' : '#10b981'));
                    
                    const div = document.createElement('div');
                    div.id = rowId;
                    div.className = `row g-1 align-items-center mb-2`;
                    div.innerHTML = `
                        <div class="${isYarn ? 'col-10' : 'col-6'}">
                            <div class="hud-scan-group p-1" style="border-color: rgba(${themeRgb}, 0.25); background: rgba(15, 23, 42, 0.6); border-radius: 6px;">
                                <input type="text" class="hud-input-scan fw-bold w-100" style="font-size: 0.75rem; color: ${themeHex}; padding: 6px;" placeholder="LOT #${index + 1}..." data-layer="${layer}" data-type="lot" value="${lot.lotNumber || lot.LotNumber || ''}" />
                                <button type="button" class="hud-scan-btn ms-1" style="color: ${themeHex};" onclick="openScannerForDynamicRow('${rowId}')"><i class="bi bi-upc-scan fs-6"></i></button>
                            </div>
                        </div>
                        ${!isYarn ? `
                        <div class="col-4">
                            <div class="d-flex flex-column" style="background: rgba(15, 23, 42, 0.6); border: 1px solid rgba(${themeRgb}, 0.3); border-radius: 6px; padding: 2px 8px;">
                                <label class="font-black opacity-50 mb-0" style="font-size: 0.55rem; letter-spacing: 0.5px; color: ${themeHex};">SG VALUE</label>
                                <div class="d-flex align-items-center">
                                    <span class="fw-900 me-1" style="font-size: 0.65rem; opacity: 0.6; color: ${themeHex};">🧪</span>
                                    <input type="number" step="0.0001" class="hud-input font-monospace fw-black p-0 border-0 bg-transparent text-end flex-grow-1" style="font-size: 1rem; color: ${themeHex};" placeholder="0.0000" data-layer="${layer}" data-type="sg" value="${lot.sgValue || lot.SGValue || ''}" />
                                </div>
                            </div>
                        </div>
                        ` : ''}
                        <div class="col-2 text-center" style="min-width: 40px;">
                            <button type="button" onclick="removeMaterialRow('${layer}', '${rowId}')" class="btn btn-link text-danger p-0 border-0 shadow-none" title="REMOVE LOT">
                                <i class="bi bi-x-circle-fill fs-5"></i>
                            </button>
                        </div>
                    `;
                    
                    listContainer.appendChild(div);
                    materialState[layer].push(rowId);
                });
                </text>
            }
        }

        async function submitUpdateReport() {
            const payload = {
                Id: document.querySelector('input[name="Id"]').value,
                DocumentNumber: document.getElementById('DocNo').value,
                RevisionNumber: parseInt(document.getElementById('RevNo').value) || 0,
                ProductionDate: document.getElementById('ProductionDate').value,
                Shift: document.getElementById('Shift').value,
                CustomerName: document.getElementById('CustomerName').value,
                HoseType: document.getElementById('HoseType').value,
                ItemCode: document.getElementById('ItemCode').value,
                SpsId: document.getElementById('SpsId')?.value || null,

                InnerMaterial: document.getElementById('InnerMaterial')?.value || document.querySelector('input[name="InnerMaterial"]')?.value || '',
                InnerMaterialActual: document.getElementById('InnerMaterialActual')?.value || document.querySelector('input[name="InnerMaterialActual"]')?.value || '',
                InnerMaterialLotNo: '', // Deprecated, use MaterialLots array
                OuterMaterial: document.getElementById('OuterMaterial')?.value || document.querySelector('input[name="OuterMaterial"]')?.value || '',
                OuterMaterialActual: document.getElementById('OuterMaterialActual')?.value || document.querySelector('input[name="OuterMaterialActual"]')?.value || '',
                OuterMaterialLotNo: '', // Deprecated, use MaterialLots array
                Yarn: document.getElementById('Yarn')?.value || document.querySelector('input[name="Yarn"]')?.value || '',
                YarnActual: document.getElementById('YarnActual')?.value || document.querySelector('input[name="YarnActual"]')?.value || '',
                YarnLotNo: '', // Deprecated, use MaterialLots array
                MiddleMaterial: document.getElementById('MiddleMaterial')?.value || '',
                MiddleMaterialActual: document.getElementById('MiddleMaterialActual')?.value || '',
                MiddleMaterialLotNo: '', // Deprecated, use MaterialLots array

                NippleDieOK: document.querySelector('input[name="NippleDieOK"]:checked')?.value === 'true',
                NippleDieInitial: document.querySelector('input[name="NippleDieInitial"]').value,
                NippleDieFinal: document.querySelector('input[name="NippleDieFinal"]').value,
                TubeDieOK: document.querySelector('input[name="TubeDieOK"]:checked')?.value === 'true',
                TubeDieInitial: document.querySelector('input[name="TubeDieInitial"]').value,
                TubeDieFinal: document.querySelector('input[name="TubeDieFinal"]').value,
                MiddleDieOK: document.querySelector('input[name="MiddleDieOK"]:checked')?.value === 'true',
                MiddleDieInitial: document.querySelector('input[name="MiddleDieInitial"]').value,
                MiddleDieFinal: document.querySelector('input[name="MiddleDieFinal"]').value,
                CoverDieOK: document.querySelector('input[name="CoverDieOK"]:checked')?.value === 'true',
                CoverDieInitial: document.querySelector('input[name="CoverDieInitial"]').value,
                CoverDieFinal: document.querySelector('input[name="CoverDieFinal"]').value,
                SpacerDieOK: document.querySelector('input[name="SpacerDieOK"]:checked')?.value === 'true',
                SpacerDieInitial: document.querySelector('input[name="SpacerDieInitial"]').value,
                SpacerDieFinal: document.querySelector('input[name="SpacerDieFinal"]').value,
                ToleranceDieOK: document.querySelector('input[name="ToleranceDieOK"]:checked')?.value === 'true',
                ToleranceInitial: document.querySelector('input[name="ToleranceInitial"]').value,
                ToleranceFinal: document.querySelector('input[name="ToleranceFinal"]').value,

                // Checkbox: gunakan .checked bukan .value === 'true'
                MeshInner10Before: document.getElementById('MeshInner10Before')?.checked ?? false,
                MeshInner40Before: document.getElementById('MeshInner40Before')?.checked ?? false,
                MeshOuter10Before: document.getElementById('MeshOuter10Before')?.checked ?? false,
                MeshOuter40Before: document.getElementById('MeshOuter40Before')?.checked ?? false,
                MeshInnerCheck: document.querySelector('input[name="MeshInnerCheck"]:checked')?.value,
                MeshOuterCheck: document.querySelector('input[name="MeshOuterCheck"]:checked')?.value,
                EmbossMarkContent: document.getElementById('EmbossMarkContent').value,
                EmbossMarkDate: document.getElementById('EmbossMarkDate').value,
                QcCond: document.querySelector('input[name="QcCond"]:checked')?.value,
                QcSurf: document.querySelector('input[name="QcSurf"]:checked')?.value,
                QcRes: document.querySelector('input[name="QcRes"]:checked')?.value,

                DAI_Awal: document.querySelector('input[name="DAI_Awal"]').value,
                DAI_Akhir: document.querySelector('input[name="DAI_Akhir"]').value,
                DAC_Awal: document.querySelector('input[name="DAC_Awal"]').value,
                DAC_Akhir: document.querySelector('input[name="DAC_Akhir"]').value,
                DRAI_Awal: document.querySelector('input[name="DRAI_Awal"]').value,
                DRAI_Akhir: document.querySelector('input[name="DRAI_Akhir"]').value,
                DRAC_Awal: document.querySelector('input[name="DRAC_Awal"]').value,
                DRAC_Akhir: document.querySelector('input[name="DRAC_Akhir"]').value,

                MaterialLots: getMaterialLotPayload(),

                Readings: pReadings.map(p => ({
                    ReadingTime: p.data.ReadingTime || new Date().toISOString(),
                    ...p.data
                }))
            };

            Swal.fire({
                title: 'UPDATING DATA...',
                text: 'Please wait while we record the changes.',
                allowOutsideClick: false,
                background: '#020617', color: '#38bdf8',
                didOpen: () => { Swal.showLoading(); }
            });

            console.log('📦 Payload being submitted:');
            console.log('  - ItemCode:', payload.ItemCode);
            console.log('  - SpsId:', payload.SpsId);
            console.log('  - Full payload:', payload);

            try {
                const res = await fetch('/ProductionReport/UpdateWithReadings', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const result = await res.json();
                if (result.success) {
                    Swal.fire({ icon: 'success', title: 'UPDATED!', text: 'Report successfully updated in the database.', background: '#0f172a', color: '#38bdf8' })
                        .then(() => window.location.href = '/ProductionReport/ParameterHistory');
                } else {
                    Swal.fire({ icon: 'error', title: 'FAILED', text: result.message || 'Server error occurred.', background: '#0f172a', color: '#f87171' });
                }
            } catch (e) {
                Swal.fire({ icon: 'error', title: 'SYSTEM ERROR', text: e.message, background: '#0f172a', color: '#f87171' });
            }
        }

        function clearSpsLink() {
            document.getElementById('SpsId').value = '';
            document.getElementById('manualItemSearch').value = '';
            Swal.fire({
                icon: 'success',
                title: 'SPS LINK CLEARED',
                text: 'Parameter setting link telah dihapus',
                toast: true, position: 'top-end', timer: 2000,
                showConfirmButton: false,
                background: '#0f172a', color: '#38bdf8'
            });
        }

        // Confirm before submit
        document.getElementById('editForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const result = await Swal.fire({
                title: '<span style="color:#fbbf24">UPDATE RECORD?</span>',
                html: '<span style="color:rgba(255,255,255,0.6)">Simpan perubahan data produksi ini ke database?</span>',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#0ea5e9',
                cancelButtonColor: '#334155',
                confirmButtonText: 'YES, UPDATE',
                cancelButtonText: 'CANCEL',
                background: '#0f172a',
                color: '#fff'
            });
            if (result.isConfirmed) this.submit();
        });

        @if (TempData["ErrorMessage"] != null) {
            <text>Swal.fire({icon:'error',title:'ERROR',text:'@TempData["ErrorMessage"]',background:'#0f172a',color:'#f87171',confirmButtonColor:'#ef4444'});</text>
        }
        @if (TempData["SuccessMessage"] != null) {
            <text>Swal.fire({icon:'success',title:'UPDATED!',text:'@TempData["SuccessMessage"]',toast:true,position:'top-end',timer:3000,showConfirmButton:false,background:'#0f172a',color:'#38bdf8'});</text>
        }
        // Initial check on load
        document.addEventListener('DOMContentLoaded', function() {
            const spsId = document.getElementById('SpsId')?.value;
            if (spsId && spsId !== '0') {
                // If we have an SPS ID, trigger the hide logic based on existing labels
                const midVal = document.getElementById('spec_MiddleDie')?.textContent || '';
                const machineHidden = document.getElementById('MachineName')?.value || '';
                const navbarMachine = Array.from(document.querySelectorAll('.navbar-right .text-warning.fw-bold'))
                                         .map(el => el.textContent.trim())
                                         .find(txt => txt.length > 0) || '';
                
                const isDoubleLayer = (machineHidden + navbarMachine).toUpperCase().includes('DL');
                const midCard = document.getElementById('die_card_MiddleDie');
                
                if (midCard && (isDoubleLayer || !midVal || midVal === '--' || midVal === '0')) {
                    midCard.classList.add('d-none');
                    midCard.style.setProperty('display', 'none', 'important');
                }
            }
        });
    </script>
}
