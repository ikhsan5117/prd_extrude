@model VelastoProductionSystem.Models.ProductionReport

@{
    ViewData["Title"] = "Edit Production Report";
}

<div class="production-blueprint pb-5">
    <div class="container-fluid p-1 p-md-2">

        <!-- HEADER HUD -->
        <div class="mb-5 py-2">
            <div class="text-center">
                <h1 class="m-0 fw-black text-white letter-spacing-2" style="font-size: 1.6rem;">EDIT PRODUCTION REPORT</h1>
                <div class="text-warning fw-bold tracking-widest" style="font-size: 0.95rem;">(PARAMETER CORRECTION)</div>
            </div>
        </div>

        <form asp-action="Edit" id="editForm">
            <input type="hidden" asp-for="Id" />
            @* Preserve immutable fields *@
            <input type="hidden" asp-for="CreatedDate" />
            <input type="hidden" asp-for="Status" />
            <input type="hidden" id="StandardParameterSettingId" name="StandardParameterSettingId" value="@Model?.StandardParameterSettingId" />
            <div asp-validation-summary="ModelOnly" class="alert mb-4" style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#f87171;border-radius:10px;"></div>

            <!-- SECTION 1: COMMAND CONSOLE (HEADER) -->
            <div class="hud-card mb-4 shadow-hud-blue border-white border-opacity-10 overflow-hidden">
                <div class="hud-card-header d-flex justify-content-between align-items-center py-2 px-3">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-terminal-fill hud-card-icon fs-6"></i>
                        <span class="hud-card-title small tracking-widest font-monospace">PRODUCTION COMMAND CONSOLE</span>
                    </div>
                    <div class="d-flex gap-3 super-small font-black opacity-40 text-uppercase letter-spacing-2">
                        <span><i class="bi bi-file-text me-1"></i>DOC: <input asp-for="DocumentNumber" id="DocNo" class="bg-transparent border-0 text-white-50 w-auto" placeholder="AUTO" /></span>
                        <span><i class="bi bi-activity me-1"></i>REV: <input asp-for="RevisionNumber" id="RevNo" class="bg-transparent border-0 text-white-50 w-auto" placeholder="0" /></span>
                    </div>
                </div>

                <!-- SPS PROTOCOL SYNC ROW -->
                <div class="p-3 bg-black bg-opacity-20 border-bottom border-white border-opacity-5">
                    <div class="row g-3 align-items-center">
                        <div class="col-md-5">
                            <div class="hud-pill p-0 d-flex flex-row overflow-hidden border border-info border-opacity-50" style="min-height:60px;background:#0f172a;border-radius:8px;">
                                <div class="flex-grow-1 p-2 px-3 d-flex flex-column justify-content-center">
                                    <label class="mb-0 text-info font-black" style="font-size:0.65rem;letter-spacing:1px;"><i class="bi bi-keyboard me-2"></i>MANUAL PROTOCOL</label>
                                    <input id="manualItemSearch" type="text" class="hud-input bg-transparent border-0 py-1 font-monospace text-white fw-bold" style="font-size:1rem;outline:none;" placeholder="ITEM CODE..." onchange="if(this.value) fetchSpsByItem(this.value)" onkeyup="if(event.key === 'Enter' && this.value) { fetchSpsByItem(this.value); this.blur(); }" autocomplete="off" />
                                </div>
                                <button type="button" onclick="let v=document.getElementById('manualItemSearch').value; if(v) fetchSpsByItem(v);" class="btn border-0 rounded-0 px-3 d-flex align-items-center justify-content-center border-start border-info border-opacity-20" style="min-width:60px;background:rgba(14,165,233,0.1);color:#0ea5e9;" title="Search">
                                    <i class="bi bi-search fs-4"></i>
                                </button>
                                <button type="button" onclick="startSpsScanner()" class="btn border-0 rounded-0 px-3 d-flex align-items-center justify-content-center border-start border-info border-opacity-20" style="min-width:70px;background:rgba(14,165,233,0.2);color:#38bdf8;" title="Scan Barcode">
                                    <i class="bi bi-qr-code-scan fs-3"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-md-7">
                            <div class="hud-pill p-0 d-flex flex-row border border-info border-opacity-50" style="min-height:60px;position:relative;background:#0f172a;border-radius:8px;">
                                <div class="flex-grow-1 p-2 px-3 d-flex flex-column justify-content-center">
                                    <label class="mb-0 text-info font-black" style="font-size:0.65rem;letter-spacing:1px;"><i class="bi bi-link-45deg me-2"></i>SPS REFERENCE LINKED &nbsp;<span id="spsLinkedLabel" class="@(Model?.StandardParameterSettingId != null ? "text-success" : "text-white-50")" style="font-size:0.7rem;">@(Model?.StandardParameterSettingId != null ? "✓ LINKED" : "— NONE —")</span></label>
                                    <div class="font-monospace fw-bold" id="spsLinkedDisplay" style="font-size:0.9rem;opacity:0.8;">
                                        @if (Model?.StandardParameterSetting != null) {
                                            <span class="text-success">[@Model.StandardParameterSetting.ItemList] @Model.StandardParameterSetting.HoseType</span>
                                        } else {
                                            <span class="text-white-50">Type item code or scan to link SPS protocol...</span>
                                        }
                                    </div>
                                </div>
                                <button type="button" onclick="clearSpsLink()" class="btn border-0 rounded-0 px-3 d-flex align-items-center justify-content-center border-start border-info border-opacity-20" style="min-width:60px;background:rgba(239,68,68,0.08);color:#f87171;" title="Clear SPS Link">
                                    <i class="bi bi-x-circle fs-4"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 4-PILL ROW -->
                <div class="p-2 bg-black bg-opacity-10">
                    <div class="row g-2">
                        <div class="col-6">
                            <div class="hud-pill-integrated border border-info border-opacity-20" style="background:rgba(15,23,42,0.8);">
                                <label><i class="bi bi-calendar-check me-2 text-info"></i>SYSTEM DATE</label>
                                <input type="date" asp-for="ProductionDate" id="ProductionDate" class="hud-input font-monospace text-primary-glow" required />
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="hud-pill-integrated border border-info border-opacity-20" style="background:rgba(15,23,42,0.8);">
                                <label><i class="bi bi-clock-history me-2 text-info"></i>SHIFT MONITORING</label>
                                <select asp-for="Shift" id="Shift" class="hud-input font-black bg-transparent border-0 text-white" style="-webkit-appearance:none;">
                                    <option value="I" class="bg-dark">SHIFT I (SIANG)</option>
                                    <option value="II" class="bg-dark">SHIFT II (SORE)</option>
                                    <option value="III" class="bg-dark">SHIFT III (MALAM)</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="hud-pill-integrated border border-info border-opacity-20" style="background:rgba(15,23,42,0.8);">
                                <label><i class="bi bi-building me-2 text-info"></i>CUSTOMER ENTITY</label>
                                <input asp-for="CustomerName" id="CustomerName" class="hud-input small text-white font-black" placeholder="PT. ADM" />
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="hud-pill-integrated border border-info border-opacity-20" style="background:rgba(15,23,42,0.8);">
                                <label><i class="bi bi-cpu me-2 text-info"></i>HOSE SPECIFICATION TYPE</label>
                                <input asp-for="HoseType" id="HoseType" class="hud-input small font-monospace text-white" placeholder="Extrusion Spec Name..." />
                            </div>
                        </div>
                    </div>
                </div>

            </div>


            <!-- SECTION 2: MATERIAL & MESH CHECKING -->
            <div class="row g-4 mb-4 align-items-start">
                <!-- CARD: MATERIAL TRACKING -->
                <div class="col-lg-7">
                    <div class="hud-card shadow-hud-blue border-white border-opacity-10 overflow-hidden">
                        <div class="hud-card-header">
                            <i class="bi bi-box-seam hud-card-icon"></i>
                            <span class="hud-card-title">MATERIAL & LOT TRACKING</span>
                        </div>
                        <table class="table-hud-unified">
                            <thead>
                                <tr class="bg-black bg-opacity-20 text-center">
                                    <th class="ps-4 text-start">DESCRIPTION</th>
                                    <th width="22%">STANDARD</th>
                                    <th width="22%">ACTUAL</th>
                                    <th width="32%" class="hud-th-scan text-info border-start border-white border-opacity-10">NO. LOT (SCAN)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="ps-4"><div class="label-stack"><span class="label-sub">INNER (MATERIAL)</span><span class="label-main">COMPOUND</span></div></td>
                                    <td><input asp-for="InnerMaterial" class="hud-input-underlined text-center" placeholder="---" /></td>
                                    <td><input asp-for="InnerMaterialActual" class="hud-input-underlined text-center" placeholder="---" /></td>
                                    <td class="hud-td-scan border-start border-white border-opacity-10">
                                        <div class="hud-scan-group">
                                            <input asp-for="InnerMaterialLotNo" class="hud-input-scan" placeholder="SCAN LOT..." />
                                            <button type="button" class="hud-scan-btn" onclick="openScanner('InnerMaterialLotNo')"><i class="bi bi-upc-scan"></i></button>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="ps-4"><div class="label-stack"><span class="label-sub">OUTER (MATERIAL)</span><span class="label-main">COMPOUND</span></div></td>
                                    <td><input asp-for="OuterMaterial" class="hud-input-underlined text-center" placeholder="---" /></td>
                                    <td><input asp-for="OuterMaterialActual" class="hud-input-underlined text-center" placeholder="---" /></td>
                                    <td class="hud-td-scan border-start border-white border-opacity-10">
                                        <div class="hud-scan-group">
                                            <input asp-for="OuterMaterialLotNo" class="hud-input-scan" placeholder="SCAN LOT..." />
                                            <button type="button" class="hud-scan-btn" onclick="openScanner('OuterMaterialLotNo')"><i class="bi bi-upc-scan"></i></button>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="ps-4"><div class="label-stack"><span class="label-sub">YARN (SUPPORT)</span><span class="label-main">POLYESTER</span></div></td>
                                    <td><input asp-for="Yarn" class="hud-input-underlined text-center" placeholder="---" /></td>
                                    <td><input asp-for="YarnActual" class="hud-input-underlined text-center" placeholder="---" /></td>
                                    <td class="hud-td-scan border-start border-white border-opacity-10">
                                        <div class="hud-scan-group">
                                            <input asp-for="YarnLotNo" class="hud-input-scan" placeholder="SCAN LOT..." />
                                            <button type="button" class="hud-scan-btn" onclick="openScanner('YarnLotNo')"><i class="bi bi-upc-scan"></i></button>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- CARD: MESH & EMBOSS -->
                <div class="col-lg-5">
                    <div class="hud-card shadow-hud-blue border-white border-opacity-10 overflow-hidden">
                        <div class="hud-card-header">
                            <i class="bi bi-patch-check hud-card-icon"></i>
                            <span class="hud-card-title">MESH & EMBOSS QUALITY</span>
                        </div>
                        <table class="table-hud-unified compact-hud instrument-style">
                            <thead>
                                <tr class="bg-black bg-opacity-40 text-center">
                                    <th class="ps-3 text-start py-2 font-monospace tracking-widest text-primary-glow">CATEGORIES</th>
                                    <th width="32%" class="py-2 border-start border-white border-opacity-5">Ø96 #10</th>
                                    <th width="32%" class="py-2 border-start border-white border-opacity-5">Ø96 #40</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr class="group-lane">
                                    <td class="ps-3 py-1"><div class="label-stack"><span class="label-sub">TIPE MESH</span><span class="label-main small">INNER (BEFORE)</span></div></td>
                                    <td class="text-center border-start border-white border-opacity-10"><div class="hud-check-box"><input type="checkbox" asp-for="MeshInner10Before"><span></span></div></td>
                                    <td class="text-center border-start border-white border-opacity-10"><div class="hud-check-box"><input type="checkbox" asp-for="MeshInner40Before"><span></span></div></td>
                                </tr>
                                <tr class="group-lane border-bottom border-white border-opacity-10">
                                    <td class="ps-3 py-1"><div class="label-stack"><span class="label-sub opacity-0 small">.</span><span class="label-main small">OUTER (BEFORE)</span></div></td>
                                    <td class="text-center border-start border-white border-opacity-10"><div class="hud-check-box"><input type="checkbox" asp-for="MeshOuter10Before"><span></span></div></td>
                                    <td class="text-center border-start border-white border-opacity-10"><div class="hud-check-box"><input type="checkbox" asp-for="MeshOuter40Before"><span></span></div></td>
                                </tr>
                                <tr>
                                    <td class="ps-3 py-2"><div class="label-stack"><span class="label-sub">MESH CHECK</span><span class="label-main small">INNER (AFTER)</span></div></td>
                                    <td colspan="2" class="pe-3 py-2 border-start border-white border-opacity-10">
                                        <div class="hud-pill-group sm"><label class="hud-pill-item">OK<input type="radio" asp-for="MeshInnerCheck" value="OK"></label><label class="hud-pill-item red">BOLONG<input type="radio" asp-for="MeshInnerCheck" value="BOLONG"></label><label class="hud-pill-item orange">ASING<input type="radio" asp-for="MeshInnerCheck" value="ASING"></label></div>
                                    </td>
                                </tr>
                                <tr class="border-bottom border-white border-opacity-10">
                                    <td class="ps-3 py-2"><div class="label-stack"><span class="label-sub opacity-0 small">.</span><span class="label-main small">OUTER (AFTER)</span></div></td>
                                    <td colspan="2" class="pe-3 py-2 border-start border-white border-opacity-10">
                                        <div class="hud-pill-group sm"><label class="hud-pill-item">OK<input type="radio" asp-for="MeshOuterCheck" value="OK"></label><label class="hud-pill-item red">BOLONG<input type="radio" asp-for="MeshOuterCheck" value="BOLONG"></label><label class="hud-pill-item orange">ASING<input type="radio" asp-for="MeshOuterCheck" value="ASING"></label></div>
                                    </td>
                                </tr>
                                <tr class="group-lane border-bottom border-white border-opacity-10">
                                    <td class="ps-3 py-2"><div class="label-stack"><span class="label-sub">EMBOSSING</span><span class="label-main small">MARK DATA</span></div></td>
                                    <td colspan="2" class="pe-3 py-2 border-start border-white border-opacity-10">
                                        <div class="row g-2 align-items-center">
                                            <div class="col-7"><input asp-for="EmbossMarkContent" id="EmbossMarkContent" class="hud-input-underlined py-1 text-center font-monospace small" placeholder="CONTENT" /></div>
                                            <div class="col-5"><input type="date" asp-for="EmbossMarkDate" id="EmbossMarkDate" class="hud-input-underlined py-1 text-center font-monospace small" /></div>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="ps-3 py-2"><div class="label-stack"><span class="label-sub">QC DETAILS</span><span class="label-main small">FINAL CHECK</span></div></td>
                                    <td colspan="2" class="pe-3 py-2 border-start border-white border-opacity-10">
                                        <div class="d-flex flex-column gap-2">
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="label-sub font-black text-white-50" style="min-width:40px">COND</span>
                                                <div class="hud-pill-group sm"><label class="hud-pill-item">BERSIH<input type="radio" asp-for="QcCond" value="BERSIH"></label><label class="hud-pill-item red">KOTOR<input type="radio" asp-for="QcCond" value="KOTOR"></label></div>
                                            </div>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="label-sub font-black text-white-50" style="min-width:40px">SURF</span>
                                                <div class="hud-pill-group sm"><label class="hud-pill-item">OK<input type="radio" asp-for="QcSurf" value="OK"></label><label class="hud-pill-item red">SCRATCH<input type="radio" asp-for="QcSurf" value="SCRATCH"></label></div>
                                            </div>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="label-sub font-black text-white-50" style="min-width:40px">RES</span>
                                                <div class="hud-pill-group sm"><label class="hud-pill-item">READ<input type="radio" asp-for="QcRes" value="READ"></label><label class="hud-pill-item red">UNREAD<input type="radio" asp-for="QcRes" value="UNREAD"></label></div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- SECTION 3: DIES DIMENSION - REDESIGNED AS CARDS -->
            <div class="row g-4 mb-4">
                <div class="col-12">
            <div class="hud-card mb-4 shadow-hud-blue border-white border-opacity-10 overflow-hidden">
                <div class="hud-card-header d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-rulers hud-card-icon"></i>
                        <span class="hud-card-title">DIES DIMENSION MEASUREMENTS</span>
                    </div>
                </div>
                
                <div class="p-3">
                    <div class="row g-3">
                        @{
                            var diesList = new[] { 
                                new { Name = "Nipple Die", Field = "NippleDieOK", SpecKey = "NippleDie", InitName = "NippleDieInitial", FinalName = "NippleDieFinal", OK = Model!.NippleDieOK, InitVal = Model!.NippleDieInitial, FinalVal = Model!.NippleDieFinal },
                                new { Name = "Tube Die", Field = "TubeDieOK", SpecKey = "TubeDie", InitName = "TubeDieInitial", FinalName = "TubeDieFinal", OK = Model!.TubeDieOK, InitVal = Model!.TubeDieInitial, FinalVal = Model!.TubeDieFinal },
                                new { Name = "Middle Die", Field = "MiddleDieOK", SpecKey = "MiddleDie", InitName = "MiddleDieInitial", FinalName = "MiddleDieFinal", OK = Model!.MiddleDieOK, InitVal = Model!.MiddleDieInitial, FinalVal = Model!.MiddleDieFinal },
                                new { Name = "Cover Die", Field = "CoverDieOK", SpecKey = "CoverDie", InitName = "CoverDieInitial", FinalName = "CoverDieFinal", OK = Model!.CoverDieOK, InitVal = Model!.CoverDieInitial, FinalVal = Model!.CoverDieFinal },
                                new { Name = "Spacer Die", Field = "SpacerDieOK", SpecKey = "SpacerDie", InitName = "SpacerDieInitial", FinalName = "SpacerDieFinal", OK = Model!.SpacerDieOK, InitVal = Model!.SpacerDieInitial, FinalVal = Model!.SpacerDieFinal },
                                new { Name = "A Distance", Field = "ToleranceDieOK", SpecKey = "ToleranceDie", InitName = "ToleranceInitial", FinalName = "ToleranceFinal", OK = Model!.ToleranceDieOK, InitVal = Model!.ToleranceInitial, FinalVal = Model!.ToleranceFinal }
                            };
                        }

                        @foreach(var die in diesList) {
                            <div class="col-md-6 col-xl-4">
                                <div class="die-card p-3 rounded-3 border border-white border-opacity-10 bg-black bg-opacity-30 h-100 d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <div class="label-stack">
                                            <span class="label-sub">INSTRUMENT</span>
                                            <span class="label-main fs-6">@die.Name</span>
                                        </div>
                                        <div class="hud-pill-group sm" style="width: 100px;">
                                            <label class="hud-pill-item">OK<input type="radio" name="@die.Field" value="true" @(die.OK == true ? "checked" : "")></label>
                                            <label class="hud-pill-item red">NG<input type="radio" name="@die.Field" value="false" @(die.OK == false ? "checked" : "")></label>
                                        </div>
                                    </div>

                                    <div class="row g-2 align-items-end mt-auto">
                                        <div class="col-4">
                                            <div class="text-center">
                                                <label class="lbl-small mb-1 text-info-glow" style="font-size: 0.55rem;">STANDARD</label>
                                                <div class="hud-input-underlined py-1 text-info-glow bg-dark bg-opacity-50 rounded-2 border-0" id="spec_@die.SpecKey" style="font-size: 0.9rem; min-height: 35px;">--</div>
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <div class="text-center">
                                                <label class="lbl-small mb-1 text-warning" style="font-size: 0.55rem;">BEFORE</label>
                                                <input name="@die.InitName" value="@die.InitVal" class="hud-input-underlined py-1 text-center font-monospace text-warning border-0 bg-white bg-opacity-5 rounded-2" placeholder="---" style="font-size: 0.9rem; min-height: 35px;" />
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <div class="text-center">
                                                <label class="lbl-small mb-1 text-warning" style="font-size: 0.55rem;">AFTER</label>
                                                <input name="@die.FinalName" value="@die.FinalVal" class="hud-input-underlined py-1 text-center font-monospace text-warning border-0 bg-white bg-opacity-5 rounded-2" placeholder="---" style="font-size: 0.9rem; min-height: 35px;" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

            <!-- SECTION: DYNAMIC PRODUCTION READINGS TABS (CENTERED) -->
            <div class="d-flex flex-column align-items-center mb-5 mt-2">
                <div class="text-info-glow opacity-40 super-small fw-black tracking-widest mb-3" style="font-size: 0.6rem;">DYNAMIC MEASUREMENT CONTROL</div>
                <div class="d-flex align-items-center gap-4">
                    <div id="readingsTabs" class="d-flex gap-2">
                        <!-- P-1, P-2, etc. will be injected here -->
                    </div>
                    <div class="add-check-trigger d-flex align-items-center gap-2 cursor-pointer no-select" onclick="addReadingPoint()">
                        <i class="bi bi-plus fs-2 text-white"></i>
                        <span class="text-white fw-900 tracking-widest" style="font-size: 1.1rem;">ADD CHECK</span>
                    </div>
                </div>
            </div>

            <!-- SECTION: SMART PARAMETER CARDS (ACTIVE RECORD VIEW) -->
            <div class="row g-4 mb-5" id="parameterCardsContainer">
                @{
                    var monSections = new[] {
                        new { 
                            Title = "SECTION 01: INNER (TUBE 1)", Icon="bi-gear-fill", Color = "#3b82f6", ID="inner",
                            Rows = new[,] { { "Head Temp.", "°C", "HeadTempInner" }, { "Cylinder 1", "°C", "Cylinder1TempInner" }, { "Cylinder 2", "°C", "Cylinder2TempInner" }, { "Cylinder 3", "°C", "Cylinder3TempInner" }, { "Screw Temp.", "°C", "ScrewTempInner" }, { "Screw Speed", "rpm", "ScrewSpeedInner" }, { "Feed Roll Ratio", "%", "FeedRollRatioInner" }, { "Pressure", "MPa", "PressureInner" } }
                        },
                        new { 
                            Title = "SECTION 02: OUTER (COVER)", Icon="bi-shield-shaded", Color = "#f59e0b", ID="outer",
                            Rows = new[,] { { "Head Temp.", "°C", "HeadTempOuter" }, { "Cylinder 1", "°C", "Cylinder1TempOuter" }, { "Cylinder 2", "°C", "Cylinder2TempOuter" }, { "Cylinder 3", "°C", "Cylinder3TempOuter" }, { "Screw Temp.", "°C", "ScrewTempOuter" }, { "Screw Speed", "rpm", "ScrewSpeedOuter" }, { "Feed Roll Ratio", "%", "FeedRollRatioOuter" }, { "Pressure", "MPa", "PressureOuter" } }
                        },
                        new { 
                            Title = "SECTION 03: SPIRAL MECHANISM", Icon="bi-sync", Color = "#10b981", ID="spiral",
                            Rows = new[,] { { "Spiral Speed", "rpm", "SpiralSpeed" }, { "Spiral Pitch (Set)", "mm", "SpiralPitchSetting" }, { "Spiral Pitch (Disp)", "mm", "SpiralPitchDisplay" } } 
                        },
                        new { 
                            Title = "SECTION 04: INFRA & UTILITY", Icon="bi-water", Color = "#0ea5e9", ID="other",
                            Rows = new[,] { { "Preset Value", "Ø mm", "PresetValue" }, { "Control Value", "Ø mm", "ControlValue" }, { "Hose Speed", "m/min", "HoseSpeed" }, { "Take-up Speed", "", "TakeupConveyorSpeed" }, { "Cool Speed", "", "CoolConveyorSpeed" }, { "Conveyor Ratio", "", "ConveyorRatio" }, { "Surface Condition", "", "UnsmoothSurface" }, { "Chiller Temp", "°C", "ChillerWaterTemp" }, { "Caterpillar Gap", "mm", "CaterpillarGap" } } 
                        }
                    };
                }

                @foreach (var mSec in monSections) {
                    <div class="col-12 col-xxl-6">
                        <div class="hud-card h-100 shadow-hud mb-1 overflow-hidden" 
                             style="border: 1px solid @(mSec.Color)44; background: rgba(15, 23, 42, 0.6); box-shadow: 0 0 20px @(mSec.Color)11;">
                            
                            <div class="hud-card-header d-flex justify-content-between align-items-center py-3 px-4" 
