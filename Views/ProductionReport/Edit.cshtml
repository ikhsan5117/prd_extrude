@model VelastoProductionSystem.Models.ProductionReport

@{
    ViewData["Title"] = "EDIT PRODUCTION COMMAND CENTER";
}

<div class="production-blueprint pb-5">
    <div class="container-fluid p-3">
        
        <!-- TOP HUD: CONTROL STATUS -->
        <div class="hud-header glass-morphism p-3 mb-3 d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-3">
                <div class="hud-logo-v">V</div>
                <div>
                    <h5 class="m-0 fw-900 tracking-widest text-white">RECORDS MONITORING & CORRECTION</h5>
                    <div class="hud-status-bar d-flex gap-2 align-items-center">
                        <div class="hud-status-led led-yellow blink"></div>
                        <span class="hud-status-text">MAINTENANCE MODE</span>
                        <span class="hud-separator">|</span>
                        <span class="hud-status-text opacity-50">RECORD ID: @Model.Id</span>
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2">
                <div class="hud-pill px-3 py-1">
                    <label>STATUS</label>
                    <span class="text-warning-glow fw-bold">UNDER CORRECTION</span>
                </div>
            </div>
        </div>

        <form asp-action="Edit" id="mainReportForm">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedBy" />
            <input type="hidden" asp-for="CreatedDate" />
            <input type="hidden" asp-for="Status" />

            <div class="row g-3">
                <!-- LEFT PANEL -->
                <div class="col-lg-8">
                    <div class="hud-card glass-morphism h-100 overflow-hidden d-flex">
                        <div class="hud-vertical-label bg-warning bg-opacity-10 text-warning">CORE DATA OVERRIDE</div>
                        <div class="p-4 flex-grow-1">
                            
                            <div class="row g-3 mb-4">
                                <div class="col-md-4">
                                    <div class="hud-pill-integrated">
                                        <label>DOCUMENT NUMBER</label>
                                        <input asp-for="DocumentNumber" class="hud-input text-info-glow" />
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="hud-pill-integrated">
                                        <label>REVISION</label>
                                        <input asp-for="RevisionNumber" class="hud-input" />
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="hud-pill-integrated">
                                        <label>PRODUCTION DATE</label>
                                        <input type="date" asp-for="ProductionDate" class="hud-input" />
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="hud-pill-integrated focus-warning">
                                        <label>SHIFT CONTROL</label>
                                        <select asp-for="Shift" class="hud-input bg-transparent border-0 text-white">
                                            <option value="I">SHIFT I</option>
                                            <option value="II">SHIFT II</option>
                                            <option value="III">SHIFT III</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="hud-pill-integrated">
                                        <label>CLIENT / CUSTOMER</label>
                                        <input asp-for="CustomerName" class="hud-input" />
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="hud-pill-integrated">
                                        <label>HOSE DESCRIPTION</label>
                                        <input asp-for="HoseType" class="hud-input" />
                                    </div>
                                </div>
                            </div>

                            <div class="hud-section-label mb-3"><i class="bi bi-layers me-2"></i>MATERIAL CONFIGURATION OVERRIDE</div>
                            <div class="table-responsive">
                                <table class="table-hud w-100">
                                    <thead>
                                        <tr>
                                            <th>ITEM</th>
                                            <th>PROPERTY SPEC</th>
                                            <th>LOT TRACKING</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td class="fw-bold">INNER LAYER</td>
                                            <td class="p-0"><input asp-for="InnerMaterialActual" class="hud-table-input" /></td>
                                            <td class="p-0"><input asp-for="InnerMaterialLotNo" class="hud-table-input text-info-glow" /></td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">OUTER LAYER</td>
                                            <td class="p-0"><input asp-for="OuterMaterialActual" class="hud-table-input" /></td>
                                            <td class="p-0"><input asp-for="OuterMaterialLotNo" class="hud-table-input text-info-glow" /></td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">YARN CORE</td>
                                            <td class="p-0"><input asp-for="YarnActual" class="hud-table-input" /></td>
                                            <td class="p-0"><input asp-for="YarnLotNo" class="hud-table-input text-info-glow" /></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- RIGHT PANEL -->
                <div class="col-lg-4">
                    <div class="d-flex flex-column h-100 gap-3">
                        <div class="hud-card glass-morphism p-3">
                            <div class="hud-section-label mb-3 text-info"><i class="bi bi-clock-history me-2"></i>PROCESS TIMELINE</div>
                            <div class="row g-2">
                                <div class="col-6"><div class="hud-pill-integrated border-info border-opacity-30"><label>DANDORI START</label><input asp-for="DandoriStartTime" type="time" class="hud-input" /></div></div>
                                <div class="col-6"><div class="hud-pill-integrated border-info border-opacity-30"><label>DANDORI END</label><input asp-for="DandoriEndTime" type="time" class="hud-input" /></div></div>
                                <div class="col-6"><div class="hud-pill-integrated border-primary border-opacity-30"><label>PROD START</label><input asp-for="ProductionStartTime" type="time" class="hud-input" /></div></div>
                                <div class="col-6"><div class="hud-pill-integrated border-primary border-opacity-30"><label>PROD END</label><input asp-for="ProductionEndTime" type="time" class="hud-input" /></div></div>
                            </div>
                        </div>

                        <div class="hud-card glass-morphism p-3">
                            <div class="hud-section-label mb-3 text-success"><i class="bi bi-box-seam me-2"></i>OUTPUT SUMMARY</div>
                            <div class="hud-pill-integrated border-success border-opacity-30">
                                <label>QUANTITY OK</label>
                                <input asp-for="QtyOk" class="hud-input fw-black fs-4 text-success" />
                            </div>
                        </div>

                        <div class="hud-card glass-morphism p-3 flex-grow-1">
                            <div class="hud-section-label mb-2"><i class="bi bi-chat-dots me-2"></i>REASON FOR CORRECTION</div>
                            <textarea asp-for="Remark" class="hud-textarea flex-grow-1 w-100" placeholder="Type reason for edit..."></textarea>
                        </div>

                        <div class="hud-card glass-morphism p-3 shadow-glow-primary border-primary border-opacity-30">
                            <button type="submit" class="btn btn-hud-primary w-100 py-3 fw-900 tracking-widest text-uppercase">UPDATE MISSION DATA</button>
                            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-hud-outline w-100 py-2 mt-2 fw-bold small">ABORT & RETURN</a>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<style>
    :root {
        --hud-bg: #020617;
        --hud-card: rgba(15, 23, 42, 0.7);
        --hud-primary: #0ea5e9;
        --hud-accent: #38bdf8;
        --hud-warning: #f59e0b;
        --hud-border: rgba(14, 165, 233, 0.2);
    }

    .production-blueprint { min-height: 100vh; background: var(--hud-bg); color: #f1f5f9; font-family: 'Inter', sans-serif; }
    .glass-morphism { background: var(--hud-card); backdrop-filter: blur(15px); border: 1px solid var(--hud-border); border-radius: 12px; }
    
    .hud-header { border-left: 4px solid var(--hud-warning); }
    .hud-logo-v { width: 44px; height: 44px; background: var(--hud-primary); color: white; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 24px; }
    
    .hud-status-led { width: 8px; height: 8px; border-radius: 50%; }
    .led-yellow { background: #f59e0b; box-shadow: 0 0 10px #f59e0b; }
    .hud-status-text { font-size: 0.65rem; font-weight: 800; letter-spacing: 1px; }
    .blink { animation: hud-blink 2s infinite; }
    @@keyframes hud-blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

    .hud-pill { background: rgba(30, 41, 59, 0.5); border: 1px solid var(--hud-border); border-radius: 8px; display: flex; flex-direction: column; }
    .hud-pill label { font-size: 0.55rem; font-weight: 900; color: var(--hud-primary); opacity: 0.7; }
    
    .hud-vertical-label { width: 35px; writing-mode: vertical-rl; transform: rotate(180deg); display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 0.7rem; border-right: 1px solid var(--hud-border); }
    
    .hud-pill-integrated { background: rgba(30, 41, 59, 0.4); border: 1px solid var(--hud-border); padding: 8px 12px; border-radius: 8px; transition: all 0.3s; }
    .hud-pill-integrated:focus-within { border-color: var(--hud-accent); background: rgba(14, 165, 233, 0.1); }
    .hud-pill-integrated label { font-size: 0.6rem; font-weight: 900; color: var(--hud-primary); display: block; margin-bottom: 2px; }
    .hud-input { background: transparent; border: none; outline: none; color: white; width: 100%; font-size: 0.9rem; font-weight: 600; padding: 0; }
    
    .hud-section-label { font-size: 0.75rem; font-weight: 900; letter-spacing: 1.5px; color: var(--hud-primary); text-transform: uppercase; border-bottom: 1px solid var(--hud-border); padding-bottom: 5px; }
    
    .table-hud { font-size: 0.85rem; border-collapse: separate; border-spacing: 0 4px; }
    .table-hud th { font-size: 0.65rem; font-weight: 900; color: var(--hud-primary); text-transform: uppercase; padding: 10px; border-bottom: 1px solid var(--hud-border); }
    .table-hud td { padding: 12px; background: rgba(30, 41, 59, 0.3); vertical-align: middle; }
    
    .hud-table-input { background: rgba(30, 41, 59, 0.5); border: 1px solid transparent; color: white; width: 100%; padding: 8px; text-align: center; border-radius: 4px; outline: none; font-weight: 700; font-size: 0.95rem; }
    .hud-table-input:focus { border-color: var(--hud-primary); }
    
    .hud-textarea { background: rgba(30, 41, 59, 0.4); border: 1px solid var(--hud-border); border-radius: 8px; color: white; padding: 10px; outline: none; font-size: 0.85rem; min-height: 100px; resize: none; }
    
    .btn-hud-primary { background: var(--hud-primary); color: white; border: none; border-radius: 8px; }
    .btn-hud-outline { background: transparent; border: 1px solid var(--hud-border); color: #94a3b8; border-radius: 8px; }
    
    .text-info-glow { color: #60a5fa; text-shadow: 0 0 8px rgba(96, 165, 250, 0.4); }
    .text-warning-glow { color: #fbbf24; text-shadow: 0 0 8px rgba(251, 191, 36, 0.4); }
    .shadow-glow-primary { box-shadow: 0 0 20px rgba(14, 165, 233, 0.3); }
    .fw-900 { font-weight: 900; }
    .tracking-widest { letter-spacing: 3px; }
</style>
