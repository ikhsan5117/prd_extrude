@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-zoom@2.2.0/dist/chartjs-plugin-zoom.min.js"></script>
    <script src="~/lib/offline-cdn/sweetalert2.all.min.js"></script>
    <script src="~/lib/offline-cdn/signalr.min.js"></script>
    <script>
        function getSearchField() {
            const mode = document.getElementById('phSearchType')?.value || '';
            if (mode === 'doc') return 'doc';
            if (mode === 'operator') return 'operator';
            if (mode === 'item') return 'item';
            return '';
        }

        function updateSearchMode() {
            const mode = getSearchField();
            const input = document.getElementById('phSearch');
            if (!input) return;

            if (mode === 'doc') input.placeholder = 'Filter doc number...';
            else if (mode === 'operator') input.placeholder = 'Filter operator...';
            else if (mode === 'item') input.placeholder = 'Filter items...';
            else input.placeholder = 'Pilih Search Type...';

            filterRows(input.value || '');
        }

        function hideAutocomplete() {
            const box = document.getElementById('phAutocomplete');
            if (box) box.style.display = 'none';
        }

        function renderAutocomplete(q) {
            const box = document.getElementById('phAutocomplete');
            const input = document.getElementById('phSearch');
            if (!box || !input) return;

            const query = (q || '').trim().toLowerCase();
            const field = getSearchField();
            const rows = Array.from(document.querySelectorAll('.ph-row'));

            if (!field) {
                box.style.display = 'none';
                box.innerHTML = '';
                return;
            }

            const values = [...new Set(rows
                .map(r => (r.dataset[field] || '').trim())
                .filter(v => v.length > 0)
            )]
            .filter(v => v.toLowerCase().includes(query))
            .slice(0, 8);

            if (values.length === 0) {
                box.style.display = 'none';
                box.innerHTML = '';
                return;
            }

            box.innerHTML = values.map(v => `<div class="ph-autocomplete-item" data-value="${v.replace(/"/g, '&quot;')}">${v}</div>`).join('');
            box.style.display = 'block';

            box.querySelectorAll('.ph-autocomplete-item').forEach(el => {
                el.addEventListener('click', () => {
                    input.value = el.dataset.value || '';
                    filterRows(input.value);
                    hideAutocomplete();
                });
            });
        }

        function filterRows(q) {
            const t = (q || '').toLowerCase();
            const field = getSearchField();
            const items = document.querySelectorAll('.ph-row');
            items.forEach(r => {
                const value = field
                    ? (r.dataset[field] || '').toLowerCase()
                    : (r.dataset.search || '').toLowerCase();
                const match = value.includes(t);
                r.classList.toggle('ph-hidden', !match);
            });

            renderAutocomplete(q);
        }

        function openDatePopup() {
            document.getElementById('datePopup').classList.add('show');
            document.getElementById('datePopupOverlay').classList.add('show');
        }

        function closeDatePopup() {
            document.getElementById('datePopup').classList.remove('show');
            document.getElementById('datePopupOverlay').classList.remove('show');
        }

        function formatDateValue(d) {
            const m = String(d.getMonth() + 1).padStart(2, '0');
            const day = String(d.getDate()).padStart(2, '0');
            return `${d.getFullYear()}-${m}-${day}`;
        }

        function setDatePreset(type) {
            const now = new Date();
            let from = new Date(now);
            let to = new Date(now);

            if (type === 'week') {
                const day = now.getDay();
                const diffToMonday = day === 0 ? 6 : day - 1;
                from.setDate(now.getDate() - diffToMonday);
            } else if (type === 'month') {
                from = new Date(now.getFullYear(), now.getMonth(), 1);
            } else if (type === 'year') {
                from = new Date(now.getFullYear(), 0, 1);
            }

            document.getElementById('startDateInput').value = formatDateValue(from);
            document.getElementById('endDateInput').value = formatDateValue(to);
        }

        function applyFilters() {
            const start = document.getElementById('startDateInput').value;
            const end = document.getElementById('endDateInput').value;
            const machine = document.getElementById('machineFilterSelect').value;
            const params = new URLSearchParams(window.location.search);

            if (start) params.set('startDate', start);
            else params.delete('startDate');

            if (end) params.set('endDate', end);
            else params.delete('endDate');

            if (machine) params.set('machineFilter', machine);
            else params.delete('machineFilter');

            window.location.href = `/ProductionReport/ParameterHistory?${params.toString()}`;
        }

        function applyDateFilter() {
            applyFilters();
        }

        function clearDateFilter() {
            const params = new URLSearchParams(window.location.search);
            params.delete('startDate');
            params.delete('endDate');
            window.location.href = `/ProductionReport/ParameterHistory?${params.toString()}`;
        }

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeDatePopup();
        });

        document.addEventListener('click', (e) => {
            const wrap = document.querySelector('.ph-search-input-wrap');
            if (!wrap || !wrap.contains(e.target)) hideAutocomplete();
        });

        updateSearchMode();

        function bindEvents() {
            document.querySelectorAll('.delete-btn').forEach(btn => {
                // Remove existing listener to avoid duplicates if called multiple times
                const newBtn = btn.cloneNode(true);
                btn.parentNode.replaceChild(newBtn, btn);
                
                newBtn.addEventListener('click', function () {
                    Swal.fire({
                        title: '<span style="color:#f87171">DELETE RECORD?</span>',
                        html: `<span style="color:rgba(255,255,255,0.6)">Permanently remove:<br><strong style="color:#38bdf8">${this.dataset.doc}</strong></span>`,
                        icon: 'warning', showCancelButton: true,
                        confirmButtonColor: '#ef4444', cancelButtonColor: '#334155',
                        confirmButtonText: 'DELETE', cancelButtonText: 'CANCEL',
                        background: '#0f172a', color: '#fff'
                    }).then(r => {
                        if (r.isConfirmed) {
                            document.getElementById('deleteId').value = this.dataset.id;
                            document.getElementById('deleteForm').submit();
                        }
                    });
                });
            });
        }

        // Initial binding
        bindEvents();

        // SignalR Live Sync
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hub/dashboard")
            .withAutomaticReconnect()
            .build();

        async function startSignalR() {
            try {
                await connection.start();
                console.log("SignalR Connected.");
            } catch (err) {
                setTimeout(startSignalR, 5000);
            }
        }

        connection.on("ReceiveUpdate", function () {
            Swal.fire({
                title: 'LIVE SYNC',
                text: 'New production data detected!',
                icon: 'info',
                background: '#0f172a', color: '#fff',
                timer: 3000, showConfirmButton: false, toast: true, position: 'top-end'
            });
            
            refreshTable();
        });

        async function refreshTable() {
            const url = window.location.href;
            try {
                const response = await fetch(url);
                const html = await response.text();
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');
                
                // Update table body
                const newBody = doc.querySelector('tbody');
                if (newBody) {
                    document.querySelector('tbody').innerHTML = newBody.innerHTML;
                    bindEvents(); // Rebind delete events
                }
                
                // Update stats cards (Total, Operators, Machines)
                const newStats = doc.querySelectorAll('.ph-stat-card .h3');
                const oldStats = document.querySelectorAll('.ph-stat-card .h3');
                newStats.forEach((n, i) => {
                    if (oldStats[i]) oldStats[i].innerText = n.innerText;
                });

                console.log("Table updated via partial sync.");
            } catch (err) {
                console.warn("Partial refresh failed, falling back to full reload:", err);
                window.location.reload();
            }
        }

        connection.on("SensorDataReceived", function (data) {
            // Show global debug toast
            const dbg = document.getElementById('dbg-toast');
            if (!dbg) {
                const d = document.createElement('div');
                d.id = 'dbg-toast';
                d.style = 'position:fixed; bottom:20px; left:20px; background:rgba(0,0,0,0.8); color:yellow; padding:8px; border-radius:10px; font-size:11px; z-index:9999; pointer-events:none;';
                d.innerHTML = `RX: ${data.machineCode} | ${data.metricValue}`;
                document.body.appendChild(d);
            } else {
                dbg.innerHTML = `RX: ${data.machineCode} | ${data.metricValue}`;
            }

            // Live sync for eval chart
            if (evalChart) {
                let smc = currentEvalMachineName || currentEvalMachineCode || "";
                if (smc.includes("CHS2L")) smc = "CHS 2 Layer";
                else if (smc.includes("CHS3L")) smc = "CHS 3 Layer";
                else if (smc.includes("DL")) smc = "Non-CHS (DL)";

                const dataMC = (data.machineCode || "").toLowerCase();
                const curMC = (currentEvalMachineCode || "").toLowerCase();
                const curMN = (currentEvalMachineName || "").toLowerCase();
                const smcLow = smc.toLowerCase();

                const isMatch = dataMC === curMC || dataMC === curMN || smcLow === dataMC ||
                    (curMC && dataMC.includes(curMC)) || (dataMC && curMC.includes(dataMC)) ||
                    (curMN && dataMC.includes(curMN)) || (dataMC && curMN.includes(dataMC));
                    
                if (isMatch) {
                    if (data.metricType && data.metricType.toLowerCase() !== 'outer_diameter') return;

                    const ts = data.timestamp;
                    const val = parseFloat(data.metricValue);
                    const dev = data.deviceId || 'Sensor';
                    
                    // Show a quick unobtrusive toast to let the user know data is streaming
                    const toast = document.getElementById('live-indicator-toast');
                    if (!toast) {
                        const t = document.createElement('div');
                        t.id = 'live-indicator-toast';
                        t.style = 'position:fixed; bottom:20px; right:20px; background:rgba(16,185,129,0.9); color:white; padding:8px 16px; border-radius:20px; font-size:12px; z-index:9999; box-shadow:0 4px 6px rgba(0,0,0,0.3); pointer-events:none; transition: opacity 0.5s;';
                        t.innerHTML = `<i class="bi bi-broadcast pulse-white me-2"></i>Live Data: ${ts} (${val})`;
                        document.body.appendChild(t);
                    } else {
                        toast.innerHTML = `<i class="bi bi-broadcast pulse-white me-2"></i>Live Data: ${ts} (${val})`;
                        toast.style.opacity = '1';
                        clearTimeout(toast.hideTimeout);
                        toast.hideTimeout = setTimeout(() => { toast.style.opacity = '0'; }, 3000);
                    }

                    if (!evalChart.data.labels.includes(ts)) {
                        evalChart.data.labels.push(ts);
                        
                        // Push correct values instead of null for standard lines
                        evalChart.data.datasets.forEach(ds => {
                            if (ds.label === 'Outer Diameter') {
                                ds.data.push(ds.data[0]); // replicate target
                            } else if (ds.label.includes('USL')) {
                                ds.data.push(ds.data[0]);
                            } else if (ds.label.includes('LSL')) {
                                ds.data.push(ds.data[0]);
                            } else {
                                ds.data.push(null);
                            }
                        });
                    }
                    
                    const labelIdx = evalChart.data.labels.indexOf(ts);
                    let ds = evalChart.data.datasets.find(d => d.label === `OD Aktual (${dev})`);
                    
                    if (!ds) {
                        const palette = ['#0ea5e9', '#fd7e14', '#20c997', '#6f42c1', '#d63384', '#0dcaf0'];
                        const devColor = palette[evalChart.data.datasets.length % palette.length];
                        ds = {
                            label: `OD Aktual (${dev})`,
                            data: new Array(evalChart.data.labels.length).fill(null),
                            borderColor: devColor,
                            backgroundColor: 'transparent',
                            borderWidth: 2,
                            pointRadius: 0,
                            pointHoverRadius: 4,
                            tension: 0.1,
                            spanGaps: true
                        };
                        evalChart.data.datasets.push(ds);
                    }
                    
                    ds.data[labelIdx] = val;
                    evalChart.update();
                }
            }
        });

        startSignalR();

        // Register zoom plugin (sama seperti Sensor Monitor Analysis)
        (function registerEvalZoomPlugin() {
            const zoomPlugin = window.ChartZoom || window['chartjs-plugin-zoom'];
            if (window.Chart && zoomPlugin && !Chart.registry.plugins.get('zoom')) {
                Chart.register(zoomPlugin);
            }
        })();

        // Evaluasi Modal Logic
        let evalChart = null;

        function zoomInEvalChart() {
            if (!evalChart || typeof evalChart.zoom !== 'function') return;
            evalChart.zoom(1.25);
        }

        function zoomOutEvalChart() {
            if (!evalChart || typeof evalChart.zoom !== 'function') return;
            evalChart.zoom(0.8);
        }

        function resetEvalChartZoom() {
            if (evalChart && typeof evalChart.resetZoom === 'function') {
                evalChart.resetZoom();
            }
        }

        let currentEvalMachineCode = '';
        let currentEvalMachineName = '';
        let currentEvalItemList = '';
        let currentEvalDocNumber = '';

        function openEvalModal(id, startTimeStr, endTimeStr, machineName, machineCode, itemList, docNumber) {
            document.getElementById('evalReportId').value = id;
            document.getElementById('evalStartTime').value = startTimeStr || '';
            document.getElementById('evalEndTime').value = endTimeStr || '';
            currentEvalMachineName = machineName || '';
            currentEvalMachineCode = machineCode || '';
            currentEvalItemList = itemList || 'N/A';
            currentEvalDocNumber = docNumber || '-';

            // Update info bar
            const infoBar = document.getElementById('evalInfoBar');
            const elDoc = document.getElementById('evalInfoDocNumber');
            const elItem = document.getElementById('evalInfoItemList');
            const elMachine = document.getElementById('evalInfoMachine');
            if (elDoc) elDoc.textContent = currentEvalDocNumber;
            if (elItem) elItem.textContent = currentEvalItemList;
            if (elMachine) elMachine.textContent = currentEvalMachineName || currentEvalMachineCode || '—';
            if (infoBar) infoBar.style.display = 'block';
            
            var modal = new bootstrap.Modal(document.getElementById('evalModal'));
            modal.show();

            loadChartData(id, startTimeStr, endTimeStr);
        }

        // Add event listener to destroy chart when modal is hidden
        document.getElementById('evalModal').addEventListener('hidden.bs.modal', function () {
            if (evalChart) { evalChart.destroy(); evalChart = null; }
        });

        async function saveAndRenderEval() {
            const id = document.getElementById('evalReportId').value;
            const start = document.getElementById('evalStartTime').value;
            const end = document.getElementById('evalEndTime').value;

            const formData = new FormData();
            formData.append("id", id);
            formData.append("start", start);
            formData.append("end", end);

            try {
                const response = await fetch('/ProductionReport/UpdateProductionTime', {
                    method: 'POST',
                    body: formData
                });
                const res = await response.json();
                if (res.success) {
                    loadChartData(id, start, end);
                } else {
                    Swal.fire("Error", res.message, "error");
                }
            } catch (e) {
                Swal.fire("Error", "Failed to update time", "error");
            }
        }

        async function loadChartData(id, start, end) {
            document.getElementById('evalChartContainer').style.display = 'none';
            document.getElementById('evalLoading').style.display = 'block';

            try {
                const response = await fetch(`/ProductionReport/GetSensorDataForAnalysis?reportId=${id}&start=${start}&end=${end}`);
                const data = await response.json();
                
                document.getElementById('evalLoading').style.display = 'none';
                document.getElementById('evalChartContainer').style.display = 'block';

                if (!data.success) {
                    Swal.fire("Error", data.message || "Failed to load data", "error");
                    return;
                }

                renderChart(data);
            } catch (e) {
                document.getElementById('evalLoading').style.display = 'none';
                Swal.fire("Error", "Failed to load chart data", "error");
            }
        }

        function evalStdLine(label, val, len, color, dash) {
            const v = parseFloat(val);
            if (isNaN(v)) return null;
            return {
                label,
                data: Array(len).fill(v),
                borderColor: color,
                borderWidth: 2,
                borderDash: dash,
                pointRadius: 0,
                fill: false,
                tension: 0,
                order: 2
            };
        }

        function renderChart(data) {
            let labels = data.logs.map(l => l.time);
            const values = data.logs.map(l => parseFloat(l.value));

            // Generate placeholder labels if data is completely empty so the grid can render
            if (labels.length === 0) {
                const startStr = document.getElementById('evalStartTime').value;
                const endStr = document.getElementById('evalEndTime').value;
                if (startStr && endStr) {
                    const s = new Date(startStr);
                    const e = new Date(endStr);
                    const step = (e - s) / 4;
                    for (let i = 0; i <= 4; i++) {
                        const d = new Date(s.getTime() + step * i);
                        labels.push(d.toTimeString().split(' ')[0].substring(0, 5));
                    }
                } else {
                    labels = ["00:00", "01:00", "02:00", "03:00", "04:00"];
                }
            }

            const pointCount = Math.max(labels.length, 1);

            const stdOD = parseFloat(data.stdOd ?? data.stdOD);
            const upperLimit = parseFloat(data.upperLimit);
            const lowerLimit = parseFloat(data.lowerLimit);
            const hasStd = !isNaN(stdOD) && stdOD > 0;
            const hasUsl = !isNaN(upperLimit) && upperLimit > 0;
            const hasLsl = !isNaN(lowerLimit) && lowerLimit > 0;

            document.getElementById('evalModalLabel').innerHTML =
                `<i class="bi bi-activity me-2"></i>EVALUASI WAKTU & SENSOR "${currentEvalMachineName || currentEvalMachineCode || 'Unknown'}"`;

            // Update the new Outer Diameter Info Label
            const elODInfo = document.getElementById('evalInfoOD');
            if (elODInfo) {
                let specs = [];
                if (hasStd) specs.push(`Outer Diameter: ${stdOD}`);
                if (hasUsl) specs.push(`USL: ${upperLimit}`);
                if (hasLsl) specs.push(`LSL: ${lowerLimit}`);
                
                elODInfo.textContent = specs.join(', ') || '—';
            }

            // Ensure chart container is visible
            const container = document.getElementById('evalChartContainer');
            container.style.display = 'block';
            container.innerHTML = `<canvas id="evalSensorChart"></canvas>`;

            const ctx = document.getElementById('evalSensorChart').getContext('2d');
            if (evalChart) evalChart.destroy();

            const datasets = [];
            const deviceGroups = {};
            
            data.logs.forEach((d, i) => {
                const dev = d.device || 'Sensor';
                if (!deviceGroups[dev]) {
                    deviceGroups[dev] = { 
                        data: new Array(data.logs.length).fill(null)
                    };
                }
                deviceGroups[dev].data[i] = parseFloat(d.value);
            });

            const palette = ['#0ea5e9', '#fd7e14', '#20c997', '#6f42c1', '#d63384', '#0dcaf0'];
            let cIdx = 0;

            for (const [dev, group] of Object.entries(deviceGroups)) {
                const devColor = palette[cIdx % palette.length];
                
                datasets.push({
                    label: `OD Aktual (${dev})`,
                    data: group.data,
                    borderColor: devColor,
                    backgroundColor: 'transparent',
                    borderWidth: 2,
                    pointBackgroundColor: devColor,
                    pointBorderColor: devColor,
                    pointRadius: data.logs.length <= 200 ? 2 : 0,
                    pointHoverRadius: 4,
                    spanGaps: true,
                    tension: 0.1,
                    fill: false,
                    order: 1
                });
                cIdx++;
            }

            if (hasStd) datasets.push(evalStdLine(`Outer Diameter`, stdOD, pointCount, '#22d3ee', [2, 4]));
            if (hasUsl) datasets.push(evalStdLine(`USL (Spec Max)`, upperLimit, pointCount, '#ff4d4d', [5, 5]));
            if (hasLsl) datasets.push(evalStdLine(`LSL (Spec Min)`, lowerLimit, pointCount, '#ffb703', [5, 5]));

            // Ensure there is at least one dataset so the grid renders
            if (datasets.length === 0) {
                datasets.push({
                    label: 'No Data',
                    data: new Array(labels.length).fill(null),
                    borderColor: 'transparent',
                    pointRadius: 0
                });
            }

            const refValues = [
                ...values.filter(v => !isNaN(v)),
                ...(hasStd ? [stdOD] : []),
                ...(hasUsl ? [upperLimit] : []),
                ...(hasLsl ? [lowerLimit] : [])
            ];
            const autoYMin = refValues.length ? Math.min(...refValues) - 0.05 : undefined;
            const autoYMax = refValues.length ? Math.max(...refValues) + 0.05 : undefined;

            const finalYMin = evalCustomYMin !== null ? evalCustomYMin : autoYMin;
            const finalYMax = evalCustomYMax !== null ? evalCustomYMax : autoYMax;

            evalChart = new Chart(ctx, {
                type: 'line',
                data: { labels, datasets: datasets.filter(Boolean) },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: {
                        legend: {
                            display: true,
                            position: 'top',
                            labels: { color: 'white', usePointStyle: true, font: { size: 11 } }
                        },
                        tooltip: { mode: 'index', intersect: false },
                        zoom: {
                            pan: {
                                enabled: true,
                                mode: 'x',
                                modifierKey: null
                            },
                            zoom: {
                                wheel: { enabled: true, speed: 0.1 },
                                pinch: { enabled: true },
                                drag: { enabled: false },
                                mode: 'x'
                            },
                            limits: {
                                x: { min: 0, max: Math.max(labels.length - 1, 0) },
                                y: {
                                    min: finalYMin != null ? finalYMin - 0.5 : undefined,
                                    max: finalYMax != null ? finalYMax + 0.5 : undefined
                                }
                            }
                        }
                    },
                    scales: {
                        x: { ticks: { color: '#94a3b8', maxRotation: 45 }, grid: { color: 'rgba(255,255,255,0.05)' } },
                        y: {
                            ticks: { 
                                color: '#94a3b8',
                                callback: function(value) {
                                    let roundedValue = Math.round(value * 1000) / 1000;
                                    return roundedValue + ' mm';
                                }
                            },
                            grid: { color: 'rgba(255,255,255,0.1)' },
                            min: finalYMin,
                            max: finalYMax,
                            suggestedMin: autoYMin,
                            suggestedMax: autoYMax
                        }
                    }
                }
            });
        }
        
        let evalCustomYMin = null;
        let evalCustomYMax = null;

        function openYAxisModal() {
            var modal = new bootstrap.Modal(document.getElementById('yAxisModal'));
            modal.show();
        }

        function applyYAxisRange() {
            const minVal = document.getElementById('yAxisMin').value;
            const maxVal = document.getElementById('yAxisMax').value;
            evalCustomYMin = minVal !== '' ? parseFloat(minVal) : null;
            evalCustomYMax = maxVal !== '' ? parseFloat(maxVal) : null;
            
            if (evalChart) {
                evalChart.options.scales.y.min = evalCustomYMin !== null ? evalCustomYMin : undefined;
                evalChart.options.scales.y.max = evalCustomYMax !== null ? evalCustomYMax : undefined;
                evalChart.update();
            }
            
            const modalEl = document.getElementById('yAxisModal');
            const modal = bootstrap.Modal.getInstance(modalEl);
            if(modal) modal.hide();
        }

        function resetYAxisRange() {
            document.getElementById('yAxisMin').value = '';
            document.getElementById('yAxisMax').value = '';
            evalCustomYMin = null;
            evalCustomYMax = null;
            
            // Re-render chart to use auto calculated bounds
            saveAndRenderEval();
            
            const modalEl = document.getElementById('yAxisModal');
            const modal = bootstrap.Modal.getInstance(modalEl);
            if(modal) modal.hide();
        }
        
        // Setup Pagination for Parameter History
        document.addEventListener('DOMContentLoaded', () => {
            function setupPagination(tableId, rowsPerPage) {
                const table = document.getElementById(tableId);
                if (!table) return;
                const tbody = table.querySelector('tbody');
                if (!tbody) return;
                const rows = Array.from(tbody.querySelectorAll('tr:not(.no-data)'));
                if(rows.length === 0) return;
                
                let currentPage = 1;
                const totalPages = Math.ceil(rows.length / rowsPerPage);

                function renderPage(page) {
                    const start = (page - 1) * rowsPerPage;
                    const end = start + rowsPerPage;
                    rows.forEach((row, i) => {
                        row.style.display = (i >= start && i < end) ? '' : 'none';
                    });
                    document.getElementById(tableId + '_pageInfo').textContent = `Halaman ${page} dari ${totalPages}`;
                    document.getElementById(tableId + '_btnPrev').disabled = page === 1;
                    document.getElementById(tableId + '_btnNext').disabled = page === totalPages;
                }

                const container = document.createElement('div');
                container.className = 'd-flex justify-content-between align-items-center mt-3 p-3';
                container.innerHTML = `
                    <span class="text-secondary small" id="${tableId}_pageInfo"></span>
                    <div class="btn-group">
                        <button id="${tableId}_btnPrev" class="btn btn-sm btn-outline-info">&laquo; Prev</button>
                        <button id="${tableId}_btnNext" class="btn btn-sm btn-outline-info">Next &raquo;</button>
                    </div>
                `;
                table.parentNode.insertBefore(container, table.nextSibling);

                document.getElementById(tableId + '_btnPrev').addEventListener('click', () => {
                    if(currentPage > 1) { currentPage--; renderPage(currentPage); }
                });
                document.getElementById(tableId + '_btnNext').addEventListener('click', () => {
                    if(currentPage < totalPages) { currentPage++; renderPage(currentPage); }
                });

                renderPage(1);
            }

            setupPagination('paramTable', 10);
        });
    </script>
}

