@model IEnumerable<VelastoProductionSystem.Models.ProductionReport>
@{
    ViewData["Title"] = "Parameter History";
    var total = Model.Count();
    var activeCount = Model.Count(x => x.Status != "COMPLETED");
    var doneCount = Model.Count(x => x.Status == "COMPLETED");
}

<div class="hud-dashboard-container" style="min-height: 100vh; background: #020617; color: #fff; padding: 1.5rem; font-family: 'Inter', sans-serif;">
    <!-- ══ GLOW DECOR ══ -->
    <div style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(circle at 50% -20%, rgba(14, 165, 233, 0.15), transparent 70%); pointer-events: none; z-index: 0;"></div>

    <!-- ══ HEADER HUD ══ -->
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4 p-3 rounded-4 border border-white border-opacity-5" style="background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(20px); position: relative; z-index: 1;">
        <div class="d-flex align-items-center gap-3">
            <div class="hud-icon-box" style="width: 64px; height: 64px; background: rgba(14, 165, 233, 0.1); border: 1px solid rgba(14, 165, 233, 0.3); border-radius: 16px; display: flex; align-items: center; justify-content: center; color: #0ea5e9; font-size: 1.8rem;">
                <i class="bi bi-clock-history"></i>
            </div>
            <div>
                <div class="super-small text-info fw-black tracking-widest mb-1" style="font-size: 0.65rem;">COMMAND CONSOLE</div>
                <h1 class="h2 fw-900 mb-0 tracking-tight" style="letter-spacing: -1px;">PARAMETER HISTORY</h1>
                <div class="d-flex align-items-center gap-2 mt-1">
                    <span class="hud-status-led led-blue blink"></span>
                    <span class="text-white-50 small fw-bold">SYSTEM ARCHIVE ACTIVE</span>
                </div>
            </div>
        </div>
        
        <div class="d-flex gap-2">
            <button onclick="exportTable()" class="btn btn-hud-outline px-3 d-flex align-items-center gap-2">
                <i class="bi bi-download"></i> EXPORT
            </button>
            <a asp-action="Create" class="btn btn-hud-primary px-4 d-flex align-items-center gap-2">
                <i class="bi bi-plus-lg fs-5"></i> NEW RECORD
            </a>
        </div>
    </div>

    <!-- ══ STATS HUD ══ -->
    <div class="row g-3 mb-4" style="position: relative; z-index: 1;">
        <div class="col-md-3">
            <div class="hud-card p-3 d-flex align-items-center gap-3">
                <div class="stat-icon-box bg-info bg-opacity-10 text-info rounded-3 p-2 px-3">
                    <i class="bi bi-layers-half fs-4"></i>
                </div>
                <div>
                    <div class="h3 fw-900 mb-0">@total</div>
                    <div class="super-small text-white-50 fw-bold">TOTAL LOGS</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="hud-card p-3 d-flex align-items-center gap-3">
                <div class="stat-icon-box bg-warning bg-opacity-10 text-warning rounded-3 p-2 px-3">
                    <i class="bi bi-activity fs-4"></i>
                </div>
                <div>
                    <div class="h3 fw-900 mb-0">@activeCount</div>
                    <div class="super-small text-white-50 fw-bold">ACTIVE SESSIONS</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="hud-card p-3 d-flex align-items-center gap-3">
                <div class="stat-icon-box bg-success bg-opacity-10 text-success rounded-3 p-2 px-3">
                    <i class="bi bi-check-all fs-4"></i>
                </div>
                <div>
                    <div class="h3 fw-900 mb-0">@doneCount</div>
                    <div class="super-small text-white-50 fw-bold">COMPLETED</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="hud-card p-2 px-3 d-flex align-items-center" style="min-height: 100%;">
                <div class="flex-grow-1">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <i class="bi bi-search text-info small"></i>
                        <span class="super-small text-white-50 fw-bold">SEARCH ENGINE</span>
                    </div>
                    <input id="phSearch" type="text" class="bg-transparent border-0 text-white w-100 fw-bold" 
                           placeholder="Filter items..." oninput="filterRows(this.value)" style="outline: none; font-size: 0.95rem;">
                </div>
            </div>
        </div>
    </div>

    <!-- ══ DATA TABLE ══ -->
    <div class="hud-table-wrapper" style="position: relative; z-index: 1;">
        <div class="table-scroll-container">
            <table class="table table-dark mb-0 sapphire-table">
                <thead>
                    <tr class="header-row">
                        <th class="ps-4">PRODUCTION DATE</th>
                        <th>DOC NUMBER</th>
                        <th>SHIFT</th>
                        <th>MACHINE</th>
                        <th>ITEM CODE</th>
                        <th>SPECIFICATION</th>
                        <th>MATERIAL (IN/OUT)</th>
                        <th class="text-center">OPERATOR</th>
                        <th class="text-center">STATUS</th>
                        <th class="text-center pe-4">COMMAND</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderByDescending(x => x.ProductionDate).ThenByDescending(x => x.Id))
                    {
                        var isCompleted = item.Status == "COMPLETED";
                        var itemCode = item.ItemCode ?? item.StandardParameterSetting?.ItemList ?? "N/A";
                        var searchText = ((item.DocumentNumber ?? "") + " " + itemCode + " " + (item.HoseType ?? "") + " " + (item.Shift ?? "") + " " + (item.MachineName ?? "") + " " + (item.CreatedBy ?? "")).ToLower();
                        
                        <tr class="align-middle ph-row" data-search="@searchText">
                            <td class="ps-4 fw-bold text-nowrap">@item.ProductionDate.ToString("dd MMM yyyy")</td>
                            <td><code class="text-primary-50">@item.DocumentNumber</code></td>
                            <td><span class="badge shift-badge @(item.Shift?.ToUpper().Contains("I") == true ? "bg-info" : "bg-warning")">@item.Shift</span></td>
                            <td>
                                <span class="badge bg-secondary bg-opacity-25 text-white border border-white border-opacity-10 font-monospace">@(item.MachineName ?? "N/A")</span>
                            </td>
                            <td><span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-20 font-monospace">@itemCode</span></td>
                            <td>
                                <div class="hose-type-tag">@item.HoseType</div>
                                <div class="super-small text-white-50 mt-1">
                                    @if (!string.IsNullOrEmpty(item.Dimension))
                                    {
                                        <span class="text-info fw-bold">DIM:</span> <span>@item.Dimension</span><br/>
                                    }
                                    @if (!string.IsNullOrEmpty(item.Yarn))
                                    {
                                        <span class="text-info fw-bold">YARN:</span> <span>@item.Yarn</span>
                                    }
                                </div>
                            </td>
                            <td>
                                <div class="extra-small text-white-50">
                                    <i class="bi bi-circle-fill text-info me-1" style="font-size: 6px;"></i>IN: <span class="text-white">@(item.InnerMaterial ?? "—")</span><br/>
                                    <i class="bi bi-circle-fill text-warning me-1" style="font-size: 6px;"></i>OUT: <span class="text-white">@(item.OuterMaterial ?? "—")</span>
                                </div>
                            </td>
                            <td class="text-center">
                                <div class="d-flex align-items-center justify-content-center gap-2">
                                    <div class="bg-primary bg-opacity-20 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 24px; height: 24px; font-size: 0.6rem; font-weight: 900;">
                                        @((item.CreatedBy?.Length > 0 == true) ? item.CreatedBy.Substring(0,1).ToUpper() : "O")
                                    </div>
                                    <div class="text-start">
                                        <div class="super-small text-white fw-bold">@(item.CreatedBy ?? "SYSTEM")</div>
                                        <div class="text-white-50" style="font-size: 0.65rem;">
                                            <i class="bi bi-clock me-1"></i>@item.CreatedDate.ToString("HH:mm")
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="status-pill @(isCompleted ? "completed" : "active")">
                                    <i class="bi @(isCompleted ? "bi-check-circle-fill" : "bi-broadcast pulse-blue") me-1"></i>
                                    @item.Status
                                </span>
                            </td>
                            <td class="text-center pe-4">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-action-glass btn-blue" title="View Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-action-glass btn-orange" title="Edit">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <button type="button" class="btn btn-action-glass btn-red delete-btn" 
                                            data-id="@item.Id" 
                                            data-doc="@item.DocumentNumber" 
                                            title="Delete">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            
            @if (!Model.Any())
            {
                <div class="text-center p-5 mt-5">
                    <div class="display-1 text-white-50 opacity-10 mb-4"><i class="bi bi-archive"></i></div>
                    <h3 class="fw-900">NO RECORDS FOUND</h3>
                    <p class="text-white-50">Database archive is currently empty or filtered out.</p>
                    <a asp-action="Create" class="btn btn-hud-primary mt-3 px-4">CREATE FIRST LOG</a>
                </div>
            }
        </div>
    </div>

    <!-- ══ FOOTER INFO ══ -->
    <div class="text-center mt-5 mb-4 py-3 border-top border-white border-opacity-5">
        <div class="super-small text-white-50 fw-black tracking-widest">
            <i class="bi bi-shield-check text-info me-2"></i>SPS INTEGRATED SYSTEM v2.0 &nbsp;|&nbsp; VELASTO PRODUCTION RECORDING
        </div>
    </div>
</div>

<form id="deleteForm" asp-action="Delete" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteId" />
</form>

<style>
    .fw-900 { font-weight: 900 !important; }
    .fw-black { font-weight: 900 !important; }
    .super-small { font-size: 9px; }
    .extra-small { font-size: 11px; }
    .tracking-widest { letter-spacing: 2px; }
    
    .hud-table-wrapper {
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(20px);
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 0;
        overflow: hidden;
    }

    .table-scroll-container {
        overflow-x: auto;
        overflow-y: auto;
        max-height: 70vh;
    }
    .table-scroll-container::-webkit-scrollbar { width: 10px; height: 10px; }
    .table-scroll-container::-webkit-scrollbar-track { background: rgba(15,23,42,0.8); }
    .table-scroll-container::-webkit-scrollbar-thumb { background: rgba(59,130,246,0.5); border-radius: 0; }
    .table-scroll-container::-webkit-scrollbar-thumb:hover { background: #3b82f6; }
    .table-scroll-container::-webkit-scrollbar-corner { background: rgba(15,23,42,0.8); }

    /* Sharp Grid Table */
    .sapphire-table { 
        color: rgba(255,255,255,0.85);
        border-collapse: collapse;
        min-width: 1200px;
    }
    .sapphire-table thead tr.header-row {
        background: linear-gradient(90deg, rgba(30, 58, 138, 0.5), rgba(37, 99, 235, 0.3));
        border-bottom: 2px solid rgba(59, 130, 246, 0.5);
        position: sticky;
        top: 0;
        z-index: 5;
    }
    .sapphire-table th { 
        font-size: 10px; 
        font-weight: 900; 
        letter-spacing: 2px; 
        color: #60a5fa; 
        padding: 14px 14px;
        text-transform: uppercase;
        white-space: nowrap;
        border-right: 1px solid rgba(59, 130, 246, 0.25) !important;
        border-bottom: 2px solid rgba(59, 130, 246, 0.4) !important;
        text-shadow: 0 0 10px rgba(96,165,250,0.4);
    }
    .sapphire-table th:last-child { border-right: none !important; }
    .sapphire-table td { 
        padding: 14px 14px; 
        border-bottom: 1px solid rgba(59, 130, 246, 0.12) !important;
        border-right: 1px solid rgba(59, 130, 246, 0.1) !important;
        vertical-align: middle;
    }
    .sapphire-table td:last-child { border-right: none !important; }
    .sapphire-table tbody tr { transition: background 0.15s; }
    .sapphire-table tbody tr:hover td { background: rgba(59, 130, 246, 0.08); }
    .sapphire-table tbody tr:nth-child(even) td { background: rgba(15, 23, 42, 0.3); }
    .sapphire-table tbody tr:nth-child(even):hover td { background: rgba(59, 130, 246, 0.08); }

    /* Sharp Hose Type Tag */
    .hose-type-tag {
        display: inline-block;
        background: rgba(37, 99, 235, 0.2);
        border: 1px solid rgba(59, 130, 246, 0.45);
        border-left: 3px solid #3b82f6;
        color: white;
        font-weight: 800;
        padding: 3px 10px;
        border-radius: 0;
        font-size: 12px;
        letter-spacing: 0.5px;
    }

    .shift-badge { padding: 4px 10px; border-radius: 0; font-weight: 900; font-size: 10px; letter-spacing: 1px; }

    .status-pill {
        display: inline-flex;
        align-items: center;
        padding: 4px 12px;
        border-radius: 0;
        font-size: 10px;
        font-weight: 900;
        letter-spacing: 1.5px;
        white-space: nowrap;
    }
    .status-pill.active { background: rgba(59, 130, 246, 0.1); color: #60a5fa; border: 1px solid rgba(59, 130, 246, 0.4); border-left: 3px solid #3b82f6; }
    .status-pill.completed { background: rgba(16, 185, 129, 0.1); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.4); border-left: 3px solid #10b981; }

    .btn-action-glass {
        width: 34px;
        height: 34px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 0;
        transition: all 0.2s;
        border: 1px solid rgba(255,255,255,0.1);
    }
    .btn-action-glass.btn-blue { color: #60a5fa; background: rgba(37, 99, 235, 0.1); border-color: rgba(59,130,246,0.3); }
    .btn-action-glass.btn-orange { color: #fbbf24; background: rgba(245, 158, 11, 0.1); border-color: rgba(251,191,36,0.3); }
    .btn-action-glass.btn-red { color: #ef4444; background: rgba(220, 38, 38, 0.1); border-color: rgba(239,68,68,0.3); }
    .btn-action-glass:hover { transform: scale(1.1); color: white; background: rgba(255,255,255,0.15); border-color: rgba(255,255,255,0.4); }

    .btn-hud-primary {
        background: linear-gradient(135deg, #0ea5e9, #2563eb);
        border: none;
        color: #fff;
        font-weight: 800;
        border-radius: 10px;
        transition: all 0.2s;
        box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);
    }
    .btn-hud-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(37, 99, 235, 0.5);
        color: #fff;
    }

    .btn-hud-outline {
        background: rgba(14, 165, 233, 0.05);
        border: 1px solid rgba(14, 165, 233, 0.2);
        color: #0ea5e9;
        font-weight: 700;
        border-radius: 10px;
        transition: all 0.2s;
    }
    .btn-hud-outline:hover {
        background: rgba(14, 165, 233, 0.15);
        border-color: #0ea5e9;
        color: #fff;
    }

    .hud-status-led {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: inline-block;
    }
    .led-blue { background: #0ea5e9; box-shadow: 0 0 10px #0ea5e9; }
    
    .blink { animation: hud-blink 2s infinite; }
    @@keyframes hud-blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

    .pulse-blue { width: 8px; height: 8px; background: #3b82f6; border-radius: 50%; display: inline-block; animation: i-pulse 2.5s infinite; filter: blur(1px); }
    @@keyframes i-pulse { 0% { opacity: 1; transform: scale(1); box-shadow: 0 0 0 0 rgba(59,130,246,0.7); } 50% { opacity: 0.5; transform: scale(0.8); } 100% { opacity: 1; transform: scale(1); box-shadow: 0 0 0 10px rgba(59,130,246,0); } }

    .ph-hidden { display: none !important; }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.12/signalr.min.js"></script>
    <script>
        function filterRows(q) {
            const t = q.toLowerCase();
            const items = document.querySelectorAll('.ph-row');
            items.forEach(r => {
                const match = r.dataset.search.includes(t);
                r.classList.toggle('ph-hidden', !match);
            });
        }

        function exportTable() {
            Swal.fire({
                title: 'PREPARING EXPORT',
                text: 'Generating CSV archive...',
                icon: 'info',
                background: '#0f172a', color: '#fff',
                timer: 1500, showConfirmButton: false, toast: true, position: 'top-end'
            });
            
            // Collect visible items
            const rows = document.querySelectorAll('.ph-row:not(.ph-hidden)');
            let csv = "Date,DocNumber,ItemCode,HoseType,Shift,Status,Operator\n";
            
            rows.forEach(r => {
                const date = r.querySelector('.badge.bg-info').innerText.trim();
                const doc = r.querySelector('.text-white-50.font-monospace').innerText.trim();
                const item = r.querySelector('h4').innerText.trim();
                const hose = r.querySelector('.text-white-50.small').innerText.trim();
                const shift = r.querySelector('.badge.bg-primary, .badge.bg-warning').innerText.trim();
                const status = r.querySelector('.tracking-widest').innerText.trim();
                const op = r.querySelector('.super-small .text-white').innerText.trim();
                
                csv += `"${date}","${doc}","${item}","${hose}","${shift}","${status}","${op}"\n`;
            });

            const a = document.createElement('a');
            a.href = URL.createObjectURL(new Blob([csv], {type:'text/csv'}));
            a.download = `ProductionHistory_${new Date().toISOString().slice(0,10)}.csv`;
            a.click();
        }

        document.querySelectorAll('.delete-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                Swal.fire({
                    title: '<span style="color:#f87171">DELETE RECORD?</span>',
                    html: `<span style="color:rgba(255,255,255,0.6)">Permanently remove:<br><strong style="color:#38bdf8">${this.dataset.doc}</strong></span>`,
                    icon: 'warning', showCancelButton: true,
                    confirmButtonColor: '#ef4444', cancelButtonColor: '#334155',
                    confirmButtonText: 'DELETE', cancelButtonText: 'CANCEL',
                    background: '#0f172a', color: '#fff'
                }).then(r => {
                    if (r.isConfirmed) {
                        document.getElementById('deleteId').value = this.dataset.id;
                        document.getElementById('deleteForm').submit();
                    }
                });
            });
        });

        // SignalR Live Sync
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hub/dashboard")
            .withAutomaticReconnect()
            .build();

        async function startSignalR() {
            try {
                await connection.start();
                console.log("SignalR Connected.");
            } catch (err) {
                setTimeout(startSignalR, 5000);
            }
        }

        connection.on("ReceiveUpdate", function () {
            Swal.fire({
                title: 'LIVE SYNC',
                text: 'New data detected. Refreshing...',
                icon: 'info',
                background: '#0f172a', color: '#fff',
                timer: 2000, showConfirmButton: false, toast: true, position: 'top-end'
            });
            setTimeout(() => window.location.reload(), 1500);
        });

        startSignalR();
    </script>
}
