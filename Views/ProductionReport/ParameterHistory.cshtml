@model IEnumerable<VelastoProductionSystem.Models.ProductionReport>

@{
    ViewData["Title"] = "Parameter History";
}

<div class="production-dashboard-sapphire fade-in">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4 header-sapphire-glass p-4 rounded-4 shadow-lg">
                <div class="d-flex align-items-center">
                    <div class="hud-icon-box glow-amber me-3">
                        <i class="bi bi-clock-history text-amber fs-3"></i>
                    </div>
                    <div>
                        <h2 class="text-white fw-black mb-0 tracking-tighter" style="font-size: 2.2rem;">PARAMETER HISTORY</h2>
                        <div class="text-amber super-small fw-bold letter-spacing-2 opacity-75 d-flex align-items-center gap-2">
                             <span class="status-dot pulse bg-amber"></span> ARCHIVED PRODUCTION SPECIFICATIONS
                        </div>
                    </div>
                </div>
                <div class="d-flex gap-3">
                    <button class="btn btn-outline-premium px-4">
                        <i class="bi bi-download me-2"></i> EXPORT DATA
                    </button>
                    <a asp-action="Create" class="btn btn-primary-premium px-4">
                        <i class="bi bi-plus-lg me-2"></i> NEW RECORD
                    </a>
                </div>
            </div>

            <div class="hud-table-wrapper">
                <div class="table-scroll-container">
                    <table class="table table-dark mb-0 sapphire-table">
                        <thead>
                            <tr class="header-row">
                                <th class="ps-4">DATE</th>
                                <th>DOC NUMBER</th>
                                <th>SHIFT</th>
                                <th>HOSE TYPE</th>
                                <th>MATERIAL (IN/OUT)</th>
                                <th class="text-center">SPS REF</th>
                                <th class="text-center">OPERATOR</th>
                                <th class="text-center">STATUS</th>
                                <th class="text-center pe-4">COMMAND</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr class="align-middle">
                                    <td class="ps-4 fw-bold text-nowrap">@item.ProductionDate.ToString("dd/MM/yy")</td>
                                    <td><code class="text-primary-50">@item.DocumentNumber</code></td>
                                    <td><span class="badge shift-badge @(item.Shift?.Contains("1") == true ? "bg-info" : "bg-warning")">@item.Shift</span></td>
                                    <td>
                                        <div class="hose-type-tag">@item.HoseType</div>
                                        <div class="super-small text-white-50 mt-1">@item.Dimension</div>
                                    </td>
                                    <td>
                                        <div class="extra-small text-white-50 lh-sm">
                                            IN: <span class="text-white fw-bold">@item.InnerMaterial</span><br/>
                                            OUT: <span class="text-white fw-bold">@item.OuterMaterial</span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        @if (item.StandardParameterSettingId != null)
                                        {
                                            <span class="text-success small fw-bold"><i class="bi bi-link-45deg"></i> Linked</span>
                                        }
                                        else
                                        {
                                            <span class="text-white-50 extra-small">Manual</span>
                                        }
                                    </td>
                                    <td class="text-center small">@item.CreatedBy</td>
                                    <td class="text-center">
                                        <span class="status-pill @(item.Status == "COMPLETED" ? "completed" : "active")">
                                            @item.Status
                                        </span>
                                    </td>
                                    <td class="text-center pe-4">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-action-glass btn-blue" title="View Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-action-glass btn-orange" title="Edit">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>
                                            <button type="button" class="btn btn-action-glass btn-red delete-btn" 
                                                    data-id="@item.Id" 
                                                    data-doc="@item.DocumentNumber" 
                                                    title="Delete">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- HIDDEN DELETE FORM -->
<form id="deleteForm" asp-action="Delete" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteId" />
</form>

<style>
    .header-sapphire-glass { 
        background: linear-gradient(135deg, rgba(30, 41, 59, 0.6), rgba(15, 23, 42, 0.8)); 
        border: 1px solid rgba(255, 191, 0, 0.15);
        backdrop-filter: blur(20px);
    }
    .hud-icon-box { 
        width: 65px; 
        height: 65px; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        border-radius: 18px;
    }
    .hud-icon-box.glow-amber {
        background: rgba(255, 191, 0, 0.1);
        border: 1px solid rgba(255, 191, 0, 0.2);
        box-shadow: 0 0 25px rgba(255, 191, 0, 0.1);
    }
    .text-amber { color: #ffbf00; }
    .bg-amber { background-color: #ffbf00; box-shadow: 0 0 10px #ffbf00; }

    .btn-primary-premium {
        background: linear-gradient(135deg, #0066ff, #0052cc);
        color: white;
        border: none;
        border-radius: 12px;
        font-weight: 700;
        transition: all 0.3s;
        box-shadow: 0 8px 20px rgba(0, 102, 255, 0.2);
    }
    .btn-primary-premium:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 30px rgba(0, 102, 255, 0.4);
        color: white;
    }

    .btn-outline-premium {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.15);
        color: white;
        border-radius: 12px;
        font-weight: 600;
        transition: all 0.3s;
    }
    .btn-outline-premium:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.3);
        transform: translateY(-3px);
        color: white;
    }

    .hud-table-wrapper { 
        background: rgba(15, 23, 42, 0.7); 
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 24px;
        overflow: hidden;
        backdrop-filter: blur(20px);
        box-shadow: 0 20px 50px rgba(0,0,0,0.4);
    }
    .table-scroll-container { overflow-x: auto; max-height: 75vh; }
    .sapphire-table { color: rgba(255,255,255,0.9); border-collapse: separate; border-spacing: 0; width: 100%; }
    .sapphire-table thead tr.header-row { 
        background: rgba(255, 255, 255, 0.03);
    }
    .sapphire-table th { 
        font-size: 11px; 
        font-weight: 800; 
        letter-spacing: 1.5px; 
        color: rgba(255, 255, 255, 0.4); 
        padding: 20px 15px; 
        text-transform: uppercase; 
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }
    .sapphire-table td { 
        padding: 18px 15px; 
        border-bottom: 1px solid rgba(255, 255, 255, 0.04); 
        vertical-align: middle; 
    }
    .sapphire-table tr:hover td {
        background: rgba(0, 102, 255, 0.05);
    }
    .hose-type-tag { 
        display: inline-block; 
        background: rgba(37, 99, 235, 0.15); 
        border: 1px solid rgba(59, 130, 246, 0.3); 
        color: #60a5fa; 
        font-weight: 700; 
        padding: 4px 12px; 
        font-size: 11px;
        border-radius: 6px;
    }
    .status-pill { padding: 6px 14px; font-size: 10px; font-weight: 800; letter-spacing: 0.5px; border-radius: 50px; text-transform: uppercase; }
    .status-pill.active { background: rgba(59, 130, 246, 0.15); color: #60a5fa; border: 1px solid rgba(59, 130, 246, 0.3); }
    .status-pill.completed { background: rgba(16, 185, 129, 0.15); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.3); }
    
    .btn-action-glass { 
        width: 38px; 
        height: 38px; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 10px;
    }
    .btn-action-glass:hover { transform: scale(1.15) translateY(-3px); background: white !important; color: black !important; }
    
    .btn-action-glass.btn-blue { color: #60a5fa; background: rgba(37, 99, 235, 0.1); }
    .btn-action-glass.btn-orange { color: #fbbf24; background: rgba(245, 158, 11, 0.1); }
    .btn-action-glass.btn-red { color: #ef4444; background: rgba(220, 38, 38, 0.1); }
    
    .super-small { font-size: 10px; }
    .extra-small { font-size: 11px; }
    .fw-black { font-weight: 950; }
    .tracking-tighter { letter-spacing: -1.2px; }
    .letter-spacing-2 { letter-spacing: 2px; }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function() {
            // Success/Error notifications from TempData
            @if (TempData["SuccessMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Berhasil!',
                    text: '@TempData["SuccessMessage"]',
                    background: '#0f172a',
                    color: '#fff',
                    timer: 3000,
                    showConfirmButton: false
                });
                </text>
            }

            $('.delete-btn').on('click', function() {
                const id = $(this).data('id');
                const docNumber = $(this).data('doc');

                Swal.fire({
                    title: 'Hapus Laporan?',
                    text: `Apakah Anda yakin ingin menghapus laporan "${docNumber}"? Tindakan ini permanen.`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ef4444',
                    cancelButtonColor: '#334155',
                    confirmButtonText: 'Ya, Hapus!',
                    cancelButtonText: 'Batal',
                    background: '#0f172a',
                    color: '#fff',
                    backdrop: `rgba(15, 23, 42, 0.4)`
                }).then((result) => {
                    if (result.isConfirmed) {
                        $('#deleteId').val(id);
                        $('#deleteForm').submit();
                    }
                });
            });
        });
    </script>
}
