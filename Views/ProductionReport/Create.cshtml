                        <div class="d-flex align-items-center">
                            <span class="text-warning-glow fw-900 me-1" style="font-size: 0.65rem; opacity: 0.6;">🧪</span>
                            <input type="number" step="0.0001" class="hud-input font-monospace text-warning fw-black p-0 border-0 bg-transparent text-end flex-grow-1" style="font-size: 1rem;" placeholder="0.0000" data-layer="${layer}" data-type="sg" />
                        </div>
                    </div>
                </div>
                ` : ''}
                <div class="col-2 text-center" style="min-width: 40px;">
                    <button type="button" onclick="removeMaterialRow('${layer}', '${rowId}')" class="btn btn-link text-danger p-0 border-0 shadow-none" title="REMOVE LOT">
                        <i class="bi bi-x-circle-fill fs-5"></i>
                    </button>
