@model VelastoProductionSystem.Models.ProductionReport

@{
    ViewData["Title"] = "EXTRUDER PRODUCTION REPORT";
}

<div class="production-blueprint no-print-bg pb-5">
    <div class="container-fluid p-4">
        
        <!-- HEADER HUD (NO BACKGROUND) -->
        <div class="mb-5 py-2">
            <div class="text-center">
                <h1 class="m-0 fw-black text-white letter-spacing-2" style="font-size: 1.6rem;">EXTRUDER PRODUCTION REPORT</h1>
                <div class="text-primary-glow fw-bold tracking-widest" style="font-size: 0.95rem;">(PARAMETER SETTING)</div>
            </div>
        </div>

        <form asp-action="Create" id="mainReportForm">
            <!-- TOP INFO GRID -->
            <div class="row g-3 mb-4">
                <div class="col-md-4"><div class="hud-pill"><label>NO. DOC.</label><input asp-for="DocumentNumber" class="hud-input fw-bold" required /></div></div>
                <div class="col-md-3"><div class="hud-pill"><label>DATE</label><input asp-for="ProductionDate" type="date" class="hud-input" value="@DateTime.Now.ToString("yyyy-MM-dd")" required /></div></div>
                <div class="col-md-3"><div class="hud-pill"><label>SHIFT</label><select asp-for="Shift" class="hud-input bg-transparent border-0"><option value="I">SHIFT I</option><option value="II" selected>SHIFT II</option><option value="III">SHIFT III</option></select></div></div>
                <div class="col-md-2"><div class="hud-pill"><label>NO. REV</label><input asp-for="RevisionNumber" class="hud-input text-center" value="0" /></div></div>
                <div class="col-md-6"><div class="hud-pill"><label>CUSTOMER</label><input asp-for="CustomerName" class="hud-input" placeholder="PT. ADM" /></div></div>
                <div class="col-md-6"><div class="hud-pill"><label>TYPE</label><input asp-for="HoseType" id="HoseType" class="hud-input" placeholder="Hose, Ventilation, Ø 11 mm x 18 mm" /></div></div>
            </div>

            <!-- ROW 2: MATERIAL & MESH CHECKING -->
            <!-- ROW 2: MATERIAL & MESH CHECKING -->
            <style>
                .hud-pill-group {
                    display: inline-flex;
                    background: rgba(0, 0, 0, 0.4);
                    padding: 3px;
                    border-radius: 8px;
                    border: 1px solid rgba(255, 255, 255, 0.1);
                    width: 100%;
                    justify-content: center;
                }
                .hud-pill-item {
                    flex: 1;
                    padding: 5px 10px;
                    font-size: 0.7rem;
                    font-weight: 900;
                    color: rgba(255, 255, 255, 0.4);
                    border-radius: 6px;
                    cursor: pointer;
                    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
                    text-transform: uppercase;
                    white-space: nowrap;
                    text-align: center;
                }
                .hud-pill-item input { display: none; }
                .hud-pill-item:has(input:checked) {
                    background: #10b981;
                    color: white;
                    box-shadow: 0 0 15px rgba(16, 185, 129, 0.4);
                }
                .hud-pill-item.red:has(input:checked) { background: #ef4444; box-shadow: 0 0 15px rgba(239, 68, 68, 0.4); }
                .hud-pill-item.orange:has(input:checked) { background: #f59e0b; box-shadow: 0 0 15px rgba(245, 158, 11, 0.4); }
                .hud-pill-item:hover:not(:has(input:checked)) {
                    background: rgba(255, 255, 255, 0.1);
                    color: white;
                }
                .hud-cell-label { font-size: 0.6rem; color: #60a5fa; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; display: block; margin-bottom: 2px; }
                .hud-cell-value { font-size: 0.85rem; font-weight: 900; color: white; display: block; line-height: 1.2; }
                .hud-input-underlined {
                    background: transparent;
                    border: none;
                    border-bottom: 2px solid rgba(255, 255, 255, 0.05);
                    color: white;
                    font-weight: 900;
                    width: 100%;
                    padding: 8px 4px;
                    text-align: center;
                    transition: all 0.3s;
                    font-size: 0.85rem;
                }
                .hud-input-underlined:focus {
                    outline: none;
                    border-bottom-color: #3b82f6;
                    background: rgba(59, 130, 246, 0.05);
                }
                .hud-input-underlined.lot { color: #0ea5e9; border-bottom-color: rgba(14, 165, 233, 0.2); background: rgba(14, 165, 233, 0.03); }
                .hud-input-underlined.lot:focus { border-bottom-color: #0ea5e9; background: rgba(14, 165, 233, 0.1); }
            </style>

            <div class="row g-4 mb-5">
                <!-- MATERIAL & LOT SECTION -->
                <div class="col-lg-7">
                    <div class="hud-card h-100 shadow-hud-blue border-white border-opacity-10 overflow-hidden d-flex">
                        <div class="hud-tag-sidebar blue"><span>MATERIAL & LOT</span></div>
                        <div class="flex-grow-1 p-0">
                            <table class="table table-dark table-borderless m-0 align-middle">
                                <thead class="bg-black bg-opacity-40 border-bottom border-white border-opacity-10">
                                    <tr>
                                        <th class="ps-4 py-3 sub-title opacity-75">CONTENT</th>
                                        <th width="24%" class="py-3 sub-title opacity-75 text-center">STANDARD</th>
                                        <th width="22%" class="py-3 sub-title opacity-75 text-center">ACTUAL</th>
                                        <th width="30%" class="py-3 sub-title text-info border-start border-white border-opacity-10 text-center">NO. LOT</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="border-bottom border-white border-opacity-5">
                                        <td class="ps-4 py-4">
                                            <span class="hud-cell-label small">INNER (MATERIAL)</span>
                                            <span class="hud-cell-value">Compound Type A</span>
                                        </td>
                                        <td><input asp-for="InnerMaterial" class="hud-input-underlined opacity-50" readonly /></td>
                                        <td><input asp-for="InnerMaterialActual" class="hud-input-underlined" placeholder="---" /></td>
                                        <td class="bg-black bg-opacity-20 border-start border-white border-opacity-10 p-3"><input asp-for="InnerMaterialLotNo" class="hud-input-underlined lot" placeholder="SCAN / TYPE LOT" /></td>
                                    </tr>
                                    <tr class="border-bottom border-white border-opacity-5">
                                        <td class="ps-4 py-4">
                                            <span class="hud-cell-label small">OUTER (MATERIAL)</span>
                                            <span class="hud-cell-value">Compound Type B</span>
                                        </td>
                                        <td><input asp-for="OuterMaterial" class="hud-input-underlined opacity-50" readonly /></td>
                                        <td><input asp-for="OuterMaterialActual" class="hud-input-underlined" placeholder="---" /></td>
                                        <td class="bg-black bg-opacity-20 border-start border-white border-opacity-10 p-3"><input asp-for="OuterMaterialLotNo" class="hud-input-underlined lot" placeholder="SCAN / TYPE LOT" /></td>
                                    </tr>
                                    <tr>
                                        <td class="ps-4 py-4">
                                            <span class="hud-cell-label small">YARN (SUPPORT)</span>
                                            <span class="hud-cell-value">Polyester Braiding</span>
                                        </td>
                                        <td><input asp-for="Yarn" class="hud-input-underlined opacity-50" readonly /></td>
                                        <td><input asp-for="YarnActual" class="hud-input-underlined" placeholder="---" /></td>
                                        <td class="bg-black bg-opacity-20 border-start border-white border-opacity-10 p-3"><input asp-for="YarnLotNo" class="hud-input-underlined lot" placeholder="SCAN / TYPE LOT" /></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- MESH & EMBOSS SECTION -->
                <div class="col-lg-5">
                    <div class="hud-card h-100 shadow-hud-blue border-white border-opacity-10 overflow-hidden d-flex">
                        <div class="hud-tag-sidebar blue-dim"><span>MESH & EMBOSS</span></div>
                        <div class="flex-grow-1 p-0">
                            <table class="table table-dark table-borderless m-0 align-middle">
                                <thead class="bg-black bg-opacity-40 border-bottom border-white border-opacity-10">
                                    <tr>
                                        <th class="ps-3 py-3 sub-title opacity-75">CHECKLISTS</th>
                                        <th width="30%" class="py-3 sub-title opacity-75 text-center">Ø96 #10</th>
                                        <th width="30%" class="py-3 sub-title opacity-75 text-center">Ø96 #40</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="bg-black bg-opacity-20 border-bottom border-white border-opacity-5">
                                        <td class="ps-3 py-2"><span class="hud-cell-label">TIPE MESH</span><span class="hud-cell-value small">Inner (Sebelum)</span></td>
                                        <td class="text-center"><div class="hud-checkbox-pill"><input type="checkbox"><span></span></div></td>
                                        <td class="text-center"><div class="hud-checkbox-pill"><input type="checkbox"><span></span></div></td>
                                    </tr>
                                    <tr class="bg-black bg-opacity-20 border-bottom border-white border-opacity-10">
                                        <td class="ps-3 py-2"><span class="hud-cell-label opacity-0">.</span><span class="hud-cell-value small">Outer (Sebelum)</span></td>
                                        <td class="text-center"><div class="hud-checkbox-pill"><input type="checkbox"><span></span></div></td>
                                        <td class="text-center"><div class="hud-checkbox-pill"><input type="checkbox"><span></span></div></td>
                                    </tr>
                                    <tr class="border-bottom border-white border-opacity-5">
                                        <td class="ps-3 py-3"><span class="hud-cell-label">MESH CHECK</span><span class="hud-cell-value small">Inner (Setelah)</span></td>
                                        <td colspan="2" class="pe-4 py-3"><div class="hud-pill-group"><label class="hud-pill-item">OK<input type="radio" name="MI" value="OK"></label><label class="hud-pill-item red">BOLONG<input type="radio" name="MI" value="B"></label><label class="hud-pill-item orange">ASING<input type="radio" name="MI" value="A"></label></div></td>
                                    </tr>
                                    <tr class="border-bottom border-white border-opacity-10">
                                        <td class="ps-3 py-3"><span class="hud-cell-label opacity-0">.</span><span class="hud-cell-value small">Outer (Setelah)</span></td>
                                        <td colspan="2" class="pe-4 py-3"><div class="hud-pill-group"><label class="hud-pill-item">OK<input type="radio" name="MO" value="OK"></label><label class="hud-pill-item red">BOLONG<input type="radio" name="MO" value="B"></label><label class="hud-pill-item orange">ASING<input type="radio" name="MO" value="A"></label></div></td>
                                    </tr>
                                    <tr class="bg-black bg-opacity-20 border-bottom border-white border-opacity-5">
                                        <td class="ps-3 py-2"><span class="hud-cell-label">EMBOSSING</span><span class="hud-cell-value small">Text Marking</span></td>
                                        <td colspan="2" class="pe-3"><input class="hud-input-underlined py-1 text-start ps-2" placeholder="Input Text..." /></td>
                                    </tr>
                                    <tr class="bg-black bg-opacity-20 border-bottom border-white border-opacity-5">
                                        <td class="ps-3 py-2"><span class="hud-cell-label opacity-0">.</span><span class="hud-cell-value small">Prod. Date</span></td>
                                        <td colspan="2" class="pe-3"><input class="hud-input-underlined py-1 text-start ps-2" placeholder="Input Date..." /></td>
                                    </tr>
                                    <tr class="bg-black bg-opacity-20">
                                        <td class="ps-3 py-2"><span class="hud-cell-label opacity-0">.</span><span class="hud-cell-value small">Details Check</span></td>
                                        <td colspan="2" class="pe-2 py-2">
                                            <div class="d-flex flex-column gap-2 pe-3">
                                                <div class="d-flex align-items-center gap-2"><span class="super-tiny opacity-50 fw-black" style="min-width:45px">COND.</span><div class="hud-pill-group"><label class="hud-pill-item">BERSIH<input type="radio" name="cond" value="B"></label><label class="hud-pill-item red">KOTOR<input type="radio" name="cond" value="K"></label></div></div>
                                                <div class="d-flex align-items-center gap-2"><span class="super-tiny opacity-50 fw-black" style="min-width:45px">SURF.</span><div class="hud-pill-group"><label class="hud-pill-item">OK<input type="radio" name="surf" value="OK"></label><label class="hud-pill-item red">SCRATCH<input type="radio" name="surf" value="S"></label></div></div>
                                                <div class="d-flex align-items-center gap-2"><span class="super-tiny opacity-50 fw-black" style="min-width:45px">RESULT</span><div class="hud-pill-group"><label class="hud-pill-item">READABLE<input type="radio" name="emb" value="T"></label><label class="hud-pill-item red">UNREAD<input type="radio" name="emb" value="X"></label></div></div>
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- SECTION: DIES DIMENSION -->
            <div class="hud-card mb-4 d-flex shadow-glow-blue">
                <div class="hud-vertical-label">DIES DIMENSION</div>
                <div class="flex-grow-1 p-0 overflow-auto">
                    <table class="table table-dark table-hud m-0 text-center w-100 table-bordered-ghost">
                        <thead>
                            <tr class="bg-black bg-opacity-40">
                                <th class="text-start ps-4">DIES DESCRIPTION</th>
                                <th width="12%">CEK VISUAL</th>
                                <th width="20%">STANDARD</th>
                                <th width="20%">BEFORE</th>
                                <th width="20%">AFTER</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var diesList = new[] { 
                                    new { Name = "Nipple Die", Std = "8.8 ± 0.1", Field = "NippleDieOK" },
                                    new { Name = "Tube Die", Std = "11.1 ± 0.1", Field = "TubeDieOK" },
                                    new { Name = "Middle Die", Std = "14.2 ± 0.1", Field = "MiddleDieOK" },
                                    new { Name = "Cover Die", Std = "15.1 ± 0.1", Field = "CoverDieOK" },
                                    new { Name = "Spacer Die", Std = "7.3 ± 0.1", Field = "SpacerDieOK" },
                                    new { Name = "A Distance", Std = "0.4 ± 0.1", Field = "ToleranceDieOK" }
                                };
                            }
                            @foreach(var die in diesList) {
                                <tr>
                                    <td class="text-start ps-4 fw-bold">@die.Name</td>
                                    <td><input type="checkbox" name="@die.Field" value="true" class="hud-check"></td>
                                    <td class="text-primary-glow font-monospace">@die.Std</td>
                                    <td><input class="hud-table-input text-center" placeholder="---" /></td>
                                    <td><input class="hud-table-input text-center" placeholder="---" /></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- SECTION: PARAMETERS TABLE (The Massive Grid) -->
            <div class="hud-card mb-4 d-flex shadow-glow-blue">
                <div class="hud-vertical-label">PARAMETER SETTING</div>
                <div class="flex-grow-1 p-0 overflow-auto">
                    <table class="table table-dark table-hud m-0 text-center super-small table-bordered-ghost">
                        <thead class="sticky-top bg-black">
                            <tr class="text-info border-bottom border-primary border-opacity-30">
                                <th class="text-start ps-4 py-3">DESCRIPTION / ITEM</th>
                                <th width="10%">STANDARD</th>
                                <th width="10%" class="bg-primary bg-opacity-20 text-white fw-900 border-x border-primary border-opacity-30">INITIAL</th>
                                @for(int i=1; i<=7; i++){ <th width="8.5%">@i</th> }
                            </tr>
                        </thead>
                        <tbody>
                            <!-- INNER (TUBE 1) -->
                            <tr class="group-header"><td colspan="10" class="text-start ps-4 bg-primary bg-opacity-10 text-primary fw-bold letter-spacing-2">INNER (TUBE 1)</td></tr>
                            @{
                                string[,] innerRows = { 
                                    { "Head Temp. (°C)", "90 ± 5", "HeadTempInner" }, 
                                    { "Cylinder 1 (°C)", "90 ± 5", "Cylinder1TempInner" },
                                    { "Cylinder 2 (°C)", "90 ± 5", "Cylinder2TempInner" },
                                    { "Cylinder 3 (°C)", "90 ± 5", "Cylinder3TempInner" },
                                    { "Screw Temp. (°C)", "90 ± 5", "ScrewTempInner" },
                                    { "Screw Speed (rpm)", "6.1 ± 2.5", "ScrewSpeedInner" },
                                    { "Feed Roll Ratio (%)", "Max 120", "FeedRollRatioInner" },
                                    { "Pressure (MPa)", "Max 50", "PressureInner" }
                                };
                                for(int r=0; r<innerRows.GetLength(0); r++){
                                    <tr>
                                        <td class="text-start ps-4">@innerRows[r,0]</td>
                                        <td class="text-white-50">@innerRows[r,1]</td>
                                        <td class="bg-primary bg-opacity-5"><input name="Init_@innerRows[r,2]" class="reading-input-min fw-bold text-warning" placeholder="..." /></td>
                                        @for(int i=1; i<=7; i++){ <td><input disabled class="reading-input-min opacity-10" /></td> }
                                    </tr>
                                }
                            }

                            <!-- OUTER (COVER) -->
                            <tr class="group-header"><td colspan="10" class="text-start ps-4 bg-warning bg-opacity-10 text-warning fw-bold letter-spacing-2">OUTER (COVER)</td></tr>
                            @{
                                string[,] outerRows = { 
                                    { "Head Temp. (°C)", "90 ± 5", "HeadTempOuter" }, 
                                    { "Cylinder 1 (°C)", "90 ± 5", "Cylinder1TempOuter" },
                                    { "Cylinder 2 (°C)", "90 ± 5", "Cylinder2TempOuter" },
                                    { "Cylinder 3 (°C)", "-", "Cylinder3TempOuter" },
                                    { "Screw Temp. (°C)", "90 ± 5", "ScrewTempOuter" },
                                    { "Screw Speed (rpm)", "8.2 ± 2.5", "ScrewSpeedOuter" },
                                    { "Feed Roll Ratio (%)", "Max 120", "FeedRollRatioOuter" },
                                    { "Pressure (MPa)", "Max 50", "PressureOuter" }
                                };
                                for(int r=0; r<outerRows.GetLength(0); r++){
                                    <tr>
                                        <td class="text-start ps-4">@outerRows[r,0]</td>
                                        <td class="text-white-50">@outerRows[r,1]</td>
                                        <td class="bg-primary bg-opacity-5"><input name="Init_@outerRows[r,2]" class="reading-input-min fw-bold text-warning" placeholder="..." /></td>
                                        @for(int i=1; i<=7; i++){ <td><input disabled class="reading-input-min opacity-10" /></td> }
                                    </tr>
                                }
                            }

                            <!-- SPIRAL -->
                            <tr class="group-header"><td colspan="10" class="text-start ps-4 bg-success bg-opacity-10 text-success fw-bold letter-spacing-2">SPIRAL</td></tr>
                            @{
                                string[,] spiralRows = { 
                                    { "Spiral Speed (rpm)", "98 ± 20", "SpiralSpeed" }, 
                                    { "Spiral Pitch (Setting)", "35 ± 5", "SpiralPitchSetting" },
                                    { "Spiral Pitch (Display)", "35 ± 5", "SpiralPitchDisplay" }
                                };
                                for(int r=0; r<spiralRows.GetLength(0); r++){
                                    <tr>
                                        <td class="text-start ps-4">@spiralRows[r,0]</td>
                                        <td class="text-white-50">@spiralRows[r,1]</td>
                                        <td class="bg-primary bg-opacity-5"><input name="Init_@spiralRows[r,2]" class="reading-input-min fw-bold text-warning" placeholder="..." /></td>
                                        @for(int i=1; i<=7; i++){ <td><input disabled class="reading-input-min opacity-10" /></td> }
                                    </tr>
                                }
                            }

                            <!-- OTHER -->
                            <tr class="group-header"><td colspan="10" class="text-info-glow fw-bold text-start ps-4 bg-info bg-opacity-10 letter-spacing-2" style="color: #0dcaf0;">OTHER</td></tr>
                            @{
                                string[,] otherRows = { 
                                    { "Preset Value (Ø mm)", "18.5 ± 0.2", "PresetValue" }, 
                                    { "Control Value (Ø mm)", "18.5 ± 0.2", "ControlValue" },
                                    { "Hose Speed (m/min)", "3.4 ± 2", "HoseSpeed" },
                                    { "Take-up Conveyor Speed (m/min)", "3.4 ± 3", "TakeupConveyorSpeed" },
                                    { "Cool Conveyor Speed (m/min)", "3.4 ± 4", "CoolConveyorSpeed" },
                                    { "Conveyor Ratio (Take up : Cool)", "100% ± 10", "ConveyorRatio" },
                                    { "Un-smooth Surface", "0.5", "UnsmoothSurface" },
                                    { "Chiller Water Temperature (°C)", "Max 15", "ChillerWaterTemp" },
                                    { "Caterpillar Gap (mm)", "18.2 ± 1", "CaterpillarGap" }
                                };
                                for(int r=0; r<otherRows.GetLength(0); r++){
                                    <tr>
                                        <td class="text-start ps-4">@otherRows[r,0]</td>
                                        <td class="text-white-50">@otherRows[r,1]</td>
                                        <td class="bg-primary bg-opacity-5"><input name="Init_@otherRows[r,2]" class="reading-input-min fw-bold text-warning" placeholder="..." /></td>
                                        @for(int i=1; i<=7; i++){ <td><input disabled class="reading-input-min opacity-10" /></td> }
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- SECTION: WASTE & FOOTER HUD -->
            <div class="row g-3">
                <div class="col-lg-7">
                    <div class="hud-card d-flex h-100 shadow-glow-blue">
                        <div class="hud-vertical-label">WASTE (KG)</div>
                        <div class="flex-grow-1 p-0">
                            <table class="table table-dark table-hud m-0 text-center super-small table-bordered-ghost">
                                <thead>
                                    <tr><th>TYPE</th><th>POINT</th><th width="35%">AWAL</th><th width="35%">AKHIR</th></tr>
                                </thead>
                                <tbody>
                                    <tr><td rowspan="2" class="fw-bold bg-black bg-opacity-20 align-middle">Dandori Awal<br>(Cleaning)</td><td class="text-start ps-3">Inner</td><td><input asp-for="WasteWeightAwal" class="hud-table-input-min" /></td><td><input asp-for="WasteWeightAkhir" class="hud-table-input-min" /></td></tr>
                                    <tr><td class="text-start ps-3">Cover</td><td><input name="WCAwal" class="hud-table-input-min" /></td><td><input name="WCAkhir" class="hud-table-input-min" /></td></tr>
                                    <tr><td rowspan="2" class="fw-bold bg-black bg-opacity-20 align-middle">Dandori Akhir<br>(Remain Mat.)</td><td class="text-start ps-3">Inner</td><td><input name="WAI_A" class="hud-table-input-min" /></td><td><input name="WAI_B" class="hud-table-input-min" /></td></tr>
                                    <tr><td class="text-start ps-3">Cover</td><td><input name="WAC_A" class="hud-table-input-min" /></td><td><input name="WAC_B" class="hud-table-input-min" /></td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="d-flex flex-column gap-3 h-100">
                        <div class="p-3 border border-danger border-opacity-30 bg-danger bg-opacity-5 rounded-1">
                             <div class="text-danger fw-900 super-small mb-1 tracking-widest"><i class="bi bi-exclamation-triangle-fill me-2"></i>OPERATIONAL NOTE</div>
                             <p class="text-white-50 m-0 super-small line-height-1-5">LAKUKAN PENGECEKAN PARAMETER PADA SAAT AWAL, TENGAH & AKHIR PROSES.</p>
                        </div>
                        <div class="mt-auto d-flex gap-2">
                             <button type="button" class="btn btn-hud-outline flex-grow-1 py-3 fw-bold" onclick="location.reload()">RESET DATA</button>
                             <button type="submit" class="btn btn-hud-primary flex-grow-1 py-3 fw-900 tracking-widest shadow-glow">
                                 <i class="bi bi-play-circle-fill me-2"></i>SAVE & INITIALIZE
                             </button>
                        </div>
                    </div>
                </div>
            </div>

        </form>
    </div>
</div>

<style>
    :root {
        --hud-primary: #0ea5e9;
        --hud-glow: #38bdf8;
        --hud-dark: #020617;
        --hud-card: rgba(15, 23, 42, 0.85);
        --hud-border: rgba(14, 165, 233, 0.3);
    }

    .production-blueprint { min-height: 100vh; background: var(--hud-dark); color: #f1f5f9; font-family: 'Inter', sans-serif; }
    .hud-header { background: rgba(30, 41, 59, 0.6); border: 1px solid var(--hud-border); border-radius: 12px; backdrop-filter: blur(15px); }
    .hud-logo-v { width: 48px; height: 48px; background: var(--hud-primary); color: white; font-weight: 900; font-size: 26px; display: flex; align-items: center; justify-content: center; border-radius: 10px; box-shadow: 0 0 20px rgba(14, 165, 233, 0.4); }
    
    .hud-pill { background: rgba(30, 41, 59, 0.6); border: 1px solid var(--hud-border); border-radius: 8px; padding: 6px 16px; display: flex; flex-direction: column; transition: all 0.3s; }
    .hud-pill:focus-within { border-color: var(--hud-glow); box-shadow: 0 0 15px rgba(14, 165, 233, 0.3); }
    .hud-pill label { font-size: 0.65rem; font-weight: 800; color: var(--hud-primary); letter-spacing: 1px; margin-bottom: 2px; }
    .hud-input { background: transparent; border: none; color: white; font-size: 0.95rem; padding: 0; outline: none; width: 100%; }

    .hud-card { background: var(--hud-card); border: 1px solid var(--hud-border); border-radius: 10px; overflow: hidden; backdrop-filter: blur(15px); }
    .hud-vertical-label { width: 45px; background: rgba(14, 165, 233, 0.15); border-right: 1px solid var(--hud-border); display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 0.75rem; color: var(--hud-primary); writing-mode: vertical-rl; transform: rotate(180deg); letter-spacing: 2px; white-space: nowrap; }

    .table-hud { border-collapse: separate; border-spacing: 0; }
    .table-hud th { background: rgba(0,0,0,0.3); color: var(--hud-primary); font-size: 0.7rem; font-weight: 800; letter-spacing: 1px; border-bottom: 1px solid var(--hud-border) !important; padding: 12px !important; }
    .table-hud td { padding: 10px !important; border-color: rgba(255,255,255,0.05) !important; vertical-align: middle; }
    .table-bordered-ghost td, .table-bordered-ghost th { border: 1px solid rgba(255,255,255,0.05); }

    .hud-table-input { background: rgba(30, 41, 59, 0.5); border: 1px solid rgba(255,255,255,0.1); border-radius: 4px; color: white; text-align: center; width: 100%; padding: 5px; outline: none; font-size: 0.85rem; }
    .hud-table-input:focus { border-color: var(--hud-primary); background: rgba(14, 165, 233, 0.1); }
    .hud-table-input-min { background: transparent; border: none; border-bottom: 1px dotted rgba(255,255,255,0.3); color: white; text-align: center; width: 100%; outline: none; padding: 2px; font-size: 0.8rem; }

    .reading-input-min { background: transparent; border: none; color: white; text-align: center; width: 100%; outline: none; }
    .hud-check { width: 22px; height: 22px; cursor: pointer; accent-color: var(--hud-primary); }
    .hud-check-min { width: 16px; height: 16px; cursor: pointer; }

    .btn-hud-primary { background: var(--hud-primary); color: white; border: none; border-radius: 6px; }
    .btn-hud-primary:hover { transform: translateY(-3px); box-shadow: 0 10px 25px rgba(14, 165, 233, 0.5); color: white; }
    .btn-hud-outline { background: transparent; border: 2px solid var(--hud-border); color: #94a3b8; border-radius: 6px; }

    .text-primary-glow { color: var(--hud-glow); text-shadow: 0 0 10px rgba(56, 189, 248, 0.4); }
    .shadow-glow-blue { box-shadow: 0 0 30px rgba(14, 165, 233, 0.15); }
    .super-small { font-size: 0.7rem; }
    .letter-spacing-2 { letter-spacing: 2.5px; }

    /* Sticky Headers for tables */
    .sticky-top { position: sticky; top: 0; z-index: 10; }

    @@media print {
        .production-blueprint { background: white !important; color: black !important; }
        .hud-header, .hud-pill, .hud-card { border: 1px solid black !important; background: white !important; color: black !important; }
        .text-white, .text-primary-glow { color: black !important; }
        .no-print { display: none !important; }
    }
</style>

