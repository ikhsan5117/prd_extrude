                return;
            }

            const rowId = `lot-${layer}-${Date.now()}`;
            const isYarn = (layer === 'yarn');
            const themeColor = layer === 'inner' ? 'info' : (layer === 'outer' ? 'warning' : 'success');
            
            const div = document.createElement('div');
            div.id = rowId;
            div.className = `row g-1 align-items-center animate__animated animate__fadeInLeft mb-2`;
            div.innerHTML = `
                <div class="${isYarn ? 'col-10' : 'col-6'}">
                    <div class="hud-scan-group p-1" style="border-color: rgba(${themeColor === 'info' ? '14, 165, 233' : (themeColor === 'warning' ? '245, 158, 11' : '16, 185, 129')}, 0.25);">
                        <input type="text" class="hud-input-scan text-${themeColor} fw-bold w-100" style="font-size: 0.75rem" placeholder="LOT #${index + 1}..." data-layer="${layer}" data-type="lot" />
                        <button type="button" class="hud-scan-btn ms-1 text-${themeColor}" onclick="openScannerForDynamicRow('${rowId}')"><i class="bi bi-upc-scan fs-6"></i></button>
                    </div>
                </div>
                ${!isYarn ? `
                <div class="col-4">
                    <div class="d-flex flex-column" style="background: rgba(15, 23, 42, 0.6); border: 1px solid rgba(245, 158, 11, 0.3); border-radius: 6px; padding: 2px 8px;">
