@model VelastoProductionSystem.Models.ProductionReport

@{
    ViewData["Title"] = "EXTRUDER PRODUCTION REPORT";
}

<div class="production-blueprint no-print-bg pb-5">
    <div class="container-fluid p-1 p-md-2">
        
        <!-- HEADER HUD (NO BACKGROUND) -->
        <div class="mb-5 py-2">
            <div class="text-center">
                <h1 class="m-0 fw-black text-white letter-spacing-2" style="font-size: 1.6rem;">EXTRUDER PRODUCTION REPORT</h1>
                <div class="text-primary-glow fw-bold tracking-widest" style="font-size: 0.95rem;">(PARAMETER SETTING)</div>
            </div>
        </div>

        <form asp-action="Create" id="mainReportForm">
            <input type="hidden" id="StandardParameterSettingId" name="StandardParameterSettingId" value="" />
            <!-- SECTION: PRODUCTION COMMAND CONSOLE (TOP HEADER) -->
            <div class="hud-card mb-4 shadow-hud-blue border-white border-opacity-10 overflow-hidden">
                <div class="hud-card-header d-flex justify-content-between align-items-center py-2 px-3">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-terminal-fill hud-card-icon fs-6"></i>
                        <span class="hud-card-title small tracking-widest font-monospace">PRODUCTION COMMAND CONSOLE</span>
                    </div>
                    <div class="d-flex gap-3 super-small font-black opacity-40 text-uppercase letter-spacing-2">
                        <span><i class="bi bi-file-text me-1"></i>DOC: <input asp-for="DocumentNumber" id="DocNo" class="bg-transparent border-0 text-white-50 w-auto" placeholder="AUTO" /></span>
                        <span><i class="bi bi-activity me-1"></i>REV: <input asp-for="RevisionNumber" id="RevNo" class="bg-transparent border-0 text-white-50 w-auto" placeholder="0" /></span>
                    </div>
                </div>

                <!-- NEW: SPS PROTOCOL SYNC -->
                <div class="p-3 bg-black bg-opacity-20 border-bottom border-white border-opacity-5 no-print">
                    <div class="row g-3 align-items-center">
                        <div class="col-md-5">
                            <div class="hud-pill p-0 d-flex flex-row overflow-hidden border border-info border-opacity-50" style="min-height: 60px; background: #0f172a; border-radius: 8px;">
                                <div class="flex-grow-1 p-2 px-3 d-flex flex-column justify-content-center">
                                    <label class="mb-0 text-info font-black" style="font-size: 0.65rem; letter-spacing: 1px;"><i class="bi bi-keyboard me-2"></i>MANUAL PROTOCOL</label>
                                    <input id="manualItemSearch" type="text" class="hud-input bg-transparent border-0 py-1 font-monospace text-white fw-bold" style="font-size: 1rem; outline: none;" placeholder="ITEM CODE..." onchange="if(this.value) fetchSpsByItem(this.value)" onkeyup="if(event.key === 'Enter' && this.value) { fetchSpsByItem(this.value); this.blur(); }" autocomplete="off" />
                                </div>
                                <button type="button" onclick="let v = document.getElementById('manualItemSearch').value; if(v) fetchSpsByItem(v);" class="btn border-0 rounded-0 px-3 d-flex align-items-center justify-content-center border-start border-info border-opacity-20" style="min-width: 60px; background: rgba(14, 165, 233, 0.1); color: #0ea5e9;" title="Search">
                                    <i class="bi bi-search fs-4"></i>
                                </button>
                                <button type="button" onclick="startSpsScanner()" class="btn border-0 rounded-0 px-3 d-flex align-items-center justify-content-center border-start border-info border-opacity-20" style="min-width: 70px; background: rgba(14, 165, 233, 0.2); color: #38bdf8;" title="Scan Barcode">
                                    <i class="bi bi-qr-code-scan fs-3"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-md-7">
                            <div class="hud-pill p-0 d-flex flex-row border border-info border-opacity-50" style="min-height: 60px; position: relative; background: #0f172a; border-radius: 8px;">
                                <div class="flex-grow-1 p-2 px-3 d-flex flex-column justify-content-center">
                                    <label class="mb-0 text-info font-black" style="font-size: 0.65rem; letter-spacing: 1px;"><i class="bi bi-list-check me-2"></i>PLANNING MASTER</label>
                                    <input id="planningSearch" type="text" class="hud-input bg-transparent border-0 py-1 font-monospace text-white fw-bold" style="font-size: 1rem; outline: none;" placeholder="SEARCH PLANNING..." oninput="filterPlanningResults(this.value)" onfocus="showPlanningResults()" autocomplete="off" />
                                    
                                    <!-- Results Container -->
                                    <div id="planningResults" class="d-none custom-tactical-scroll" style="position: absolute; top: 100%; left: 0; right: 0; background: #0f172a; border: 1px solid #0ea5e9; border-top: none; z-index: 1000; max-height: 350px; overflow-y: auto; box-shadow: 0 10px 25px rgba(0,0,0,0.8); border-radius: 0 0 12px 12px;">
                                        <!-- Items will be injected here -->
                                    </div>
                                </div>
                                <button type="button" onclick="refreshPlanningItems()" class="btn border-0 rounded-0 px-3 d-flex align-items-center justify-content-center border-start border-info border-opacity-20" style="min-width: 60px; background: rgba(14, 165, 233, 0.1); color: #0ea5e9;" title="Refresh Planning">
                                    <i class="bi bi-arrow-clockwise fs-4"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="p-2 bg-black bg-opacity-10">
                    <div class="row g-2">
                        <div class="col-6">
                            <div class="hud-pill-integrated border border-info border-opacity-20" style="background: rgba(15, 23, 42, 0.8);">
                                <label><i class="bi bi-calendar-check me-2 text-info"></i>SYSTEM DATE</label>
                                <input type="date" asp-for="ProductionDate" id="ProductionDate" class="hud-input font-monospace text-primary-glow" value="@DateTime.Now.ToString("yyyy-MM-dd")" required onchange="refreshPlanningItems()" />
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="hud-pill-integrated border border-info border-opacity-20" style="background: rgba(15, 23, 42, 0.8);">
                                <label><i class="bi bi-clock-history me-2 text-info"></i>SHIFT MONITORING</label>
                                <select asp-for="Shift" id="Shift" class="hud-input font-black bg-transparent border-0 text-white" style="-webkit-appearance: none;" onchange="refreshPlanningItems()">
                                    <option value="I" class="bg-dark">SHIFT I (SIANG)</option>
                                    <option value="II" class="bg-dark" selected>SHIFT II (SORE)</option>
                                    <option value="III" class="bg-dark">SHIFT III (MALAM)</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="hud-pill-integrated border border-info border-opacity-20" style="background: rgba(15, 23, 42, 0.8);">
                                <label><i class="bi bi-building me-2 text-info"></i>CUSTOMER ENTITY</label>
                                <input asp-for="CustomerName" id="CustomerName" class="hud-input small text-white font-black" placeholder="PT. ADM" />
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="hud-pill-integrated border border-info border-opacity-20" style="background: rgba(15, 23, 42, 0.8);">
                                <label><i class="bi bi-cpu me-2 text-info"></i>HOSE SPECIFICATION TYPE</label>
                                <input asp-for="HoseType" id="HoseType" class="hud-input small font-monospace text-white" placeholder="Extrusion Spec Name..." />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ROW 2: MATERIAL & MESH CHECKING -->
            <!-- ROW 2: MATERIAL & MESH CHECKING -->
            <style>
                .hud-pill-group {
                    display: inline-flex;
                    background: rgba(15, 23, 42, 0.6);
                    padding: 4px;
                    border-radius: 8px;
                    border: 1px solid rgba(14, 165, 233, 0.2);
                    width: 100%;
                    gap: 4px;
                }
                .hud-pill-item {
                    flex: 1;
                    padding: 8px 4px;
                    font-size: 0.75rem;
                    font-weight: 900;
                    color: rgba(255, 255, 255, 0.3);
                    border-radius: 6px;
                    cursor: pointer;
                    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
                    text-transform: uppercase;
                    text-align: center;
                    border: 1px solid transparent;
                }
                .hud-pill-item input { display: none; }
                .hud-pill-item:has(input:checked) {
                    background: #10b981;
                    color: white;
                    box-shadow: 0 0 15px rgba(16, 185, 129, 0.5);
                    border-color: rgba(255,255,255,0.2);
                }
                .hud-pill-item.red:has(input:checked) { 
                    background: #ef4444; 
                    box-shadow: 0 0 15px rgba(239, 68, 68, 0.5);
                }
                .hud-pill-item.orange:has(input:checked) { 
                    background: #f59e0b; 
                    box-shadow: 0 0 15px rgba(245, 158, 11, 0.5);
                }
                .hud-pill-group.sm { border-radius: 6px; padding: 4px; }
                .hud-pill-group.sm .hud-pill-item { padding: 8px 2px; font-size: 0.7rem; border-radius: 4px; }
                
                .compact-hud td { padding: 4px 1px !important; } /* REDUCED PADDING TO PREVENT INPUT SQUEEZING */
                .compact-hud th { padding: 6px 1px !important; }
                .instrument-style { font-family: 'JetBrains Mono', 'Roboto Mono', monospace; }

                /* INTEGRATED DASHBOARD PILLS */
                .hud-pill-integrated { 
                    background: rgba(30, 41, 59, 0.4); 
                    border: 1px solid rgba(14, 165, 233, 0.2); 
                    border-radius: 6px; 
                    padding: 8px 12px; 
                    display: flex; 
                    flex-direction: column; 
                    transition: all 0.3s;
                }
                .hud-pill-integrated:focus-within { 
                    border-color: #0ea5e9; 
                    background: rgba(14, 165, 233, 0.1); 
                    box-shadow: 0 0 15px rgba(14, 165, 233, 0.2); 
                }
                .hud-pill-integrated label { 
                    font-size: 0.6rem; 
                    font-weight: 800; 
                    color: #38bdf8; 
                    letter-spacing: 1px; 
                    margin-bottom: 4px; 
                    text-transform: uppercase;
                }
                .hud-pill-integrated .hud-input { 
                    font-size: 0.85rem; 
                    background: transparent; 
                    border: none; 
                    color: white; 
                    padding: 0; 
                    width: 100%;
                    outline: none;
                }
                .group-lane { background: rgba(14, 165, 233, 0.03); }
                .font-black { font-weight: 900 !important; font-size: 0.6rem !important; }

                /* CUSTOM CHECKBOX STYLE - LARGE & FUTURISTIC */
                .hud-check-box { position: relative; width: 32px; height: 32px; margin: 0 auto; cursor: pointer; }
                .hud-check-box input { 
                    position: absolute; 
                    opacity: 0; 
                    width: 100%; 
                    height: 100%; 
                    cursor: pointer; 
                    z-index: 2; 
                    margin: 0;
                }
                .hud-check-box span {
                    position: absolute; top: 0; left: 0; height: 32px; width: 32px;
                    background-color: rgba(15, 23, 42, 0.6);
                    border: 2px solid rgba(14, 165, 233, 0.2);
                    border-radius: 8px; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                    z-index: 1;
                }
                .hud-check-box:hover input ~ span { border-color: #0ea5e9; background: rgba(14, 165, 233, 0.1); }
                .hud-check-box input:checked ~ span { 
                    background-color: #0ea5e9; 
                    border-color: white; 
                    box-shadow: 0 0 20px rgba(14, 165, 233, 0.6); 
                }
                .hud-check-box span:after {
                    content: ""; position: absolute; display: none;
                    left: 11px; top: 5px; width: 8px; height: 16px;
                    border: solid white; border-width: 0 4px 4px 0;
                    transform: rotate(45deg);
                }
                .hud-check-box input:checked ~ span:after { display: block; }
                
                .hud-card-header {
                    background: linear-gradient(90deg, rgba(14, 165, 233, 0.15) 0%, transparent 100%);
                    border-bottom: 1px solid rgba(14, 165, 233, 0.3);
                    padding: 10px 20px;
                    display: flex;
                    align-items: center;
                    gap: 12px;
                }
                .hud-card-title {
                    font-size: 0.85rem;
                    font-weight: 900;
                    letter-spacing: 2px;
                    color: #0ea5e9;
                    text-transform: uppercase;
                }
                .hud-card-icon { color: #0ea5e9; font-size: 1.1rem; }
                
                .table-hud-unified { width: 100%; border-collapse: collapse; }
                .table-hud-unified th { 
                    padding: 12px; 
                    font-size: 0.65rem; 
                    font-weight: 800; 
                    color: rgba(255, 255, 255, 0.5); 
                    text-transform: uppercase; 
                    letter-spacing: 1px;
                    border-bottom: 1px solid rgba(255,255,255,0.05);
                }
                .table-hud-unified td { padding: 12px; vertical-align: middle; border-bottom: 1px solid rgba(255,255,255,0.05); }
                .label-stack { display: flex; flex-direction: column; gap: 2px; }
                .label-main { font-size: 0.85rem; font-weight: 900; color: white; line-height: 1; }
                .label-sub { font-size: 0.6rem; font-weight: 700; color: #60a5fa; text-transform: uppercase; opacity: 0.8; }
                
                /* SCAN ZONE STYLING */
                .hud-th-scan { background: rgba(14, 165, 233, 0.05); color: #0ea5e9 !important; font-weight: 900 !important; }
                .hud-td-scan { background: rgba(0, 0, 0, 0.2); padding: 8px 12px !important; }
                .hud-scan-group {
                    display: flex;
                    align-items: center;
                    background: rgba(15, 23, 42, 0.6);
                    border: 1px solid rgba(14, 165, 233, 0.2);
                    border-radius: 6px;
                    padding: 2px 4px;
                    transition: all 0.3s;
                }
                .hud-scan-group:focus-within {
                    border-color: #0ea5e9;
                    box-shadow: 0 0 15px rgba(14, 165, 233, 0.2);
                    background: rgba(14, 165, 233, 0.05);
                }
                .hud-input-scan {
                    background: transparent;
                    border: none;
                    color: #0ea5e9;
                    font-weight: 900;
                    font-size: 0.85rem;
                    padding: 8px;
                    width: 100%;
                    outline: none;
                    letter-spacing: 1px;
                }
                .hud-scan-btn {
                    background: rgba(14, 165, 233, 0.1);
                    border: none;
                    color: #0ea5e9;
                    padding: 6px 10px;
                    border-radius: 4px;
                    cursor: pointer;
                    transition: all 0.2s;
                }
                .hud-scan-btn:hover { background: #0ea5e9; color: white; }
                .hud-input-underlined {
                    background: transparent;
                    border: none;
                    border-bottom: 2px solid rgba(255, 255, 255, 0.05);
                    color: white;
                    font-weight: 900;
                    width: 100%;
                    padding: 8px 0; /* REMOVED TO PREVENT CLIPPING */
                    text-align: center;
                    transition: all 0.3s;
                    font-size: 1.1rem; /* HIGHER LEGIBILITY */
                    min-height: 46px; /* MATCHES CELL HEIGHT */
                    font-family: 'JetBrains Mono', monospace;
                }
                .hud-input-underlined:focus {
                    outline: none;
                    border-bottom-color: #3b82f6;
                    background: rgba(59, 130, 246, 0.05);
                }
                .param-row-hud { 
                    transition: all 0.3s; 
                    background: rgba(255,255,255,0.03);
                    border: 1px solid rgba(255,255,255,0.05);
                }
                .param-row-hud:hover { 
                    background: rgba(56, 189, 248, 0.08); 
                    border-color: rgba(56, 189, 248, 0.2);
                    transform: translateY(-2px);
                }
                
                .text-info-glow {
                    color: #38bdf8;
                    text-shadow: 0 0 10px rgba(56, 189, 248, 0.4);
                }

                .valid-success { 
                    background: rgba(16, 185, 129, 0.15) !important; 
                    border-bottom-color: #10b981 !important; 
                    box-shadow: 0 4px 15px rgba(16, 185, 129, 0.2);
                    color: #10b981 !important;
                }
                .valid-error { 
                    background: rgba(239, 68, 68, 0.15) !important; 
                    border-bottom-color: #ef4444 !important; 
                    box-shadow: 0 4px 15px rgba(239, 68, 68, 0.2);
                    color: #ef4444 !important;
                    animation: shake-hud 0.4s ease-in-out;
                }
                
                @@keyframes shake-hud { 0%,100% { transform:translateX(0); } 20%,60% { transform:translateX(-5px); } 40%,80% { transform:translateX(5px); } }
                
                .btn-detail-toggle { background: transparent; border: none; color: #38bdf8; transition: all 0.3s; }
                .btn-detail-toggle.active i { transform: rotate(180deg); color: #f59e0b; opacity: 1 !important; }

                .valid-success { border-bottom-color: #10b981 !important; color: #10b981 !important; text-shadow: 0 0 10px rgba(16, 185, 129, 0.4); }
                .valid-error { border-bottom-color: #ef4444 !important; color: #ef4444 !important; text-shadow: 0 0 10px rgba(239, 68, 68, 0.4); }
                
                .custom-scrollbar::-webkit-scrollbar { height: 4px; }
                .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(56, 189, 248, 0.2); border-radius: 10px; }
                
                .blink-once { animation: blink-blue 0.5s ease-in-out; }
                @@keyframes blink-blue { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; color: #38bdf8; } }
            </style>

            <div class="row g-4 mb-5">
                <!-- CARD 1: MATERIAL -->
                <div class="col-lg-7">
                    <div class="hud-card h-100 shadow-hud-blue border-white border-opacity-10 overflow-hidden">
                        <div class="hud-card-header">
                            <i class="bi bi-box-seam hud-card-icon"></i>
                            <span class="hud-card-title">MATERIAL & LOT TRACKING</span>
                        </div>
                        <table class="table-hud-unified">
                            <thead>
                                <tr class="bg-black bg-opacity-20 text-center">
                                    <th class="ps-4 text-start">DESCRIPTION</th>
                                    <th width="22%">STANDARD</th>
                                    <th width="22%">ACTUAL</th>
                                    <th width="32%" class="hud-th-scan text-info border-start border-white border-opacity-10">NO. LOT (SCAN)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="ps-4">
                                        <div class="label-stack"><span class="label-sub">INNER (MATERIAL)</span><span class="label-main">COMPOUND</span></div>
                                    </td>
                                    <td><input asp-for="InnerMaterial" class="hud-input-underlined text-center opacity-50" readonly /></td>
                                    <td><input asp-for="InnerMaterialActual" class="hud-input-underlined text-center" placeholder="---" /></td>
                                    <td class="hud-td-scan border-start border-white border-opacity-10">
                                        <div class="hud-scan-group">
                                            <input asp-for="InnerMaterialLotNo" class="hud-input-scan" placeholder="SCAN LOT..." />
                                            <button type="button" class="hud-scan-btn" onclick="openScanner('InnerMaterialLotNo')"><i class="bi bi-upc-scan"></i></button>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="ps-4">
                                        <div class="label-stack"><span class="label-sub">OUTER (MATERIAL)</span><span class="label-main">COMPOUND</span></div>
                                    </td>
                                    <td><input asp-for="OuterMaterial" class="hud-input-underlined text-center opacity-50" readonly /></td>
                                    <td><input asp-for="OuterMaterialActual" class="hud-input-underlined text-center" placeholder="---" /></td>
                                    <td class="hud-td-scan border-start border-white border-opacity-10">
                                        <div class="hud-scan-group">
                                            <input asp-for="OuterMaterialLotNo" class="hud-input-scan" placeholder="SCAN LOT..." />
                                            <button type="button" class="hud-scan-btn" onclick="openScanner('OuterMaterialLotNo')"><i class="bi bi-upc-scan"></i></button>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="ps-4">
                                        <div class="label-stack"><span class="label-sub">YARN (SUPPORT)</span><span class="label-main">POLYESTER</span></div>
                                    </td>
                                    <td><input asp-for="Yarn" class="hud-input-underlined text-center opacity-50" readonly /></td>
                                    <td><input asp-for="YarnActual" class="hud-input-underlined text-center" placeholder="---" /></td>
                                    <td class="hud-td-scan border-start border-white border-opacity-10">
                                        <div class="hud-scan-group">
                                            <input asp-for="YarnLotNo" class="hud-input-scan" placeholder="SCAN LOT..." />
                                            <button type="button" class="hud-scan-btn" onclick="openScanner('YarnLotNo')"><i class="bi bi-upc-scan"></i></button>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- CARD 2: MESH & EMBOSS -->
                <div class="col-lg-5">
                    <div class="hud-card h-100 shadow-hud-blue border-white border-opacity-10 overflow-hidden">
                        <div class="hud-card-header">
                            <i class="bi bi-patch-check hud-card-icon"></i>
                            <span class="hud-card-title">MESH & EMBOSS QUALITY</span>
                        </div>
                        <table class="table-hud-unified compact-hud instrument-style">
                            <thead>
                                <tr class="bg-black bg-opacity-40 text-center">
                                    <th class="ps-3 text-start py-2 font-monospace tracking-widest text-primary-glow">CATEGORIES</th>
                                    <th width="32%" class="py-2 border-start border-white border-opacity-5">Ø96 #10</th>
                                    <th width="32%" class="py-2 border-start border-white border-opacity-5">Ø96 #40</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- MESH TYPE ZONE -->
                                <tr class="group-lane">
                                    <td class="ps-3 py-1"><div class="label-stack"><span class="label-sub">TIPE MESH</span><span class="label-main small">INNER (BEFORE)</span></div></td>
                                    <td class="text-center border-start border-white border-opacity-10"><div class="hud-check-box"><input type="checkbox" asp-for="MeshInner10Before"><span></span></div></td>
                                    <td class="text-center border-start border-white border-opacity-10"><div class="hud-check-box"><input type="checkbox" asp-for="MeshInner40Before"><span></span></div></td>
                                </tr>
                                <tr class="group-lane border-bottom border-white border-opacity-10">
                                    <td class="ps-3 py-1"><div class="label-stack"><span class="label-sub opacity-0 small">.</span><span class="label-main small">OUTER (BEFORE)</span></div></td>
                                    <td class="text-center border-start border-white border-opacity-10"><div class="hud-check-box"><input type="checkbox" asp-for="MeshOuter10Before"><span></span></div></td>
                                    <td class="text-center border-start border-white border-opacity-10"><div class="hud-check-box"><input type="checkbox" asp-for="MeshOuter40Before"><span></span></div></td>
                                </tr>
                                <!-- MESH CHECK ZONE -->
                                <tr>
                                    <td class="ps-3 py-3"><div class="label-stack"><span class="label-sub">MESH CHECK</span><span class="label-main small">INNER (AFTER)</span></div></td>
                                    <td colspan="2" class="pe-3 py-3 border-start border-white border-opacity-10">
                                        <div class="hud-pill-group sm"><label class="hud-pill-item">OK<input type="radio" asp-for="MeshInnerCheck" value="OK"></label><label class="hud-pill-item red">BOLONG<input type="radio" asp-for="MeshInnerCheck" value="BOLONG"></label><label class="hud-pill-item orange">ASING<input type="radio" asp-for="MeshInnerCheck" value="ASING"></label></div>
                                    </td>
                                </tr>
                                <tr class="border-bottom border-white border-opacity-10">
                                    <td class="ps-3 py-3"><div class="label-stack"><span class="label-sub opacity-0 small">.</span><span class="label-main small">OUTER (AFTER)</span></div></td>
                                    <td colspan="2" class="pe-3 py-3 border-start border-white border-opacity-10">
                                        <div class="hud-pill-group sm"><label class="hud-pill-item">OK<input type="radio" asp-for="MeshOuterCheck" value="OK"></label><label class="hud-pill-item red">BOLONG<input type="radio" asp-for="MeshOuterCheck" value="BOLONG"></label><label class="hud-pill-item orange">ASING<input type="radio" asp-for="MeshOuterCheck" value="ASING"></label></div>
                                    </td>
                                </tr>
                                <!-- EMBOSSING ZONE -->
                                <tr class="group-lane border-bottom border-white border-opacity-10">
                                    <td class="ps-3 py-3"><div class="label-stack"><span class="label-sub">EMBOSSING</span><span class="label-main small">MARK DATA</span></div></td>
                                    <td colspan="2" class="pe-3 py-3 border-start border-white border-opacity-10">
                                        <div class="row g-2 align-items-center">
                                            <div class="col-7"><input asp-for="EmbossMarkContent" class="hud-input-underlined py-1 text-center font-monospace small" placeholder="CONTENT" /></div>
                                            <div class="col-5"><input type="date" asp-for="EmbossMarkDate" class="hud-input-underlined py-1 text-center font-monospace small" /></div>
                                        </div>
                                    </td>
                                </tr>
                                <!-- FINAL QC ZONE -->
                                <tr>
                                    <td class="ps-3 py-3"><div class="label-stack"><span class="label-sub">QC DETAILS</span><span class="label-main small">FINAL CHECK</span></div></td>
                                    <td colspan="2" class="pe-3 py-3 border-start border-white border-opacity-10">
                                        <div class="d-flex flex-column gap-2">
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="label-sub font-black text-white-50" style="min-width:40px">COND</span>
                                                <div class="hud-pill-group sm">
                                                    <label class="hud-pill-item">BERSIH<input type="radio" asp-for="QcCond" value="BERSIH"></label>
                                                    <label class="hud-pill-item red">KOTOR<input type="radio" asp-for="QcCond" value="KOTOR"></label>
                                                </div>
                                            </div>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="label-sub font-black text-white-50" style="min-width:40px">SURF</span>
                                                <div class="hud-pill-group sm">
                                                    <label class="hud-pill-item">OK<input type="radio" asp-for="QcSurf" value="OK"></label>
                                                    <label class="hud-pill-item red">SCRATCH<input type="radio" asp-for="QcSurf" value="SCRATCH"></label>
                                                </div>
                                            </div>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="label-sub font-black text-white-50" style="min-width:40px">RES</span>
                                                <div class="hud-pill-group sm">
                                                    <label class="hud-pill-item">READ<input type="radio" asp-for="QcRes" value="READ"></label>
                                                    <label class="hud-pill-item red">UNREAD<input type="radio" asp-for="QcRes" value="UNREAD"></label>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- SECTION: DIES DIMENSION - REDESIGNED AS CARDS -->
            <div class="hud-card mb-4 shadow-hud-blue border-white border-opacity-10 overflow-hidden">
                <div class="hud-card-header d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-rulers hud-card-icon"></i>
                        <span class="hud-card-title">DIES DIMENSION MEASUREMENTS</span>
                    </div>
                    <div class="super-small text-info-glow opacity-50 font-monospace">INTERACTIVE INSTRUMENT PANEL</div>
                </div>
                
                <div class="p-3">
                    <div class="row g-3">
                        @{
                            var diesList = new[] { 
                                new { Name = "Nipple Die", Std = "--", Field = "NippleDieOK", SpecKey = "NippleDie", InitName = "NippleDieInitial", FinalName = "NippleDieFinal" },
                                new { Name = "Tube Die", Std = "--", Field = "TubeDieOK", SpecKey = "TubeDie", InitName = "TubeDieInitial", FinalName = "TubeDieFinal" },
                                new { Name = "Middle Die", Std = "--", Field = "MiddleDieOK", SpecKey = "MiddleDie", InitName = "MiddleDieInitial", FinalName = "MiddleDieFinal" },
                                new { Name = "Cover Die", Std = "--", Field = "CoverDieOK", SpecKey = "CoverDie", InitName = "CoverDieInitial", FinalName = "CoverDieFinal" },
                                new { Name = "Spacer Die", Std = "--", Field = "SpacerDieOK", SpecKey = "SpacerDie", InitName = "SpacerDieInitial", FinalName = "SpacerDieFinal" },
                                new { Name = "A Distance", Std = "--", Field = "ToleranceDieOK", SpecKey = "ToleranceDie", InitName = "ToleranceInitial", FinalName = "ToleranceFinal" }
                            };
                        }

                        @foreach(var die in diesList) {
                            <div class="col-md-6 col-xl-4">
                                <div class="die-card p-3 rounded-3 border border-white border-opacity-10 bg-black bg-opacity-30 h-100 d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <div class="label-stack">
                                            <span class="label-sub">INSTRUMENT</span>
                                            <span class="label-main fs-6">@die.Name</span>
                                        </div>
                                        <div class="hud-pill-group sm" style="width: 100px;">
                                            <label class="hud-pill-item">OK<input type="radio" name="@die.Field" value="true"></label>
                                            <label class="hud-pill-item red">NG<input type="radio" name="@die.Field" value="false"></label>
                                        </div>
                                    </div>

                                    <div class="row g-2 align-items-end mt-auto">
                                        <div class="col-4">
                                            <div class="text-center">
                                                <label class="lbl-small mb-1 text-info-glow" style="font-size: 0.55rem;">STANDARD</label>
                                                <div class="hud-input-underlined py-1 text-info-glow bg-dark bg-opacity-50 rounded-2 border-0" id="spec_@die.SpecKey" style="font-size: 0.9rem; min-height: 35px;">@die.Std</div>
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <div class="text-center">
                                                <label class="lbl-small mb-1 text-warning" style="font-size: 0.55rem;">BEFORE</label>
                                                <input name="@die.InitName" class="hud-input-underlined py-1 text-center font-monospace text-warning border-0 bg-white bg-opacity-5 rounded-2" placeholder="---" style="font-size: 0.9rem; min-height: 35px;" />
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <div class="text-center">
                                                <label class="lbl-small mb-1 text-warning" style="font-size: 0.55rem;">AFTER</label>
                                                <input name="@die.FinalName" class="hud-input-underlined py-1 text-center font-monospace text-warning border-0 bg-white bg-opacity-5 rounded-2" placeholder="---" style="font-size: 0.9rem; min-height: 35px;" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <style>
                    .die-card { 
                        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
                        position: relative; 
                        overflow: hidden;
                    }
                    .die-card:hover { 
                        background: rgba(14, 165, 233, 0.08) !important; 
                        border-color: rgba(14, 165, 233, 0.4) !important;
                        transform: translateY(-2px);
                        box-shadow: 0 5px 15px rgba(0,0,0,0.3);
                    }
                    .die-card::before {
                        content: '';
                        position: absolute;
                        top: 0; left: 0; width: 3px; height: 100%;
                        background: rgba(255,255,255,0.05);
                        transition: all 0.3s;
                    }
                    .die-card:hover::before {
                        background: var(--hud-primary);
                        box-shadow: 0 0 10px var(--hud-primary);
                    }
                </style>
            </div>

            <!-- SECTION: DYNAMIC PRODUCTION READINGS TABS (CENTERED) -->
            <div class="d-flex flex-column align-items-center mb-5 mt-2">
                <div class="text-info-glow opacity-40 super-small fw-black tracking-widest mb-3" style="font-size: 0.6rem;">DYNAMIC MEASUREMENT CONTROL</div>
                <div class="d-flex align-items-center gap-4">
                    <div id="readingsTabs" class="d-flex gap-2">
                        <!-- P-1, P-2, etc. will be injected here -->
                    </div>
                    <div class="add-check-trigger d-flex align-items-center gap-2 cursor-pointer no-select" onclick="addReadingPoint()">
                        <i class="bi bi-plus fs-2 text-white"></i>
                        <span class="text-white fw-900 tracking-widest" style="font-size: 1.1rem;">ADD CHECK</span>
                    </div>
                </div>
                <div class="mt-3 font-monospace super-small opacity-50 text-uppercase tracking-widest no-print d-flex align-items-center gap-2">
                    <i class="bi bi-info-circle fs-6"></i> <span>SELECT RECORD TO VIEW/EDIT PARAMETERS</span>
                </div>
            </div>

            <style>
                .no-select { user-select: none; }
                .add-check-trigger { 
                    opacity: 0.6; 
                    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                    padding: 8px 15px;
                    border-radius: 8px;
                }
                .add-check-trigger:hover { 
                    opacity: 1; 
                    background: rgba(255,255,255,0.05);
                    transform: translateX(5px);
                }
                .active-tab { 
                    background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%) !important; 
                    color: white !important; 
                    box-shadow: 0 0 25px rgba(14, 165, 233, 0.6) !important; 
                    border-color: #7dd3fc !important;
                    transform: translateY(-3px);
                }
                .reading-tab {
                    min-width: 95px;
                    text-align: center;
                    font-weight: 900;
                    letter-spacing: 1px;
                    cursor: pointer;
                    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                    border: 2px solid rgba(255, 255, 255, 0.12);
                    background: rgba(15, 23, 42, 0.8);
                    border-radius: 10px;
                    backdrop-filter: blur(5px);
                }
                .reading-tab:hover:not(.active-tab) { 
                    border-color: rgba(14, 165, 233, 0.6);
                    background: rgba(14, 165, 233, 0.1);
                    transform: translateY(-2px);
                }
            </style>

            <!-- SECTION: SMART PARAMETER CARDS (ACTIVE RECORD VIEW) -->
            <div class="row g-4 mb-5" id="parameterCardsContainer">
                @{
                    var monSections = new[] {
                        new { 
                            Title = "SECTION 01: INNER (TUBE 1)", Icon="bi-gear-fill", Color = "#3b82f6", ID="inner",
                            Rows = new[,] { { "Head Temp.", "°C", "HeadTempInner" }, { "Cylinder 1", "°C", "Cylinder1TempInner" }, { "Cylinder 2", "°C", "Cylinder2TempInner" }, { "Cylinder 3", "°C", "Cylinder3TempInner" }, { "Screw Temp.", "°C", "ScrewTempInner" }, { "Screw Speed", "rpm", "ScrewSpeedInner" }, { "Feed Roll Ratio", "%", "FeedRollRatioInner" }, { "Pressure", "MPa", "PressureInner" } }
                        },
                        new { 
                            Title = "SECTION 02: OUTER (COVER)", Icon="bi-shield-shaded", Color = "#f59e0b", ID="outer",
                            Rows = new[,] { { "Head Temp.", "°C", "HeadTempOuter" }, { "Cylinder 1", "°C", "Cylinder1TempOuter" }, { "Cylinder 2", "°C", "Cylinder2TempOuter" }, { "Cylinder 3", "°C", "Cylinder3TempOuter" }, { "Screw Temp.", "°C", "ScrewTempOuter" }, { "Screw Speed", "rpm", "ScrewSpeedOuter" }, { "Feed Roll Ratio", "%", "FeedRollRatioOuter" }, { "Pressure", "MPa", "PressureOuter" } }
                        },
                        new { 
                            Title = "SECTION 03: SPIRAL MECHANISM", Icon="bi-sync", Color = "#10b981", ID="spiral",
                            Rows = new[,] { { "Spiral Speed", "rpm", "SpiralSpeed" }, { "Spiral Pitch (Set)", "mm", "SpiralPitchSetting" }, { "Spiral Pitch (Disp)", "mm", "SpiralPitchDisplay" } } 
                        },
                        new { 
                            Title = "SECTION 04: INFRA & UTILITY", Icon="bi-water", Color = "#0ea5e9", ID="other",
                            Rows = new[,] { { "Preset Value", "Ø mm", "PresetValue" }, { "Control Value", "Ø mm", "ControlValue" }, { "Hose Speed", "m/min", "HoseSpeed" }, { "Take-up Speed", "", "TakeupConveyorSpeed" }, { "Cool Speed", "", "CoolConveyorSpeed" }, { "Conveyor Ratio", "", "ConveyorRatio" }, { "Surface Condition", "", "UnsmoothSurface" }, { "Chiller Temp", "°C", "ChillerWaterTemp" }, { "Caterpillar Gap", "mm", "CaterpillarGap" } } 
                        }
                    };
                }

                @foreach (var mSec in monSections) {
                    <div class="col-12 col-xxl-6">
                        <div class="hud-card h-100 shadow-hud mb-1 overflow-hidden" 
                             style="border: 1px solid @(mSec.Color)44; background: rgba(15, 23, 42, 0.6); box-shadow: 0 0 20px @(mSec.Color)11;">
                            
                            <div class="hud-card-header d-flex justify-content-between align-items-center py-3 px-4" 
                                 style="background: linear-gradient(90deg, @(mSec.Color)33 0%, transparent 100%); border-bottom: 2px solid @(mSec.Color)66;">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="p-2 rounded-3" style="background: @(mSec.Color)22; border: 1px solid @(mSec.Color)44;">
                                        <i class="bi @mSec.Icon fs-4" style="color: @mSec.Color"></i>
                                    </div>
                                    <span class="hud-card-title tracking-widest text-white fw-900" style="font-size: 1.1rem; text-shadow: 0 0 10px @(mSec.Color)66;">@mSec.Title</span>
                                </div>
                            </div>
                            
                            <div class="p-4 bg-black bg-opacity-20">
                                <div class="row g-4">
                                    @for (int r = 0; r < mSec.Rows.GetLength(0); r++) {
                                        var key = mSec.Rows[r, 2];
                                        <div class="col-6">
                                            <div class="param-tile-modern rounded-3 p-3 text-center h-100 d-flex flex-column justify-content-between"
                                                 style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); transition: all 0.3s; position: relative; overflow: hidden;">
                                                
                                                <div class="d-flex justify-content-between align-items-start mb-2">
                                                    <span class="text-white opacity-60 super-small fw-black tracking-widest">@(mSec.Rows[r, 0].ToUpper())</span>
                                                    <span class="badge rounded-pill super-small" style="background: @(mSec.Color)22; color: @mSec.Color; border: 1px solid @(mSec.Color)44;">@mSec.Rows[r, 1]</span>
                                                </div>
                                                
                                                <div class="std-zone py-2 mb-2 rounded-2" style="background: rgba(0,0,0,0.3); border: 1px dashed rgba(255,255,255,0.1);">
                                                    <div class="super-small opacity-40 text-uppercase mb-1" style="font-size: 0.55rem;">Standard Target</div>
                                                    <div class="font-monospace fw-black" id="spec_@key" style="font-size: 1.1rem; color: @mSec.Color; filter: drop-shadow(0 0 5px @(mSec.Color)44);">--</div>
                                                </div>
                                                
                                                <div class="input-zone">
                                                    <input id="input_@key"
                                                           onchange="updateReadingData('@key', this.value)"
                                                           oninput="validateParam(this, 'spec_@key')"
                                                           class="vibrant-hud-input w-100" 
                                                           placeholder="0.00" 
                                                           style="--theme-color: @mSec.Color;" />
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <style>
                .vibrant-hud-input {
                    background: rgba(255,255,255,0.05);
                    border: 2px solid rgba(255,255,255,0.1);
                    border-radius: 8px;
                    color: white;
                    text-align: center;
                    font-family: 'JetBrains Mono', monospace;
                    font-weight: 900;
                    font-size: 1.8rem;
                    height: 65px;
                    width: 100%;
                    outline: none;
                    transition: all 0.3s;
                }
                .vibrant-hud-input:focus {
                    background: rgba(255,255,255,0.1);
                    border-color: var(--theme-color);
                    box-shadow: 0 0 20px var(--theme-color);
                    transform: translateY(-2px);
                }
                .param-tile-modern:hover {
                    background: rgba(255,255,255,0.07) !important;
                    border-color: rgba(255,255,255,0.2) !important;
                    transform: translateY(-5px);
                }
            </style>

            <!-- SECTION: WASTE & FOOTER HUD -->
            <div class="row g-3">
                <div class="col-lg-7">
                    <div class="hud-card h-100 shadow-hud-blue border-white border-opacity-10 p-3 bg-black bg-opacity-40">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-trash text-info fs-5 me-2"></i>
                            <div class="text-info-glow tracking-widest fw-black">WASTE PERFORMANCE (KG)</div>
                        </div>
                        
                        <div class="row g-3">
                            <!-- DANDORI AWAL -->
                            <div class="col-md-6">
                                <div class="border border-white border-opacity-10 rounded-2 p-2 bg-black bg-opacity-20 h-100">
                                    <div class="text-white opacity-50 super-small fw-bold tracking-widest mb-2 border-bottom border-info border-opacity-25 pb-1">DANDORI AWAL (CLEANING)</div>
                                    
                                    <div class="d-flex flex-column gap-2 mt-2">
                                        <div class="hud-pill-integrated border-white border-opacity-5 bg-black bg-opacity-40 p-2 rounded-1">
                                            <div class="mb-1"><label class="text-info super-small fw-bold"><i class="bi bi-circle-fill me-1" style="font-size: 0.5rem"></i>INNER TUBE</label></div>
                                            <div class="d-flex gap-2 bg-dark bg-opacity-50 rounded border border-white border-opacity-10 p-1">
                                                <div class="flex-grow-1 position-relative">
                                                    <span class="position-absolute top-50 start-0 translate-middle-y ms-2 super-small opacity-50">AWAL</span>
                                                    <input asp-for="DAI_Awal" class="hud-input text-end text-primary-glow fw-bold font-monospace pe-2 h-100" placeholder="-" />
                                                </div>
                                                <div class="border-start border-white border-opacity-10"></div>
                                                <div class="flex-grow-1 position-relative">
                                                    <span class="position-absolute top-50 start-0 translate-middle-y ms-2 super-small opacity-50">AKHIR</span>
                                                    <input asp-for="DAI_Akhir" class="hud-input text-end text-primary-glow fw-bold font-monospace pe-2 h-100" placeholder="-" />
                                                </div>
                                            </div>
                                        </div>

                                        <div class="hud-pill-integrated border-white border-opacity-5 bg-black bg-opacity-40 p-2 rounded-1">
                                            <div class="mb-1"><label class="text-warning super-small fw-bold"><i class="bi bi-circle-fill me-1" style="font-size: 0.5rem"></i>COVER</label></div>
                                            <div class="d-flex gap-2 bg-dark bg-opacity-50 rounded border border-white border-opacity-10 p-1">
                                                <div class="flex-grow-1 position-relative">
                                                    <span class="position-absolute top-50 start-0 translate-middle-y ms-2 super-small opacity-50">AWAL</span>
                                                    <input asp-for="DAC_Awal" class="hud-input text-end text-warning fw-bold font-monospace pe-2 h-100" style="text-shadow: 0 0 8px rgba(250,204,21,0.4);" placeholder="-" />
                                                </div>
                                                <div class="border-start border-white border-opacity-10"></div>
                                                <div class="flex-grow-1 position-relative">
                                                    <span class="position-absolute top-50 start-0 translate-middle-y ms-2 super-small opacity-50">AKHIR</span>
                                                    <input asp-for="DAC_Akhir" class="hud-input text-end text-warning fw-bold font-monospace pe-2 h-100" style="text-shadow: 0 0 8px rgba(250,204,21,0.4);" placeholder="-" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- DANDORI AKHIR -->
                            <div class="col-md-6">
                                <div class="border border-white border-opacity-10 rounded-2 p-2 bg-black bg-opacity-20 h-100">
                                    <div class="text-white opacity-50 super-small fw-bold tracking-widest mb-2 border-bottom border-warning border-opacity-25 pb-1">DANDORI AKHIR (REMAIN)</div>
                                    
                                    <div class="d-flex flex-column gap-2 mt-2">
                                        <div class="hud-pill-integrated border-white border-opacity-5 bg-black bg-opacity-40 p-2 rounded-1">
                                            <div class="mb-1"><label class="text-info super-small fw-bold"><i class="bi bi-circle-fill me-1" style="font-size: 0.5rem"></i>INNER TUBE</label></div>
                                            <div class="d-flex gap-2 bg-dark bg-opacity-50 rounded border border-white border-opacity-10 p-1">
                                                <div class="flex-grow-1 position-relative">
                                                    <span class="position-absolute top-50 start-0 translate-middle-y ms-2 super-small opacity-50">AWAL</span>
                                                    <input asp-for="DRAI_Awal" class="hud-input text-end text-primary-glow fw-bold font-monospace pe-2 h-100" placeholder="-" />
                                                </div>
                                                <div class="border-start border-white border-opacity-10"></div>
                                                <div class="flex-grow-1 position-relative">
                                                    <span class="position-absolute top-50 start-0 translate-middle-y ms-2 super-small opacity-50">AKHIR</span>
                                                    <input asp-for="DRAI_Akhir" class="hud-input text-end text-primary-glow fw-bold font-monospace pe-2 h-100" placeholder="-" />
                                                </div>
                                            </div>
                                        </div>

                                        <div class="hud-pill-integrated border-white border-opacity-5 bg-black bg-opacity-40 p-2 rounded-1">
                                            <div class="mb-1"><label class="text-warning super-small fw-bold"><i class="bi bi-circle-fill me-1" style="font-size: 0.5rem"></i>COVER</label></div>
                                            <div class="d-flex gap-2 bg-dark bg-opacity-50 rounded border border-white border-opacity-10 p-1">
                                                <div class="flex-grow-1 position-relative">
                                                    <span class="position-absolute top-50 start-0 translate-middle-y ms-2 super-small opacity-50">AWAL</span>
                                                    <input asp-for="DRAC_Awal" class="hud-input text-end text-warning fw-bold font-monospace pe-2 h-100" style="text-shadow: 0 0 8px rgba(250,204,21,0.4);" placeholder="-" />
                                                </div>
                                                <div class="border-start border-white border-opacity-10"></div>
                                                <div class="flex-grow-1 position-relative">
                                                    <span class="position-absolute top-50 start-0 translate-middle-y ms-2 super-small opacity-50">AKHIR</span>
                                                    <input asp-for="DRAC_Akhir" class="hud-input text-end text-warning fw-bold font-monospace pe-2 h-100" style="text-shadow: 0 0 8px rgba(250,204,21,0.4);" placeholder="-" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="d-flex flex-column h-100 gap-3">
                        <!-- PREMIUM PROTOCOL ALERT -->
                        <div class="hud-card border-danger border-opacity-40 bg-danger bg-opacity-10 shadow-hud-red p-3 d-flex align-items-center gap-3">
                             <div class="hud-status-led led-red blink"></div>
                             <div>
                                <div class="text-danger-glow fw-900 super-small tracking-widest mb-1"><i class="bi bi-shield-lock-fill me-1"></i>SYSTEM PROTOCOL</div>
                                <p class="text-white font-monospace super-small m-0 opacity-90 fw-bold">VERIFIKASI PARAMETER: AWAL / TENGAH / AKHIR PROSES.</p>
                             </div>
                        </div>

                        <!-- DIGITAL SIGN-OFF PANEL -->
                        <div class="hud-card p-3 bg-black bg-opacity-40 border-white border-opacity-10 shadow-hud-blue">
                            <div class="text-info-glow super-small fw-black mb-3 tracking-widest ps-1"><i class="bi bi-vector-pen me-2"></i>OPERATIONAL SIGN-OFF</div>
                            <div class="d-flex flex-column gap-2">
                                <div class="hud-pill-integrated border-white border-opacity-5">
                                    <label>DIBUAT (OPERATOR)</label>
                                    <input asp-for="CreatedBy" class="hud-input text-primary-glow font-black h-auto py-1" placeholder="ENTER NAME..." />
                                </div>
                                <div class="row g-2">
                                    <div class="col-6">
                                        <div class="hud-pill-integrated border-white border-opacity-5 opacity-50">
                                            <label>CHECKED (LEADER)</label>
                                            <input asp-for="CheckedBy" class="hud-input small" readonly placeholder="---" />
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="hud-pill-integrated border-white border-opacity-5 opacity-50">
                                            <label>APPROVED (FOREMAN)</label>
                                            <input asp-for="ApprovedBy" class="hud-input small" readonly placeholder="---" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- FINAL CONTROL TERMINAL -->
                        <div class="hud-card p-3 flex-grow-1 d-flex flex-column bg-black bg-opacity-40 border-white border-opacity-10 shadow-hud-blue">
                             <div class="text-info-glow super-small fw-black mb-3 tracking-widest ps-1"><i class="bi bi-terminal-fill me-2"></i>FINAL COMMANDS</div>
                             <div class="mt-auto d-flex gap-2">
                                <button type="button" class="btn btn-hud-outline flex-grow-1 py-3 fw-bold small d-flex align-items-center justify-content-center gap-2" style="border-width: 1px;" onclick="location.reload()">
                                    <i class="bi bi-trash3-fill"></i> RESET
                                </button>
                                <button type="button" class="btn btn-hud-primary flex-grow-3 py-3 fw-900 tracking-widest shadow-glow-primary border-0 rounded-1 d-flex align-items-center justify-content-center gap-2" style="font-size: 1.1rem;" onclick="submitReportWithReadings()">
                                    <i class="bi bi-cloud-arrow-up-fill fs-5"></i> SAVE REPORT
                                </button>
                             </div>
                        </div>
                    </div>
                </div>
            </div>

        </form>
    </div>
</div>

<style>
    :root {
        --hud-primary: #0ea5e9;
        --hud-glow: #38bdf8;
        --hud-dark: #020617;
        --hud-card: rgba(15, 23, 42, 0.85);
        --hud-border: rgba(14, 165, 233, 0.3);
    }

    .production-blueprint { min-height: 100vh; background: var(--hud-dark); color: #f1f5f9; font-family: 'Inter', sans-serif; }
    .hud-header { background: rgba(30, 41, 59, 0.6); border: 1px solid var(--hud-border); border-radius: 12px; backdrop-filter: blur(15px); }
    .hud-logo-v { width: 48px; height: 48px; background: var(--hud-primary); color: white; font-weight: 900; font-size: 26px; display: flex; align-items: center; justify-content: center; border-radius: 10px; box-shadow: 0 0 20px rgba(14, 165, 233, 0.4); }
    
    .hud-pill { background: rgba(30, 41, 59, 0.6); border: 1px solid var(--hud-border); border-radius: 8px; padding: 6px 16px; display: flex; flex-direction: column; transition: all 0.3s; }
    .hud-pill:focus-within { border-color: var(--hud-glow); box-shadow: 0 0 15px rgba(14, 165, 233, 0.3); }
    .hud-pill label { font-size: 0.65rem; font-weight: 800; color: var(--hud-primary); letter-spacing: 1px; margin-bottom: 2px; }
    .hud-input { background: transparent; border: none; color: white; font-size: 0.95rem; padding: 0; outline: none; width: 100%; }

    .hud-card { background: var(--hud-card); border: 1px solid var(--hud-border); border-radius: 10px; overflow: hidden; backdrop-filter: blur(15px); }
    .hud-vertical-label { width: 45px; background: rgba(14, 165, 233, 0.15); border-right: 1px solid var(--hud-border); display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 0.75rem; color: var(--hud-primary); writing-mode: vertical-rl; transform: rotate(180deg); letter-spacing: 2px; white-space: nowrap; }

    .table-hud { border-collapse: separate; border-spacing: 0; }
    .table-hud th { background: rgba(0,0,0,0.3); color: var(--hud-primary); font-size: 0.7rem; font-weight: 800; letter-spacing: 1px; border-bottom: 1px solid var(--hud-border) !important; padding: 12px !important; }
    .table-hud td { padding: 10px !important; border-color: rgba(255,255,255,0.05) !important; vertical-align: middle; }
    .table-bordered-ghost td, .table-bordered-ghost th { border: 1px solid rgba(255,255,255,0.05); }

    .hud-table-input { background: rgba(30, 41, 59, 0.5); border: 1px solid rgba(255,255,255,0.1); border-radius: 4px; color: white; text-align: center; width: 100%; padding: 5px; outline: none; font-size: 0.85rem; }
    .hud-table-input:focus { border-color: var(--hud-primary); background: rgba(14, 165, 233, 0.1); }
    .hud-table-input-min { background: transparent; border: none; border-bottom: 1px dotted rgba(255,255,255,0.3); color: white; text-align: center; width: 100%; outline: none; padding: 2px; font-size: 0.8rem; }

    .reading-input-min { background: transparent; border: none; color: white; text-align: center; width: 100%; outline: none; }
    .hud-check { width: 22px; height: 22px; cursor: pointer; accent-color: var(--hud-primary); }
    .hud-check-min { width: 16px; height: 16px; cursor: pointer; }

    .btn-hud-primary { background: var(--hud-primary); color: white; border: none; border-radius: 6px; }
    .btn-hud-primary:hover { transform: translateY(-3px); box-shadow: 0 10px 25px rgba(14, 165, 233, 0.5); color: white; }
    .btn-hud-outline { background: transparent; border: 2px solid var(--hud-border); color: #94a3b8; border-radius: 6px; }

    .text-primary-glow { color: var(--hud-glow); text-shadow: 0 0 10px rgba(56, 189, 248, 0.4); }
    .shadow-glow-blue { box-shadow: 0 0 30px rgba(14, 165, 233, 0.15); }
