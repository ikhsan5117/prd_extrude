        // --- DYNAMIC READINGS MANAGEMENT (MODERNIZED) ---
        let currentReadingIndex = 0;
        let pReadings = [
            { id: 0, label: 'P-1', time: new Date().getHours().toString().padStart(2, '0') + ':' + new Date().getMinutes().toString().padStart(2, '0'), data: {} }
        ];

        function addReadingPoint() {
            saveCurrentInputsToMemory();

            const now = new Date();
            const timeStr = now.getHours().toString().padStart(2, '0') + ':' + now.getMinutes().toString().padStart(2, '0');
            const nextId = pReadings.length;
            
            pReadings.push({
                id: nextId,
                label: `P-${nextId + 1}`,
                time: timeStr,
                data: {}
            });
            
            switchReadingTab(nextId);
        }

        function switchReadingTab(index) {
            saveCurrentInputsToMemory();
            currentReadingIndex = index;
            renderTabs();
            loadCurrentDataFromMemory();
        }

        function saveCurrentInputsToMemory() {
            if (currentReadingIndex === -1) return;
            const activeData = pReadings[currentReadingIndex].data;
            const inputElements = document.querySelectorAll('#parameterCardsContainer input[id^="input_"]');
            inputElements.forEach(inp => {
                const key = inp.id.replace('input_', '');
                activeData[key] = inp.value;
            });
        }

        function loadCurrentDataFromMemory() {
            if (currentReadingIndex === -1) return;
            const activeData = pReadings[currentReadingIndex].data;
            const inputElements = document.querySelectorAll('#parameterCardsContainer input[id^="input_"]');
            inputElements.forEach(inp => {
                const key = inp.id.replace('input_', '');
                inp.value = activeData[key] || '';
                validateParam(inp, 'spec_' + key);
            });
        }

        function renderTabs() {
            const container = document.getElementById('readingsTabs');
            if(!container) return;
            container.innerHTML = pReadings.map((p, idx) => `
                <div class="btn btn-hud-outline reading-tab py-1 px-3 d-flex flex-column align-items-center rounded ${idx === currentReadingIndex ? 'active-tab' : ''}" 
                     style="position: relative;" onclick="switchReadingTab(${idx})">
                    ${idx > 0 ? `
                    <button type="button" class="btn p-0 text-danger border-0 shadow-none" 
                            style="position: absolute; top: -8px; right: -8px; z-index: 10; background: #020617; border-radius: 50%; width: 18px; height: 18px; display: flex; align-items: center; justify-content: center;" 
                            onclick="event.stopPropagation(); removeReadingPoint(${idx})">
                        <i class="bi bi-x-circle-fill" style="font-size: 0.9rem;"></i>
                    </button>` : ''}
                    <span style="font-size: 0.6rem; opacity: 0.6;">${p.label}</span>
                    <span class="small fw-bold">${p.time}</span>
                </div>
            `).join('');
        }

        function removeReadingPoint(index) {
            if (index === 0) return;
            
            Swal.fire({
                title: 'DELETE CHECK POINT?',
                text: `Remove ${pReadings[index].label} and its data?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#334155',
                confirmButtonText: 'YES, DELETE',
                background: '#020617',
                color: '#fff'
            }).then((result) => {
                if (result.isConfirmed) {
                    pReadings.splice(index, 1);
                    // Re-label all points
                    pReadings.forEach((p, i) => { p.label = `P-${i + 1}`; });
                    
                    // Adjust current focus
                    if (currentReadingIndex >= pReadings.length) {
                        currentReadingIndex = pReadings.length - 1;
                    } else if (currentReadingIndex === index) {
                        currentReadingIndex = Math.max(0, index - 1);
                    }
                    
                    renderTabs();
                    loadCurrentDataFromMemory();
                }
            });
        }

        function updateReadingData(key, value) {
            if (pReadings[currentReadingIndex]) {
                pReadings[currentReadingIndex].data[key] = value;
            }
        }

        // --- DYNAMIC MATERIAL LOT MANAGEMENT ---
