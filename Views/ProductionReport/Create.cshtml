@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/html5-qrcode"></script>
    <script>
        let html5QrCode;

        async function openScanner(targetId) {
            Swal.fire({
                title: 'SCANNING MATERIAL LOT',
                html: `
                    <div id="reader-container" style="width: 100%; min-height: 250px; background: #000; border-radius: 8px; overflow: hidden; border: 2px solid #0ea5e9;">
                        <div id="reader"></div>
                    </div>
                    <div class="mt-3 text-info-glow small fw-bold tracking-widest">POSITION BARCODE WITHIN FRAME</div>
                `,
                background: '#020617',
                color: '#0ea5e9',
                showConfirmButton: false,
                showCloseButton: true,
                width: '90%',
                didOpen: () => {
                    const config = { fps: 10, qrbox: { width: 250, height: 150 } };
                    html5QrCode = new Html5Qrcode("reader");
                    
                    html5QrCode.start(
                        { facingMode: "environment" }, 
                        config,
                        (decodedText) => {
                            // On Success
                            document.getElementById(targetId).value = decodedText;
                            document.getElementById(targetId).parentElement.classList.add('glow-success');
                            setTimeout(() => document.getElementById(targetId).parentElement.classList.remove('glow-success'), 2000);
                            
                            html5QrCode.stop().then(() => {
                                Swal.close();
                                // Optional haptic feedback
                                if (window.navigator.vibrate) window.navigator.vibrate(100);
                            });
                        },
                        (errorMessage) => { /* scanning... */ }
                    ).catch(err => {
                        console.error(err);
                        document.getElementById('reader').innerHTML = `<div class="p-4 text-danger small">CAMERA ERROR: ${err}</div>`;
                    });
                },
                willClose: () => {
                    if (html5QrCode && html5QrCode.isScanning) {
                        html5QrCode.stop();
                    }
                }
            });
        }

        // --- SPS SYNC LOGIC ---
        async function startSpsScanner() {
            Swal.fire({
                title: '<div class="text-primary-glow font-monospace small">SPS OPTICAL SCANNER</div>',
                html: `
                    <div id="sps-reader-container" style="width: 100%; min-height: 250px; background: #000; border-radius: 8px; overflow: hidden; border: 2px solid #0ea5e9;">
                        <div id="sps-reader"></div>
                    </div>
                `,
                background: '#020617',
                showConfirmButton: false,
                showCloseButton: true,
                didOpen: () => {
                    const scanQrCode = new Html5Qrcode("sps-reader");
                    const config = { fps: 10, qrbox: { width: 250, height: 250 } };
                    scanQrCode.start({ facingMode: "environment" }, config, async (decodedText) => {
                        await scanQrCode.stop();
                        Swal.close();
                        fetchSpsByItem(decodedText);
                    });
                }
            });
        }

        async function fetchSpsByItem(code) {
            Swal.fire({
                title: 'SEARCHING PROTOCOL...',
                text: `VALIDATING: ${code.trim().toUpperCase()}`,
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); }
            });

            try {
                const res = await fetch(`/ProductionReport/GetSpsByItem?itemCode=${encodeURIComponent(code.trim())}`);
                if (!res.ok) throw new Error('PROTOCOL NOT FOUND');
                const data = await res.json();
                Swal.close();
                applySpsToForm(data);
            } catch (e) {
                Swal.fire({
                    title: 'SYNC ERROR',
                    text: `Kode '${code}' tidak ditemukan di Database SPS Masterlist!`,
                    icon: 'warning',
                    confirmButtonColor: '#0ea5e9'
                });
            }
        }

        function applySpsToForm(sps) {
            console.log("Applying SPS Data:", sps);

            // UNLOCK FORM (SHOW CONTENT)
            const overlay = document.getElementById('formLockOverlay');
            const wrapper = document.getElementById('formContentBlurWrapper');
            const container = document.getElementById('mainFormContainer');

            if (overlay) overlay.remove(); // REMOVE COMPLETELY
            if (container) {
                container.style.minHeight = '0';
                container.style.pointerEvents = 'auto';
            }
            
            if (wrapper) {
                wrapper.style.display = 'block';
                wrapper.style.pointerEvents = 'auto';
                wrapper.style.opacity = '1';
                wrapper.style.visibility = 'visible';
                wrapper.classList.remove('d-none');
                wrapper.classList.add('animate__animated', 'animate__fadeInUp');
            }

            const itemCode = sps.itemList || sps.itemCode || sps.productCode || '';
            document.getElementById('manualItemSearch').value = itemCode;
            document.getElementById('DocNo').value = sps.documentNumber || sps.DocumentNumber || '---';
            document.getElementById('RevNo').value = sps.revisionNumber || sps.RevisionNumber || '0';
            document.getElementById('HoseType').value = sps.hoseType || sps.HoseType || '';
            document.getElementById('CustomerName').value = sps.customerName || sps.CustomerName || '';
            
            // Materials mapping
            document.getElementById('InnerMaterial').value = sps.innerMaterial || sps.InnerMaterial || sps.innerTube || sps.InnerTube || '';
            document.getElementById('OuterMaterial').value = sps.outerMaterial || sps.OuterMaterial || sps.outerCover || sps.OuterCover || '';
            document.getElementById('Yarn').value = sps.yarnType || sps.YarnType || sps.material || sps.Material || '';

            let spsIdEl = document.getElementById('StandardParameterSettingId');
            if (spsIdEl) spsIdEl.value = sps.id || sps.Id || '';

            const formatVal = (val, prefix = '', suffix = '') => {
                if (val === undefined || val === null || val === '') return '---';
                let strVal = String(val).trim();
                // Prevent duplicate symbols
                if (suffix.includes('±') && strVal.includes('±')) suffix = '';
                if (prefix.toLowerCase().includes('max') && strVal.toLowerCase().includes('max')) prefix = '';
                return `${prefix}${strVal}${suffix}`;
            };

            const specMappings = {
                'HeadTempInner': formatVal(sps.headTempInner || sps.headTemp || sps.HeadTemp || sps.HeadTemp1, '', ' ± 5'),
                'Cylinder1TempInner': formatVal(sps.cylinder1TempInner || sps.cylinder1Temp || sps.Cylinder1Temp || sps.Cylinder1_1, '', ' ± 5'),
                'Cylinder2TempInner': formatVal(sps.cylinder2TempInner || sps.cylinder2Temp || sps.Cylinder2Temp || sps.Cylinder2_1, '', ' ± 5'),
                'Cylinder3TempInner': formatVal(sps.cylinder3TempInner || sps.cylinder3Temp || sps.Cylinder3Temp || sps.Cylinder1_3, '', ' ± 5'),
                'ScrewTempInner': formatVal(sps.screwTempInner || sps.screwTemp || sps.ScrewTemp || sps.ScrewTemp1, '', ' ± 5'),
                'ScrewSpeedInner': formatVal(sps.screwSpeedInner || sps.screwSpeed || sps.ScrewSpeed || sps.ScrewSpeed1, '', ' ± 2'),
                'FeedRollRatioInner': formatVal(sps.feedRollRatioInner || sps.feedRollRatio || sps.FeedRollRatio || sps.Feed1, 'Max '),
                'PressureInner': formatVal(sps.pressureInner || sps.pressure || sps.Pressure || sps.Pressure1, 'Max '),

                'HeadTempOuter': formatVal(sps.headTempOuter || sps.headTemp || sps.HeadTemp || sps.HeadTemp2, '', ' ± 5'),
                'Cylinder1TempOuter': formatVal(sps.cylinder1TempOuter || sps.cylinder1Temp || sps.Cylinder1Temp || sps.Cylinder1_2, '', ' ± 5'),
                'Cylinder2TempOuter': formatVal(sps.cylinder2TempOuter || sps.cylinder2Temp || sps.Cylinder2Temp || sps.Cylinder2_2, '', ' ± 5'),
                'Cylinder3TempOuter': formatVal(sps.cylinder3TempOuter || sps.cylinder3Temp || sps.Cylinder3Temp || sps.Cylinder3_2, '', ' ± 5'),
                'ScrewTempOuter': formatVal(sps.screwTempOuter || sps.screwTemp || sps.ScrewTemp || sps.ScrewTemp2, '', ' ± 5'),
                'ScrewSpeedOuter': formatVal(sps.screwSpeedOuter || sps.screwSpeed || sps.ScrewSpeed || sps.ScrewSpeed2, '', ' ± 2'),
                'FeedRollRatioOuter': formatVal(sps.feedRollRatioOuter || sps.feedRollRatio || sps.FeedRollRatio || sps.Feed2, 'Max '),
                'PressureOuter': formatVal(sps.pressureOuter || sps.pressure || sps.Pressure || sps.Pressure2, 'Max '),

                'SpiralSpeed': formatVal(sps.spiralSpeed || sps.SpiralSpeed, '', ' ± 20'),
                'SpiralPitchSetting': formatVal(sps.toleranceSpiralPitch || sps.ToleranceSpiralPitch, '', ' ± 5'),
                'SpiralPitchDisplay': formatVal(sps.toleranceSpiralPitch || sps.ToleranceSpiralPitch, '', ' ± 5'),
                'PresetValue': formatVal(sps.presetValve || sps.PresetValue || sps.presetValue, '', ' ± 0.5'),
                'ControlValue': formatVal(sps.controlValue || sps.ControlValue),
                'HoseSpeed': formatVal(sps.hoseSpeed || sps.HoseSpeed),
                'TakeupConveyorSpeed': formatVal(sps.takeUpConveyorSpeed || sps.TakeUpConveyorSpeed || sps.takeupConveyorSpeed || sps.TakeupConveyorSpeed),
                'CoolConveyorSpeed': formatVal(sps.coolConveyorSpeed || sps.CoolConveyorSpeed),
                'ConveyorRatio': formatVal(sps.conveyorRatio || sps.ConveyorRatio),
                'ChillerWaterTemp': formatVal(sps.chillerWaterTemp || sps.ChillerWaterTemp),
                'CaterpillarGap': formatVal(sps.caterpillarGap || sps.CaterpillarGap),
                'UnsmoothSurface': formatVal(sps.unsmoothSurface || sps.UnsmoothSurface || 'OK'),

                'NippleDie': formatVal(sps.innerDie || sps.InnerDie || sps.nipple || sps.Nipple),
                'TubeDie': formatVal(sps.tubeDie || sps.TubeDie),
                'MiddleDie': formatVal(sps.middleDie || sps.MiddleDie || sps.tubeDie || sps.TubeDie),
                'CoverDie': formatVal(sps.coverDie || sps.CoverDie),
                'SpacerDie': formatVal(sps.spacerDie || sps.SpacerDie),
                'ToleranceDie': formatVal(sps.toleranceDie || sps.ToleranceDie || sps.toleranceInner || sps.ToleranceInner)
            };

            for (const [key, val] of Object.entries(specMappings)) {
                const el = document.getElementById('spec_' + key);
                const mainInput = document.getElementById('input_' + key);
                const isNoData = (val === '---' || val === '' || val === null);

                if (el) {
                    el.innerText = val;
                    el.classList.add('blink-once');
                    
                    // Logic to Disable/Lock inputs if no standard exists
                    if (isNoData) {
                        if (mainInput) {
                            mainInput.disabled = true;
                            mainInput.placeholder = "N/A";
                            mainInput.value = "";
                            mainInput.closest('.param-tile-modern')?.style.setProperty('opacity', '0.4', 'important');
                            mainInput.closest('.param-tile-modern')?.style.setProperty('pointer-events', 'none', 'important');
                        }
                    } else {
                        if (mainInput) {
                            mainInput.disabled = false;
                            mainInput.placeholder = "0.00";
                            mainInput.closest('.param-tile-modern')?.style.setProperty('opacity', '1', 'important');
                            mainInput.closest('.param-tile-modern')?.style.setProperty('pointer-events', 'auto', 'important');
                        }
                    }

                    if (key.includes('Die') || key === 'ToleranceDie') {
                        const dieRadios = {
                            'NippleDie': { field: 'NippleDieOK', init: 'NippleDieInitial', final: 'NippleDieFinal' },
                            'TubeDie': { field: 'TubeDieOK', init: 'TubeDieInitial', final: 'TubeDieFinal' },
                            'MiddleDie': { field: 'MiddleDieOK', init: 'MiddleDieInitial', final: 'MiddleDieFinal' },
                            'CoverDie': { field: 'CoverDieOK', init: 'CoverDieInitial', final: 'CoverDieFinal' },
                            'SpacerDie': { field: 'SpacerDieOK', init: 'SpacerDieInitial', final: 'SpacerDieFinal' },
                            'ToleranceDie': { field: 'ToleranceDieOK', init: 'ToleranceInitial', final: 'ToleranceFinal' }
                        };
                        const d = dieRadios[key];
                        if (d) {
                            const container = document.getElementsByName(d.init)[0]?.closest('.die-card');
                            if (isNoData) {
                                document.getElementsByName(d.init)[0].disabled = true;
                                document.getElementsByName(d.final)[0].disabled = true;
                                if (container) {
                                    container.style.opacity = "0.4";
                                    container.style.pointerEvents = "none";
                                }
                            } else {
                                document.getElementsByName(d.init)[0].disabled = false;
                                document.getElementsByName(d.final)[0].disabled = false;
                                if (container) {
                                    container.style.opacity = "1";
                                    container.style.pointerEvents = "auto";
                                }
                            }
                            checkDieStatus('spec_' + key, d.field, d.init, d.final);
                        }
                    } else {
                        const inputs = document.querySelectorAll(`[name$="${key}"]`);
                        inputs.forEach(inp => { 
                            if (isNoData) {
                                inp.disabled = true;
                                inp.placeholder = "N/A";
                            } else {
                                inp.disabled = false;
                                if(inp.value) validateParam(inp, 'spec_' + key); 
                            }
                        });
                    }
                }
            }

            Swal.fire({
                title: 'SPS SYNC SUCCESS',
                text: 'Protokol ' + (sps.hoseType || sps.HoseType || '') + ' berhasil dimuat!',
                icon: 'success',
                toast: true,
                position: 'top-end',
                timer: 3000,
                showConfirmButton: false
            });
        }

        // --- PARAMETER VALIDATION LOGIC ---
        // --- PARAMETER VALIDATION LOGIC ---
        function computeValidity(valStr, specText) {
            // Replace comma with dot for validation
            const normalizedVal = valStr.replace(',', '.');
            const val = parseFloat(normalizedVal);
            if (valStr === "" || isNaN(val) || !specText || specText === '--') return true;

            let isValid = true;
            try {
                // Normalize specText as well (replace comma with dot)
                let workingText = specText.replace(',', '.').replace(/max\.?/i, '').replace(/min\.?/i, '').replace(/[A-Za-z°%]/g, '').trim();

                if (specText.includes('±')) {
                    const parts = specText.replace(',', '.').split('±');
                    const target = parseFloat(parts[0].replace(/[^-0-9.]/g, ''));
                    const tolerance = parseFloat(parts[1].replace(/[^-0-9.]/g, ''));
                    if (!isNaN(target) && !isNaN(tolerance)) {
                        isValid = (val >= (target - tolerance) && val <= (target + tolerance));
                    }
                } else if (specText.toLowerCase().includes('max')) {
                    const limit = parseFloat(workingText.replace(/[^-0-9.]/g, ''));
                    if (!isNaN(limit)) isValid = (val <= limit);
                } else if (specText.toLowerCase().includes('min')) {
                    const limit = parseFloat(workingText.replace(/[^-0-9.]/g, ''));
                    if (!isNaN(limit)) isValid = (val >= limit);
                } else if (specText.includes('-') && !specText.startsWith('-')) {
                    // Range logic (e.g. 10-14)
                    const rangeParts = specText.split('-');
                    const min = parseFloat(rangeParts[0].replace(',', '.').replace(/[^-0-9.]/g, ''));
                    const max = parseFloat(rangeParts[1].replace(',', '.').replace(/[^-0-9.]/g, ''));
                    if (!isNaN(min) && !isNaN(max)) {
                        isValid = (val >= min && val <= max);
                    }
                } else {
                    const target = parseFloat(workingText.replace(/[^-0-9.]/g, ''));
                    if(!isNaN(target)) isValid = (val === target);
                }
            } catch (e) { isValid = false; }
            return isValid;
        }

        function validateParam(input, specId) {
            const specEl = document.getElementById(specId);
            if(!specEl) return;
            const specText = specEl.innerText.trim();
            const isValid = computeValidity(input.value.trim(), specText);
            
            if (input.value.trim() === "") {
                input.classList.remove('valid-success', 'valid-error');
                return;
            }

            if (isValid) {
                input.classList.add('valid-success');
                input.classList.remove('valid-error');
            } else {
                input.classList.add('valid-error');
                input.classList.remove('valid-success');
            }
        }

        function checkDieStatus(specId, radioFieldName, initName, finalName) {
            const initInp = document.querySelector(`[name="${initName}"]`);
            const finalInp = document.querySelector(`[name="${finalName}"]`);
            const specEl = document.getElementById(specId);
            if(!specEl) return;
            const specText = specEl.innerText.trim();
            if(specText === '--') return;

            let isInitOk = true;
            let isFinalOk = true;

            if(initInp && initInp.value) isInitOk = computeValidity(initInp.value, specText);
            if(finalInp && finalInp.value) isFinalOk = computeValidity(finalInp.value, specText);

            // Styling
            if(initInp) {
                if(!initInp.value) initInp.classList.remove('valid-success', 'valid-error');
                else { initInp.classList.toggle('valid-success', isInitOk); initInp.classList.toggle('valid-error', !isInitOk); }
            }
            if(finalInp) {
                if(!finalInp.value) finalInp.classList.remove('valid-success', 'valid-error');
                else { finalInp.classList.toggle('valid-success', isFinalOk); finalInp.classList.toggle('valid-error', !isFinalOk); }
            }

            // Radio logic: Source of truth is BOTH (if any is NG, overall is NG. If only one has value, that one decides)
            let overallOk = true;
            if(initInp.value && finalInp.value) overallOk = isInitOk && isFinalOk;
            else if(initInp.value) overallOk = isInitOk;
            else if(finalInp.value) overallOk = isFinalOk;

            const radios = document.getElementsByName(radioFieldName);
            if (radios.length > 0) {
                for(let r of radios) {
                    if(r.value === 'true') r.checked = overallOk;
                    if(r.value === 'false') r.checked = !overallOk;
                }
            }
        }

        function toggleSingleDetail(key) {
