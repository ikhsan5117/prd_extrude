        function removeMaterialRow(layer, rowId) {
            const el = document.getElementById(rowId);
            if (el) {
                el.classList.replace('animate__fadeInLeft', 'animate__fadeOutRight');
                setTimeout(() => {
                    el.remove();
                    materialState[layer] = materialState[layer].filter(id => id !== rowId);
                }, 300);
            }
        }

        function openScannerForDynamicRow(rowId) {
            const input = document.getElementById(rowId).querySelector('input[data-type="lot"]');
            openScannerCustom((code) => {
                input.value = code;
                input.classList.add('blink-once');
            });
        }

        function openScannerCustom(callback) {
            const modalEl = document.getElementById('scannerModal');
            const modal = new bootstrap.Modal(modalEl);
            modal.show();

            setTimeout(() => {
                html5QrCode = new Html5Qrcode("reader");
                const config = { fps: 10, qrbox: { width: 220, height: 220 } };

                html5QrCode.start({ facingMode: "environment" }, config, (decodedText) => {
                    callback(decodedText);
                    closeScannerModal();
                    // Optional beep sound could be added here
                }).catch(err => {
                    console.error("Scanner failed", err);
                });
            }, 300);
        }

        function closeScannerModal() {
            const modalEl = document.getElementById('scannerModal');
            const modal = bootstrap.Modal.getInstance(modalEl);
            if (html5QrCode && html5QrCode.isScanning) {
                html5QrCode.stop().then(() => {
                    modal.hide();
                }).catch(() => modal.hide());
            } else {
                modal.hide();
            }
        }

        function getMaterialLotPayload() {
            const results = [];
            ['inner', 'outer', 'yarn'].forEach(layer => {
                const container = document.getElementById(`${layer}-lot-list`);
                const rows = container.querySelectorAll('.row');
                rows.forEach(row => {
                    const lot = row.querySelector('input[data-type="lot"]').value;
                    const sgInput = row.querySelector('input[data-type="sg"]');
                    const sg = sgInput ? sgInput.value.replace(',', '.') : null;
                    
                    if (lot || sg) {
                        results.push({
                            LayerType: layer.toUpperCase(),
                            MaterialName: document.getElementById(layer === 'yarn' ? 'Yarn' : (layer === 'inner' ? 'InnerMaterial' : 'OuterMaterial')).value,
                            MaterialActual: document.getElementById(layer === 'yarn' ? 'YarnActual' : (layer === 'inner' ? 'InnerMaterialActual' : 'OuterMaterialActual')).value,
                            LotNumber: lot,
                            SGValue: sg ? parseFloat(sg) : null
                        });
                    }
                });
            });
            return results;
        }

        async function submitReportWithReadings() {
            const hoseType = document.getElementById('HoseType').value;
            if (!hoseType || hoseType.trim() === '') {
                Swal.fire({
                    title: 'DATA KOSONG!',
                    text: 'Anda belum memilih Planning / Item yang akan diproduksi. Harap lengkapi form sebelum submit.',
                    icon: 'warning',
                    confirmButtonColor: '#0ea5e9',
                    background: '#020617',
                    color: '#fff'
                });
                return;
            }

            saveCurrentInputsToMemory();

            const confirm = await Swal.fire({
                title: 'SAVE PRODUCTION REPORT?',
                text: `Transmiting ${pReadings.length} measurement records to the mainframe.`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#0ea5e9',
                confirmButtonText: 'YES, TRANSMIT',
                background: '#020617',
                color: '#fff'
            });

            if (!confirm.isConfirmed) return;

            Swal.fire({ title: 'UPLOADING DATASET...', didOpen: () => Swal.showLoading(), background: '#020617', color: '#0ea5e9' });

            const payload = {
                DocumentNumber: document.getElementById('DocNo').value,
                RevisionNumber: parseInt(document.getElementById('RevNo').value) || 0,
                ProductionDate: document.getElementById('ProductionDate').value,
                Shift: document.getElementById('Shift').value,
                CustomerName: document.getElementById('CustomerName').value,
