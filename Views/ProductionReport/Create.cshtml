</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/html5-qrcode"></script>
    <script>
        let html5QrCode;

        async function openScanner(targetId) {
            Swal.fire({
                title: 'SCANNING MATERIAL LOT',
                html: `
                    <div id="reader-container" style="width: 100%; min-height: 250px; background: #000; border-radius: 8px; overflow: hidden; border: 2px solid #0ea5e9;">
                        <div id="reader"></div>
                    </div>
                    <div class="mt-3 text-info-glow small fw-bold tracking-widest">POSITION BARCODE WITHIN FRAME</div>
                `,
                background: '#020617',
                color: '#0ea5e9',
                showConfirmButton: false,
                showCloseButton: true,
                width: '90%',
                didOpen: () => {
                    const config = { fps: 10, qrbox: { width: 250, height: 150 } };
                    html5QrCode = new Html5Qrcode("reader");
                    
                    html5QrCode.start(
                        { facingMode: "environment" }, 
                        config,
                        (decodedText) => {
                            // On Success
                            document.getElementById(targetId).value = decodedText;
                            document.getElementById(targetId).parentElement.classList.add('glow-success');
                            setTimeout(() => document.getElementById(targetId).parentElement.classList.remove('glow-success'), 2000);
                            
                            html5QrCode.stop().then(() => {
                                Swal.close();
                                // Optional haptic feedback
                                if (window.navigator.vibrate) window.navigator.vibrate(100);
                            });
                        },
                        (errorMessage) => { /* scanning... */ }
                    ).catch(err => {
                        console.error(err);
                        document.getElementById('reader').innerHTML = `<div class="p-4 text-danger small">CAMERA ERROR: ${err}</div>`;
                    });
                },
                willClose: () => {
                    if (html5QrCode && html5QrCode.isScanning) {
                        html5QrCode.stop();
                    }
                }
            });
        }

        // --- SPS SYNC LOGIC ---
        async function startSpsScanner() {
            Swal.fire({
                title: '<div class="text-primary-glow font-monospace small">SPS OPTICAL SCANNER</div>',
                html: `
                    <div id="sps-reader-container" style="width: 100%; min-height: 250px; background: #000; border-radius: 8px; overflow: hidden; border: 2px solid #0ea5e9;">
                        <div id="sps-reader"></div>
                    </div>
                `,
                background: '#020617',
                showConfirmButton: false,
                showCloseButton: true,
                didOpen: () => {
                    const scanQrCode = new Html5Qrcode("sps-reader");
                    const config = { fps: 10, qrbox: { width: 250, height: 250 } };
                    scanQrCode.start({ facingMode: "environment" }, config, async (decodedText) => {
                        await scanQrCode.stop();
                        Swal.close();
                        fetchSpsByItem(decodedText);
                    });
                }
            });
        }

        async function fetchSpsByItem(code) {
            Swal.fire({
                title: 'SEARCHING PROTOCOL...',
                text: `VALIDATING: ${code.trim().toUpperCase()}`,
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); }
            });

            try {
                const res = await fetch(`/ProductionReport/GetSpsByItem?itemCode=${encodeURIComponent(code.trim())}`);
                if (!res.ok) throw new Error('PROTOCOL NOT FOUND');
                const data = await res.json();
                Swal.close();
                applySpsToForm(data);
            } catch (e) {
                Swal.fire({
                    title: 'SYNC ERROR',
                    text: `Kode '${code}' tidak ditemukan di Database SPS Masterlist!`,
                    icon: 'warning',
                    confirmButtonColor: '#0ea5e9'
                });
            }
        }

        function applySpsToForm(sps) {
            // Header Info
            document.getElementById('DocNo').value = sps.documentNumber || '---';
            document.getElementById('RevNo').value = sps.revisionNumber || '0';
            document.getElementById('HoseType').value = sps.hoseType || '';
            document.getElementById('CustomerName').value = sps.customerName || '';
            
            // Materials
            document.getElementById('InnerMaterial').value = sps.innerMaterial || '';
            document.getElementById('OuterMaterial').value = sps.outerMaterial || '';
            document.getElementById('Yarn').value = sps.yarnType || '';
            
            let spsIdEl = document.getElementById('StandardParameterSettingId');
            if (spsIdEl) spsIdEl.value = sps.id || '';

            const formatVal = (val, prefix = '', suffix = '') => {
                if (val === undefined || val === null || val === '') return '---';
                if (typeof val === 'string' && (val.includes('±') || val.includes('+') || val.includes('-'))) {
                    // Prevent duplicate suffixes if Masterlist already contains formatting like '90+/-5' or '1.0±0.1'
                    return `${prefix}${val}`;
                }
                return `${prefix}${val}${suffix}`;
            };

            // Update Table Specs
            const specMappings = {
                'HeadTempInner': formatVal(sps.headTempInner ?? sps.headTemp, '', ' ± 5'),
                'Cylinder1TempInner': formatVal(sps.cylinder1TempInner ?? sps.cylinder1Temp, '', ' ± 5'),
                'Cylinder2TempInner': formatVal(sps.cylinder2TempInner ?? sps.cylinder2Temp, '', ' ± 5'),
                'Cylinder3TempInner': formatVal(sps.cylinder3TempInner ?? sps.cylinder3Temp, '', ' ± 5'),
                'ScrewTempInner': formatVal(sps.screwTempInner ?? sps.screwTemp, '', ' ± 5'),
                'ScrewSpeedInner': formatVal(sps.screwSpeedInner ?? sps.screwSpeed, '', ' ± 2'),
                'FeedRollRatioInner': formatVal(sps.feedRollRatioInner ?? sps.feedRollRatio, 'Max '),
                'PressureInner': formatVal(sps.pressureInner ?? sps.pressure, 'Max '),
                
                'HeadTempOuter': formatVal(sps.headTempOuter ?? sps.headTemp, '', ' ± 5'),
                'Cylinder1TempOuter': formatVal(sps.cylinder1TempOuter ?? sps.cylinder1Temp, '', ' ± 5'),
                'Cylinder2TempOuter': formatVal(sps.cylinder2TempOuter ?? sps.cylinder2Temp, '', ' ± 5'),
                'Cylinder3TempOuter': formatVal(sps.cylinder3TempOuter ?? sps.cylinder3Temp, '', ' ± 5'),
                'ScrewTempOuter': formatVal(sps.screwTempOuter ?? sps.screwTemp, '', ' ± 5'),
                'ScrewSpeedOuter': formatVal(sps.screwSpeedOuter ?? sps.screwSpeed, '', ' ± 2'),
                'FeedRollRatioOuter': formatVal(sps.feedRollRatioOuter ?? sps.feedRollRatio, 'Max '),
                'PressureOuter': formatVal(sps.pressureOuter ?? sps.pressure, 'Max '),
                
                'SpiralSpeed': formatVal(sps.spiralSpeed, '', ' ± 20'),
                'SpiralPitchSetting': formatVal(sps.spiralPitch, '', ' ± 5'),
                'SpiralPitchDisplay': formatVal(sps.spiralPitchDisplay, '', ' ± 5'),
                
                'PresetValue': formatVal(sps.presetValve, '', ' ± 0.5'),
                'ControlValue': formatVal(sps.controlValue),
                'HoseSpeed': formatVal(sps.hoseSpeed),
                'TakeupConveyorSpeed': formatVal(sps.takeupConveyorSpeed),
                'CoolConveyorSpeed': formatVal(sps.coolConveyorSpeed),
                'ConveyorRatio': formatVal(sps.conveyorRatio),
                'UnsmoothSurface': formatVal(sps.unsmoothSurface),
                'ChillerWaterTemp': formatVal(sps.chillerWaterTemp),
                'CaterpillarGap': formatVal(sps.caterpillarGap),

                // Dies Measurements
                'NippleDie': formatVal(sps.innerDie, '', ' ± 0.1'),
                'TubeDie': formatVal(sps.tubeDie, '', ' ± 0.1'),
                'MiddleDie': formatVal(sps.middleDie, '', ' ± 0.1'),
                'CoverDie': formatVal(sps.coverDie, '', ' ± 0.1'),
                'SpacerDie': formatVal(sps.spacerDie, '', ' ± 0.1'),
                'ToleranceDie': formatVal(sps.toleranceDie, '', ' ± 0.1')
            };

            for (const [key, val] of Object.entries(specMappings)) {
                const el = document.getElementById('spec_' + key);
                if (el) {
                    el.innerText = val;
                    el.classList.add('blink-once');
                    
                    // Auto-validate current inputs if they have values
                    const inputs = document.querySelectorAll(`[name$="_${key}"]`);
                    inputs.forEach(inp => { if(inp.value) validateParam(inp, 'spec_' + key); });
                }
            }

            Swal.fire({
                title: 'SPS SYNC SUCCESS',
                text: 'Protokol ' + sps.hoseType + ' berhasil dimuat!',
                icon: 'success',
                toast: true,
                position: 'top-end',
                timer: 3000,
                showConfirmButton: false
            });
        }

        // --- PARAMETER VALIDATION LOGIC ---
        function validateParam(input, specId) {
            const valStr = input.value.trim();
            const val = parseFloat(valStr);
            const specEl = document.getElementById(specId);
            if(!specEl) return;
            const specText = specEl.innerText.trim();
            
            console.log(`Validating [${valStr}] against [${specText}]`);

            if (valStr === "" || isNaN(val) || !specText || specText === '--') {
                input.classList.remove('valid-success', 'valid-error');
                return;
            }


            let isValid = true;
            try {
                // Pre-clean: strip "Max.", "Min.", etc. to avoid token errors (like Max. 15 being parsed as .15)
                let workingText = specText.replace(/max\.?/i, '').replace(/min\.?/i, '').replace(/[A-Za-z°%]/g, '').trim();

                if (specText.includes('±')) {
                    const parts = specText.split('±');
                    const target = parseFloat(parts[0].replace(/[^-0-9.]/g, ''));
                    const tolerance = parseFloat(parts[1].replace(/[^-0-9.]/g, ''));
                    if (!isNaN(target) && !isNaN(tolerance)) {
                        isValid = (val >= (target - tolerance) && val <= (target + tolerance));
                    }
                } else if (specText.toLowerCase().includes('max')) {
                    const limit = parseFloat(workingText.replace(/[^-0-9.]/g, ''));
                    if (!isNaN(limit)) isValid = (val <= limit);
                } else if (specText.toLowerCase().includes('min')) {
                    const limit = parseFloat(workingText.replace(/[^-0-9.]/g, ''));
                    if (!isNaN(limit)) isValid = (val >= limit);
                } else if (specText.includes('-')) {
                    const range = specText.replace(/[^-0-9.]+/g, ' ').trim().split(/\s+/).map(s => parseFloat(s));
                    if (range.length >= 2) isValid = (val >= range[0] && val <= range[1]);
                } else {
                    const target = parseFloat(workingText.replace(/[^-0-9.]/g, ''));
                    if(!isNaN(target)) isValid = (val === target);
                }
            } catch (e) { 
                console.error("Validation Logic Error:", e); 
                isValid = false;
            }

            if (isValid) {
                input.classList.add('valid-success');
                input.classList.remove('valid-error');
            } else {
                input.classList.add('valid-error');
                input.classList.remove('valid-success');
            }
        }

        function toggleSingleDetail(key) {
            const drawer = document.getElementById('detail_' + key);
            const icon = document.getElementById('icon_' + key);
            drawer.classList.toggle('d-none');
            icon.parentElement.classList.toggle('active');
        }

        function toggleAllDetails(sectionId) {
            const container = document.getElementById('body_' + sectionId);
            if(!container) return;
            const drawers = container.querySelectorAll('.detail-drawer');
            const buttons = container.querySelectorAll('.btn-detail-toggle');
            
            let isOpening = false;
            for(let d of drawers) { if(d.classList.contains('d-none')) { isOpening = true; break; } }

            drawers.forEach(d => isOpening ? d.classList.remove('d-none') : d.classList.add('d-none'));
            buttons.forEach(b => isOpening ? b.classList.add('active') : b.classList.remove('active'));
        }

        // --- DYNAMIC READINGS MANAGEMENT (MODERNIZED) ---
        let currentReadingIndex = 0;
        let pReadings = [
            { id: 0, label: 'P-1', time: new Date().getHours().toString().padStart(2, '0') + ':' + new Date().getMinutes().toString().padStart(2, '0'), data: {} }
        ];

        function addReadingPoint() {
            saveCurrentInputsToMemory();

            const now = new Date();
            const timeStr = now.getHours().toString().padStart(2, '0') + ':' + now.getMinutes().toString().padStart(2, '0');
            const nextId = pReadings.length;
            
            pReadings.push({
                id: nextId,
                label: `P-${nextId + 1}`,
                time: timeStr,
                data: {}
            });
            
            switchReadingTab(nextId);
        }

        function switchReadingTab(index) {
            saveCurrentInputsToMemory();
            currentReadingIndex = index;
            renderTabs();
            loadCurrentDataFromMemory();
        }

        function saveCurrentInputsToMemory() {
            if (currentReadingIndex === -1) return;
            const activeData = pReadings[currentReadingIndex].data;
            const inputElements = document.querySelectorAll('#parameterCardsContainer input[id^="input_"]');
            inputElements.forEach(inp => {
                const key = inp.id.replace('input_', '');
                activeData[key] = inp.value;
            });
        }

        function loadCurrentDataFromMemory() {
            if (currentReadingIndex === -1) return;
            const activeData = pReadings[currentReadingIndex].data;
            const inputElements = document.querySelectorAll('#parameterCardsContainer input[id^="input_"]');
            inputElements.forEach(inp => {
                const key = inp.id.replace('input_', '');
                inp.value = activeData[key] || '';
                validateParam(inp, 'spec_' + key);
            });
        }

        function renderTabs() {
            const container = document.getElementById('readingsTabs');
            if(!container) return;
            container.innerHTML = pReadings.map((p, idx) => `
                <div class="btn btn-hud-outline reading-tab py-1 px-3 d-flex flex-column align-items-center rounded ${idx === currentReadingIndex ? 'active-tab' : ''}" onclick="switchReadingTab(${idx})">
                    <span style="font-size: 0.6rem; opacity: 0.6;">${p.label}</span>
                    <span class="small fw-bold">${p.time}</span>
                </div>
            `).join('');
        }

        function updateReadingData(key, value) {
            if (pReadings[currentReadingIndex]) {
                pReadings[currentReadingIndex].data[key] = value;
            }
        }

        async function submitReportWithReadings() {
            saveCurrentInputsToMemory();

            const confirm = await Swal.fire({
                title: 'SAVE PRODUCTION REPORT?',
                text: `Transmiting ${pReadings.length} measurement records to the mainframe.`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#0ea5e9',
                confirmButtonText: 'YES, TRANSMIT',
                background: '#020617',
                color: '#fff'
            });

            if (!confirm.isConfirmed) return;

            Swal.fire({ title: 'UPLOADING DATASET...', didOpen: () => Swal.showLoading(), background: '#020617', color: '#0ea5e9' });

            const payload = {
                DocumentNumber: document.getElementById('DocNo').value,
                RevisionNumber: parseInt(document.getElementById('RevNo').value) || 0,
                ProductionDate: document.getElementById('ProductionDate').value,
                Shift: document.getElementById('Shift').value,
                CustomerName: document.getElementById('CustomerName').value,
                HoseType: document.getElementById('HoseType').value,
                
                InnerMaterial: document.getElementById('InnerMaterial').value,
                InnerMaterialActual: document.getElementById('InnerMaterialActual').value,
                InnerMaterialLotNo: document.getElementById('InnerMaterialLotNo').value,
                
                OuterMaterial: document.getElementById('OuterMaterial').value,
                OuterMaterialActual: document.getElementById('OuterMaterialActual').value,
                OuterMaterialLotNo: document.getElementById('OuterMaterialLotNo').value,
                
                Yarn: document.getElementById('Yarn').value,
                YarnActual: document.getElementById('YarnActual').value,
                YarnLotNo: document.getElementById('YarnLotNo').value,

                DAI_Awal: document.getElementById('DAI_Awal').value,
                DAI_Akhir: document.getElementById('DAI_Akhir').value,
                DAC_Awal: document.getElementById('DAC_Awal').value,
                DAC_Akhir: document.getElementById('DAC_Akhir').value,
                DRAI_Awal: document.getElementById('DRAI_Awal').value,
                DRAI_Akhir: document.getElementById('DRAI_Akhir').value,
                DRAC_Awal: document.getElementById('DRAC_Awal').value,
                DRAC_Akhir: document.getElementById('DRAC_Akhir').value,

                StandardParameterSettingId: document.getElementById('StandardParameterSettingId')?.value ? parseInt(document.getElementById('StandardParameterSettingId').value) : null,

                NippleDieOK: document.querySelector('input[name="NippleDieOK"]:checked')?.value === 'true',
                NippleDieInitial: document.querySelector('input[name="NippleDieInitial"]')?.value,
                NippleDieFinal: document.querySelector('input[name="NippleDieFinal"]')?.value,
                TubeDieOK: document.querySelector('input[name="TubeDieOK"]:checked')?.value === 'true',
                TubeDieInitial: document.querySelector('input[name="TubeDieInitial"]')?.value,
                TubeDieFinal: document.querySelector('input[name="TubeDieFinal"]')?.value,
                MiddleDieOK: document.querySelector('input[name="MiddleDieOK"]:checked')?.value === 'true',
                MiddleDieInitial: document.querySelector('input[name="MiddleDieInitial"]')?.value,
                MiddleDieFinal: document.querySelector('input[name="MiddleDieFinal"]')?.value,
                CoverDieOK: document.querySelector('input[name="CoverDieOK"]:checked')?.value === 'true',
                CoverDieInitial: document.querySelector('input[name="CoverDieInitial"]')?.value,
                CoverDieFinal: document.querySelector('input[name="CoverDieFinal"]')?.value,
                SpacerDieOK: document.querySelector('input[name="SpacerDieOK"]:checked')?.value === 'true',
                SpacerDieInitial: document.querySelector('input[name="SpacerDieInitial"]')?.value,
                SpacerDieFinal: document.querySelector('input[name="SpacerDieFinal"]')?.value,
                ToleranceDieOK: document.querySelector('input[name="ToleranceDieOK"]:checked')?.value === 'true',
                ToleranceInitial: document.querySelector('input[name="ToleranceInitial"]')?.value,
                ToleranceFinal: document.querySelector('input[name="ToleranceFinal"]')?.value,

                MeshInner10Before: document.querySelector('input[name="MeshInner10Before"]:checked')?.value === 'true',
                MeshInner40Before: document.querySelector('input[name="MeshInner40Before"]:checked')?.value === 'true',
                MeshOuter10Before: document.querySelector('input[name="MeshOuter10Before"]:checked')?.value === 'true',
                MeshOuter40Before: document.querySelector('input[name="MeshOuter40Before"]:checked')?.value === 'true',
                MeshInnerCheck: document.querySelector('input[name="MeshInnerCheck"]:checked')?.value,
                MeshOuterCheck: document.querySelector('input[name="MeshOuterCheck"]:checked')?.value,

                EmbossMarkContent: document.getElementById('EmbossMarkContent')?.value,
                EmbossMarkDate: document.getElementById('EmbossMarkDate')?.value,
                QcCond: document.querySelector('input[name="QcCond"]:checked')?.value,
                QcSurf: document.querySelector('input[name="QcSurf"]:checked')?.value,
                QcRes: document.querySelector('input[name="QcRes"]:checked')?.value,

                CreatedBy: document.getElementById('CreatedBy').value,
                
                Readings: pReadings.map(p => ({
                    ReadingTime: new Date().toISOString(),
                    RecordedBy: document.getElementById('CreatedBy').value || 'Operator',
                    ...p.data
                }))
            };

            try {
                const res = await fetch('/ProductionReport/SaveWithReadings', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const result = await res.json();
                if (result.success) {
                    Swal.fire('UPLOAD COMPLETE', 'Report archived successfully in the digital vault.', 'success')
                        .then(() => window.location.href = '/ProductionReport/Index');
                } else {
                    Swal.fire('TRANSMISSION ERROR', result.message || 'The server rejected the dataset.', 'error');
                }
            } catch (e) {
                Swal.fire('SYSTEM CRITICAL', e.message, 'error');
            }
        }

        // --- PLANNING SEARCH & REFRESH LOGIC (RESTORED) ---
        let planningItemsCache = [];
        let planningResultItems = [];
        let planningResultIndex = -1;

        async function refreshPlanningItems() {
            const date = document.getElementById('ProductionDate').value;
            const shift = document.getElementById('Shift').value;
            const searchInput = document.getElementById('planningSearch');
            
            if (!date || !shift) return;

            searchInput.placeholder = "LOADING PLANNING...";
            searchInput.disabled = true;
            document.getElementById('planningResults').classList.add('d-none');

            try {
                const res = await fetch(`/ProductionReport/GetPlanningItems?date=${date}&shift=${encodeURIComponent(shift)}`);
                planningItemsCache = await res.json();
                
                searchInput.disabled = false;
                if (planningItemsCache.length > 0) {
                    searchInput.placeholder = `TYPE ITEM CODE (${planningItemsCache.length} ITEMS LOADED)`;
                } else {
                    searchInput.placeholder = "NO ITEMS IN PLAN FOR THIS DAY";
                }
                searchInput.value = "";
                planningResultItems = planningItemsCache;
                planningResultIndex = -1;
            } catch (e) {
                console.error("Failed to fetch planning items:", e);
                searchInput.placeholder = "ERROR LOADING DATA";
            }
        }

        function showPlanningResults() {
            const container = document.getElementById('planningResults');
            if (planningResultItems.length > 0) {
                container.classList.remove('d-none');
            }
        }

        // Close dropdown when clicking outside
        document.addEventListener('click', function(e) {
            const container = document.getElementById('planningResults');
            const searchInput = document.getElementById('planningSearch');
            if (container && !container.contains(e.target) && e.target !== searchInput) {
                container.classList.add('d-none');
            }
        });

        function filterPlanningResults(query) {
            const sanitizedQuery = query.trim().toUpperCase();
            const results = sanitizedQuery.length === 0 ? planningItemsCache : planningItemsCache.filter(item => 
                (item.itemCode && item.itemCode.toUpperCase().includes(sanitizedQuery)) || 
                (item.itemName && item.itemName.toUpperCase().includes(sanitizedQuery))
            );

            planningResultItems = results;
            planningResultIndex = -1;
            renderResults(results, sanitizedQuery.length === 0);
        }

        function renderResults(items, showAll = false) {
            const container = document.getElementById('planningResults');
            container.innerHTML = "";
            
            if (items.length === 0) {
                container.innerHTML = `<div class="p-3 text-white-50 super-small font-monospace">--- NO TACTICAL MATCH FOUND ---</div>`;
                container.classList.remove('d-none');
                return;
            }

            items.forEach((item, index) => {
                const div = document.createElement('div');
                div.className = "p-3 border-bottom border-white border-opacity-5 cursor-pointer transition-all planning-result-item";
                div.style.background = "rgba(15, 23, 42, 0.98)";
                div.dataset.index = index;
                div.innerHTML = `
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="d-flex flex-column gap-1">
                            <span class="text-info-glow fw-900 font-monospace" style="font-size: 1.1rem; letter-spacing: 1px;">[${item.itemCode}]</span>
                            <span class="text-white small opacity-80 fw-bold">${item.itemName}</span>
                        </div>
                        <div class="text-end">
                            <div class="super-small text-info opacity-50 fw-black tracking-widest mb-1">PLANNING SCHEDULE</div>
                            <div class="badge bg-info bg-opacity-10 border border-info border-opacity-20 text-info fw-bold font-monospace" style="font-size: 0.65rem;">
                                ${item.dateShift ? item.dateShift : 'NO DATE'}
                            </div>
                        </div>
                    </div>
                `;
                div.onclick = () => selectPlanningItem(item);
                div.onmouseenter = () => highlightPlanningResult(index);
                container.appendChild(div);
            });

            container.classList.remove('d-none');
        }

        function highlightPlanningResult(index) {
            const container = document.getElementById('planningResults');
            const options = Array.from(container.querySelectorAll('.planning-result-item'));
            if (!options.length) return;
            options.forEach(opt => opt.classList.remove('planning-result-highlight'));
            const target = options[index];
            if (target) {
                target.classList.add('planning-result-highlight');
                planningResultIndex = index;
                target.scrollIntoView({ block: 'nearest' });
            }
        }

        function selectPlanningItem(item) {
            console.log("SELECTED ITEM DATA:", item); // Debugging
            
            document.getElementById('planningSearch').value = `[${item.itemCode}] ${item.itemName}`;
            document.getElementById('planningResults').classList.add('d-none');
            
            // Auto-sync Date
            if (item.DateProduction) {
                const pDate = item.DateProduction.split('T')[0];
                document.getElementById('ProductionDate').value = pDate;
            } else if (item.date) {
                document.getElementById('ProductionDate').value = item.date;
            }

            // Auto-sync Shift (Robust Mapping)
            if (item.Shift || item.shift) {
                let rawShift = (item.Shift || item.shift).toString().toUpperCase();
                console.log("RAW SHIFT FROM DB:", rawShift);

                if (rawShift.includes('1') || rawShift === 'I' || rawShift.includes('SIANG') || rawShift.includes('ONE')) {
                    document.getElementById('Shift').value = 'I';
                } else if (rawShift.includes('2') || rawShift === 'II' || rawShift.includes('SORE') || rawShift.includes('TWO')) {
                    document.getElementById('Shift').value = 'II';
                } else if (rawShift.includes('3') || rawShift === 'III' || rawShift.includes('MALAM') || rawShift.includes('THREE')) {
                    document.getElementById('Shift').value = 'III';
                }
            }

            fetchSpsByItem(item.itemCode);
        }

        async function fetchSpsByItem(code) {
            try {
                const res = await fetch(`/ProductionReport/GetSpsByItem?itemCode=${encodeURIComponent(code.trim())}`);
                const data = await res.json();
                if (data.success === false) throw new Error('PROTOCOL NOT FOUND');
                applySpsToForm(data);
            } catch (e) {
                console.warn(e.message);
                Swal.fire({
                    title: 'PROTOCOL UNKNOWN',
                    text: `Warning: SPS Masterlist for [${code}] is missing or not registered.`,
                    icon: 'warning',
                    background: '#020617',
                    color: '#0ea5e9',
                    confirmButtonColor: '#0ea5e9'
                });
            }
        }

        function applySpsToForm(sps) {
            document.getElementById('DocNo').value = sps.documentNumber || '---';
            document.getElementById('RevNo').value = sps.revisionNumber || '0';
            document.getElementById('HoseType').value = sps.hoseType || '';
            document.getElementById('CustomerName').value = sps.customerName || '';
            document.getElementById('InnerMaterial').value = sps.innerMaterial || '';
            document.getElementById('OuterMaterial').value = sps.outerMaterial || '';
            document.getElementById('Yarn').value = sps.yarnType || '';

            let spsIdEl = document.getElementById('StandardParameterSettingId');
            if (spsIdEl) spsIdEl.value = sps.id || '';

            const formatVal = (val, prefix = '', suffix = '') => {
                if (val === undefined || val === null || val === '') return '---';
                // Hindari double ± jika dari database sudah ada
                let strVal = String(val).trim();
                if (suffix.includes('±') && strVal.includes('±')) {
                    suffix = '';
                }
                return `${prefix}${strVal}${suffix}`;
            };

            const specMappings = {
                'HeadTempInner': formatVal(sps.headTempInner, '', ' ± 5'),
                'Cylinder1TempInner': formatVal(sps.cylinder1TempInner, '', ' ± 5'),
                'Cylinder2TempInner': formatVal(sps.cylinder2TempInner, '', ' ± 5'),
                'Cylinder3TempInner': formatVal(sps.cylinder3TempInner, '', ' ± 5'),
                'ScrewTempInner': formatVal(sps.screwTempInner, '', ' ± 5'),
                'ScrewSpeedInner': formatVal(sps.screwSpeedInner, '', ' ± 2'),
                'FeedRollRatioInner': formatVal(sps.feedRollRatioInner, 'Max '),
                'PressureInner': formatVal(sps.pressureInner, 'Max '),
                'HeadTempOuter': formatVal(sps.headTempOuter, '', ' ± 5'),
                'Cylinder1TempOuter': formatVal(sps.cylinder1TempOuter, '', ' ± 5'),
                'Cylinder2TempOuter': formatVal(sps.cylinder2TempOuter, '', ' ± 5'),
                'Cylinder3TempOuter': formatVal(sps.cylinder3TempOuter, '', ' ± 5'),
                'ScrewTempOuter': formatVal(sps.screwTempOuter, '', ' ± 5'),
                'ScrewSpeedOuter': formatVal(sps.screwSpeedOuter, '', ' ± 2'),
                'FeedRollRatioOuter': formatVal(sps.feedRollRatioOuter, 'Max '),
                'PressureOuter': formatVal(sps.pressureOuter, 'Max '),
                'SpiralSpeed': formatVal(sps.spiralSpeed, '', ' ± 20'),
                'SpiralPitchSetting': formatVal(sps.spiralPitch, '', ' ± 5'),
                'SpiralPitchDisplay': formatVal(sps.spiralPitchDisplay, '', ' ± 5'),
                'PresetValue': formatVal(sps.presetValve, '', ' ± 0.5'),
                'ControlValue': formatVal(sps.controlValue),
                'HoseSpeed': formatVal(sps.hoseSpeed),
                'TakeupConveyorSpeed': formatVal(sps.takeupConveyorSpeed),
                'CoolConveyorSpeed': formatVal(sps.coolConveyorSpeed),
                'ConveyorRatio': formatVal(sps.conveyorRatio),
                'UnsmoothSurface': formatVal(sps.unsmoothSurface),
                'ChillerWaterTemp': formatVal(sps.chillerWaterTemp),
                'CaterpillarGap': formatVal(sps.caterpillarGap),
                'NippleDie': formatVal(sps.innerDie, '', ' ± 0.1'),
                'TubeDie': formatVal(sps.tubeDie, '', ' ± 0.1'),
                'MiddleDie': formatVal(sps.middleDie, '', ' ± 0.1'),
                'CoverDie': formatVal(sps.coverDie, '', ' ± 0.1'),
                'SpacerDie': formatVal(sps.spacerDie, '', ' ± 0.1'),
                'ToleranceDie': formatVal(sps.toleranceDie, '', ' ± 0.1')
            };

            for (const [key, val] of Object.entries(specMappings)) {
                const el = document.getElementById('spec_' + key);
                if (el) {
                    el.innerText = val;
                    el.classList.add('blink-once');
                }
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            renderTabs();
            refreshPlanningItems();
            
            const searchInput = document.getElementById('planningSearch');
            if (searchInput) {
                searchInput.addEventListener('input', (e) => filterPlanningResults(e.target.value));
                searchInput.addEventListener('focus', () => document.getElementById('planningResults').classList.remove('d-none'));
            }
        });
    </script>
    <style>
        .hover-bg-success:hover { background: rgba(16, 185, 129, 0.2) !important; color: white; }
        .planning-result-highlight { background: rgba(14, 165, 233, 0.15) !important; border-color: rgba(14, 165, 233, 0.45) !important; }
        .cursor-pointer { cursor: pointer; }
        .transition-all { transition: all 0.2s ease; }
        .glow-success { border-color: #10b981 !important; box-shadow: 0 0 20px rgba(16, 185, 129, 0.4) !important; }
        #reader__scan_region video { width: 100% !important; object-fit: cover !important; }
        #reader__dashboard_section_csr button { background: #0ea5e9; color: white; border: none; padding: 5px 15px; border-radius: 4px; margin: 5px; font-weight: 800; font-size: 0.7rem; text-transform: uppercase; }
        .swal2-close { color: #ef4444 !important; }
        .valid-success { box-shadow: inset 0 -3px 0 #10b981 !important; }
        .valid-error { box-shadow: inset 0 -3px 0 #ef4444 !important; animation: shake-hud-input 0.3s; }
        @@keyframes shake-hud-input { 0%,100%{transform:translateX(0)} 25%{transform:translateX(-3px)} 75%{transform:translateX(3px)} }

        .custom-tactical-scroll::-webkit-scrollbar { width: 6px; }
        .custom-tactical-scroll::-webkit-scrollbar-track { background: rgba(15, 23, 42, 0.9); }
        .custom-tactical-scroll::-webkit-scrollbar-thumb { background: #0ea5e9; border-radius: 10px; border: 2px solid rgba(15, 23, 42, 0.9); }
        .custom-tactical-scroll::-webkit-scrollbar-thumb:hover { background: #38bdf8; }
    </style>
}
