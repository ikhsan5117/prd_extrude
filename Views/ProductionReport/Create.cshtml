@model VelastoProductionSystem.Models.ProductionReport

@{
    ViewData["Title"] = "EXTRUDER PRODUCTION REPORT";
}

<div class="production-blueprint no-print-bg pb-5">
    <div class="container-fluid p-1 p-md-2">
        
        <!-- HEADER HUD (NO BACKGROUND) -->
        <div class="mb-5 py-2">
            <div class="text-center">
                <h1 class="m-0 fw-black text-white letter-spacing-2" style="font-size: 1.6rem;">EXTRUDER PRODUCTION REPORT</h1>
                <div class="text-primary-glow fw-bold tracking-widest" style="font-size: 0.95rem;">(PARAMETER SETTING)</div>
            </div>
        </div>

        <form asp-action="Create" id="mainReportForm">
            <!-- SECTION: PRODUCTION COMMAND CONSOLE (TOP HEADER) -->
            <div class="hud-card mb-4 shadow-hud-blue border-white border-opacity-10 overflow-hidden">
                <div class="hud-card-header d-flex justify-content-between align-items-center py-2 px-3">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-terminal-fill hud-card-icon fs-6"></i>
                        <span class="hud-card-title small tracking-widest font-monospace">PRODUCTION COMMAND CONSOLE</span>
                    </div>
                    <div class="d-flex gap-3 super-small font-black opacity-40 text-uppercase letter-spacing-2">
                        <span><i class="bi bi-file-text me-1"></i>DOC: <input asp-for="DocumentNumber" id="DocNo" class="bg-transparent border-0 text-white-50 w-auto" placeholder="AUTO" /></span>
                        <span><i class="bi bi-activity me-1"></i>REV: <input asp-for="RevisionNumber" id="RevNo" class="bg-transparent border-0 text-white-50 w-auto" placeholder="0" /></span>
                    </div>
                </div>

                <!-- NEW: SPS PROTOCOL SYNC -->
                <div class="p-3 bg-primary bg-opacity-5 border-bottom border-white border-opacity-5 no-print">
                    <div class="row g-3 align-items-center">
                        <div class="col-md-9">
                            <div class="hud-pill border-info border-opacity-40">
                                <label><i class="bi bi-keyboard me-2 text-info"></i>TYPE ITEM CODE (MANUAL)</label>
                                <input id="manualItemSearch" type="text" class="hud-input bg-dark border-0 py-1 font-monospace" placeholder="EX: VHFUNC-..." onchange="fetchSpsByItem(this.value)" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <button type="button" onclick="startSpsScanner()" class="btn btn-hud-primary h-100 w-100 py-3 shadow-glow-blue border border-white border-opacity-25" style="min-height: 58px;">
                                <i class="bi bi-qr-code-scan me-2"></i> SPS SYNC SCANNER
                            </button>
                        </div>
                    </div>
                </div>
                <div class="p-3 bg-black bg-opacity-30 border-bottom border-white border-opacity-5">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <div class="hud-pill-integrated shadow-glow-blue border-white border-opacity-5">
                                <label><i class="bi bi-calendar-check me-2 text-primary"></i>SYSTEM DATE</label>
                                <input type="date" asp-for="ProductionDate" class="hud-input font-monospace text-primary-glow" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="hud-pill-integrated shadow-glow-blue border-white border-opacity-5">
                                <label><i class="bi bi-clock-history me-2 text-primary"></i>SHIFT</label>
                                <select asp-for="Shift" class="hud-input font-black bg-transparent border-0" style="-webkit-appearance: none;">
                                    <option value="I" class="bg-dark">SHIFT I</option>
                                    <option value="II" class="bg-dark" selected>SHIFT II</option>
                                    <option value="III" class="bg-dark">SHIFT III</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="hud-pill-integrated shadow-glow-blue border-white border-opacity-5">
                                <label><i class="bi bi-building me-2 text-primary"></i>CUSTOMER ENTITY</label>
                                <input asp-for="CustomerName" id="CustomerName" class="hud-input small text-white-50 font-black" placeholder="PT. ADM" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="hud-pill-integrated shadow-glow-blue border-white border-opacity-5">
                                <label><i class="bi bi-cpu me-2 text-primary"></i>HOSE SPECIFICATION TYPE</label>
                                <input asp-for="HoseType" id="HoseType" class="hud-input small font-monospace text-white-50" placeholder="Extrusion Spec Name..." />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ROW 2: MATERIAL & MESH CHECKING -->
            <!-- ROW 2: MATERIAL & MESH CHECKING -->
            <style>
                .hud-pill-group {
                    display: inline-flex;
                    background: rgba(0, 0, 0, 0.4);
                    padding: 3px;
                    border-radius: 6px;
                    border: 1px solid rgba(255, 255, 255, 0.1);
                    width: 100%;
                }
                .hud-pill-item {
                    flex: 1;
                    padding: 6px 4px;
                    font-size: 0.7rem;
                    font-weight: 900;
                    color: rgba(255, 255, 255, 0.3);
                    border-radius: 4px;
                    cursor: pointer;
                    transition: all 0.2s;
                    text-transform: uppercase;
                    text-align: center;
                }
                .hud-pill-item input { display: none; }
                .hud-pill-item:has(input:checked) {
                    background: #10b981;
                    color: white;
                    box-shadow: 0 0 12px rgba(16, 185, 129, 0.3);
                }
                .hud-pill-item.red:has(input:checked) { background: #ef4444; }
                .hud-pill-item.orange:has(input:checked) { background: #f59e0b; }
                .hud-pill-group.sm { border-radius: 4px; padding: 2px; }
                .hud-pill-group.sm .hud-pill-item { padding: 3px 2px; font-size: 0.65rem; border-radius: 3px; }
                
                .compact-hud td { padding: 4px 1px !important; } /* REDUCED PADDING TO PREVENT INPUT SQUEEZING */
                .compact-hud th { padding: 6px 1px !important; }
                .instrument-style { font-family: 'JetBrains Mono', 'Roboto Mono', monospace; }

                /* INTEGRATED DASHBOARD PILLS */
                .hud-pill-integrated { 
                    background: rgba(30, 41, 59, 0.4); 
                    border: 1px solid rgba(14, 165, 233, 0.2); 
                    border-radius: 6px; 
                    padding: 8px 12px; 
                    display: flex; 
                    flex-direction: column; 
                    transition: all 0.3s;
                }
                .hud-pill-integrated:focus-within { 
                    border-color: #0ea5e9; 
                    background: rgba(14, 165, 233, 0.1); 
                    box-shadow: 0 0 15px rgba(14, 165, 233, 0.2); 
                }
                .hud-pill-integrated label { 
                    font-size: 0.6rem; 
                    font-weight: 800; 
                    color: #38bdf8; 
                    letter-spacing: 1px; 
                    margin-bottom: 4px; 
                    text-transform: uppercase;
                }
                .hud-pill-integrated .hud-input { 
                    font-size: 0.85rem; 
                    background: transparent; 
                    border: none; 
                    color: white; 
                    padding: 0; 
                    width: 100%;
                    outline: none;
                }
                .group-lane { background: rgba(14, 165, 233, 0.03); }
                .font-black { font-weight: 900 !important; font-size: 0.6rem !important; }

                /* CUSTOM CHECKBOX STYLE */
                .hud-check-box { position: relative; width: 22px; height: 22px; margin: 0 auto; }
                .hud-check-box input { opacity: 0; width: 0; height: 0; cursor: pointer; }
                .hud-check-box span {
                    position: absolute; top: 0; left: 0; height: 22px; width: 22px;
                    background-color: rgba(0, 0, 0, 0.4);
                    border: 2px solid rgba(14, 165, 233, 0.3);
                    border-radius: 4px; transition: all 0.2s;
                }
                .hud-check-box:hover input ~ span { border-color: #0ea5e9; }
                .hud-check-box input:checked ~ span { background-color: rgba(14, 165, 233, 0.2); border-color: #0ea5e9; box-shadow: 0 0 10px rgba(14, 165, 233, 0.3); }
                .hud-check-box span:after {
                    content: ""; position: absolute; display: none;
                    left: 7px; top: 2px; width: 6px; height: 12px;
                    border: solid #0ea5e9; border-width: 0 3px 3px 0;
                    transform: rotate(45deg);
                }
                .hud-check-box input:checked ~ span:after { display: block; }
                
                .hud-card-header {
                    background: linear-gradient(90deg, rgba(14, 165, 233, 0.15) 0%, transparent 100%);
                    border-bottom: 1px solid rgba(14, 165, 233, 0.3);
                    padding: 10px 20px;
                    display: flex;
                    align-items: center;
                    gap: 12px;
                }
                .hud-card-title {
                    font-size: 0.85rem;
                    font-weight: 900;
                    letter-spacing: 2px;
                    color: #0ea5e9;
                    text-transform: uppercase;
                }
                .hud-card-icon { color: #0ea5e9; font-size: 1.1rem; }
                
                .table-hud-unified { width: 100%; border-collapse: collapse; }
                .table-hud-unified th { 
                    padding: 12px; 
                    font-size: 0.65rem; 
                    font-weight: 800; 
                    color: rgba(255, 255, 255, 0.5); 
                    text-transform: uppercase; 
                    letter-spacing: 1px;
                    border-bottom: 1px solid rgba(255,255,255,0.05);
                }
                .table-hud-unified td { padding: 12px; vertical-align: middle; border-bottom: 1px solid rgba(255,255,255,0.05); }
                .label-stack { display: flex; flex-direction: column; gap: 2px; }
                .label-main { font-size: 0.85rem; font-weight: 900; color: white; line-height: 1; }
                .label-sub { font-size: 0.6rem; font-weight: 700; color: #60a5fa; text-transform: uppercase; opacity: 0.8; }
                
                /* SCAN ZONE STYLING */
                .hud-th-scan { background: rgba(14, 165, 233, 0.05); color: #0ea5e9 !important; font-weight: 900 !important; }
                .hud-td-scan { background: rgba(0, 0, 0, 0.2); padding: 8px 12px !important; }
                .hud-scan-group {
                    display: flex;
                    align-items: center;
                    background: rgba(15, 23, 42, 0.6);
                    border: 1px solid rgba(14, 165, 233, 0.2);
                    border-radius: 6px;
                    padding: 2px 4px;
                    transition: all 0.3s;
                }
                .hud-scan-group:focus-within {
                    border-color: #0ea5e9;
                    box-shadow: 0 0 15px rgba(14, 165, 233, 0.2);
                    background: rgba(14, 165, 233, 0.05);
                }
                .hud-input-scan {
                    background: transparent;
                    border: none;
                    color: #0ea5e9;
                    font-weight: 900;
                    font-size: 0.85rem;
                    padding: 8px;
                    width: 100%;
                    outline: none;
                    letter-spacing: 1px;
                }
                .hud-scan-btn {
                    background: rgba(14, 165, 233, 0.1);
                    border: none;
                    color: #0ea5e9;
                    padding: 6px 10px;
                    border-radius: 4px;
                    cursor: pointer;
                    transition: all 0.2s;
                }
                .hud-scan-btn:hover { background: #0ea5e9; color: white; }
                .hud-input-underlined {
                    background: transparent;
                    border: none;
                    border-bottom: 2px solid rgba(255, 255, 255, 0.05);
                    color: white;
                    font-weight: 900;
                    width: 100%;
                    padding: 8px 0; /* REMOVED TO PREVENT CLIPPING */
                    text-align: center;
                    transition: all 0.3s;
                    font-size: 1.1rem; /* HIGHER LEGIBILITY */
                    min-height: 46px; /* MATCHES CELL HEIGHT */
                    font-family: 'JetBrains Mono', monospace;
                }
                .hud-input-underlined:focus {
                    outline: none;
                    border-bottom-color: #3b82f6;
                    background: rgba(59, 130, 246, 0.05);
                }
            </style>

            <div class="row g-4 mb-5">
                <!-- CARD 1: MATERIAL -->
                <div class="col-lg-7">
                    <div class="hud-card h-100 shadow-hud-blue border-white border-opacity-10 overflow-hidden">
                        <div class="hud-card-header">
                            <i class="bi bi-box-seam hud-card-icon"></i>
                            <span class="hud-card-title">MATERIAL & LOT TRACKING</span>
                        </div>
                        <table class="table-hud-unified">
                            <thead>
                                <tr class="bg-black bg-opacity-20 text-center">
                                    <th class="ps-4 text-start">DESCRIPTION</th>
                                    <th width="22%">STANDARD</th>
                                    <th width="22%">ACTUAL</th>
                                    <th width="32%" class="hud-th-scan text-info border-start border-white border-opacity-10">NO. LOT (SCAN)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="ps-4">
                                        <div class="label-stack"><span class="label-sub">INNER (MATERIAL)</span><span class="label-main">COMPOUND</span></div>
                                    </td>
                                    <td><input asp-for="InnerMaterial" class="hud-input-underlined text-center opacity-50" readonly /></td>
                                    <td><input asp-for="InnerMaterialActual" class="hud-input-underlined text-center" placeholder="---" /></td>
                                    <td class="hud-td-scan border-start border-white border-opacity-10">
                                        <div class="hud-scan-group">
                                            <input asp-for="InnerMaterialLotNo" class="hud-input-scan" placeholder="SCAN LOT..." />
                                            <button type="button" class="hud-scan-btn" onclick="openScanner('InnerMaterialLotNo')"><i class="bi bi-upc-scan"></i></button>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="ps-4">
                                        <div class="label-stack"><span class="label-sub">OUTER (MATERIAL)</span><span class="label-main">COMPOUND</span></div>
                                    </td>
                                    <td><input asp-for="OuterMaterial" class="hud-input-underlined text-center opacity-50" readonly /></td>
                                    <td><input asp-for="OuterMaterialActual" class="hud-input-underlined text-center" placeholder="---" /></td>
                                    <td class="hud-td-scan border-start border-white border-opacity-10">
                                        <div class="hud-scan-group">
                                            <input asp-for="OuterMaterialLotNo" class="hud-input-scan" placeholder="SCAN LOT..." />
                                            <button type="button" class="hud-scan-btn" onclick="openScanner('OuterMaterialLotNo')"><i class="bi bi-upc-scan"></i></button>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="ps-4">
                                        <div class="label-stack"><span class="label-sub">YARN (SUPPORT)</span><span class="label-main">POLYESTER</span></div>
                                    </td>
                                    <td><input asp-for="Yarn" class="hud-input-underlined text-center opacity-50" readonly /></td>
                                    <td><input asp-for="YarnActual" class="hud-input-underlined text-center" placeholder="---" /></td>
                                    <td class="hud-td-scan border-start border-white border-opacity-10">
                                        <div class="hud-scan-group">
                                            <input asp-for="YarnLotNo" class="hud-input-scan" placeholder="SCAN LOT..." />
                                            <button type="button" class="hud-scan-btn" onclick="openScanner('YarnLotNo')"><i class="bi bi-upc-scan"></i></button>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- CARD 2: MESH & EMBOSS -->
                <div class="col-lg-5">
                    <div class="hud-card h-100 shadow-hud-blue border-white border-opacity-10 overflow-hidden">
                        <div class="hud-card-header">
                            <i class="bi bi-patch-check hud-card-icon"></i>
                            <span class="hud-card-title">MESH & EMBOSS QUALITY</span>
                        </div>
                        <table class="table-hud-unified compact-hud instrument-style">
                            <thead>
                                <tr class="bg-black bg-opacity-40 text-center">
                                    <th class="ps-3 text-start py-2 font-monospace tracking-widest text-primary-glow">CATEGORIES</th>
                                    <th width="32%" class="py-2 border-start border-white border-opacity-5">Ø96 #10</th>
                                    <th width="32%" class="py-2 border-start border-white border-opacity-5">Ø96 #40</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- MESH TYPE ZONE -->
                                <tr class="group-lane">
                                    <td class="ps-3 py-1"><div class="label-stack"><span class="label-sub">TIPE MESH</span><span class="label-main small">INNER (BEFORE)</span></div></td>
                                    <td class="text-center border-start border-white border-opacity-5"><div class="hud-check-box"><input type="checkbox"><span></span></div></td>
                                    <td class="text-center border-start border-white border-opacity-5"><div class="hud-check-box"><input type="checkbox"><span></span></div></td>
                                </tr>
                                <tr class="group-lane border-bottom border-white border-opacity-10">
                                    <td class="ps-3 py-1"><div class="label-stack"><span class="label-sub opacity-0 small">.</span><span class="label-main small">OUTER (BEFORE)</span></div></td>
                                    <td class="text-center border-start border-white border-opacity-5"><div class="hud-check-box"><input type="checkbox"><span></span></div></td>
                                    <td class="text-center border-start border-white border-opacity-5"><div class="hud-check-box"><input type="checkbox"><span></span></div></td>
                                </tr>
                                <!-- MESH CHECK ZONE -->
                                <tr>
                                    <td class="ps-3 py-2"><div class="label-stack"><span class="label-sub">MESH CHECK</span><span class="label-main small">INNER (AFTER)</span></div></td>
                                    <td colspan="2" class="pe-3 py-2 border-start border-white border-opacity-5">
                                        <div class="hud-pill-group sm"><label class="hud-pill-item">OK<input type="radio" name="MI" value="OK"></label><label class="hud-pill-item red">BOLONG<input type="radio" name="MI" value="B"></label><label class="hud-pill-item orange">ASING<input type="radio" name="MI" value="A"></label></div>
                                    </td>
                                </tr>
                                <tr class="border-bottom border-white border-opacity-10">
                                    <td class="ps-3 py-2"><div class="label-stack"><span class="label-sub opacity-0 small">.</span><span class="label-main small">OUTER (AFTER)</span></div></td>
                                    <td colspan="2" class="pe-3 py-2 border-start border-white border-opacity-5">
                                        <div class="hud-pill-group sm"><label class="hud-pill-item">OK<input type="radio" name="MO" value="OK"></label><label class="hud-pill-item red">BOLONG<input type="radio" name="MO" value="B"></label><label class="hud-pill-item orange">ASING<input type="radio" name="MO" value="A"></label></div>
                                    </td>
                                </tr>
                                <!-- EMBOSSING ZONE -->
                                <tr class="group-lane border-bottom border-white border-opacity-10">
                                    <td class="ps-3 py-2"><div class="label-stack"><span class="label-sub">EMBOSSING</span><span class="label-main small">MARK DATA</span></div></td>
                                    <td colspan="2" class="pe-3 py-2 border-start border-white border-opacity-5">
                                        <div class="row g-2 align-items-center">
                                            <div class="col-7"><input class="hud-input-underlined py-1 text-start ps-2 super-small" placeholder="Text Content..." /></div>
                                            <div class="col-5"><input class="hud-input-underlined py-1 text-center super-small" placeholder="Prod. Date" /></div>
                                        </div>
                                    </td>
                                </tr>
                                <!-- FINAL QC ZONE -->
                                <tr>
                                    <td class="ps-3 py-2"><div class="label-stack"><span class="label-sub">QC DETAILS</span><span class="label-main small">FINAL CHECK</span></div></td>
                                    <td colspan="2" class="pe-3 py-2 border-start border-white border-opacity-5">
                                        <div class="d-flex flex-column gap-1">
                                            <div class="d-flex align-items-center gap-2"><span class="label-sub font-black text-white" style="min-width:35px">COND</span><div class="hud-pill-group sm"><label class="hud-pill-item">BERSIH<input type="radio" name="cond" value="B"></label><label class="hud-pill-item red">KOTOR<input type="radio" name="cond" value="K"></label></div></div>
                                            <div class="d-flex align-items-center gap-2"><span class="label-sub font-black text-white" style="min-width:35px">SURF</span><div class="hud-pill-group sm"><label class="hud-pill-item">OK<input type="radio" name="surf" value="OK"></label><label class="hud-pill-item red">SCRATCH<input type="radio" name="surf" value="S"></label></div></div>
                                            <div class="d-flex align-items-center gap-2"><span class="label-sub font-black text-white" style="min-width:35px">RES</span><div class="hud-pill-group sm"><label class="hud-pill-item">READ<input type="radio" name="emb" value="T"></label><label class="hud-pill-item red">UNREAD<input type="radio" name="emb" value="X"></label></div></div>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- SECTION: DIES DIMENSION -->
            <div class="hud-card mb-4 shadow-hud-blue border-white border-opacity-10 overflow-hidden">
                <div class="hud-card-header">
                    <i class="bi bi-rulers hud-card-icon"></i>
                    <span class="hud-card-title">DIES DIMENSION MEASUREMENTS</span>
                </div>
                <div class="p-0 overflow-auto">
                    <table class="table-hud-unified compact-hud instrument-style">
                        <thead>
                            <tr class="bg-black bg-opacity-40 text-center">
                                <th class="ps-4 text-start py-2 font-monospace tracking-widest text-primary-glow">DIES DESCRIPTION</th>
                                <th width="15%" class="py-2 border-start border-white border-opacity-5">CEK VISUAL</th>
                                <th width="18%" class="py-2 border-start border-white border-opacity-5">STANDARD</th>
                                <th width="20%" class="py-2 border-start border-white border-opacity-5">INITIAL (BEFORE)</th>
                                <th width="20%" class="py-2 border-start border-white border-opacity-5">FINAL (AFTER)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var diesList = new[] { 
                                    new { Name = "Nipple Die", Std = "--", Field = "NippleDieOK", SpecKey = "NippleDie" },
                                    new { Name = "Tube Die", Std = "--", Field = "TubeDieOK", SpecKey = "TubeDie" },
                                    new { Name = "Middle Die", Std = "--", Field = "MiddleDieOK", SpecKey = "MiddleDie" },
                                    new { Name = "Cover Die", Std = "--", Field = "CoverDieOK", SpecKey = "CoverDie" },
                                    new { Name = "Spacer Die", Std = "--", Field = "SpacerDieOK", SpecKey = "SpacerDie" },
                                    new { Name = "A Distance", Std = "--", Field = "ToleranceDieOK", SpecKey = "ToleranceDie" }
                                };
                            }
                            @foreach(var die in diesList) {
                                <tr class="group-lane">
                                    <td class="ps-4 py-2 fw-bold text-white-50">@die.Name</td>
                                    <td class="border-start border-white border-opacity-5">
                                        <div class="hud-pill-group sm"><label class="hud-pill-item">OK<input type="radio" name="@die.Field" value="true"></label><label class="hud-pill-item red">NG<input type="radio" name="@die.Field" value="false"></label></div>
                                    </td>
                                    <td class="text-info-glow font-monospace text-center border-start border-white border-opacity-5" id="spec_@die.SpecKey">@die.Std</td>
                                    <td class="border-start border-white border-opacity-5"><input class="hud-input-underlined py-1 text-center font-monospace text-warning" placeholder="---" /></td>
                                    <td class="border-start border-white border-opacity-5"><input class="hud-input-underlined py-1 text-center font-monospace text-warning" placeholder="---" /></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- SECTION: PARAMETERS TABLE (The Massive Grid) -->
            <div class="hud-card mb-4 shadow-hud-blue border-white border-opacity-10 overflow-hidden">
                <div class="hud-card-header">
                    <i class="bi bi-cpu hud-card-icon"></i>
                    <span class="hud-card-title">PARAMETER SETTING MONITORING</span>
                </div>
                <div class="p-0 overflow-auto">
                    <table class="table-hud-unified compact-hud instrument-style text-center">
                        <thead class="sticky-top bg-black">
                            <tr class="bg-black bg-opacity-80 text-info-glow border-bottom border-white border-opacity-10">
                                <th class="text-start ps-4 py-3 font-monospace tracking-widest small">INSTRUMENT / ITEM</th>
                                <th width="10%" class="small">SPECIFICATION</th>
                                <th width="10%" class="hud-th-scan text-white fw-900 border-x border-white border-opacity-10">INITIAL</th>
                                @for(int i=1; i<=7; i++){ <th width="9.5%" class="border-start border-white border-opacity-5 small text-white-50">@i</th> }
                            </tr>
                        </thead>
                        <tbody>
                            <!-- INNER (TUBE 1) -->
                            <tr class="bg-primary border-bottom border-white border-opacity-10">
                                <td colspan="10" class="text-start ps-4 py-2 text-white font-monospace tracking-widest fw-black" style="font-size: 0.9rem; letter-spacing: 2px;">
                                    <i class="bi bi-gear-fill me-2 text-warning"></i>SECTION 01: INNER (TUBE 1)
                                </td>
                                                     @{
                                string[,] innerRows = { 
                                    { "Head Temp. (°C)", "--", "HeadTempInner" }, 
                                    { "Cylinder 1 (°C)", "--", "Cylinder1TempInner" },
                                    { "Cylinder 2 (°C)", "--", "Cylinder2TempInner" },
                                    { "Cylinder 3 (°C)", "--", "Cylinder3TempInner" },
                                    { "Screw Temp. (°C)", "--", "ScrewTempInner" },
                                    { "Screw Speed (rpm)", "--", "ScrewSpeedInner" },
                                    { "Feed Roll Ratio (%)", "--", "FeedRollRatioInner" },
                                    { "Pressure (MPa)", "--", "PressureInner" }
                                };
                                for(int r=0; r<innerRows.GetLength(0); r++){
                                    <tr class="group-lane">
                                        <td class="text-start ps-4 text-white font-black opacity-100 small">@innerRows[r,0]</td>
                                        <td class="text-primary font-monospace small opacity-100 fw-bold" id="spec_@innerRows[r,2]">@innerRows[r,1]</td>
                                        <td class="bg-black bg-opacity-40 border-x border-white border-opacity-10"><input name="Init_@innerRows[r,2]" class="hud-input-underlined text-warning fw-bold py-1" placeholder="..." /></td>
                                        @for(int i=1; i<=7; i++){ <td class="border-start border-white border-opacity-5"><input name="C@(i)_@innerRows[r,2]" class="hud-input-underlined py-1" placeholder="-" /></td> }
                                    </tr>
                                }
                            }

                            <!-- OUTER (COVER) -->
                            <tr class="bg-warning border-bottom border-white border-opacity-10">
                                <td colspan="10" class="text-start ps-4 py-2 text-black font-monospace tracking-widest fw-black" style="font-size: 0.9rem; letter-spacing: 2px;">
                                    <i class="bi bi-gear-fill me-2 text-white"></i>SECTION 02: OUTER (COVER)
                                </td>
                            </tr>
                            @{
                                string[,] outerRows = { 
                                    { "Head Temp. (°C)", "--", "HeadTempOuter" }, 
                                    { "Cylinder 1 (°C)", "--", "Cylinder1TempOuter" },
                                    { "Cylinder 2 (°C)", "--", "Cylinder2TempOuter" },
                                    { "Cylinder 3 (°C)", "--", "Cylinder3TempOuter" },
                                    { "Screw Temp. (°C)", "--", "ScrewTempOuter" },
                                    { "Screw Speed (rpm)", "--", "ScrewSpeedOuter" },
                                    { "Feed Roll Ratio (%)", "--", "FeedRollRatioOuter" },
                                    { "Pressure (MPa)", "--", "PressureOuter" }
                                };
                                for(int r=0; r<outerRows.GetLength(0); r++){
                                    <tr class="group-lane">
                                        <td class="text-start ps-4 text-white font-black opacity-100 small">@outerRows[r,0]</td>
                                        <td class="text-warning font-monospace small opacity-100 fw-bold" id="spec_@outerRows[r,2]">@outerRows[r,1]</td>
                                        <td class="bg-black bg-opacity-40 border-x border-white border-opacity-10"><input name="Init_@outerRows[r,2]" class="hud-input-underlined text-warning fw-bold py-1" placeholder="..." /></td>
                                        @for(int i=1; i<=7; i++){ <td class="border-start border-white border-opacity-5"><input name="C@(i)_@outerRows[r,2]" class="hud-input-underlined py-1" placeholder="-" /></td> }
                                    </tr>
                                }
                            }

                            <!-- SPIRAL -->
                            <tr class="bg-success border-bottom border-white border-opacity-10">
                                <td colspan="10" class="text-start ps-4 py-2 text-white font-monospace tracking-widest fw-black" style="font-size: 0.9rem; letter-spacing: 2px;">
                                    <i class="bi bi-gear-fill me-2 text-warning"></i>SECTION 03: SPIRAL MECHANISM
                                </td>
                            </tr>
                            @{
                                string[,] spiralRows = { 
                                    { "Spiral Speed (rpm)", "--", "SpiralSpeed" }, 
                                    { "Spiral Pitch (Setting)", "--", "SpiralPitchSetting" },
                                    { "Spiral Pitch (Display)", "--", "SpiralPitchDisplay" }
                                };
                                for(int r=0; r<spiralRows.GetLength(0); r++){
                                    <tr class="group-lane">
                                        <td class="text-start ps-4 text-white font-black opacity-100 small">@spiralRows[r,0]</td>
                                        <td class="text-success font-monospace small opacity-100 fw-bold" id="spec_@spiralRows[r,2]">@spiralRows[r,1]</td>
                                        <td class="bg-black bg-opacity-40 border-x border-white border-opacity-10"><input name="Init_@spiralRows[r,2]" class="hud-input-underlined text-warning fw-bold py-1" placeholder="..." /></td>
                                        @for(int i=1; i<=7; i++){ <td class="border-start border-white border-opacity-5"><input name="C@(i)_@spiralRows[r,2]" class="hud-input-underlined py-1" placeholder="-" /></td> }
                                    </tr>
                                }
                            }

                            <!-- OTHER -->
                            <tr class="bg-info border-bottom border-white border-opacity-10">
                                <td colspan="10" class="text-start ps-4 py-2 text-white font-monospace tracking-widest fw-black" style="font-size: 0.9rem; letter-spacing: 2px;">
                                    <i class="bi bi-gear-fill me-2 text-warning"></i>SECTION 04: INFRASTRUCTURE & OTHER
                                </td>
                            </tr>
                            @{
                                string[,] otherRows = { 
                                    { "Preset Value (Ø mm)", "--", "PresetValue" }, 
                                    { "Control Value (Ø mm)", "--", "ControlValue" },
                                    { "Hose Speed (m/min)", "--", "HoseSpeed" },
                                    { "Take-up Conveyor Speed (m/min)", "--", "TakeupConveyorSpeed" },
                                    { "Cool Conveyor Speed (m/min)", "--", "CoolConveyorSpeed" },
                                    { "Conveyor Ratio (Take up : Cool)", "--", "ConveyorRatio" },
                                    { "Un-smooth Surface", "--", "UnsmoothSurface" },
                                    { "Chiller Water Temperature (°C)", "--", "ChillerWaterTemp" },
                                    { "Caterpillar Gap (mm)", "--", "CaterpillarGap" }
                                };
                                for(int r=0; r<otherRows.GetLength(0); r++){
                                    <tr class="group-lane">
                                        <td class="text-start ps-4 text-white font-black opacity-100 small">@otherRows[r,0]</td>
                                        <td class="text-info font-monospace small opacity-100 fw-bold" id="spec_@otherRows[r,2]">@otherRows[r,1]</td>
                                        <td class="bg-black bg-opacity-40 border-x border-white border-opacity-10"><input name="Init_@otherRows[r,2]" class="hud-input-underlined text-warning fw-bold py-1" placeholder="..." /></td>
                                        @for(int i=1; i<=7; i++){ <td class="border-start border-white border-opacity-5"><input name="C@(i)_@otherRows[r,2]" class="hud-input-underlined py-1" placeholder="-" /></td> }
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- SECTION: WASTE & FOOTER HUD -->
            <div class="row g-3">
                <div class="col-lg-7">
                    <div class="hud-card d-flex h-100 shadow-hud-blue border-white border-opacity-10 overflow-hidden">
                        <div class="hud-vertical-label bg-black bg-opacity-40 fw-black text-info font-monospace tracking-widest pt-2">WASTE PERFORMANCE</div>
                        <div class="flex-grow-1 p-0 overflow-hidden">
                            <table class="table-hud-unified instrument-style m-0 text-center super-small font-monospace">
                                <thead>
                                    <tr class="bg-black bg-opacity-60 text-info">
                                        <th width="30%" class="ps-3 text-start small border border-white border-opacity-20">PHASE / POINT</th>
                                        <th width="35%" class="bg-primary bg-opacity-10 text-white small border border-white border-opacity-20">AWAL (kg)</th>
                                        <th width="35%" class="bg-success bg-opacity-10 text-white small border border-white border-opacity-20">AKHIR (kg)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="group-lane">
                                        <td class="text-start ps-3 py-1 border border-white border-opacity-20">
                                            <div class="fw-bold text-white super-small opacity-50">DANDORI AWAL</div>
                                            <div class="text-info super-small fw-bold">INNER TUBE</div>
                                        </td>
                                        <td class="p-1 align-middle border border-white border-opacity-20"><input name="DAI_Awal" class="hud-input-underlined text-warning fw-black text-center py-1" placeholder="0.00" /></td>
                                        <td class="p-1 align-middle border border-white border-opacity-20"><input name="DAI_Akhir" class="hud-input-underlined text-warning fw-black text-center py-1" placeholder="0.00" /></td>
                                    </tr>
                                    <tr class="group-lane">
                                        <td class="text-start ps-3 py-1 border border-white border-opacity-20">
                                            <div class="fw-bold text-white super-small opacity-50">DANDORI AWAL</div>
                                            <div class="text-warning super-small fw-bold">COVER</div>
                                        </td>
                                        <td class="p-1 align-middle border border-white border-opacity-20"><input name="DAC_Awal" class="hud-input-underlined text-warning fw-black text-center py-1" placeholder="0.00" /></td>
                                        <td class="p-1 align-middle border border-white border-opacity-20"><input name="DAC_Akhir" class="hud-input-underlined text-warning fw-black text-center py-1" placeholder="0.00" /></td>
                                    </tr>
                                    <tr class="group-lane">
                                        <td class="text-start ps-3 py-1 border border-white border-opacity-20">
                                            <div class="fw-bold text-white super-small opacity-50">DANDORI AKHIR</div>
                                            <div class="text-info super-small fw-bold">INNER TUBE</div>
                                        </td>
                                        <td class="p-1 align-middle border border-white border-opacity-20"><input name="DRAI_Awal" class="hud-input-underlined text-warning fw-black text-center py-1" placeholder="0.00" /></td>
                                        <td class="p-1 align-middle border border-white border-opacity-20"><input name="DRAI_Akhir" class="hud-input-underlined text-warning fw-black text-center py-1" placeholder="0.00" /></td>
                                    </tr>
                                    <tr class="group-lane">
                                        <td class="text-start ps-3 py-1 border border-white border-opacity-20">
                                            <div class="fw-bold text-white super-small opacity-50">DANDORI AKHIR</div>
                                            <div class="text-warning super-small fw-bold">COVER</div>
                                        </td>
                                        <td class="p-1 align-middle border border-white border-opacity-20"><input name="DRAC_Awal" class="hud-input-underlined text-warning fw-black text-center py-1" placeholder="0.00" /></td>
                                        <td class="p-1 align-middle border border-white border-opacity-20"><input name="DRAC_Akhir" class="hud-input-underlined text-warning fw-black text-center py-1" placeholder="0.00" /></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="d-flex flex-column h-100 gap-3">
                        <!-- PREMIUM PROTOCOL ALERT -->
                        <div class="hud-card border-danger border-opacity-40 bg-danger bg-opacity-10 shadow-hud-red p-3 d-flex align-items-center gap-3">
                             <div class="hud-status-led led-red blink"></div>
                             <div>
                                <div class="text-danger-glow fw-900 super-small tracking-widest mb-1"><i class="bi bi-shield-lock-fill me-1"></i>SYSTEM PROTOCOL</div>
                                <p class="text-white font-monospace super-small m-0 opacity-90 fw-bold">VERIFIKASI PARAMETER: AWAL / TENGAH / AKHIR PROSES.</p>
                             </div>
                        </div>

                        <!-- DIGITAL SIGN-OFF PANEL -->
                        <div class="hud-card p-3 bg-black bg-opacity-40 border-white border-opacity-10 shadow-hud-blue">
                            <div class="text-info-glow super-small fw-black mb-3 tracking-widest ps-1"><i class="bi bi-vector-pen me-2"></i>OPERATIONAL SIGN-OFF</div>
                            <div class="d-flex flex-column gap-2">
                                <div class="hud-pill-integrated border-white border-opacity-5">
                                    <label>DIBUAT (OPERATOR)</label>
                                    <input asp-for="CreatedBy" class="hud-input text-primary-glow font-black h-auto py-1" placeholder="ENTER NAME..." />
                                </div>
                                <div class="row g-2">
                                    <div class="col-6">
                                        <div class="hud-pill-integrated border-white border-opacity-5 opacity-50">
                                            <label>CHECKED (LEADER)</label>
                                            <input asp-for="CheckedBy" class="hud-input small" readonly placeholder="---" />
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="hud-pill-integrated border-white border-opacity-5 opacity-50">
                                            <label>APPROVED (FOREMAN)</label>
                                            <input asp-for="ApprovedBy" class="hud-input small" readonly placeholder="---" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- FINAL CONTROL TERMINAL -->
                        <div class="hud-card p-3 flex-grow-1 d-flex flex-column bg-black bg-opacity-40 border-white border-opacity-10 shadow-hud-blue">
                             <div class="text-info-glow super-small fw-black mb-3 tracking-widest ps-1"><i class="bi bi-terminal-fill me-2"></i>FINAL COMMANDS</div>
                             <div class="mt-auto d-flex gap-2">
                                <button type="button" class="btn btn-hud-outline flex-grow-1 py-3 fw-bold small d-flex align-items-center justify-content-center gap-2" style="border-width: 1px;" onclick="location.reload()">
                                    <i class="bi bi-trash3-fill"></i> RESET
                                </button>
                                <button type="submit" class="btn btn-hud-primary flex-grow-3 py-3 fw-900 tracking-widest shadow-glow-primary border-0 rounded-1 d-flex align-items-center justify-content-center gap-2" style="font-size: 1.1rem;">
                                    <i class="bi bi-cloud-arrow-up-fill fs-5"></i> SAVE REPORT
                                </button>
                             </div>
                        </div>
                    </div>
                </div>
            </div>

        </form>
    </div>
</div>

<style>
    :root {
        --hud-primary: #0ea5e9;
        --hud-glow: #38bdf8;
        --hud-dark: #020617;
        --hud-card: rgba(15, 23, 42, 0.85);
        --hud-border: rgba(14, 165, 233, 0.3);
    }

    .production-blueprint { min-height: 100vh; background: var(--hud-dark); color: #f1f5f9; font-family: 'Inter', sans-serif; }
    .hud-header { background: rgba(30, 41, 59, 0.6); border: 1px solid var(--hud-border); border-radius: 12px; backdrop-filter: blur(15px); }
    .hud-logo-v { width: 48px; height: 48px; background: var(--hud-primary); color: white; font-weight: 900; font-size: 26px; display: flex; align-items: center; justify-content: center; border-radius: 10px; box-shadow: 0 0 20px rgba(14, 165, 233, 0.4); }
    
    .hud-pill { background: rgba(30, 41, 59, 0.6); border: 1px solid var(--hud-border); border-radius: 8px; padding: 6px 16px; display: flex; flex-direction: column; transition: all 0.3s; }
    .hud-pill:focus-within { border-color: var(--hud-glow); box-shadow: 0 0 15px rgba(14, 165, 233, 0.3); }
    .hud-pill label { font-size: 0.65rem; font-weight: 800; color: var(--hud-primary); letter-spacing: 1px; margin-bottom: 2px; }
    .hud-input { background: transparent; border: none; color: white; font-size: 0.95rem; padding: 0; outline: none; width: 100%; }

    .hud-card { background: var(--hud-card); border: 1px solid var(--hud-border); border-radius: 10px; overflow: hidden; backdrop-filter: blur(15px); }
    .hud-vertical-label { width: 45px; background: rgba(14, 165, 233, 0.15); border-right: 1px solid var(--hud-border); display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 0.75rem; color: var(--hud-primary); writing-mode: vertical-rl; transform: rotate(180deg); letter-spacing: 2px; white-space: nowrap; }

    .table-hud { border-collapse: separate; border-spacing: 0; }
    .table-hud th { background: rgba(0,0,0,0.3); color: var(--hud-primary); font-size: 0.7rem; font-weight: 800; letter-spacing: 1px; border-bottom: 1px solid var(--hud-border) !important; padding: 12px !important; }
    .table-hud td { padding: 10px !important; border-color: rgba(255,255,255,0.05) !important; vertical-align: middle; }
    .table-bordered-ghost td, .table-bordered-ghost th { border: 1px solid rgba(255,255,255,0.05); }

    .hud-table-input { background: rgba(30, 41, 59, 0.5); border: 1px solid rgba(255,255,255,0.1); border-radius: 4px; color: white; text-align: center; width: 100%; padding: 5px; outline: none; font-size: 0.85rem; }
    .hud-table-input:focus { border-color: var(--hud-primary); background: rgba(14, 165, 233, 0.1); }
    .hud-table-input-min { background: transparent; border: none; border-bottom: 1px dotted rgba(255,255,255,0.3); color: white; text-align: center; width: 100%; outline: none; padding: 2px; font-size: 0.8rem; }

    .reading-input-min { background: transparent; border: none; color: white; text-align: center; width: 100%; outline: none; }
    .hud-check { width: 22px; height: 22px; cursor: pointer; accent-color: var(--hud-primary); }
    .hud-check-min { width: 16px; height: 16px; cursor: pointer; }

    .btn-hud-primary { background: var(--hud-primary); color: white; border: none; border-radius: 6px; }
    .btn-hud-primary:hover { transform: translateY(-3px); box-shadow: 0 10px 25px rgba(14, 165, 233, 0.5); color: white; }
    .btn-hud-outline { background: transparent; border: 2px solid var(--hud-border); color: #94a3b8; border-radius: 6px; }

    .text-primary-glow { color: var(--hud-glow); text-shadow: 0 0 10px rgba(56, 189, 248, 0.4); }
    .shadow-glow-blue { box-shadow: 0 0 30px rgba(14, 165, 233, 0.15); }
    .super-small { font-size: 0.7rem; }
    .letter-spacing-2 { letter-spacing: 2.5px; }

    /* STATUS LED & ANIMATIONS */
    .hud-status-led { width: 10px; height: 10px; border-radius: 50%; display: inline-block; box-shadow: 0 0 10px rgba(255, 255, 255, 0.2); }
    .led-red { background: #ef4444; box-shadow: 0 0 15px rgba(239, 68, 68, 0.6); }
    .blink { animation: hud-blink 1.5s infinite; }
    @@keyframes hud-blink { 
        0%, 100% { opacity: 1; transform: scale(1); } 
        50% { opacity: 0.4; transform: scale(0.85); } 
    }

    .flex-grow-2 { flex-grow: 2; }
    .flex-grow-3 { flex-grow: 3; }

    /* Sticky Headers for tables */
    .sticky-top { position: sticky; top: 0; z-index: 10; }

    @@media print {
        .production-blueprint { background: white !important; color: black !important; }
        .hud-header, .hud-pill, .hud-card { border: 1px solid black !important; background: white !important; color: black !important; }
        .text-white, .text-primary-glow { color: black !important; }
        .no-print { display: none !important; }
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/html5-qrcode"></script>
    <script>
        let html5QrCode;

        async function openScanner(targetId) {
            Swal.fire({
                title: 'SCANNING MATERIAL LOT',
                html: `
                    <div id="reader-container" style="width: 100%; min-height: 250px; background: #000; border-radius: 8px; overflow: hidden; border: 2px solid #0ea5e9;">
                        <div id="reader"></div>
                    </div>
                    <div class="mt-3 text-info-glow small fw-bold tracking-widest">POSITION BARCODE WITHIN FRAME</div>
                `,
                background: '#020617',
                color: '#0ea5e9',
                showConfirmButton: false,
                showCloseButton: true,
                width: '90%',
                didOpen: () => {
                    const config = { fps: 10, qrbox: { width: 250, height: 150 } };
                    html5QrCode = new Html5Qrcode("reader");
                    
                    html5QrCode.start(
                        { facingMode: "environment" }, 
                        config,
                        (decodedText) => {
                            // On Success
                            document.getElementById(targetId).value = decodedText;
                            document.getElementById(targetId).parentElement.classList.add('glow-success');
                            setTimeout(() => document.getElementById(targetId).parentElement.classList.remove('glow-success'), 2000);
                            
                            html5QrCode.stop().then(() => {
                                Swal.close();
                                // Optional haptic feedback
                                if (window.navigator.vibrate) window.navigator.vibrate(100);
                            });
                        },
                        (errorMessage) => { /* scanning... */ }
                    ).catch(err => {
                        console.error(err);
                        document.getElementById('reader').innerHTML = `<div class="p-4 text-danger small">CAMERA ERROR: ${err}</div>`;
                    });
                },
                willClose: () => {
                    if (html5QrCode && html5QrCode.isScanning) {
                        html5QrCode.stop();
                    }
                }
            });
        }

        // --- SPS SYNC LOGIC ---
        async function startSpsScanner() {
            Swal.fire({
                title: '<div class="text-primary-glow font-monospace small">SPS OPTICAL SCANNER</div>',
                html: `
                    <div id="sps-reader-container" style="width: 100%; min-height: 250px; background: #000; border-radius: 8px; overflow: hidden; border: 2px solid #0ea5e9;">
                        <div id="sps-reader"></div>
                    </div>
                `,
                background: '#020617',
                showConfirmButton: false,
                showCloseButton: true,
                didOpen: () => {
                    const scanQrCode = new Html5Qrcode("sps-reader");
                    const config = { fps: 10, qrbox: { width: 250, height: 250 } };
                    scanQrCode.start({ facingMode: "environment" }, config, async (decodedText) => {
                        await scanQrCode.stop();
                        Swal.close();
                        fetchSpsByItem(decodedText);
                    });
                }
            });
        }

        async function fetchSpsByItem(code) {
            Swal.fire({
                title: 'SEARCHING PROTOCOL...',
                text: `VALIDATING: ${code.trim().toUpperCase()}`,
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); }
            });

            try {
                const res = await fetch(`/ProductionReport/GetSpsByItem?itemCode=${encodeURIComponent(code.trim())}`);
                if (!res.ok) throw new Error('PROTOCOL NOT FOUND');
                const data = await res.json();
                Swal.close();
                applySpsToForm(data);
            } catch (e) {
                Swal.fire({
                    title: 'SYNC ERROR',
                    text: `Kode '${code}' tidak ditemukan di Database SPS Masterlist!`,
                    icon: 'warning',
                    confirmButtonColor: '#0ea5e9'
                });
            }
        }

        document.getElementById('spsSelector').addEventListener('change', async function() {
            const id = this.value;
            if (!id) return;
            try {
                const res = await fetch(`/ProductionReport/GetSpsById/${id}`);
                const data = await res.json();
                applySpsToForm(data);
            } catch (e) {
                console.error(e);
            }
        });

        function applySpsToForm(sps) {
            // Header Info
            document.getElementById('DocNo').value = sps.documentNumber || '---';
            document.getElementById('RevNo').value = sps.revisionNumber || '0';
            document.getElementById('HoseType').value = sps.hoseType || '';
            document.getElementById('CustomerName').value = sps.customerName || '';
            
            // Materials
            document.getElementById('InnerMaterial').value = sps.innerMaterial || '';
            document.getElementById('OuterMaterial').value = sps.outerMaterial || '';
            document.getElementById('Yarn').value = sps.yarnType || '';

            // Update Table Specs
            const specMappings = {
                'HeadTempInner': sps.headTemp + ' ± 5',
                'Cylinder1TempInner': sps.cylinder1Temp + ' ± 5',
                'Cylinder2TempInner': sps.cylinder2Temp + ' ± 5',
                'Cylinder3TempInner': sps.cylinder3Temp + ' ± 5',
                'ScrewTempInner': sps.screwTemp + ' ± 5',
                'ScrewSpeedInner': sps.screwSpeed + ' ± 2',
                'FeedRollRatioInner': 'Max ' + sps.feedRollRatio,
                'PressureInner': 'Max ' + sps.pressure,
                
                'HeadTempOuter': sps.headTemp + ' ± 5',
                'Cylinder1TempOuter': sps.cylinder1Temp + ' ± 5',
                'Cylinder2TempOuter': sps.cylinder2Temp + ' ± 5',
                'Cylinder3TempOuter': sps.cylinder3Temp + ' ± 5',
                'ScrewTempOuter': sps.screwTemp + ' ± 5',
                'ScrewSpeedOuter': sps.screwSpeed + ' ± 2',
                'FeedRollRatioOuter': 'Max ' + sps.feedRollRatio,
                'PressureOuter': 'Max ' + sps.pressure,
                
                'SpiralSpeed': sps.spiralSpeed + ' ± 20',
                'SpiralPitchSetting': sps.spiralPitch + ' ± 5',
                'SpiralPitchDisplay': sps.spiralPitchDisplay + ' ± 5',
                
                'PresetValue': sps.presetValve + ' ± 0.5',
                'ControlValue': sps.controlValue,
                'HoseSpeed': sps.hoseSpeed,
                'TakeupConveyorSpeed': sps.takeupConveyorSpeed,
                'CoolConveyorSpeed': sps.coolConveyorSpeed,
                'ConveyorRatio': sps.conveyorRatio,
                'UnsmoothSurface': sps.unsmoothSurface,
                'ChillerWaterTemp': sps.chillerWaterTemp,
                'CaterpillarGap': sps.caterpillarGap,

                // Dies Measurements
                'NippleDie': sps.innerDie + ' ± 0.1',
                'TubeDie': sps.tubeDie + ' ± 0.1',
                'MiddleDie': sps.middleDie + ' ± 0.1',
                'CoverDie': sps.coverDie + ' ± 0.1',
                'SpacerDie': sps.spacerDie + ' ± 0.1',
                'ToleranceDie': sps.toleranceDie + ' ± 0.1'
            };

            for (const [key, val] of Object.entries(specMappings)) {
                const el = document.getElementById('spec_' + key);
                if (el) {
                    el.innerText = val;
                    el.classList.add('blink-once');
                }
            }

            document.getElementById('syncStatus').innerHTML = `<i class="bi bi-shield-fill-check text-success me-1"></i>SYNCED: [${sps.itemList}] ${sps.hoseType}`;
            document.getElementById('syncStatus').parentElement.classList.add('border-success');
            
            Swal.fire({
                title: 'SPS SYNC SUCCESS',
                text: 'Protokol ' + sps.hoseType + ' berhasil dimuat!',
                icon: 'success',
                toast: true,
                position: 'top-end',
                timer: 3000,
                showConfirmButton: false
            });
        }
    </script>
    <style>
        .glow-success { border-color: #10b981 !important; box-shadow: 0 0 20px rgba(16, 185, 129, 0.4) !important; }
        #reader__scan_region video { width: 100% !important; object-fit: cover !important; }
        #reader__dashboard_section_csr button { background: #0ea5e9; color: white; border: none; padding: 5px 15px; border-radius: 4px; margin: 5px; font-weight: 800; font-size: 0.7rem; text-transform: uppercase; }
        .swal2-close { color: #ef4444 !important; }
    </style>
}
