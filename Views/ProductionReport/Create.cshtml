@model VelastoProductionSystem.Models.ProductionReport

@{
    ViewData["Title"] = "NOW I'M PRODUCE";
}

<div class="production-dashboard fade-in">
    <div class="container-fluid py-3 px-0">
        
        <!-- COMPACT HEADER ACTION BAR -->
        <div class="d-flex justify-content-between align-items-center mb-3 no-print header-glass p-2 px-3">
            <div class="d-flex align-items-center">
                <div class="brand-hexagon me-2">
                    <i class="bi bi-hexagon-fill text-primary shadow-glow"></i>
                </div>
                <div>
                    <h5 class="text-white fw-900 mb-0 tracking-tighter">LINE CONTROL <span class="text-primary">F1</span></h5>
                    <div class="d-flex align-items-center" style="margin-top: -4px;">
                        <span class="status-indicator-min pulse-blue me-2"></span>
                        <span class="text-white-50 super-small fw-bold letter-spacing-1">SYSTEM ONLINE</span>
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-primary-glass btn-sm px-3" onclick="startScanner()">
                    <i class="bi bi-qr-code-scan me-1"></i> SCAN ITEM
                </button>
                <a asp-action="Index" class="btn btn-outline-glass btn-sm px-3">BACK</a>
            </div>
        </div>

        <!-- SCANNER MODAL -->
        <div class="modal fade no-print" id="scannerModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content scanner-modal-glass border-0">
                    <div class="modal-header border-bottom border-primary border-opacity-25 py-2 px-3">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-qr-code-scan text-primary me-2 fs-5"></i>
                            <h6 class="modal-title text-white fw-bold mb-0">HUD SCANNER</h6>
                        </div>
                        <button type="button" class="btn-close btn-close-white scale-75" data-bs-dismiss="modal" onclick="stopScanner()"></button>
                    </div>
                    <div class="modal-body p-0 position-relative bg-black overflow-hidden" id="scannerBody" style="min-height: 250px; max-height: 60vh; width: 100%; transition: height 0.3s ease;">
                        <video id="video" style="width: 100%; height: 100%; object-fit: contain;"></video>
                        <canvas id="canvas" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 10;"></canvas>
                        <div class="scan-laser"></div>
                    </div>
                    <div class="modal-footer border-top border-primary border-opacity-25 py-2 px-3">
                        <div class="d-flex w-100 justify-content-between align-items-center">
                            <span class="text-white-50 extra-small tracking-widest"><i class="bi bi-broadcast pulse-blue me-1"></i> ACTIVE</span>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-primary-glass btn-sm px-3 py-1" onclick="switchCamera()">
                                    <i class="bi bi-camera-rotate small"></i>
                                </button>
                                <button type="button" class="btn btn-danger-glass btn-sm px-3 py-1" data-bs-dismiss="modal" onclick="stopScanner()">
                                    EXIT
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <form asp-action="Create" id="mainForm">
            <div class="main-glass-card shadow-2xl">
                
                <!-- TOP HEADER: TITLE & COMPACT DOC INFO -->
                <div class="row g-0 border-bottom border-primary border-opacity-25">
                    <div class="col-lg-9 p-4 d-flex align-items-center justify-content-center bg-hud-navy">
                        <div class="text-center">
                            <h2 class="fw-900 text-white mb-1 text-glow" style="font-size: 2rem;">NOW I'M PRODUCE :</h2>
                            <div class="d-flex align-items-center justify-content-center gap-2">
                                <span class="text-white-50 fw-bold extra-small tracking-widest">PT. VELASTO INDONESIA</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 p-0 border-start border-primary border-opacity-25 bg-hud-navy">
                        <table class="table table-dark table-sm m-0 extra-small doc-header-table border-0 h-100">
                            <tr>
                                <td class="text-white-50 ps-2 py-0 border-0 border-bottom border-primary border-opacity-10 align-middle header-label" style="width: 130px;">No. Dokumen</td>
                                <td class="pe-2 py-0 border-0 border-bottom border-primary border-opacity-10 align-middle">
                                    <div class="d-flex align-items-center">
                                        <span class="text-primary fw-bold me-1">:</span>
                                        <input asp-for="DocumentNumber" id="DocumentNumber" class="header-input" value="" placeholder="VI-SOP-PROD-131" />
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td class="text-white-50 ps-2 py-0 border-0 border-bottom border-primary border-opacity-10 align-middle header-label">No. Revisi</td>
                                <td class="pe-2 py-0 border-0 border-bottom border-primary border-opacity-10 align-middle">
                                    <div class="d-flex align-items-center">
                                        <span class="text-primary fw-bold me-1">:</span>
                                        <input asp-for="RevisionNumber" id="RevisionNumber" type="text" class="header-input" value="" placeholder="0" />
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td class="text-white-50 ps-2 py-0 border-0 align-middle header-label">Effective Date</td>
                                <td class="pe-2 py-0 border-0 align-middle">
                                    <div class="d-flex align-items-center">
                                        <span class="text-primary fw-bold me-1">:</span>
                                        <input name="EffectiveDate" id="EffectiveDate" class="header-input" value="" placeholder="01/01/2024" />
                                    </div>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- MAIN WORKSPACE -->
                <div class="row g-0 border border-primary border-opacity-20 d-flex flex-wrap flex-md-nowrap">
                    
                    <!-- LEFT COLUMN: PRODUCT SPECS -->
                    <div class="col-md-4 p-3 border-end border-primary border-opacity-20 bg-hud-navy">
                        <div class="d-flex flex-column h-100 gap-3">
                            <div class="spec-group">
                                <div class="spec-label mb-1"><i class="bi bi-upc-scan me-2"></i>1. HOSE TYPE</div>
                                <div class="spec-card">
                                    <input asp-for="HoseType" class="spec-input fw-bold" placeholder="SCAN BARCODE..." />
                                </div>
                            </div>
                            <div class="spec-group">
                                <div class="spec-label mb-1"><i class="bi bi-diagram-3 me-2"></i>2. CLASS</div>
                                <div class="spec-card">
                                    <input name="Class" class="spec-input" value="-" />
                                </div>
                            </div>
                            <div class="spec-group">
                                <div class="spec-label mb-1"><i class="bi bi-rulers me-2"></i>3. DIMENSION</div>
                                <div class="spec-card">
                                    <input asp-for="Dimension" class="spec-input highlight" placeholder="---" />
                                </div>
                            </div>
                            <div class="spec-group">
                                <div class="spec-label mb-1"><i class="bi bi-puzzle me-2"></i>4. YARN</div>
                                <div class="spec-card">
                                    <input asp-for="Yarn" id="Yarn" class="spec-input" placeholder="---" />
                                </div>
                            </div>
                            <div class="flex-grow-1"></div>
                        </div>
                    </div>

                    <!-- CENTER COLUMN: TIME & SCHEDULING -->
                    <div class="col-md-5 p-3 border-end border-primary border-opacity-20 bg-hud-navy">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="section-tag">TIME CONTROL</div>
                            <div class="hud-date-box">
                                <i class="bi bi-calendar3 me-2 text-primary"></i>
                                <input asp-for="ProductionDate" type="date" class="bg-transparent border-0 text-white extra-small fw-bold" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                            </div>
                        </div>

                        <!-- TIME GRIDS -->
                        <div class="row g-3">
                            <div class="col-12">
                                <div class="glass-table-container">
                                    <div class="table-header-min">DANDORI <span class="ms-1 text-white-50 opacity-50">| SETUP MONITORING</span></div>
                                    <table class="table table-dark table-borderless m-0 text-center extra-small align-middle">
                                        <thead class="text-white-50 border-bottom border-primary border-opacity-20">
                                            <tr>
                                                <th rowspan="2" width="30%" class="align-middle border-end border-white border-opacity-10">PHASE</th>
                                                <th colspan="2" class="py-1 border-bottom border-white border-opacity-10">WAKTU</th>
                                            </tr>
                                            <tr>
                                                <th class="py-1">AWAL</th>
                                                <th class="py-1">AKHIR</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr class="border-bottom border-white border-opacity-5">
                                                <td class="text-start ps-3 py-2 fw-bold text-white-50 border-end border-white border-opacity-10">START PROD.</td>
                                                <td class="py-2"><input asp-for="DandoriStartTime" type="time" class="time-hud-input" /></td>
                                                <td class="py-2"><input asp-for="DandoriEndTime" type="time" class="time-hud-input" /></td>
                                            </tr>
                                            <tr>
                                                <td class="text-start ps-3 py-2 fw-bold text-white-50 border-end border-white border-opacity-10">AKHIR PROD.</td>
                                                <td class="py-2"><input asp-for="DandoriEndStartTime" type="time" class="time-hud-input" /></td>
                                                <td class="py-2"><input asp-for="DandoriEndEndTime" type="time" class="time-hud-input" /></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="glass-table-container">
                                    <div class="table-header-min secondary">PRODUCTION <span class="ms-1 text-white-50 opacity-50">| ACTUAL RUN</span></div>
                                    <table class="table table-dark table-borderless m-0 text-center extra-small align-middle">
                                        <thead class="text-white-50 border-bottom border-primary border-opacity-20">
                                            <tr>
                                                <th colspan="2" class="py-1 border-bottom border-white border-opacity-10">WAKTU</th>
                                            </tr>
                                            <tr>
                                                <th class="py-1">AWAL</th>
                                                <th class="py-1">AKHIR</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td class="p-2 border-end border-white border-opacity-5"><input asp-for="ProductionStartTime" type="time" class="time-hud-input highlight fs-6 p-2" /></td>
                                                <td class="p-2"><input asp-for="ProductionEndTime" type="time" class="time-hud-input highlight fs-6 p-2" /></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- RIGHT COLUMN: TARGETS -->
                    <div class="col-md-3 p-2 border-start border-primary border-opacity-20 bg-hud-navy overflow-hidden">
                        <div class="target-card mb-3">
                            <div class="target-header">CHS 2 L DANDORI TARGET</div>
                            <table class="table table-dark table-xs m-0 text-center border-white border-opacity-10">
                                <thead class="text-white-50">
                                    <tr class="super-small">
                                        <th width="30%">TARGET TIME</th>
                                        <th>DIES</th>
                                        <th>MATERIAL</th>
                                        <th>BENANG</th>
                                    </tr>
                                </thead>
                                <tbody class="extra-small">
                                    <tr><td>20 Min</td><td>O</td><td>-</td><td>-</td></tr>
                                    <tr><td>40 Min</td><td>O</td><td>O</td><td>-</td></tr>
                                    <tr><td>55 Min</td><td>O</td><td>O</td><td>O</td></tr>
                                </tbody>
                            </table>
                        </div>
                        <div class="target-card">
                            <div class="target-header secondary">CHS 3 L DANDORI TARGET</div>
                            <table class="table table-dark table-xs m-0 text-center border-white border-opacity-10">
                                <thead class="text-white-50">
                                    <tr class="super-small">
                                        <th width="30%">TARGET TIME</th>
                                        <th>DIES</th>
                                        <th>MATERIAL</th>
                                        <th>BENANG</th>
                                    </tr>
                                </thead>
                                <tbody class="extra-small">
                                    <tr><td>30 Min</td><td>O</td><td>-</td><td>-</td></tr>
                                    <tr><td>45 Min</td><td>O</td><td>O</td><td>-</td></tr>
                                    <tr><td>60 Min</td><td>O</td><td>O</td><td>O</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- BOTTOM ROW: MATERIALS & SPV -->
                <div class="row g-0 border border-top-0 border-primary border-opacity-20 bg-hud-navy">
                    <div class="col-lg-10 p-4">
                        <div class="section-tag mb-4">MATERIAL VERIFICATION</div>
                        
                        <div class="material-grid">
                            <!-- INNER -->
                            <div class="material-row-hud mb-1">
                                <div class="mat-item-label">1) Inner :</div>
                                <div class="mat-inputs-group">
                                    <div class="mat-field-wrap">
                                        <input asp-for="InnerMaterial" class="mat-line-input highlight" placeholder=".........." />
                                    </div>
                                    <div class="mat-field-wrap">
                                        <span class="mat-inline-label">No.Lot :</span>
                                        <input asp-for="InnerMaterialLotNo" class="mat-line-input" placeholder=".........." />
                                    </div>
                                    <div class="mat-field-wrap mini">
                                        <span class="mat-inline-label">SG :</span>
                                        <input asp-for="InnerMaterialSG" class="mat-line-input text-center" type="text" value="" placeholder=".........." />
                                    </div>
                                </div>
                            </div>
                            <!-- MIDDLE -->
                            <div class="material-row-hud mb-1">
                                <div class="mat-item-label">2) Middle :</div>
                                <div class="mat-inputs-group">
                                    <div class="mat-field-wrap">
                                        <input name="MaterialMiddleCode" class="mat-line-input" placeholder=".........." />
                                    </div>
                                    <div class="mat-field-wrap">
                                        <span class="mat-inline-label">No.Lot :</span>
                                        <input name="MaterialMiddleLot" class="mat-line-input" placeholder=".........." />
                                    </div>
                                    <div class="mat-field-wrap mini">
                                        <span class="mat-inline-label">SG :</span>
                                        <input name="MaterialMiddleSG" class="mat-line-input text-center" type="text" value="" placeholder=".........." />
                                    </div>
                                </div>
                            </div>
                            <!-- OUTER -->
                            <div class="material-row-hud">
                                <div class="mat-item-label">3) Outer :</div>
                                <div class="mat-inputs-group">
                                    <div class="mat-field-wrap">
                                        <input asp-for="OuterMaterial" class="mat-line-input highlight" placeholder=".........." />
                                    </div>
                                    <div class="mat-field-wrap">
                                        <span class="mat-inline-label">No.Lot :</span>
                                        <input asp-for="OuterMaterialLotNo" class="mat-line-input" placeholder=".........." />
                                    </div>
                                    <div class="mat-field-wrap mini">
                                        <span class="mat-inline-label">SG :</span>
                                        <input asp-for="OuterMaterialSG" class="mat-line-input text-center" type="text" value="" placeholder=".........." />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- SPV SIGNATURE -->
                    <div class="col-lg-2 border-start border-primary border-opacity-20 d-flex flex-column align-items-center justify-content-center p-3 bg-hud-navy">
                        <div class="section-tag mb-3 text-center w-100">SPV CHECK</div>
                        <div class="d-flex flex-column gap-2">
                            <!-- Hidden Fields for Verification -->
                            <input type="hidden" id="VerifyInner" name="VerifyInner" value="false" />
                            <input type="hidden" id="VerifyMiddle" name="VerifyMiddle" value="false" />
                            <input type="hidden" id="VerifyOuter" name="VerifyOuter" value="false" />

                            <div class="glass-sig-box cursor-pointer" id="spv-1" onclick="verifySPV(this, 'Inner')">
                                <i class="bi bi-shield-slash text-white-50 opacity-20"></i>
                            </div>
                            <div class="glass-sig-box cursor-pointer" id="spv-2" onclick="verifySPV(this, 'Middle')">
                                <i class="bi bi-shield-slash text-white-50 opacity-20"></i>
                            </div>
                            <div class="glass-sig-box cursor-pointer" id="spv-3" onclick="verifySPV(this, 'Outer')">
                                <i class="bi bi-shield-slash text-white-50 opacity-20"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- HUD ALERT -->
                <div class="p-2 bg-danger bg-opacity-10 border-top border-danger border-opacity-20">
                    <div class="container-fluid text-start">
                        <span class="text-white-50 hud-note-text fw-bold tracking-widest">NOTE:</span>
                        <span class="text-danger hud-note-text fw-bold tracking-widest ms-2">JANGAN MENJALANKAN PRODUKSI SEBELUM CHECKSHEET INI DI CHECK OLEH SUPERVISOR.</span>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-3 pb-4 no-print">
                <button type="submit" class="btn btn-success-start btn-md px-5 rounded-0 fw-bold shadow-glow-blue">
                    <i class="bi bi-play-fill me-1"></i> START PRODUCTION
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    :root {
        --velasto-blue: #2563eb;
        --neon-blue: #00d2ff;
        --neon-glow: 0 0 10px rgba(0, 210, 255, 0.5);
        --hud-navy: rgba(15, 23, 42, 0.85);
    }
    
    .production-dashboard { background: #0f172a; min-height: 100vh; padding-bottom: 50px; }
    .header-glass { background: var(--hud-navy); backdrop-filter: blur(10px); border: 1px solid rgba(59, 130, 246, 0.2); }
    
    .section-tag { background: rgba(59, 130, 246, 0.15); border-left: 3px solid var(--neon-blue); color: #60a5fa; font-size: 10px; font-weight: 900; padding: 4px 10px; letter-spacing: 2px; text-transform: uppercase; display: inline-block; }
    
    .bg-hud-navy { background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(8px); }
    .spec-card { background: rgba(30, 41, 59, 0.3); border: 1px solid rgba(59, 130, 246, 0.2); border-left: 4px solid var(--neon-blue); padding: 8px 15px; display: flex; flex-direction: column; transition: all 0.3s; position: relative; }
    .spec-card::after { content: ''; position: absolute; left: 0; top: 0; width: 3px; height: 100%; background: var(--neon-blue); opacity: 0.5; }
    .spec-card:focus-within { border-color: var(--neon-blue); box-shadow: 0 0 15px rgba(59, 130, 246, 0.2); }
    .spec-label { color: #60a5fa; font-size: 11px; font-weight: 900; letter-spacing: 2px; text-transform: uppercase; }
    .spec-input { background: transparent; border: none; color: white; font-size: 18px; font-weight: 700; width: 100%; outline: none; }
    .spec-input.highlight { color: #60a5fa; text-shadow: var(--neon-glow); }
    .super-small { font-size: 8px !important; }
    .hud-note-text { font-size: 15px !important; }

    .hud-date-box { background: rgba(0,0,0,0.3); border: 1px solid rgba(59, 130, 246, 0.2); padding: 2px 10px; display: flex; align-items: center; border-bottom: 2px dotted rgba(59, 130, 246, 0.5); }

    .material-row-hud { display: flex; align-items: center; background: transparent; padding: 4px 0; gap: 10px; border-bottom: 1px solid rgba(255,255,255,0.03); }
    .mat-item-label { color: #e2e8f0; font-size: 15px; font-weight: 700; width: 130px; white-space: nowrap; }
    .mat-inputs-group { display: flex; flex-grow: 1; gap: 20px; }
    .mat-field-wrap { display: flex; align-items: center; flex-grow: 1; gap: 10px; }
    .mat-field-wrap.mini { flex-grow: 0; width: 140px; }
    .mat-inline-label { color: #94a3b8; font-size: 15px; font-weight: 800; white-space: nowrap; }
    .mat-line-input { background: transparent; border: none; border-bottom: 2px dotted rgba(59, 130, 246, 0.4); color: white; font-size: 15px; font-weight: 700; width: 100%; outline: none; padding-bottom: 2px; }
    .mat-line-input:focus { border-bottom-style: solid; border-bottom-color: var(--neon-blue); }
    .mat-line-input.highlight { color: #60a5fa; }

    .glass-sig-box { width: 100px; height: 50px; border: 1px solid rgba(59, 130, 246, 0.2); background: rgba(30, 41, 59, 0.4); display: flex; align-items: center; justify-content: center; transition: all 0.3s; }
    .glass-sig-box.active { border-color: var(--neon-blue); background: rgba(59, 130, 246, 0.15); box-shadow: 0 0 20px rgba(59, 130, 246, 0.4); }
    .glass-sig-box:hover { border-color: #60a5fa; background: rgba(59, 130, 246, 0.05); }
    .cursor-pointer { cursor: pointer; }

    /* Legacy Support */
    .cyber-line-input { width: 100%; background: transparent; border: none; border-bottom: 1px dotted rgba(59, 130, 246, 0.3); color: white !important; font-size: 13px; font-weight: 600; padding: 4px 0; outline: none !important; }
    .cyber-line-input[readonly] { color: #94a3b8 !important; }
    
    .time-hud-input { background: rgba(30, 41, 59, 0.5); border: 1px solid rgba(59, 130, 246, 0.3); color: #60a5fa; font-size: 13px; font-weight: bold; width: 100%; border-radius: 0; padding: 4px; outline: none; }
    .time-hud-input.highlight { color: #fbbf24; border-color: rgba(251, 191, 36, 0.5); background: rgba(251, 191, 36, 0.05); }

    /* Sharp Grid HUD */
    .glass-table-container { border: 1px solid rgba(59, 130, 246, 0.2); border-radius: 0px; background: rgba(15, 23, 42, 0.4); }
    .table-header-min { background: rgba(37, 99, 235, 0.3); color: #fff; font-size: 10px; font-weight: 900; text-align: center; padding: 5px; letter-spacing: 1px; border-bottom: 1px solid rgba(59, 130, 246, 0.3); }
    .table-header-min.secondary { background: rgba(71, 85, 105, 0.3); }

    /* Material Rows Sharp */
    .material-row { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
    .mat-label { width: 220px; color: #e2e8f0; }
    .mat-code-input { background: transparent; border: none; color: #60a5fa; width: 80px; font-weight: 800; font-size: 11px; outline: none; }
    .mat-inputs { display: flex; flex-grow: 1; gap: 15px; }
    .mat-input-wrap { display: flex; align-items: center; flex-grow: 1; }
    .mat-line-input { width: 100%; background: transparent; border: none; border-bottom: 1px dotted #484f58; color: white; font-size: 12px; font-weight: 600; padding: 2px 5px; outline: none; }
    .mat-line-input.mini { width: 60px; flex-grow: 0; }
    .header-input { background: transparent; border: none; color: #60a5fa; font-weight: 800; font-size: 15px; width: 100%; outline: none; }
    .header-input:focus { background: rgba(59, 130, 246, 0.1); }
    .header-label { font-size: 15px; font-weight: 600; white-space: nowrap; }

    /* Signature Sharp */
    .glass-sig-box { width: 60px; height: 40px; border: 1px solid #30363d; background: #0d1117; display: flex; align-items: center; justify-content: center; }
    .glass-sig-box.active { border-color: #3b82f6; box-shadow: 0 0 10px rgba(59, 130, 246, 0.2); }

    /* Buttons Sharp */
    .btn-primary-glass { background: #2563eb; border: none; border-radius: 0; color: white; transition: all 0.2s; }
    .btn-success-start { background: #059669; border: none; color: white; transition: all 0.2s; }
    .btn-success-start:hover { background: #10b981; box-shadow: 0 0 20px rgba(16, 185, 129, 0.3); }
    .rounded-0 { border-radius: 0px !important; }

    .pulse-blue { width: 6px; height: 6px; background: #3b82f6; border-radius: 50%; display: inline-block; animation: pulse 2s infinite; }
    @@keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.3; } 100% { opacity: 1; } }

    /* Tablet Responsive Sharp */
    @@media (max-width: 992px) {
        .main-content { padding: 5px !important; }
        .row.g-0 { border-bottom: 1px solid rgba(255,255,255,0.05); }
    }
    
    .target-card { background: rgba(30, 41, 59, 0.4); border: 1px solid rgba(59, 130, 246, 0.1); padding: 5px; }
    .target-header { background: #1e293b; color: #60a5fa; font-size: 9px; font-weight: 800; text-align: center; padding: 2px; border-bottom: 1px solid rgba(59, 130, 246, 0.2); }
    .table-xs th, .table-xs td { padding: 2px 4px !important; font-size: 9px !important; }

    /* Scanner Enhanced HUD Style in Popup */
    .scanner-modal-glass { 
        background: rgba(10, 14, 23, 0.9) !important; 
        backdrop-filter: blur(25px); 
        border: 1px solid rgba(0, 102, 255, 0.3); 
        border-radius: 0;
        box-shadow: 0 0 50px rgba(0,0,0,0.8);
    }
    
    .hud-scanner-overlay { 
        position: relative; 
        background: #000; 
        width: 100%; 
        aspect-ratio: 4/3;
        overflow: hidden; 
        margin: 0 auto; 
    }
    
    #reader { width: 100% !important; border: none !important; }
    #reader video { object-fit: cover !important; width: 100% !important; height: auto !important; }
    
    /* Dynamic Scanning Laser */
    .scan-laser {
        position: absolute;
        top: 0;
        left: 10%;
        width: 80%;
        height: 2px;
        background: linear-gradient(to right, transparent, var(--neon-blue), #fff, var(--neon-blue), transparent);
        box-shadow: 0 0 10px var(--neon-blue);
        z-index: 10;
        animation: scanLines 2s ease-in-out infinite;
    }

    @@keyframes scanLines {
        0% { top: 5%; opacity: 0; }
        15% { opacity: 1; }
        85% { opacity: 1; }
        100% { top: 95%; opacity: 0; }
    }

    .hud-scanner-overlay::after {
        content: '';
        position: absolute;
        inset: 0;
        background-image: 
            linear-gradient(rgba(0, 102, 255, 0.08) 1px, transparent 1px),
            linear-gradient(90deg, rgba(0, 102, 255, 0.08) 1px, transparent 1px);
        background-size: 40px 40px;
        z-index: 5;
        pointer-events: none;
    }
</style>

@section Scripts {
    <script src="https://unpkg.com/@@zxing/library@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const hints = new Map();
        const formats = [
            ZXing.BarcodeFormat.QR_CODE,
            ZXing.BarcodeFormat.CODE_128,
            ZXing.BarcodeFormat.CODE_39,
            ZXing.BarcodeFormat.EAN_13,
            ZXing.BarcodeFormat.EAN_8,
            ZXing.BarcodeFormat.ITF,
            ZXing.BarcodeFormat.DATA_MATRIX,
            ZXing.BarcodeFormat.UPC_A,
            ZXing.BarcodeFormat.UPC_E
        ];
        hints.set(ZXing.DecodeHintType.POSSIBLE_FORMATS, formats);
        hints.set(ZXing.DecodeHintType.TRY_HARDER, true);
        hints.set(ZXing.DecodeHintType.ASSUME_GS1_CODE_128, true);
        
        const codeReader = new ZXing.BrowserMultiFormatReader(hints);
        let selectedDeviceId;
        let videoDevices = [];
        let currentDeviceIndex = 0;
        let isProcessing = false;

        function startScanner() {
            isProcessing = false;
            const modalEl = document.getElementById('scannerModal');
            const modal = new bootstrap.Modal(modalEl);
            modal.show();
            
            initScanner();
        }

        async function initScanner() {
            try {
                videoDevices = await codeReader.listVideoInputDevices();
                if (videoDevices.length === 0) return;

                // Initial selection: try to find rear camera
                if (!selectedDeviceId) {
                    const rearCamera = videoDevices.find(device => 
                        device.label.toLowerCase().includes('back') || 
                        device.label.toLowerCase().includes('rear') ||
                        device.label.toLowerCase().includes('environment')
                    );
                    if (rearCamera) {
                        selectedDeviceId = rearCamera.deviceId;
                        currentDeviceIndex = videoDevices.indexOf(rearCamera);
                    } else {
                        selectedDeviceId = videoDevices[0].deviceId;
                        currentDeviceIndex = 0;
                    }
                }

                const video = document.getElementById('video');
                
                video.onloadedmetadata = () => {
                    const body = document.getElementById('scannerBody');
                    if (video.videoWidth > 0) {
                        const ratio = video.videoHeight / video.videoWidth;
                        const targetHeight = body.clientWidth * ratio;
                        // Limit height to 60% of viewport to prevent tablet overflow
                        body.style.height = Math.min(targetHeight, window.innerHeight * 0.6) + 'px';
                    }
                };

                // ULTRA STRENGTH CONSTRAINTS
                const constraints = {
                    video: {
                        deviceId: selectedDeviceId ? { exact: selectedDeviceId } : undefined,
                        width: { ideal: 1920 },
                        height: { ideal: 1080 },
                        facingMode: { ideal: "environment" },
                        frameRate: { ideal: 60, min: 30 },
                        advanced: [
                            { focusMode: "continuous" },
                            { exposureMode: "continuous" },
                            { whiteBalanceMode: "continuous" }
                        ]
                    }
                };

                codeReader.decodeFromConstraints(constraints, 'video', (result, err) => {
                    if (isProcessing) return;

                    const canvas = document.getElementById('canvas');
                    const ctx = canvas.getContext('2d');
                    
                    if (video.videoWidth > 0 && (canvas.width !== video.videoWidth || canvas.height !== video.videoHeight)) {
                        canvas.width = video.videoWidth;
                        canvas.height = video.videoHeight;
                    }

                    ctx.clearRect(0, 0, canvas.width, canvas.height);

                    if (result) {
                        drawResultPoints(result.resultPoints, ctx);
                        if (result.text && !isProcessing) {
                            isProcessing = true;
                            // Visual Flash effect
                            video.style.transition = 'filter 0.3s';
                            video.style.filter = 'brightness(5) saturate(0)';
                            setTimeout(() => {
                                video.style.filter = '';
                                onScanSuccess(result.text);
                            }, 400);
                        }
                    }
                });
            } catch (err) {
                console.error(err);
            }
        }

        function drawResultPoints(points, ctx) {
            if (!points || points.length === 0) return;
            
            ctx.strokeStyle = '#00d2ff';
            ctx.fillStyle = 'rgba(0, 102, 255, 0.2)';
            ctx.lineWidth = 6;
            ctx.lineJoin = 'round';
            
            ctx.beginPath();
            
            // If barcode (usually 2 points), draw a thick highlight bar
            if (points.length === 2) {
                const p1 = points[0];
                const p2 = points[1];
                const height = 40; // width of the highlight
                ctx.moveTo(p1.x, p1.y - height/2);
                ctx.lineTo(p2.x, p2.y - height/2);
                ctx.lineTo(p2.x, p2.y + height/2);
                ctx.lineTo(p1.x, p1.y + height/2);
            } else {
                // If QR code or more (usually 3-4 points)
                ctx.moveTo(points[0].x, points[0].y);
                for (let i = 1; i < points.length; i++) {
                    ctx.lineTo(points[i].x, points[i].y);
                }
            }
            
            ctx.closePath();
            ctx.fill();
            
            // Outer Glow
            ctx.shadowBlur = 20;
            ctx.shadowColor = '#00d2ff';
            ctx.stroke();
            ctx.shadowBlur = 0;
        }

        function switchCamera() {
            if (videoDevices.length <= 1) return;
            
            isProcessing = true;
            codeReader.reset();
            
            // Cycle through devices
            currentDeviceIndex = (currentDeviceIndex + 1) % videoDevices.length;
            selectedDeviceId = videoDevices[currentDeviceIndex].deviceId;
            
            isProcessing = false;
            initScanner();
        }

        function stopScanner() {
            isProcessing = false;
            codeReader.reset();
            const modalEl = document.getElementById('scannerModal');
            const modal = bootstrap.Modal.getInstance(modalEl);
            if (modal) modal.hide();
        }
        async function onScanSuccess(decodedText) {
            const cleanCode = decodedText.trim();
            stopScanner();
            
            // Safety reset if anything fails
            setTimeout(() => { isProcessing = false; }, 3000);

            document.getElementById('HoseType').value = cleanCode;
            
            Swal.fire({
                title: 'SYNCING...',
                html: '<span class="text-info fw-bold">' + cleanCode + '</span>',
                background: '#0d1117',
                color: '#60a5fa',
                showConfirmButton: false,
                timer: 2000,
                didOpen: () => Swal.showLoading()
            });
            
            try {
                const res = await fetch(`/ProductionReport/GetMasterByItem?itemCode=${encodeURIComponent(cleanCode)}`);
                const data = await res.json();
                
                if (data) {
                    // Update Header Documents
                    document.getElementById('DocumentNumber').value = data.documentNumber || '';
                    document.getElementById('RevisionNumber').value = data.revisionNumber || '';
                    document.getElementById('EffectiveDate').value = data.revisionDate || '';

                    // Update main fields
                    document.getElementById('Dimension').value = data.dimensi || '';
                    document.getElementById('Yarn').value = data.yarn || 'ARAMID'; 
                    
                    // Update material codes (HoseType is just the code, maybe show Customer + HoseType)
                    document.getElementById('InnerMaterial').value = data.innerTube || '';
                    document.getElementById('OuterMaterial').value = data.outerCover || '';
                    
                    Swal.fire({
                        icon: 'success',
                        title: 'MASTER DATA CONNECTED',
                        text: data.customer + ' | ' + data.hoseType,
                        background: '#0d1117',
                        color: '#fff',
                        timer: 2000,
                        showConfirmButton: false
                    });
                } else {
                    Swal.fire({
                        icon: 'warning',
                        title: 'DATA NOT FOUND',
                        text: 'Item [' + cleanCode + '] tidak ada di Masterlist SPS.',
                        background: '#0d1117',
                        color: '#fff',
                        confirmButtonColor: '#2563eb'
                    });
                }
            } catch (e) { 
                Swal.fire({ 
                    icon: 'error', 
                    title: 'SYSTEM ERROR', 
                    text: 'Gagal menghubungi server master data.',
                    background: '#0d1117', 
                    color: '#fff' 
                }); 
            }
        }

        async function verifySPV(el, layer) {
            if (el.classList.contains('active')) return;

            const { value: pin } = await Swal.fire({
                title: `VERIFY ${layer.toUpperCase()} LAYER`,
                input: 'password',
                inputPlaceholder: 'Masukan PIN Supervisor',
                inputAttributes: {
                    autocapitalize: 'off',
                    autocorrect: 'off'
                },
                background: '#0f172a',
                color: '#fff',
                confirmButtonColor: '#2563eb',
                showCancelButton: true
            });

            if (pin === '1234') { // Mock PIN for demo
                el.classList.add('active');
                el.innerHTML = '<i class="bi bi-shield-check text-info fs-3 pulse-blue"></i>';
                document.getElementById(`Verify${layer}`).value = "true";
                
                Swal.fire({
                    icon: 'success',
                    title: 'APPROVED',
                    text: `${layer} Layer Verified!`,
                    background: '#0f172a',
                    color: '#fff',
                    timer: 1500,
                    showConfirmButton: false
                });
            } else if (pin) {
                Swal.fire({
                    icon: 'error',
                    title: 'ACCESS DENIED',
                    text: 'PIN Supervisor Salah!',
                    background: '#0f172a',
                    color: '#fff'
                });
            }
        }
    </script>
}
