@model VelastoProductionSystem.Models.ProductionReport

@{
    ViewData["Title"] = "Production Monitoring Dashboard";
    var readings = Model.ProductionReadings.OrderBy(r => r.ReadingTime).ToList();
    var std = Model.StandardParameterSetting ?? new VelastoProductionSystem.Models.StandardParameterSetting();
    var currentPortal = Context.Request.Query["portal"].ToString();
}

<div class="production-dashboard-sapphire fade-in">
    <!-- PORTAL SELECTION / TOGGLE (No Print) -->
    <div class="d-flex justify-content-center gap-3 mb-4 no-print header-sapphire-glass p-3">
        <a href="?portal=parameter" class="portal-btn @(currentPortal == "parameter" || string.IsNullOrEmpty(currentPortal) ? "active" : "")">
            <i class="bi bi-gear-wide-connected fs-4"></i>
            <div>
                <span class="small fw-bold d-block text-white-50">OPERATOR 1</span>
                <span class="fw-black">PARAMETER SETTING</span>
            </div>
        </a>
        <a href="?portal=dimension" class="portal-btn @(currentPortal == "dimension" ? "active" : "")">
            <i class="bi bi-rulers fs-4"></i>
            <div>
                <span class="small fw-bold d-block text-white-50">OPERATOR 2</span>
                <span class="fw-black">DIMENSION REPORT</span>
            </div>
        </a>
        
        <div class="ms-auto d-flex align-items-center gap-2">
            <button onclick="window.print()" class="btn btn-outline-glass btn-sm">
                <i class="bi bi-printer me-1"></i> PRINT
            </button>
            <button type="button" class="btn btn-danger-glass btn-sm" data-bs-toggle="modal" data-bs-target="#finishProductionModal">
                <i class="bi bi-flag-fill me-1"></i> FINISH
            </button>
        </div>
    </div>

    @if (currentPortal == "dimension")
    {
        <!-- ============================================= -->
        <!-- PORTAL 2: DIMENSION (Modern HUD Wrapper)      -->
        <!-- ============================================= -->
        <div class="hud-container fade-in">
            <div class="paper-replica shadow-2xl mx-auto mb-5">
                <div class="paper-padding text-uppercase">
                    <div class="row g-0 border-form-bold mb-3">
                        <div class="col-3 p-3 border-end-form d-flex align-items-center justify-content-center">
                             <div class="d-flex align-items-center bg-dark p-2 rounded">
                                <h4 class="fw-black mb-0 text-white" style="font-family: Arial Black; letter-spacing: -1px; font-size: 24px;">V</h4>
                                <div class="ms-1">
                                    <h5 class="fw-black mb-0 text-white" style="letter-spacing: 2px; font-size: 14px; line-height: 1;">VELASTO</h5>
                                </div>
                             </div>
                        </div>
                        <div class="col-6 p-2 text-center border-end-form align-middle">
                            <h5 class="fw-bold mb-0">Extruder Production Report</h5>
                            <div class="fw-bold small">(Dimension)</div>
                        </div>
                        <div class="col-3 p-2 text-center d-flex flex-column justify-content-center">
                             <div class="super-small fw-bold">NO DOC: @Model.DocumentNumber</div>
                             <div class="super-small fw-bold">DATE: @Model.ProductionDate.ToString("dd/MM/yy")</div>
                        </div>
                    </div>

                    <div class="table-container-modern">
                         <table class="grid-form w-100">
                            <thead>
                                <tr>
                                    <th>TIME</th><th>ITEM</th><th>INNER DIA</th><th>IN THICK X</th><th>IN THICK Y</th><th>TOTAL X</th><th>TOTAL Y</th><th>PITCH</th><th>VISUAL</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach(var r in readings) {
                                    <tr class="row-hover">
                                        <td>@r.ReadingTime.ToString("HH:mm")</td>
                                        <td>@Model.HoseType</td>
                                        <td class="text-center">@r.InnerDiameter</td>
                                        <td class="text-center">@r.InnerThicknessX</td>
                                        <td class="text-center">@r.InnerThicknessY</td>
                                        <td class="text-center">@r.TotalThicknessX</td>
                                        <td class="text-center">@r.TotalThicknessY</td>
                                        <td class="text-center">@r.SpiralPitch</td>
                                        <td class="text-center fw-bold @(r.VisualCheck == "OK" ? "text-success" : "text-danger")">@r.VisualCheck</td>
                                    </tr>
                                }
                            </tbody>
                         </table>
                    </div>

                    <div class="mt-4 no-print d-flex justify-content-center">
                        <button type="button" class="btn btn-velasto-glow-green px-5 rounded-pill" data-bs-toggle="modal" data-bs-target="#addDimModal">
                            <i class="bi bi-rulers me-2"></i> INPUT DATA KUALITAS (DIMENSI)
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- ============================================= -->
        <!-- PORTAL 1: PARAMETER SETTING (Modern HUD)      -->
        <!-- ============================================= -->
        <div class="hud-container fade-in">
            <div class="paper-replica shadow-2xl mx-auto mb-5">
            <div class="paper-padding text-uppercase" style="font-size: 10px;">
                
                <!-- 1. HEADER & INFO SECTION (Pixel Perfect Integration) -->
                <div class="border-form-bold">
                    <!-- TOP ROW -->
                    <div class="row g-0 border-bottom-form-bold">
                        <div class="col-3 border-end-form p-2 d-flex align-items-center justify-content-center">
                             <div class="d-flex align-items-center">
                                <h4 class="fw-black mb-0 me-2" style="font-family: Arial Black, sans-serif; letter-spacing: -1px; font-size: 24px;">V</h4>
                                <div>
                                    <h5 class="fw-black mb-0" style="letter-spacing: 2px; font-size: 18px; line-height: 1;">VELASTO</h5>
                                    <div class="super-small fw-bold" style="letter-spacing: 3px; font-size: 7px;">INDONESIA</div>
                                </div>
                             </div>
                        </div>
                        <div class="col-5 border-end-form p-2 d-flex flex-column justify-content-center align-items-center text-center">
                            <h6 class="fw-bold mb-0" style="font-size: 15px; letter-spacing: 0.5px;">Extruder Production Report</h6>
                            <div class="fw-bold" style="font-size: 12px;">(Parameter Setting)</div>
                        </div>
                        <div class="col-4">
                            <table class="w-100 h-100 text-center fw-bold m-0 border-0" style="font-size: 9px;">
                                <tr>
                                    <td class="border-end-form border-bottom-form p-1" style="width: 33.33%;">Disetujui</td>
                                    <td class="border-end-form border-bottom-form p-1" style="width: 33.33%;">Diperiksa</td>
                                    <td class="border-bottom-form p-1" style="width: 33.33%;">Dibuat</td>
                                </tr>
                                <tr style="height: 45px;">
                                    <td class="border-end-form"></td>
                                    <td class="border-end-form"></td>
                                    <td></td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <!-- BOTTOM ROW -->
                    <div class="row g-0 h-100">
                        <div class="col-5 border-end-form p-2">
                            <div class="mb-1 d-flex">
                                <span style="width: 60px;">No. Doc.</span>: <span class="border-bottom border-dark flex-grow-1 ms-1 ps-2">@Model.DocumentNumber</span>
                            </div>
                            <div class="mb-1 d-flex">
                                <span style="width: 60px;">Date</span>: <span class="border-bottom border-dark flex-grow-1 ms-1 ps-2">@Model.ProductionDate.ToString("dd.MM.yy")</span>
                            </div>
                            <div class="mb-1 d-flex">
                                <span style="width: 60px;">Shift</span>: <span class="border-bottom border-dark flex-grow-1 ms-1 ps-2">@Model.Shift</span>
                            </div>
                            <div class="mb-1 d-flex">
                                <span style="width: 60px;">Cust.</span>: <span class="border-bottom border-dark flex-grow-1 ms-1 ps-2">@Model.CustomerName</span>
                            </div>
                            <div class="d-flex">
                                <span style="width: 60px;">Tipe</span>: <span class="border-bottom border-dark flex-grow-1 ms-1 ps-2">@Model.HoseType @Model.Dimension</span>
                            </div>
                        </div>
                        <div class="col-1 border-end-form d-flex align-items-center justify-content-center bg-white">
                            <table class="p-0 border-form m-2 text-center" style="width: 40px; font-size: 9px;">
                                <tr class="border-bottom-form"><td>DARI</td></tr>
                                <tr><td class="fw-bold fs-6">1</td></tr>
                            </table>
                        </div>
                        <div class="col-6">
                            <table class="w-100 h-100 m-0 border-0 text-center align-middle" style="font-size: 8px;">
                                <tr class="border-bottom-form fw-bold" style="height: 20px;">
                                    <td class="border-end-form" style="width: 20%;">No. Rev.</td>
                                    <td class="border-end-form" style="width: 50%;">Description</td>
                                    <td style="width: 30%;">Date</td>
                                </tr>
                                <tr class="border-bottom-form" style="height: 15px;"><td class="border-end-form"></td><td class="border-end-form"></td><td></td></tr>
                                <tr class="border-bottom-form" style="height: 15px;"><td class="border-end-form"></td><td class="border-end-form"></td><td></td></tr>
                                <tr style="height: 15px;"><td class="border-end-form"></td><td class="border-end-form"></td><td></td></tr>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- 3. TOP GRID (Material, Dies, Mesh) -->
                <div class="row g-0 border-form mb-0">
                    <!-- MATERIAL & DIES -->
                    <div class="col-6 border-end-form">
                         <table class="w-100 grid-form border-0">
                            <!-- MATERIAL SECTION -->
                            <tr>
                                <th width="30" rowspan="4" class="align-middle text-center p-0 border-bottom-0" style="writing-mode: vertical-rl; transform: rotate(180deg); background:#f0f0f0; letter-spacing: 2px;">MATERIAL</th>
                                <th colspan="2" style="background:#f0f0f0; border-bottom: 0;"></th>
                                <th width="90" style="background:#f0f0f0;" class="text-center">STANDARD</th>
                                <th width="120" style="background:#f0f0f0;" class="text-center border-end-0">ACTUAL</th>
                                <th rowspan="4" width="60" style="background:#f4f4f4;" class="border-start-form"></th>
                            </tr>
                            <tr>
                                <td colspan="2" class="text-start ps-2">INNER(MATERIAL)</td>
                                <td class="text-center">@(Model.InnerMaterial ?? "-")</td>
                                <td class="p-0 border-end-0"><input type="text" class="input-transparent w-100 h-100 text-center fw-bold text-primary" value="@(Model.InnerMaterialActual ?? Model.InnerMaterial ?? "")" /></td>
                            </tr>
                            <tr>
                                <td colspan="2" class="text-start ps-2">OUTER(MATERIAL)</td>
                                <td class="text-center">@(Model.OuterMaterial ?? "-")</td>
                                <td class="p-0 border-end-0"><input type="text" class="input-transparent w-100 h-100 text-center fw-bold text-primary" value="@(Model.OuterMaterialActual ?? Model.OuterMaterial ?? "")" /></td>
                            </tr>
                            <tr>
                                <td colspan="2" class="text-start ps-2">YARN</td>
                                <td class="text-center">ARAMID</td>
                                <td class="p-0 border-end-0"><input type="text" class="input-transparent w-100 h-100 text-center fw-bold text-primary" value="@(Model.YarnActual ?? Model.Yarn ?? "ARAMID")" /></td>
                            </tr>
                            
                            <!-- DIES DIMENSION SECTION -->
                            <tr class="border-top-form">
                                <th width="30" rowspan="7" class="align-middle text-center p-0" style="writing-mode: vertical-rl; transform: rotate(180deg); background:#f0f0f0; letter-spacing: 2px;">DIES DIMENSION</th>
                                <th style="background:#f0f0f0;" class="text-start ps-2">DIES</th>
                                <th width="100" style="background:#f0f0f0;" class="text-center">CEK VISUAL</th>
                                <th width="90" style="background:#f0f0f0;" class="text-center">STANDARD</th>
                                <th width="60" style="background:#f0f0f0;" class="text-center">BEFORE</th>
                                <th width="60" style="background:#f0f0f0; border-right: 0 !important;" class="text-center">AFTER</th>
                            </tr>
                            <tr>
                                <td class="text-start ps-2">Ø NIPPLE DIE</td>
                                <td class="p-0 align-middle">
                                    <div class="d-flex justify-content-center gap-1 align-items-center h-100" style="font-size: 10px;">
                                        <label class="mb-0 d-flex align-items-center gap-1">OK <input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" style="width:14px; height:14px; margin-top:-1px!important;"></label>
                                        <label class="mb-0 d-flex align-items-center gap-1">NG <input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" style="width:14px; height:14px; margin-top:-1px!important;"></label>
                                    </div>
                                </td>
                                <td class="text-center">@(std.InnerDie == 0 ? "8.8±0.1" : std.InnerDie.ToString())</td>
                                <td class="p-0"><input type="text" class="input-transparent w-100 text-center text-dark" placeholder="---" /></td>
                                <td class="p-0 border-end-0"><input type="text" class="input-transparent w-100 text-center text-dark" placeholder="---" /></td>
                            </tr>
                            <tr>
                                <td class="text-start ps-2">Ø TUBE DIE</td>
                                <td class="p-0 align-middle">
                                    <div class="d-flex justify-content-center gap-1 align-items-center h-100" style="font-size: 10px;">
                                        <label class="mb-0 d-flex align-items-center gap-1">OK <input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" style="width:14px; height:14px; margin-top:-1px!important;"></label>
                                        <label class="mb-0 d-flex align-items-center gap-1">NG <input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" style="width:14px; height:14px; margin-top:-1px!important;"></label>
                                    </div>
                                </td>
                                <td class="text-center">@(std.TubeDie == 0 ? "11.1±0.1" : std.TubeDie.ToString())</td>
                                <td class="p-0"><input type="text" class="input-transparent w-100 text-center text-dark" placeholder="---" /></td>
                                <td class="p-0 border-end-0"><input type="text" class="input-transparent w-100 text-center text-dark" placeholder="---" /></td>
                            </tr>
                            <tr>
                                <td class="text-start ps-2">Ø MIDDLE DIE</td>
                                <td class="p-0 align-middle">
                                    <div class="d-flex justify-content-center gap-1 align-items-center h-100" style="font-size: 10px;">
                                        <label class="mb-0 d-flex align-items-center gap-1">OK <input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" style="width:14px; height:14px; margin-top:-1px!important;"></label>
                                        <label class="mb-0 d-flex align-items-center gap-1">NG <input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" style="width:14px; height:14px; margin-top:-1px!important;"></label>
                                    </div>
                                </td>
                                <td class="text-center">@(std.MiddleDie == 0 ? "14.2±0.1" : std.MiddleDie.ToString())</td>
                                <td class="p-0"><input type="text" class="input-transparent w-100 text-center text-dark" placeholder="---" /></td>
                                <td class="p-0 border-end-0"><input type="text" class="input-transparent w-100 text-center text-dark" placeholder="---" /></td>
                            </tr>
                            <tr>
                                <td class="text-start ps-2">Ø COVER DIE</td>
                                <td class="p-0 align-middle">
                                    <div class="d-flex justify-content-center gap-1 align-items-center h-100" style="font-size: 10px;">
                                        <label class="mb-0 d-flex align-items-center gap-1">OK <input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" style="width:14px; height:14px; margin-top:-1px!important;"></label>
                                        <label class="mb-0 d-flex align-items-center gap-1">NG <input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" style="width:14px; height:14px; margin-top:-1px!important;"></label>
                                    </div>
                                </td>
                                <td class="text-center">@(std.CoverDie == 0 ? "15.1±0.1" : std.CoverDie.ToString())</td>
                                <td class="p-0"><input type="text" class="input-transparent w-100 text-center text-dark" placeholder="---" /></td>
                                <td class="p-0 border-end-0"><input type="text" class="input-transparent w-100 text-center text-dark" placeholder="---" /></td>
                            </tr>
                            <tr>
                                <td class="text-start ps-2">Ø SPACER DIE</td>
                                <td class="p-0 align-middle">
                                    <div class="d-flex justify-content-center gap-1 align-items-center h-100" style="font-size: 10px;">
                                        <label class="mb-0 d-flex align-items-center gap-1">OK <input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" style="width:14px; height:14px; margin-top:-1px!important;"></label>
                                        <label class="mb-0 d-flex align-items-center gap-1">NG <input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" style="width:14px; height:14px; margin-top:-1px!important;"></label>
                                    </div>
                                </td>
                                <td class="text-center">@(std.SpacerDie == 0 ? "7.3±0.1" : std.SpacerDie.ToString())</td>
                                <td class="p-0"><input type="text" class="input-transparent w-100 text-center text-dark" placeholder="---" /></td>
                                <td class="p-0 border-end-0"><input type="text" class="input-transparent w-100 text-center text-dark" placeholder="---" /></td>
                            </tr>
                            <tr>
                                <td class="text-start ps-2">A DISTANCE</td>
                                <td class="p-0 align-middle">
                                    <div class="d-flex justify-content-center gap-1 align-items-center h-100" style="font-size: 10px;">
                                        <label class="mb-0 d-flex align-items-center gap-1">OK <input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" style="width:14px; height:14px; margin-top:-1px!important;"></label>
                                        <label class="mb-0 d-flex align-items-center gap-1">NG <input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" style="width:14px; height:14px; margin-top:-1px!important;"></label>
                                    </div>
                                </td>
                                <td class="text-center">0.4±0.1</td>
                                <td class="p-0"><input type="text" class="input-transparent w-100 text-center text-dark" placeholder="---" /></td>
                                <td class="p-0 border-end-0"><input type="text" class="input-transparent w-100 text-center text-dark" placeholder="---" /></td>
                            </tr>
                        </table>
                    </div>
                    <!-- MESH & EMBOSS -->
                    <div class="col-6">
                        <table class="w-100 grid-form border-0 h-100">
                            <!-- Header -->
                            <tr>
                                <th width="80" style="background:#f0f0f0;" class="border-end-0"></th>
                                <th width="80" style="background:#f0f0f0;" class="text-start ps-2 border-start-0">Content</th>
                                <th style="background:#f0f0f0;" class="text-center">Ø96 #10</th>
                                <th colspan="2" style="background:#f0f0f0;" class="text-center border-end-0">Ø96 #40</th>
                            </tr>

                            <!-- Tipe Mesh -->
                            <tr>
                                <td rowspan="2" class="align-middle text-center p-1" style="background-color: #f4f4f4; font-size: 11px;">Tipe Mesh<br/>(Sebelum<br/>Proses)</td>
                                <td class="text-start ps-2">Inner</td>
                                <td class="p-0 align-middle text-center"><input type="text" class="input-transparent w-100 h-100 text-center text-dark" placeholder="~" /></td>
                                <td colspan="2" class="p-0 align-middle text-center border-end-0"><input type="text" class="input-transparent w-100 h-100 text-center text-dark" placeholder="~" /></td>
                            </tr>
                            <tr>
                                <td class="text-start ps-2">Outer</td>
                                <td class="p-0 align-middle text-center"><input type="text" class="input-transparent w-100 h-100 text-center text-dark" placeholder="~" /></td>
                                <td colspan="2" class="p-0 align-middle text-center border-end-0"><input type="text" class="input-transparent w-100 h-100 text-center text-dark" placeholder="~" /></td>
                            </tr>

                            <!-- Mesh Checking -->
                            <tr class="border-top-form">
                                <td rowspan="2" class="align-middle text-center p-1" style="background-color: #f4f4f4; font-size: 11px;">Mesh<br/>Checking<br/>(Setelah<br/>Proses)</td>
                                <td class="text-start ps-2">Inner</td>
                                <td class="p-0 align-middle px-2">
                                    <label class="mb-0 d-flex align-items-center gap-1" style="font-size: 11px;"><input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" style="width:13px; height:13px;"> OK</label>
                                </td>
                                <td class="p-0 align-middle px-2">
                                    <label class="mb-0 d-flex align-items-center gap-1" style="font-size: 11px;"><input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" style="width:13px; height:13px;"> Bolong</label>
                                </td>
                                <td class="p-0 align-middle px-2 border-end-0">
                                    <label class="mb-0 d-flex align-items-center gap-1" style="font-size: 11px;"><input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" style="width:13px; height:13px;"> Material Asing</label>
                                </td>
                            </tr>
                            <tr>
                                <td class="text-start ps-2">Outer</td>
                                <td class="p-0 align-middle px-2">
                                    <label class="mb-0 d-flex align-items-center gap-1" style="font-size: 11px;"><input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" style="width:13px; height:13px;"> OK</label>
                                </td>
                                <td class="p-0 align-middle px-2">
                                    <label class="mb-0 d-flex align-items-center gap-1" style="font-size: 11px;"><input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" style="width:13px; height:13px;"> Bolong</label>
                                </td>
                                <td class="p-0 align-middle px-2 border-end-0">
                                    <label class="mb-0 d-flex align-items-center gap-1" style="font-size: 11px;"><input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" style="width:13px; height:13px;"> Material Asing</label>
                                </td>
                            </tr>

                            <!-- Emboss Marking -->
                            <tr class="border-top-form">
                                <td rowspan="5" class="align-middle text-center p-1 border-bottom-0" style="background-color: #f4f4f4; font-size: 11px;">Emboss<br/>Marking<br/>Check<br/>(Setelah<br/>Proses)</td>
                                <td class="text-start ps-2">Text</td>
                                <td colspan="3" class="p-0 align-middle border-end-0"><input type="text" class="input-transparent w-100 h-100 px-2 text-start text-dark fw-bold" placeholder="~" /></td>
                            </tr>
                            <tr>
                                <td class="text-start ps-2">Date</td>
                                <td colspan="3" class="p-0 align-middle border-end-0"><input type="text" class="input-transparent w-100 h-100 px-2 text-start text-dark fw-bold" placeholder="~" /></td>
                            </tr>
                            <tr>
                                <td class="text-start ps-2">Condition</td>
                                <td colspan="1" class="p-0 align-middle px-2 border-end-0">
                                    <label class="mb-0 d-flex align-items-center gap-1" style="font-size: 11px;"><input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" style="width:13px; height:13px;"> Bersih</label>
                                </td>
                                <td colspan="2" class="p-0 align-middle px-2 border-end-0">
                                    <label class="mb-0 d-flex align-items-center gap-1" style="font-size: 11px;"><input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" style="width:13px; height:13px;"> Kotor</label>
                                </td>
                            </tr>
                            <tr>
                                <td class="text-start ps-2">Surface</td>
                                <td colspan="1" class="p-0 align-middle px-2 border-end-0">
                                    <label class="mb-0 d-flex align-items-center gap-1" style="font-size: 11px;"><input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" style="width:13px; height:13px;"> OK</label>
                                </td>
                                <td colspan="2" class="p-0 align-middle px-2 border-end-0">
                                    <label class="mb-0 d-flex align-items-center gap-1" style="font-size: 11px;"><input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" style="width:13px; height:13px;"> Scratch</label>
                                </td>
                            </tr>
                            <tr>
                                <td class="text-start ps-2 border-bottom-0">Text</td>
                                <td colspan="1" class="p-0 align-middle px-2 border-end-0 border-bottom-0">
                                    <label class="mb-0 d-flex align-items-center gap-1" style="font-size: 11px;"><input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" style="width:13px; height:13px;"> Terbaca</label>
                                </td>
                                <td colspan="2" class="p-0 align-middle px-2 border-end-0 border-bottom-0">
                                    <label class="mb-0 d-flex align-items-center gap-1" style="font-size: 11px;"><input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" style="width:13px; height:13px;"> Tdk Terbaca</label>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- 4. MAIN MONITORING TABLE (Tablet-Friendly Sticky Labels) -->
                <div class="table-container-modern shadow-inner mt-2">
                    <div class="table-responsive-modern border border-dark">
                        <table class="grid-form w-100 m-0">
                            <thead class="sticky-top bg-light">
                                <tr>
                                    <th colspan="2" class="sticky-col label-col text-center align-middle" width="220" style="background:#f0f0f0; font-size: 13px;">TIME</th>
                                    <th class="sticky-col std-col text-center" width="100" style="background:#f0f0f0; font-size: 13px;">INITIAL<br/>:</th>
                                    @for(int i=1; i<=7; i++) { <th width="60" class="text-center" style="background:#f0f0f0; font-size: 13px;">@i<br/>:</th> }
                                    <th width="40" class="bg-secondary text-white text-center border-start-0">...</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- INNER SECTION -->
                                 @{
                                    var innerRows = new[] {
                                        new { Label = "HEAD TEMP. (°C)", Key = "HeadTempInner", Std = (std.HeadTemp == 0 ? "90" : std.HeadTemp.ToString()) + "±5" },
                                        new { Label = "CYLINDER 1 (°C)", Key = "Cylinder1TempInner", Std = (std.Cylinder1Temp == 0 ? "90" : std.Cylinder1Temp.ToString()) + "±5" },
                                        new { Label = "CYLINDER 2 (°C)", Key = "Cylinder2TempInner", Std = (std.Cylinder2Temp == 0 ? "90" : std.Cylinder2Temp.ToString()) + "±5" },
                                        new { Label = "CYLINDER 3 (°C)", Key = "Cylinder3TempInner", Std = (std.Cylinder3Temp == 0 ? "90" : std.Cylinder3Temp.ToString()) + "±5" },
                                        new { Label = "SCREW TEMP. (°C)", Key = "ScrewTempInner", Std = (std.ScrewTemp == 0 ? "90" : std.ScrewTemp.ToString()) + "±5" },
                                        new { Label = "SCREW SPEED (RPM)", Key = "ScrewSpeedInner", Std = (std.ScrewSpeed == 0 ? "6.1" : std.ScrewSpeed.ToString()) + "±2.5" },
                                        new { Label = "FEED ROLL RATIO (%)", Key = "FeedRollRatioInner", Std = "MAX. 120" },
                                        new { Label = "PRESSURE(MPa)", Key = "PressureInner", Std = "MAX. " + (std.Pressure == 0 ? "50" : std.Pressure.ToString()) }
                                    };
                                }
                                @for(int r = 0; r < innerRows.Length; r++) {
                                    var row = innerRows[r];
                                    <tr class="row-hover">
                                        @if(r == 0) {
                                            <td rowspan="@innerRows.Length" width="30" class="align-middle text-center p-0" style="writing-mode: vertical-rl; transform: rotate(180deg); background:#e9ecef; letter-spacing: 2px; border-right: 1px solid #dee2e6;">INNER (TUBE 1)</td>
                                        }
                                        <td class="text-end pe-2 sticky-col label-col bg-white border-start-0" width="190" style="font-size: 11px;">@row.Label</td>
                                        <td class="text-center fw-bold sticky-col std-col bg-light" style="font-size: 11px;">@row.Std</td>
                                        <td class="text-center p-0 cell-active border-end-form"><input type="text" class="input-transparent w-100 text-center text-dark fw-bold" value="@(readings.FirstOrDefault()?.GetType().GetProperty(row.Key)?.GetValue(readings.FirstOrDefault()) ?? "")" /></td>
                                        @for(int i=1; i<=7; i++) {
                                            <td class="text-center p-0 cell-input"><input type="text" class="input-transparent w-100 text-center text-dark fw-bold" value="@(readings.Skip(i).FirstOrDefault()?.GetType().GetProperty(row.Key)?.GetValue(readings.Skip(i).FirstOrDefault()) ?? "")" /></td>
                                        }
                                        <td class="bg-light border-start-form"></td>
                                    </tr>
                                }

                                <!-- OUTER SECTION -->
                                 @{
                                    var outerRows = new[] {
                                        new { Label = "HEAD TEMP. (°C)", Key = "HeadTempOuter", Std = "90±5" },
                                        new { Label = "CYLINDER 1 (°C)", Key = "Cylinder1TempOuter", Std = "90±5" },
                                        new { Label = "CYLINDER 2 (°C)", Key = "Cylinder2TempOuter", Std = "90±5" },
                                        new { Label = "CYLINDER 3 (°C)", Key = "Cylinder3TempOuter", Std = "-" },
                                        new { Label = "SCREW TEMP. (°C)", Key = "ScrewTempOuter", Std = "90±5" },
                                        new { Label = "SCREW SPEED (RPM)", Key = "ScrewSpeedOuter", Std = "8.2±2.5" },
                                        new { Label = "FEED ROLL RATIO (%)", Key = "FeedRollRatioOuter", Std = "MAX. 120" },
                                        new { Label = "PRESSURE(MPa)", Key = "PressureOuter", Std = "MAX. 50" }
                                    };
                                }
                                <tr class="border-top-form"></tr>
                                @for(int r = 0; r < outerRows.Length; r++) {
                                    var row = outerRows[r];
                                    <tr class="row-hover">
                                        @if(r == 0) {
                                            <td rowspan="@outerRows.Length" width="30" class="align-middle text-center p-0" style="writing-mode: vertical-rl; transform: rotate(180deg); background:#e9ecef; letter-spacing: 2px; border-right: 1px solid #dee2e6;">OUTER (COVER)</td>
                                        }
                                        <td class="text-end pe-2 sticky-col label-col bg-white border-start-0" width="190" style="font-size: 11px;">@row.Label</td>
                                        <td class="text-center fw-bold sticky-col std-col bg-light" style="font-size: 11px;">@row.Std</td>
                                        <td class="text-center p-0 cell-active border-end-form"><input type="text" class="input-transparent w-100 text-center text-dark fw-bold" value="@(readings.FirstOrDefault()?.GetType().GetProperty(row.Key)?.GetValue(readings.FirstOrDefault()) ?? "")" /></td>
                                        @for(int i=1; i<=7; i++) {
                                            <td class="text-center p-0 cell-input"><input type="text" class="input-transparent w-100 text-center text-dark fw-bold" value="@(readings.Skip(i).FirstOrDefault()?.GetType().GetProperty(row.Key)?.GetValue(readings.Skip(i).FirstOrDefault()) ?? "")" /></td>
                                        }
                                        <td class="bg-light border-start-form"></td>
                                    </tr>
                                }

                                <!-- SPIRAL SECTION -->
                                 @{
                                    var spiralRows = new[] {
                                        new { Label = "SPIRAL SPEED (RPM)", Key = "SpiralSpeed", Std = "98±20" },
                                        new { Label = "SPIRAL PITCH (SETTING)", Key = "SpiralPitchSetting", Std = "35±5" },
                                        new { Label = "SPIRAL PITCH (DISPLAY)", Key = "SpiralPitchDisplay", Std = "35±5" }
                                    };
                                }
                                <tr class="border-top-form"></tr>
                                @for(int r = 0; r < spiralRows.Length; r++) {
                                    var row = spiralRows[r];
                                    <tr class="row-hover">
                                        @if(r == 0) {
                                            <td rowspan="@spiralRows.Length" width="30" class="align-middle text-center p-0" style="writing-mode: vertical-rl; transform: rotate(180deg); background:#e9ecef; letter-spacing: 2px; border-right: 1px solid #dee2e6;">SPIRAL</td>
                                        }
                                        <td class="text-end pe-2 sticky-col label-col bg-white border-start-0" width="190" style="font-size: 11px;">@row.Label</td>
                                        <td class="text-center fw-bold sticky-col std-col bg-light" style="font-size: 11px;">@row.Std</td>
                                        <td class="text-center p-0 cell-active border-end-form"><input type="text" class="input-transparent w-100 text-center text-dark fw-bold" value="@(readings.FirstOrDefault()?.GetType().GetProperty(row.Key)?.GetValue(readings.FirstOrDefault()) ?? "")" /></td>
                                        @for(int i=1; i<=7; i++) {
                                            <td class="text-center p-0 cell-input"><input type="text" class="input-transparent w-100 text-center text-dark fw-bold" value="@(readings.Skip(i).FirstOrDefault()?.GetType().GetProperty(row.Key)?.GetValue(readings.Skip(i).FirstOrDefault()) ?? "")" /></td>
                                        }
                                        <td class="bg-light border-start-form"></td>
                                    </tr>
                                }

                                <!-- OTHER SECTION -->
                                 @{
                                    var otherRows = new[] {
                                        new { Label = "PRESET VALUE (Ø mm)", Key = "PresetValue", Std = "18.5±0.2" },
                                        new { Label = "CONTROL VALUE (Ø mm)", Key = "ControlValue", Std = "18.5±0.2" },
                                        new { Label = "HOSE SPEED (m/min)", Key = "HoseSpeed", Std = "3.4±2" },
                                        new { Label = "TAKE UP CONVEYOR SPEED (m/min)", Key = "TakeupConveyorSpeed", Std = "3.4±3" },
                                        new { Label = "COOL CONVEYOR SPEED (m/min)", Key = "CoolConveyorSpeed", Std = "3.4±4" },
                                        new { Label = "CONVEYOR RATIO (TAKE UP : COOL)", Key = "ConveyorRatio", Std = "100%±10" },
                                        new { Label = "UN SMOOTH SURFACE", Key = "UnsmoothSurface", Std = "0.5" },
                                        new { Label = "CHILLER WATER TEMPERATURE (°C)", Key = "ChillerWaterTemp", Std = "MAX. 15" },
                                        new { Label = "CATERPILLAR GAP (mm)", Key = "CaterpillarGap", Std = "18.2±1" }
                                    };
                                }
                                <tr class="border-top-form"></tr>
                                @for(int r = 0; r < otherRows.Length; r++) {
                                    var row = otherRows[r];
                                    <tr class="row-hover">
                                        @if(r == 0) {
                                            <td rowspan="@otherRows.Length" width="30" class="align-middle text-center p-0" style="writing-mode: vertical-rl; transform: rotate(180deg); background:#e9ecef; letter-spacing: 2px; border-right: 1px solid #dee2e6;">OTHER</td>
                                        }
                                        <td class="text-end pe-2 sticky-col label-col bg-white border-start-0" width="190" style="font-size: 11px;">@row.Label</td>
                                        <td class="text-center fw-bold sticky-col std-col bg-light" style="font-size: 11px;">@row.Std</td>
                                        <td class="text-center p-0 cell-active border-end-form"><input type="text" class="input-transparent w-100 text-center text-dark fw-bold" value="@(readings.FirstOrDefault()?.GetType().GetProperty(row.Key)?.GetValue(readings.FirstOrDefault()) ?? "")" /></td>
                                        @for(int i=1; i<=7; i++) {
                                            <td class="text-center p-0 cell-input"><input type="text" class="input-transparent w-100 text-center text-dark fw-bold" value="@(readings.Skip(i).FirstOrDefault()?.GetType().GetProperty(row.Key)?.GetValue(readings.Skip(i).FirstOrDefault()) ?? "")" /></td>
                                        }
                                        <td class="bg-light border-start-form"></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- 5. WASTE SECTION (Modernized) -->
                <div class="row g-0 border-form-bold mt-2 bg-light">
                    <div class="col-9 border-end-form">
                        <table class="grid-form w-100 border-0 m-0">
                            <tr class="bg-secondary text-white">
                                <th width="120">WASTE (KG)</th>
                                <th class="text-center" width="80">CONTENT</th>
                                <th class="text-center">AWAL</th>
                                <th class="text-center">AKHIR</th>
                            </tr>
                            <tr class="bg-white">
                                <td rowspan="2" class="text-center align-middle fw-bold">DANDORY AWAL (CLEANING)</td>
                                <td class="ps-2">INNER</td>
                                <td class="text-center">@(Model.WasteInnerAwal)</td>
                                <td class="text-center">@(Model.WasteInnerAkhir)</td>
                            </tr>
                            <tr class="bg-white">
                                <td class="ps-2">COVER</td>
                                <td class="text-center">@(Model.WasteCoverAwal)</td>
                                <td class="text-center">@(Model.WasteCoverAkhir)</td>
                            </tr>
                        </table>
                    </div>
                    <div class="col-3 p-2 d-flex align-items-center justify-content-center text-center">
                        <div class="small fw-bold text-danger" style="line-height: 1.2;">
                            <i class="bi bi-info-circle-fill me-1"></i> NOTE: <br/>LAKUKAN PENGECEKAN PARAMETER PADA SAAT AWAL, TENGAH & AKHIR PROSES.
                        </div>
                    </div>
                </div>

                <!-- INPUT TRIGGER PARAMETER -->
                <div class="mt-4 no-print d-flex justify-content-center gap-3">
                    <button type="button" id="btnVerify" class="btn btn-outline-info px-4 rounded-pill fw-bold border-2" onclick="startVerifyScanner()">
                        <i class="bi bi-qr-code-scan me-2"></i> VERIFY ITEM (SCAN)
                    </button>
                    <!-- Locked By Default -->
                    <button type="button" id="btnInput" class="btn btn-velasto-glow px-4 rounded-pill opacity-50 pe-none" data-bs-toggle="modal" data-bs-target="#addReadingModal">
                        <i class="bi bi-lock-fill me-2" id="iconLock"></i> <span id="textInput">INPUT TERKUNCI</span> (JAM KE-@(readings.Count))
                    </button>
                </div>
            </div>
        </div>
    </div>

    }
</div>

<!-- ============================================= -->
<!-- MODALS FOR INPUT & SCANNER                    -->
<!-- ============================================= -->

<!-- SCANNER MODAL FOR VERIFICATION -->
<div class="modal fade no-print" id="scannerVerifyModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content scanner-modal-glass border-0">
            <div class="modal-header border-bottom border-info border-opacity-25 pb-2">
                <div class="d-flex align-items-center">
                    <i class="bi bi-shield-check text-info me-2 fs-4"></i>
                    <h5 class="modal-title text-white fw-bold tracking-widest">SPS ITEM VERIFICATION</h5>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" onclick="stopScanner()"></button>
            </div>
            <div class="modal-body p-0 position-relative border-0 bg-black">
                <div class="hud-scanner-overlay" style="aspect-ratio:4/3; overflow:hidden; position:relative;">
                    <div id="reader-verify" style="width:100%;"></div>
                    <div style="position: absolute; top:50%; left:0; width:100%; height:2px; background:linear-gradient(to right, transparent, #0dcaf0, transparent); box-shadow: 0 0 15px #0dcaf0; z-index:10; transform: translateY(-50%);"></div>
                </div>
            </div>
            <div class="modal-footer border-top border-info border-opacity-25 py-2 bg-hud-navy">
                <div class="d-flex w-100 justify-content-between align-items-center px-2">
                    <span class="text-info extra-small tracking-widest"><i class="bi bi-broadcast pulse-info me-1"></i> AWAITING ITEM BARCODE...</span>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-outline-info btn-sm px-4" onclick="switchCamera()">
                            <i class="bi bi-camera-rotate me-1"></i> SWITCH
                        </button>
                        <button type="button" class="btn btn-danger btn-sm px-4" data-bs-dismiss="modal" onclick="stopScanner()">
                            CLOSE
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- MODAL OPERATOR 1 (FULL PARAMETER HUD) -->
<div class="modal fade no-print" id="addReadingModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content scanner-modal-glass border-0">
            <div class="modal-header border-bottom border-primary border-opacity-25 pb-3">
                <div class="d-flex align-items-center">
                    <div class="hud-icon-box me-3"><i class="bi bi-cpu text-primary fs-3"></i></div>
                    <div>
                        <h4 class="modal-title text-white fw-black mb-0">OPERATOR 1 MONITORING</h4>
                        <div class="text-primary-50 small fw-bold">INPUT PARAMETER MESIN - JAM KE-@(readings.Count + 1)</div>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AddReading" method="post" id="parameterForm">
                <input type="hidden" name="ProductionReportId" value="@Model.Id" />
                <input type="hidden" name="RecordedBy" value="Operator 1" />
                <div class="modal-body p-0">
                    <ul class="nav nav-tabs hud-tabs border-0" id="readingTabs" role="tablist">
                        <li class="nav-item flex-grow-1"><button class="nav-link active w-100 py-3" data-bs-toggle="tab" data-bs-target="#tab-inner">INNER (TUBE 1)</button></li>
                        <li class="nav-item flex-grow-1"><button class="nav-link w-100 py-3" data-bs-toggle="tab" data-bs-target="#tab-outer">OUTER (COVER)</button></li>
                        <li class="nav-item flex-grow-1"><button class="nav-link w-100 py-3" data-bs-toggle="tab" data-bs-target="#tab-spiral">SPIRAL & OTHERS</button></li>
                    </ul>

                    <div class="tab-content p-4 bg-hud-navy-dark">
                        <!-- TAB INNER -->
                        <div class="tab-pane fade show active" id="tab-inner">
                            <div class="row g-4">
                                @foreach(var f in new[] { 
                                    new { L="Head Temp", N="HeadTempInner", U="°C" }, new { L="Cyl 1", N="Cylinder1TempInner", U="°C" },
                                    new { L="Cyl 2", N="Cylinder2TempInner", U="°C" }, new { L="Cyl 3", N="Cylinder3TempInner", U="°C" },
                                    new { L="Screw Temp", N="ScrewTempInner", U="°C" }, new { L="Screw Speed", N="ScrewSpeedInner", U="RPM" },
                                    new { L="Feed Roll", N="FeedRollRatioInner", U="%" }, new { L="Pressure", N="PressureInner", U="MPa" }
                                }) {
                                    <div class="col-md-3">
                                        <div class="hud-input-group">
                                            <label class="hud-label">@f.L <span class="unit">(@f.U)</span></label>
                                            <input name="@f.N" type="number" step="0.1" class="hud-input-lg w-100" placeholder="0.0" />
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- TAB OUTER -->
                        <div class="tab-pane fade" id="tab-outer">
                            <div class="row g-4">
                                @foreach(var f in new[] { 
                                    new { L="Head Temp", N="HeadTempOuter", U="°C" }, new { L="Cyl 1", N="Cylinder1TempOuter", U="°C" },
                                    new { L="Cyl 2", N="Cylinder2TempOuter", U="°C" }, new { L="Cyl 3", N="Cylinder3TempOuter", U="°C" },
                                    new { L="Screw Temp", N="ScrewTempOuter", U="°C" }, new { L="Screw Speed", N="ScrewSpeedOuter", U="RPM" },
                                    new { L="Feed Roll", N="FeedRollRatioOuter", U="%" }, new { L="Pressure", N="PressureOuter", U="MPa" }
                                }) {
                                    <div class="col-md-3">
                                        <div class="hud-input-group">
                                            <label class="hud-label text-warning">@f.L <span class="unit">(@f.U)</span></label>
                                            <input name="@f.N" type="number" step="0.1" class="hud-input-lg w-100 border-warning-subtle" placeholder="0.0" />
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- TAB SPIRAL & OTHERS -->
                        <div class="tab-pane fade" id="tab-spiral">
                            <div class="row g-4">
                                <div class="col-md-3"><label class="hud-label text-info">Spiral Speed (rpm)</label><input name="SpiralSpeed" type="number" step="0.1" class="hud-input-lg w-100" /></div>
                                <div class="col-md-3"><label class="hud-label text-info">Pitch (Set)</label><input name="SpiralPitchSetting" type="number" step="0.1" class="hud-input-lg w-100" /></div>
                                <div class="col-md-3"><label class="hud-label text-info">Pitch (Disp)</label><input name="SpiralPitchDisplay" type="number" step="0.1" class="hud-input-lg w-100" /></div>
                                <div class="col-md-3"><label class="hud-label text-info">Hose Speed (m/min)</label><input name="HoseSpeed" type="number" step="0.1" class="hud-input-lg w-100" /></div>
                                
                                <div class="col-md-4"><label class="hud-label text-success">Take-up Speed</label><input name="TakeupConveyorSpeed" type="number" step="0.1" class="hud-input-lg w-100" /></div>
                                <div class="col-md-4"><label class="hud-label text-success">Cool Conv Speed</label><input name="CoolConveyorSpeed" type="number" step="0.1" class="hud-input-lg w-100" /></div>
                                <div class="col-md-4"><label class="hud-label text-success">Conv Ratio (%)</label><input name="ConveyorRatio" type="text" class="hud-input-lg w-100" placeholder="100%" /></div>
                                
                                <div class="col-md-3"><label class="hud-label">Chiller Temp</label><input name="ChillerWaterTemp" type="number" step="0.1" class="hud-input-lg w-100" /></div>
                                <div class="col-md-3"><label class="hud-label">Preset View</label><input name="PresetValue" type="number" step="0.1" class="hud-input-lg w-100" /></div>
                                <div class="col-md-3"><label class="hud-label">Control Value</label><input name="ControlValue" type="number" step="0.1" class="hud-input-lg w-100" /></div>
                                <div class="col-md-3"><label class="hud-label">Caterpillar Gap</label><input name="CaterpillarGap" type="number" step="0.1" class="hud-input-lg w-100" /></div>
                                
                                <div class="col-12"><label class="hud-label text-danger">Unsmooth Surface (mm)</label><input name="UnsmoothSurface" type="number" step="0.01" class="hud-input-lg w-100 text-danger" placeholder="0.5" /></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top border-primary border-opacity-10 bg-hud-navy">
                    <button type="button" class="btn btn-outline-light px-4" data-bs-dismiss="modal">CANCEL</button>
                    <button type="submit" class="btn btn-primary px-5 fw-bold neon-pulse-blue">SUBMIT ALL READINGS</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL OPERATOR 2 (DIMENSION HUD) -->
<div class="modal fade no-print" id="addDimModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content scanner-modal-glass border-0">
            <div class="modal-header border-bottom border-success border-opacity-25 pb-3">
