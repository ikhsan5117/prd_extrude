                    </div>
                    <div class="col-4">
                        <div class="border border-dark p-2 h-100 bg-light">
                            <div class="small fw-bold border-bottom border-dark pb-1 mb-1 text-primary">LINE REMARK / NOTES</div>
                            <div class="small text-muted font-monospace">@(string.IsNullOrEmpty(Model.Remark) ? "-" : Model.Remark)</div>
                        </div>
                    </div>
                </div>

                <!-- SCANNER TRIGGER ELIMINATED -->
                <div class="mt-4 no-print d-flex justify-content-center gap-3">
                    <button type="button" id="btnInput" class="btn btn-primary px-4 rounded-pill" data-bs-toggle="modal" data-bs-target="#addReadingModal">
                        <i class="bi bi-plus-circle-fill me-2"></i> INPUT DATA PARAMETER (JAM KE-@(readings.Count))
                    </button>
                </div>
            </div>
        </div>
    </div>

    }
</div>

<!-- ============================================= -->
<!-- MODALS FOR INPUT & SCANNER                    -->
<!-- ============================================= -->

<!-- SCANNER MODAL FOR VERIFICATION -->
<div class="modal fade no-print" id="scannerVerifyModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content scanner-modal-glass border-0">
            <div class="modal-header border-bottom border-info border-opacity-25 pb-2">
                <div class="d-flex align-items-center">
                    <i class="bi bi-shield-check text-info me-2 fs-4"></i>
                    <h5 class="modal-title text-white fw-bold tracking-widest">SPS ITEM VERIFICATION</h5>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" onclick="stopScanner()"></button>
            </div>
            <div class="modal-body p-0 position-relative border-0 bg-black">
                <div class="hud-scanner-overlay" style="aspect-ratio:4/3; overflow:hidden; position:relative;">
                    <div id="reader-verify" style="width:100%;"></div>
                    <div style="position: absolute; top:50%; left:0; width:100%; height:2px; background:linear-gradient(to right, transparent, #0dcaf0, transparent); box-shadow: 0 0 15px #0dcaf0; z-index:10; transform: translateY(-50%);"></div>
                </div>
            </div>
            <div class="modal-footer border-top border-info border-opacity-25 py-2 bg-hud-navy">
                <div class="d-flex w-100 justify-content-between align-items-center px-2">
                    <span class="text-info extra-small tracking-widest"><i class="bi bi-broadcast pulse-info me-1"></i> AWAITING ITEM BARCODE...</span>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-outline-info btn-sm px-4" onclick="switchCamera()">
                            <i class="bi bi-camera-rotate me-1"></i> SWITCH
                        </button>
                        <button type="button" class="btn btn-danger btn-sm px-4" data-bs-dismiss="modal" onclick="stopScanner()">
                            CLOSE
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- MODAL OPERATOR 1 (FULL PARAMETER HUD) -->
<div class="modal fade no-print" id="addReadingModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content scanner-modal-glass border-0">
            <div class="modal-header border-bottom border-primary border-opacity-25 pb-3">
                <div class="d-flex align-items-center">
                    <div class="hud-icon-box me-3"><i class="bi bi-cpu text-primary fs-3"></i></div>
                    <div>
                        <h4 class="modal-title text-white fw-black mb-0">OPERATOR 1 MONITORING</h4>
                        <div class="text-primary-50 small fw-bold">INPUT PARAMETER MESIN - JAM KE-@(readings.Count + 1)</div>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AddReading" method="post" id="parameterForm">
                <input type="hidden" name="ProductionReportId" value="@Model.Id" />
                <input type="hidden" name="RecordedBy" value="Operator 1" />
                <div class="modal-body p-0">
                    <ul class="nav nav-tabs hud-tabs border-0" id="readingTabs" role="tablist">
                        <li class="nav-item flex-grow-1"><button class="nav-link active w-100 py-3" data-bs-toggle="tab" data-bs-target="#tab-inner">INNER (TUBE 1)</button></li>
                        <li class="nav-item flex-grow-1"><button class="nav-link w-100 py-3" data-bs-toggle="tab" data-bs-target="#tab-outer">OUTER (COVER)</button></li>
                        <li class="nav-item flex-grow-1"><button class="nav-link w-100 py-3" data-bs-toggle="tab" data-bs-target="#tab-spiral">SPIRAL & OTHERS</button></li>
                    </ul>

                    <div class="tab-content p-4 bg-hud-navy-dark">
                        <!-- TAB INNER -->
                        <div class="tab-pane fade show active" id="tab-inner">
                            <div class="row g-4">
                                @foreach(var f in new[] { 
                                    new { L="Head Temp", N="HeadTempInner", U="°C" }, new { L="Cyl 1", N="Cylinder1TempInner", U="°C" },
                                    new { L="Cyl 2", N="Cylinder2TempInner", U="°C" }, new { L="Cyl 3", N="Cylinder3TempInner", U="°C" },
                                    new { L="Screw Temp", N="ScrewTempInner", U="°C" }, new { L="Screw Speed", N="ScrewSpeedInner", U="RPM" },
                                    new { L="Feed Roll", N="FeedRollRatioInner", U="%" }, new { L="Pressure", N="PressureInner", U="MPa" }
                                }) {
                                    <div class="col-md-3">
                                        <div class="hud-input-group">
                                            <label class="hud-label">@f.L <span class="unit">(@f.U)</span></label>
                                            <input name="@f.N" type="number" step="0.1" class="hud-input-lg w-100" placeholder="0.0" />
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- TAB OUTER -->
                        <div class="tab-pane fade" id="tab-outer">
                            <div class="row g-4">
                                @foreach(var f in new[] { 
                                    new { L="Head Temp", N="HeadTempOuter", U="°C" }, new { L="Cyl 1", N="Cylinder1TempOuter", U="°C" },
                                    new { L="Cyl 2", N="Cylinder2TempOuter", U="°C" }, new { L="Cyl 3", N="Cylinder3TempOuter", U="°C" },
                                    new { L="Screw Temp", N="ScrewTempOuter", U="°C" }, new { L="Screw Speed", N="ScrewSpeedOuter", U="RPM" },
                                    new { L="Feed Roll", N="FeedRollRatioOuter", U="%" }, new { L="Pressure", N="PressureOuter", U="MPa" }
                                }) {
                                    <div class="col-md-3">
                                        <div class="hud-input-group">
                                            <label class="hud-label text-warning">@f.L <span class="unit">(@f.U)</span></label>
                                            <input name="@f.N" type="number" step="0.1" class="hud-input-lg w-100 border-warning-subtle" placeholder="0.0" />
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- TAB SPIRAL & OTHERS -->
                        <div class="tab-pane fade" id="tab-spiral">
                            <div class="row g-4">
                                <div class="col-md-3"><label class="hud-label text-info">Spiral Speed (rpm)</label><input name="SpiralSpeed" type="number" step="0.1" class="hud-input-lg w-100" /></div>
                                <div class="col-md-3"><label class="hud-label text-info">Pitch (Set)</label><input name="SpiralPitchSetting" type="number" step="0.1" class="hud-input-lg w-100" /></div>
                                <div class="col-md-3"><label class="hud-label text-info">Pitch (Disp)</label><input name="SpiralPitchDisplay" type="number" step="0.1" class="hud-input-lg w-100" /></div>
                                <div class="col-md-3"><label class="hud-label text-info">Hose Speed (m/min)</label><input name="HoseSpeed" type="number" step="0.1" class="hud-input-lg w-100" /></div>
                                
                                <div class="col-md-4"><label class="hud-label text-success">Take-up Speed</label><input name="TakeupConveyorSpeed" type="number" step="0.1" class="hud-input-lg w-100" /></div>
                                <div class="col-md-4"><label class="hud-label text-success">Cool Conv Speed</label><input name="CoolConveyorSpeed" type="number" step="0.1" class="hud-input-lg w-100" /></div>
                                <div class="col-md-4"><label class="hud-label text-success">Conv Ratio (%)</label><input name="ConveyorRatio" type="text" class="hud-input-lg w-100" placeholder="100%" /></div>
                                
                                <div class="col-md-3"><label class="hud-label">Chiller Temp</label><input name="ChillerWaterTemp" type="number" step="0.1" class="hud-input-lg w-100" /></div>
                                <div class="col-md-3"><label class="hud-label">Preset View</label><input name="PresetValue" type="number" step="0.1" class="hud-input-lg w-100" /></div>
                                <div class="col-md-3"><label class="hud-label">Control Value</label><input name="ControlValue" type="number" step="0.1" class="hud-input-lg w-100" /></div>
                                <div class="col-md-3"><label class="hud-label">Caterpillar Gap</label><input name="CaterpillarGap" type="number" step="0.1" class="hud-input-lg w-100" /></div>
                                
                                <div class="col-12"><label class="hud-label text-danger">Unsmooth Surface (mm)</label><input name="UnsmoothSurface" type="number" step="0.01" class="hud-input-lg w-100 text-danger" placeholder="0.5" /></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top border-primary border-opacity-10 bg-hud-navy">
                    <button type="button" class="btn btn-outline-light px-4" data-bs-dismiss="modal">CANCEL</button>
                    <button type="submit" class="btn btn-primary px-5 fw-bold neon-pulse-blue">SUBMIT ALL READINGS</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL OPERATOR 2 (DIMENSION HUD) -->
<div class="modal fade no-print" id="addDimModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content scanner-modal-glass border-0">
            <div class="modal-header border-bottom border-success border-opacity-25 pb-3">
                <div class="d-flex align-items-center">
                    <div class="hud-icon-box bg-success bg-opacity-10 me-3"><i class="bi bi-rulers text-success fs-3"></i></div>
                    <div>
                        <h4 class="modal-title text-white fw-black mb-0">OPERATOR 2 - QUALITY CONTROL</h4>
                        <div class="text-success-50 small fw-bold">INPUT DIMENSI & VISUAL - @DateTime.Now.ToString("HH:mm")</div>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AddDimensionReading" method="post">
                <input type="hidden" name="ProductionReportId" value="@Model.Id" />
                <div class="modal-body p-4 bg-hud-navy-dark">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="hud-input-group border-success border-opacity-10">
                                <label class="hud-label text-success">Inner Diameter (mm)</label>
                                <input name="InnerDiameter" type="number" step="0.01" class="hud-input-lg w-100 text-success" placeholder="0.00" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="hud-input-group">
                                <label class="hud-label">Thick X (mm)</label>
                                <input name="InnerThicknessX" type="number" step="0.01" class="hud-input-lg w-100" placeholder="0.00" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="hud-input-group">
                                <label class="hud-label">Thick Y (mm)</label>
                                <input name="InnerThicknessY" type="number" step="0.01" class="hud-input-lg w-100" placeholder="0.00" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="hud-input-group">
                                <label class="hud-label">Total X (mm)</label>
                                <input name="TotalThicknessX" type="number" step="0.01" class="hud-input-lg w-100" placeholder="0.00" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="hud-input-group">
                                <label class="hud-label">Total Y (mm)</label>
                                <input name="TotalThicknessY" type="number" step="0.01" class="hud-input-lg w-100" placeholder="0.00" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="hud-input-group">
                                <label class="hud-label">Spiral Pitch (mm)</label>
                                <input name="SpiralPitch" type="number" step="0.01" class="hud-input-lg w-100" placeholder="0.00" />
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="hud-input-group bg-dark bg-opacity-25">
                                <label class="hud-label">Visual Status Check</label>
                                <div class="d-flex gap-2">
                                    <input type="radio" class="btn-check" name="VisualCheck" id="v-ok" value="OK" checked>
                                    <label class="btn btn-outline-success flex-grow-1 py-3 fw-bold" for="v-ok">OK - PASSED</label>
                                    
                                    <input type="radio" class="btn-check" name="VisualCheck" id="v-sc" value="SC">
                                    <label class="btn btn-outline-warning flex-grow-1 py-3 fw-bold" for="v-sc">SC - SCRATCH</label>
                                    
                                    <input type="radio" class="btn-check" name="VisualCheck" id="v-ng" value="NG">
                                    <label class="btn btn-outline-danger flex-grow-1 py-3 fw-bold" for="v-ng">NG - REJECT</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top border-success border-opacity-10 bg-hud-navy">
                    <button type="button" class="btn btn-outline-light px-4" data-bs-dismiss="modal">CANCEL</button>
                    <button type="submit" class="btn btn-success px-5 fw-bold">SAVE QUALITY DATA</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL FINISH PRODUCTION & WASTE -->
<div class="modal fade no-print" id="finishProductionModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content scanner-modal-glass border-0">
            <div class="modal-header border-bottom border-danger border-opacity-25 pb-3">
                <div class="d-flex align-items-center">
                    <div class="hud-icon-box bg-danger bg-opacity-10 me-3"><i class="bi bi-flag-fill text-danger fs-3"></i></div>
                    <div>
                        <h4 class="modal-title text-white fw-black mb-0">PRODUCTION FINAL RECAP</h4>
                        <div class="text-danger-50 small fw-bold">INPUT WASTE & SELESAIKAN PROSES</div>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="FinishProduction" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="modal-body p-4 bg-hud-navy-dark">
                    <div class="row g-4">
                        <!-- WASTE SECTION -->
                        <div class="col-12">
                            <h6 class="text-white-50 border-bottom border-white border-opacity-10 pb-2 mb-3 fw-bold">DANDORY & WASTE (KG)</h6>
                            <div class="row g-3">
                                <div class="col-md-3"><label class="hud-label">INNER AWAL</label><input name="WasteInnerAwal" type="number" step="0.01" class="hud-input-lg w-100" value="@Model.WasteInnerAwal" /></div>
                                <div class="col-md-3"><label class="hud-label">INNER AKHIR</label><input name="WasteInnerAkhir" type="number" step="0.01" class="hud-input-lg w-100" value="@Model.WasteInnerAkhir" /></div>
                                <div class="col-md-3"><label class="hud-label">COVER AWAL</label><input name="WasteCoverAwal" type="number" step="0.01" class="hud-input-lg w-100" value="@Model.WasteCoverAwal" /></div>
                                <div class="col-md-3"><label class="hud-label">COVER AKHIR</label><input name="WasteCoverAkhir" type="number" step="0.01" class="hud-input-lg w-100" value="@Model.WasteCoverAkhir" /></div>
                            </div>
                        </div>

                        <!-- RECAP SECTION -->
                        <div class="col-12">
                            <h6 class="text-white-50 border-bottom border-white border-opacity-10 pb-2 mb-3 fw-bold">FINAL ACCOMPLISHMENT</h6>
                            <div class="row g-3">
                                <div class="col-md-4"><label class="hud-label text-info">Qty OK (Pcs/m)</label><input name="qtyOk" id="finish-ok" type="number" class="hud-input-lg w-100" value="@Model.QtyOk" /></div>
                                <div class="col-md-4"><label class="hud-label text-warning">NG Dimension</label><input name="ngDim" id="finish-ng-dim" type="number" class="hud-input-lg w-100" value="@Model.NgDimension" /></div>
                                <div class="col-md-4"><label class="hud-label text-danger">NG Visual</label><input name="ngVis" id="finish-ng-vis" type="number" class="hud-input-lg w-100" value="@Model.NgVisual" /></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top border-danger border-opacity-10 bg-hud-navy">
                    <div class="me-auto text-white">
                        <span class="small opacity-50 fw-bold">TOTAL QTY:</span>
                        <span class="fs-4 fw-black text-primary" id="finish-total-display">0</span>
                    </div>
                    <button type="button" class="btn btn-outline-light px-4" data-bs-dismiss="modal">CANCEL</button>
                    <button type="submit" class="btn btn-danger px-5 fw-bold neon-pulse-red" onclick="return confirm('Apakah Anda yakin ingin menyelesaikan produksi ini?')">FINISH PRODUCTION</button>
                </div>
            </form>
        </div>
    </div>
</div>

