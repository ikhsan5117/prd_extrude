@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script>
        function downloadPDF() {
            const element = document.getElementById('printArea');
            if (!element) return;

            // Deteksi portal mana yang aktif
            const portal = new URLSearchParams(window.location.search).get('portal') || 'dashboard';
            const isIdentity = portal === 'identity';
            const isDimension = portal === 'dimension';
            const isDashboard = portal === 'dashboard' || portal === '';

            if (isIdentity) {
                Swal.fire({ title: 'GENERATING PDF...', html: 'Mempersiapkan laporan...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });

                html2pdf().set({
                    margin: [4, 3, 4, 3],
                    filename: 'IdentityCard_@(Model.DocumentNumber.Replace("/", "_")).pdf',
                    image: { type: 'png' },
                    html2canvas: {
                        scale: 2,
                        useCORS: true,
                        allowTaint: false,
                        backgroundColor: '#ffffff',
                        onclone: (clonedDoc) => {
                            // Rapikan printArea
                            const pa = clonedDoc.getElementById('printArea');
                            if (pa) pa.style.cssText = 'padding:0;margin:0;background:white;min-height:auto;display:block;';

                            // Perkecil landscape-sheet agar muat A4 landscape
                            const sheet = clonedDoc.querySelector('.landscape-sheet');
                            if (sheet) sheet.style.cssText = 'width:1000px;min-height:auto;padding:12px;border:3px solid #000;box-shadow:none;font-size:8px;margin:0;';

                            const inner = clonedDoc.querySelector('.inner-border');
                            if (inner) inner.style.padding = '10px';

                            clonedDoc.querySelectorAll('.hand-ink').forEach(el => el.style.fontSize = '1.1rem');
                            clonedDoc.querySelectorAll('.label-main').forEach(el => el.style.fontSize = '0.8rem');
                            clonedDoc.querySelectorAll('.header-title').forEach(el => el.style.fontSize = '1.8rem');

                            // Fix image paths
                            clonedDoc.querySelectorAll('img').forEach(img => {
                                const src = img.getAttribute('src') || '';
                                if (src && !src.startsWith('http') && !src.startsWith('data:')) {
                                    img.src = window.location.origin + (src.startsWith('/') ? src : '/' + src);
                                }
                            });
                        }
                    },
                    jsPDF: { unit: 'mm', format: 'a4', orientation: 'landscape' },
                    pagebreak: { mode: ['avoid-all'] }
                }).from(element).save()
                .then(() => Swal.fire({ icon: 'success', title: 'DOWNLOAD COMPLETE', timer: 1500, showConfirmButton: false }))
                .catch(err => Swal.fire({ icon: 'error', title: 'GAGAL', text: err.message }));
                return;
            }

            // =============================================
            // PORTAL LAIN: Pakai html2pdf seperti biasa
            // =============================================
            Swal.fire({
                title: 'GENERATING PDF...',
                html: 'Mempersiapkan laporan produksi...',
                allowOutsideClick: false,
                didOpen: () => Swal.showLoading()
            });

            const isLandscape = portal === 'identity' || portal === 'dimension';

            const opt = {
                margin:      [3, 3, 3, 3],
                filename:    'Report_@(Model.DocumentNumber.Replace("/", "_"))_' + portal.toUpperCase() + '.pdf',
                image:       { type: 'png' },
                html2canvas: {
                    scale: 3,
                    useCORS: true,
                    allowTaint: false,
                    backgroundColor: '#ffffff',
                    letterRendering: true,
                    onclone: (clonedDoc) => {
                        const clonedEl = clonedDoc.getElementById('printArea');
                        if (clonedEl) {
                            clonedEl.style.background = 'white';
                            clonedEl.style.padding = '0';
                            clonedEl.style.margin = '0';
                            clonedEl.style.minHeight = 'auto';

                            if (portal === 'identity') {
                                const sheet = clonedEl.querySelector('.landscape-sheet');
                                if (sheet) {
                                    sheet.style.width = '1000px';
                                    sheet.style.minHeight = 'auto';
                                    sheet.style.padding = '15px 20px';
                                    sheet.style.fontSize = '9px';
                                    sheet.style.boxShadow = 'none';
                                }
                            } else {
                                const isDashboardPortal = (portal === 'dashboard' || portal === '');
                                // Apply pdf-fit to compress vertical height, and use 950px width for a good portrait fit
                                const targetWidth = portal === 'dimension' ? '1050px' : '950px';
                                clonedEl.style.width = targetWidth;
                                
                                // Always apply pdf-fit to compress table padding and fonts
                                clonedEl.classList.add('pdf-fit');
                                
                                const paper = clonedEl.querySelector('.paper-replica');
                                if (paper) {
                                    paper.style.width = targetWidth;
                                    paper.style.maxWidth = 'none';
                                    paper.style.margin = '0 auto';
                                    paper.style.padding = isDashboardPortal ? '0' : '5px';
                                    paper.style.boxShadow = 'none';
                                    paper.style.border = '2px solid #000';
                                }
                            }
                        }
                        // Fix image paths
                        clonedDoc.querySelectorAll('img').forEach(img => {
                            const src = img.getAttribute('src') || '';
                            if (src && !src.startsWith('http') && !src.startsWith('data:')) {
                                img.src = window.location.origin + (src.startsWith('/') ? src : '/' + src);
                            }
                        });
                    }
                },
                jsPDF:       { unit: 'mm', format: 'a4', orientation: isLandscape ? 'landscape' : 'portrait' },
                pagebreak:   { mode: ['avoid-all', 'css', 'legacy'] }
            };

            html2pdf().set(opt).from(element).save()
                .then(() => {
                    Swal.fire({ icon: 'success', title: 'DOWNLOAD SUCCESS', timer: 1500, showConfirmButton: false });
                })
                .catch(err => {
                    Swal.fire({ icon: 'error', title: 'DOWNLOAD FAILED', text: err.message });
                });
        }
    </script>
    <script src="https://unpkg.com/html5-qrcode"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // ==========================================
        // SCANNER ITEM VERIFICATION LOGIC
        // ==========================================
        let html5QrCode;
        let cameraDevices = [];
        let currentCamIdx = 0;

        async function startVerifyScanner() {
            const mEl = document.getElementById('scannerVerifyModal');
            const modal = new bootstrap.Modal(mEl);
            modal.show();
            
            try {
                cameraDevices = await Html5Qrcode.getCameras();
                if (cameraDevices && cameraDevices.length > 0) {
                    currentCamIdx = cameraDevices.findIndex(c => 
                        c.label.toLowerCase().includes('back') || c.label.toLowerCase().includes('environment')
                    );
                    if (currentCamIdx === -1) currentCamIdx = 0;
                }
                if (html5QrCode && html5QrCode.isScanning) {
                    await html5QrCode.stop();
                }
                initScanner();
            } catch (err) {
                initScanner(); 
            }
        }

        function initScanner() {
            if (!html5QrCode) html5QrCode = new Html5Qrcode("reader-verify");
            
            let target = { facingMode: "environment" };
            if (cameraDevices && cameraDevices.length > 0 && cameraDevices[currentCamIdx]) {
                target = cameraDevices[currentCamIdx].id;
            }
            
            html5QrCode.start(target, { fps: 20, aspectRatio: 1.0 }, onScanSuccess)
                .catch(e => {
                    if (!cameraDevices || cameraDevices.length === 0) {
                        html5QrCode.start({ facingMode: "user" }, { fps: 20, aspectRatio: 1.0 }, onScanSuccess);
                    }
                });
        }

        async function switchCamera() {
            if (!html5QrCode) return;
            if (cameraDevices.length > 1) {
                currentCamIdx = (currentCamIdx + 1) % cameraDevices.length;
                if (html5QrCode.isScanning) {
                    await html5QrCode.stop();
                    initScanner();
                }
            } else {
                const isEnv = html5QrCode.isScanning ? true : false; 
                await html5QrCode.stop();
                html5QrCode.start({ facingMode: isEnv ? "user" : "environment" }, { fps: 20, aspectRatio: 1.0 }, onScanSuccess);
            }
        }

        async function stopScanner() {
            if (html5QrCode && html5QrCode.isScanning) {
                try { await html5QrCode.stop(); } catch (e) {}
            }
        }

        async function onScanSuccess(decodedText) {
            stopScanner();
            const modalEl = document.getElementById('scannerVerifyModal');
            const modal = bootstrap.Modal.getInstance(modalEl);
            if (modal) modal.hide();

            Swal.fire({
                title: 'VERIFYING DATA...',
                text: 'Memeriksa kecocokan Part List dengan Standard...',
                allowOutsideClick: false,
                background: '#0d1117',
                color: '#fff',
                didOpen: () => Swal.showLoading()
            });

            try {
                const res = await fetch(`/ProductionReport/GetMasterByItem?itemCode=${encodeURIComponent(decodedText)}`);
                const data = await res.json();
                
                const currentHoseType = '@Model.HoseType';
                
                if (data && data.hoseType === currentHoseType) {
                    // Match! Kunci dibuka
                    Swal.fire({
                        icon: 'success',
                        title: 'VERIFIED MATCH!',
                        html: `Hose Type: <b class="text-success">${data.hoseType}</b>.<br/>Akses Input Parameter Dibuka!`,
                        background: '#0d1117', color: '#fff'
                    });
                    
                    document.getElementById('btnInput').classList.remove('opacity-50', 'pe-none');
                    document.getElementById('iconLock').classList.replace('bi-lock-fill', 'bi-unlock-fill');
                    document.getElementById('textInput').innerText = 'INPUT DATA PARAMETER';
                    
                    var btnVerify = document.getElementById('btnVerify');
                    btnVerify.classList.replace('btn-outline-info', 'btn-success');
                    btnVerify.innerHTML = '<i class="bi bi-shield-check me-2"></i> VERIFIED';
                    btnVerify.classList.add('pe-none');
                } else {
                    // Reject
                    Swal.fire({
                        icon: 'error',
                        title: 'SPEC MISMATCH / REJECTED',
                        html: `Part List <b class="text-warning">${decodedText}</b> memiliki Hose Type: <b>${data ? data.hoseType : 'Tidak Ditemukan'}</b>.<br/>Sangat tidak sesuai dengan produksi saat ini (<b>${currentHoseType}</b>).`,
                        background: '#3f1115', color: '#fff'
                    });
                }
            } catch (e) {
                Swal.fire({ icon: 'error', title: 'SERVER ERROR', background: '#0d1117', color: '#fff' });
            }
        }

        async function saveRecap() {
            const data = {
                reportId: @Model.Id,
                vinCode: document.getElementById('rec-vincode').value,
                qtyOk: document.getElementById('rec-ok').value,
                ngDim: document.getElementById('rec-ngdim').value,
                ngVis: document.getElementById('rec-ngvis').value,
                remark: document.getElementById('rec-remark').value
            };

            const res = await fetch('/ProductionReport/UpdateRecap', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams(data)
            });
            const result = await res.json();
            if (result.success) {
                Swal.fire({ icon: 'success', title: 'Recap Saved!', toast: true, position: 'top-end', showConfirmButton: false, timer: 2000 });
            }
        }

        async function saveDimRecap() {
            const data = {
                reportId: @Model.Id,
                actualLength: document.getElementById('rec-actlen').value,
                qtyOk: document.getElementById('rec-qtyok').value,
                ngDim: document.getElementById('rec-ngdim').value,
                ngVis: document.getElementById('rec-ngvis').value,
                remark: document.getElementById('rec-remark-dim').value
            };

            const res = await fetch('/ProductionReport/UpdateRecap', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams(data)
            });
            const result = await res.json();
            if (result.success) {
                Swal.fire({ 
                    icon: 'success', 
                    title: 'DIMENSION RECAP UPDATED', 
                    toast: true, 
                    position: 'top-end', 
                    showConfirmButton: false, 
                    timer: 2000,
                    background: '#0d1117',
                    color: '#fff'
                });
            }
        }

        // Live Total Qty Calculation for Finish Modal
        const finishInputs = ['finish-ok', 'finish-ng-dim', 'finish-ng-vis'];
        function updateFinishTotal() {
            const ok = parseInt(document.getElementById('finish-ok')?.value) || 0;
            const ngDim = parseInt(document.getElementById('finish-ng-dim')?.value) || 0;
            const ngVis = parseInt(document.getElementById('finish-ng-vis')?.value) || 0;
            const display = document.getElementById('finish-total-display');
            if (display) display.innerText = ok + ngDim + ngVis;
        }
        finishInputs.forEach(id => {
            const el = document.getElementById(id);
            if (el) el.addEventListener('input', updateFinishTotal);
        });
        updateFinishTotal(); // Initial call

        // APPROVAL PROTOCOL LOGIC
        function openApprovalModal(role) {
            Swal.fire({
                title: `VERIFIKASI ${role}`,
                html: `
                    <div class="text-center p-3">
                        <i class="bi bi-shield-lock-fill text-info fs-1 mb-3"></i>
                        <div class="text-white-50 small mb-3">SILAKAN MASUKKAN PIN ATAU SCAN ID CARD</div>
                        <input type="password" id="staffPin" class="form-control text-center bg-dark text-white fw-bold fs-4 border-info" 
                               placeholder="****" maxlength="6" style="letter-spacing: 10px;">
                    </div>
                `,
                background: '#0d1117',
                color: '#fff',
                showCancelButton: true,
                confirmButtonText: 'VERIFY NOW',
                confirmButtonColor: '#3b82f6',
                preConfirm: () => {
                    const pin = Swal.getPopup().querySelector('#staffPin').value;
                    if (!pin) { Swal.showValidationMessage('PIN WAJIB DIISI!'); return false; }
                    return { pin: pin };
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    verifyStaff(role, result.value.pin);
                }
            });
        }

        async function verifyStaff(role, pin) {
            const res = await fetch('/ProductionReport/VerifyApproval', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ id: @Model.Id, role: role, pin: pin })
            });
            const data = await res.json();
            if (data.success) {
                Swal.fire({ icon: 'success', title: 'VERIFIKASI BERHASIL!', text: `Terima kasih, ${data.name}`, timer: 1500, showConfirmButton: false });
                setTimeout(() => location.reload(), 1500);
            } else {
                Swal.fire({ icon: 'error', title: 'GAGAL!', text: data.message });
            }
        }
    </script>
}
