                                </td>
                            </tr>
                            <tr>
                                <td class="text-start ps-2">Outer</td>
                                <td class="p-0 align-middle px-2">
                                    <label class="mb-0 d-flex align-items-center gap-1" style="font-size: 11px;"><input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" @(Model.MeshOuterCheck == "OK" ? "checked" : "") style="width:13px; height:13px;"> OK</label>
                                </td>
                                <td class="p-0 align-middle px-2">
                                    <label class="mb-0 d-flex align-items-center gap-1" style="font-size: 11px;"><input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" @(Model.MeshOuterCheck == "BOLONG" ? "checked" : "") style="width:13px; height:13px;"> Bolong</label>
                                </td>
                                <td class="p-0 align-middle px-2 border-end-0">
                                    <label class="mb-0 d-flex align-items-center gap-1" style="font-size: 11px;"><input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" @(Model.MeshOuterCheck == "ASING" ? "checked" : "") style="width:13px; height:13px;"> Material Asing</label>
                                </td>
                            </tr>

                            <!-- Emboss Marking -->
                            <tr class="border-top-form">
                                <td rowspan="5" class="align-middle text-center p-1 border-bottom-0" style="background-color: #f4f4f4; font-size: 11px;">Emboss<br/>Marking<br/>Check<br/>(Setelah<br/>Proses)</td>
