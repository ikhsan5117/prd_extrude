                                </td>
                                <td colspan="2" class="p-0 align-middle px-2 border-end-0">
                                    <label class="mb-0 d-flex align-items-center gap-1" style="font-size: 11px;"><input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" @(Model.QcCond == "KOTOR" ? "checked" : "") style="width:13px; height:13px;"> Kotor</label>
                                </td>
                            </tr>
                            <tr>
                                <td class="text-start ps-2">Surface</td>
