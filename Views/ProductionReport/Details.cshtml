@inject VelastoProductionSystem.Data.ApplicationDbContext _context
@model VelastoProductionSystem.Models.ProductionReport

@{
    ViewData["Title"] = "Production Monitoring Dashboard";
    var readings = Model.ProductionReadings.OrderBy(r => r.ReadingTime).ToList();
    var std = (ViewBag.Sps as VelastoProductionSystem.Models.SpsNoDoc) ?? new VelastoProductionSystem.Models.SpsNoDoc();
    var currentPortal = Context.Request.Query["portal"].ToString();

    // Helpers for robust parsing
    decimal D(string? s, decimal def) {
        if (string.IsNullOrEmpty(s)) return def;
        var matches = System.Text.RegularExpressions.Regex.Matches(s.Replace(",", "."), @"\d+(?:\.\d+)?");
        return (matches.Count > 0) ? decimal.Parse(matches[0].Value, System.Globalization.CultureInfo.InvariantCulture) : def;
    }
    decimal DTol(string? s, decimal def) {
        if (string.IsNullOrEmpty(s)) return def;
        var matches = System.Text.RegularExpressions.Regex.Matches(s.Replace(",", "."), @"\d+(?:\.\d+)?");
        if (matches.Count == 0) return def;
        decimal val = decimal.Parse(matches[matches.Count - 1].Value, System.Globalization.CultureInfo.InvariantCulture);
        return (val > 2.0m) ? def : val;
    }
}

<div class="production-dashboard-sapphire fade-in">
    <!-- PREMUIM ACTION TOOLBAR (No Print) -->
    <div class="no-print sticky-top mb-4 p-2 p-md-3 bg-hud-navy-dark border-bottom border-primary border-opacity-25 shadow-lg fade-in" style="z-index: 1000; backdrop-filter: blur(15px); margin-top: 70px; border-radius: 0 0 20px 20px;">
        <div class="container-fluid d-flex flex-column flex-xl-row align-items-center justify-content-between gap-3">
            <div class="d-flex flex-wrap align-items-center justify-content-center gap-2 gap-md-3">
                @{
                    var backUrl = "/ProductionReport/Index";
                    var backLabel = "MONITOR";
                    var userRole = Context.Session.GetString("UserRole");
                    var isOperator = userRole != "ADMIN_ENG" && userRole != "LEADER_QC";
                    var referer = Context.Request.Headers["Referer"].ToString();
                    
                    if (currentPortal == "dimension") {
                        backUrl = "/ProductionReport/DimensionHistory";
                        backLabel = "HISTORY";
                    } else if (currentPortal == "parameter") {
                        backUrl = "/ProductionReport/ParameterHistory";
                        backLabel = "HISTORY";
                    } else if (isOperator) {
                        if (!string.IsNullOrEmpty(referer) && (referer.Contains("/Dimensi/Index") || referer.Contains("/ProductionReport/Create"))) {
                            backUrl = referer;
                        } else {
                            backUrl = "/ProductionReport/Create";
                        }
                        backLabel = "MENU INPUT";
                    } else if (referer.Contains("ParameterHistory")) {
                        backUrl = "/ProductionReport/ParameterHistory";
                        backLabel = "HISTORY";
                    }
                }
                <a href="@backUrl" class="btn btn-outline-light btn-sm px-3 rounded-pill border-opacity-25">
                    <i class="bi bi-arrow-left me-1 me-md-2"></i> <span class="d-none d-sm-inline">KEMBALI KE @backLabel</span><span class="d-inline d-sm-none">KEMBALI</span>
                </a>
                <div class="vr bg-white opacity-25 d-none d-md-block" style="height: 24px;"></div>
                <div class="btn-group btn-group-sm rounded-pill p-1 bg-black bg-opacity-25 border border-white border-opacity-10">
                    <a href="?id=@Model.Id&portal=dashboard" class="btn rounded-pill px-3 px-md-4 @(currentPortal != "identity" ? "btn-primary shadow-glow" : "btn-link text-white text-decoration-none opacity-50")">
                        <i class="bi bi-speedometer2 me-1"></i><span class="d-none d-sm-inline">DASHBOARD</span><span class="d-inline d-sm-none">DASH</span>
                    </a>
                    <a href="?id=@Model.Id&portal=identity" class="btn rounded-pill px-3 px-md-4 @(currentPortal == "identity" ? "btn-info shadow-glow" : "btn-link text-white text-decoration-none opacity-50")">
                        <i class="bi bi-card-checklist me-1"></i><span class="d-none d-sm-inline">IDENTITY CARD</span><span class="d-inline d-sm-none">ID CARD</span>
                    </a>
                </div>
            </div>

            <div class="d-flex flex-wrap align-items-center justify-content-center gap-2">
                <button onclick="downloadPDF()" class="btn btn-outline-info btn-sm px-3 px-md-4 rounded-pill fw-bold neon-glow-info">
                    <i class="bi bi-file-earmark-pdf me-1"></i> <span class="d-none d-sm-inline">DOWNLOAD PDF</span><span class="d-inline d-sm-none">PDF</span>
                </button>
                <button onclick="window.print()" class="btn btn-outline-primary btn-sm px-3 px-md-4 rounded-pill fw-bold">
                    <i class="bi bi-printer me-1"></i> <span class="d-none d-sm-inline">PRINT REPORT</span><span class="d-inline d-sm-none">PRINT</span>
                </button>
            </div>
        </div>
    </div>

    @if (currentPortal == "identity")
    {
        <style>
            @@import url('https://fonts.googleapis.com/css2?family=Caveat:wght@700&display=swap');
            @@media print {
                @@page { size: landscape; margin: 0; }
                body { margin: 0; }
                .no-print { display: none !important; }
            }
            .landscape-sheet { 
                background: white; 
                width: 1350px; /* Maksimal lebar untuk visibilitas tinggi */
                min-height: 750px;
                padding: 10px; 
                color: #000; 
                font-family: 'Segoe UI', Arial, sans-serif; 
                border: 2px solid #000; 
                margin: 0 auto; 
                box-shadow: 0 0 40px rgba(0,0,0,0.1); 
                position: relative; 
            }
            .inner-border {
                border: 1px solid #000;
                padding: 10px;
                height: 100%;
                width: 100%;
            }
            .landscape-sheet table { border-collapse: collapse; border: 1px solid #000; width: 100%; }
            .landscape-sheet td, .landscape-sheet th { border: 1px solid #000; padding: 3px 6px; font-size: 10px; line-height: 1.1; color: #000; }
            .hand-ink { font-family: 'Caveat', cursive; color: #0033cc; font-size: 1.8rem; vertical-align: bottom; font-weight: bold; }
            .dots-fill { border-bottom: 2px solid #000; flex-grow: 1; min-height: 32px; display: inline-block; margin-left: 5px; position: relative; }
            .label-main { font-size: 1.2rem; color: #000; font-weight: 500; white-space: nowrap; }
            .header-title { text-align: center; font-size: 2.8rem; font-weight: bold; margin-bottom: 0; letter-spacing: 3px; }
            .spv-box-outer { border: 2px solid #000; width: 160px; padding: 8px; height: 180px; display: flex; flex-direction: column; align-items: center; justify-content: space-between; }
            .spv-sq { width: 120px; height: 45px; border: 2px solid #000; margin: 2px 0; }
            .border-bottom-form-bold { border-bottom: 3px solid #000; }
            .border-end-form { border-right: 2px solid #000; }
            .super-small { font-size: 8px; text-transform: uppercase; color: #000; }
        </style>

        <div id="printArea" class="fade-in py-5 bg-secondary bg-opacity-10" style="min-height: 100vh; overflow-x: auto; -webkit-overflow-scrolling: touch;">
            <div class="d-inline-flex min-w-100 justify-content-center p-3" style="min-width: 1450px;">
                <div class="landscape-sheet">
                    <div class="inner-border">
                    <!-- ROW 1: HEADER -->
                    <div class="row align-items-start mb-2">
                        <div class="col-4"></div>
                        <div class="col-4 text-center">
                            <h1 class="header-title">NOW I'M PRODUCE :</h1>
                        </div>
                        <div class="col-4 text-end">
                            <table style="width: 300px; display: inline-table;">
                                <tr><td style="width: 45%; background: #f8f9fa;">No. Dokumen</td><td>: @Model.DocumentNumber</td></tr>
                                <tr><td style="background: #f8f9fa;">No. Revisi</td><td>: @Model.RevisionNumber</td></tr>
                                <tr><td style="background: #f8f9fa;">Effective Date</td><td>: @Model.CreatedDate.ToString("dd.MM.yy")</td></tr>
                            </table>
                        </div>
                    </div>

                    <!-- 1:1 PHOTO REPLICA: 3 COLUMN MAIN BLOCK -->
                    <div class="row g-0 mt-2 mb-5 align-items-start">
                        
                        <!-- COLUMN 1: IDENTITIES -->
                        <div class="col-4">
                            <div class="d-flex flex-column gap-3 pe-4">
                                <div class="d-flex align-items-end">
                                    <span class="label-main" style="width: 130px;">1. Hose Type</span>
                                    <div class="dots-fill"><span class="hand-ink" style="position: absolute; left: 10px; bottom: 2px; transform: rotate(-1.5deg);">: @Model.HoseType</span></div>
                                </div>
                                <div class="d-flex align-items-end">
                                    <span class="label-main" style="width: 130px;">2. Class</span>
                                    <div class="dots-fill"><span class="hand-ink" style="position: absolute; left: 10px; bottom: 2px; transform: rotate(-0.5deg);">: @Model.CustomerName</span></div>
                                </div>
                                <div class="d-flex align-items-end">
                                    <span class="label-main" style="width: 130px;">3. Dimension</span>
                                    <div class="dots-fill"><span class="hand-ink" style="position: absolute; left: 10px; bottom: 2px; transform: rotate(1deg);">: ø @Model.Dimension</span></div>
                                </div>
                                <div class="d-flex align-items-end">
                                    <span class="label-main" style="width: 130px;">4. Yarn</span>
                                    <div class="dots-fill"><span class="hand-ink" style="position: absolute; left: 10px; bottom: 2px; transform: rotate(-1.5deg);">: @(Model.YarnActual ?? Model.Yarn)</span></div>
                                </div>
                            </div>
                        </div>

                        <!-- COLUMN 2: DATE & TIMING -->
                        <div class="col-4 px-3">
                            <div class="d-flex align-items-end mb-4">
                                <span class="label-main" style="font-size: 1.4rem;">Date</span>
                                <div class="dots-fill text-center ms-3" style="width: 250px;"><span class="hand-ink" style="position: absolute; left: 20px; bottom: 2px; transform: rotate(-1deg);">: @Model.ProductionDate.ToString("dd.MM.yy")</span></div>
                            </div>
                            
                            <div class="d-flex gap-3 align-items-start mb-4">
                                <span class="fw-bold label-main" style="width: 100px; font-size: 1.4rem;">Dandori</span>
                                <table style="width: 240px; border: 1px solid #000;">
                                    <tr><th rowspan="2" style="width: 100px;"></th><th colspan="2" class="text-center">Waktu</th></tr>
                                    <tr><th class="text-center">Awal</th><th class="text-center">Akhir</th></tr>
                                    <tr><td style="font-size: 9px; padding: 1px 4px;">Start Prod.</td><td class="text-center hand-ink" style="font-size:12px">@Model.DAI_Awal</td><td class="text-center hand-ink" style="font-size:12px">@Model.DAI_Akhir</td></tr>
                                    <tr><td style="font-size: 9px; padding: 1px 4px;">Akhir Prod.</td><td class="text-center hand-ink" style="font-size:12px">@Model.DRAI_Awal</td><td class="text-center hand-ink" style="font-size:12px">@Model.DRAI_Akhir</td></tr>
                                </table>
                            </div>

                            <div class="d-flex gap-3 align-items-start">
                                <span class="fw-bold label-main" style="width: 100px; font-size: 1.4rem; padding-top: 10px;">Production</span>
                                <table style="width: 180px; border: 1px solid #000; margin-top: 10px;">
                                    <tr><th colspan="2" class="text-center">Waktu</th></tr>
                                    <tr><th class="text-center">Awal</th><th class="text-center">Akhir</th></tr>
                                    <tr><td class="text-center hand-ink" style="height: 30px; vertical-align:middle; font-size:14px">@Model.DAC_Awal</td><td class="text-center hand-ink" style="height: 30px; vertical-align:middle; font-size:14px">@Model.DAC_Akhir</td></tr>
                                </table>
                            </div>
                        </div>

                        <!-- COLUMN 3: TARGET TABLES -->
                        <div class="col-4 ps-5">
                            <div class="mb-4">
                                <div class="fw-bold mb-1" style="font-size: 9px; letter-spacing: 0.5px;">CHS 2 L DANDORY TARGET</div>
                                <table style="width: 100%; text-align: center; font-size: 7px;">
                                    <tr class="fw-bold"><td>TARGET TIME</td><td>DIES</td><td>MATERIAL</td><td>BENANG</td></tr>
                                    <tr><td>20 Minute</td><td>O</td><td>O</td><td>-</td></tr>
                                    <tr><td>40 Minute</td><td>O</td><td>O</td><td>O</td></tr>
                                    <tr><td>55 Minute</td><td>O</td><td>O</td><td>O</td></tr>
                                </table>
                            </div>
                            <div>
                                <div class="fw-bold mb-1" style="font-size: 9px; letter-spacing: 0.5px;">CHS 3 L DANDORY TARGET</div>
                                <table style="width: 100%; text-align: center; font-size: 7px;">
                                    <tr class="fw-bold"><td>TARGET TIME</td><td>DIES</td><td>MATERIAL</td><td>BENANG</td></tr>
                                    <tr><td>30 Minute</td><td>O</td><td>O</td><td>-</td></tr>
                                    <tr><td>45 Minute</td><td>O</td><td>O</td><td>O</td></tr>
                                    <tr><td>60 Minute</td><td>O</td><td>O</td><td>O</td></tr>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- ROW 3: MATERIAL LIST WIDE -->
                    <div class="mt-5 border-top border-dark pt-3">
                        <h5 class="fw-bold mb-4" style="font-size: 1.5rem;">Material :</h5>
                        <div class="d-flex flex-column gap-4">
                            <div class="d-flex align-items-end">
                                <span class="label-main" style="width: 110px;">1) Inner :</span>
                                <div class="dots-fill ps-3" style="min-width: 350px;"><span class="hand-ink">@(Model.InnerMaterialActual ?? Model.InnerMaterial)</span></div>
                                <span class="label-main mx-4">No.Lot :</span>
                                <div class="dots-fill ps-3" style="min-width: 300px;">
                                    <span class="hand-ink" style="font-size: 1.2rem;">
                                        @{
                                            var innerLots = Model.MaterialLots.Where(x => x.LayerType == "INNER").Select(x => x.LotNumber).ToList();
                                            var innerShow = innerLots.Any() ? string.Join(", ", innerLots) : Model.InnerMaterialLotNo;
                                        }
                                        @innerShow
                                    </span>
                                </div>
                                <span class="label-main mx-4">SG :</span>
                                <div class="dots-fill ps-3" style="min-width: 150px;">
                                    <span class="hand-ink" style="font-size: 1.2rem;">
                                        @{
                                            var innerSGs = Model.MaterialLots.Where(x => x.LayerType == "INNER" && x.SGValue.HasValue).Select(x => x.SGValue!.Value).ToList();
                                            var innerSGShow = innerSGs.Any() ? ((decimal)innerSGs.Average()).ToString("0.000") : (Model.InnerMaterialSG?.ToString("0.000") ?? "-");
                                        }
                                        @innerSGShow
                                    </span>
                                </div>
                            </div>
                            @{
                                var middleLots = Model.MaterialLots.Where(x => x.LayerType == "MIDDLE").Select(x => x.LotNumber).ToList();
                                var middleShow = middleLots.Any() ? string.Join(", ", middleLots) : Model.MiddleMaterialLotNo;
                                var middleSGs = Model.MaterialLots.Where(x => x.LayerType == "MIDDLE" && x.SGValue.HasValue).Select(x => x.SGValue!.Value).ToList();
                                var middleSGShow = middleSGs.Any() ? ((decimal)middleSGs.Average()).ToString("0.000") : (Model.MiddleMaterialSG?.ToString("0.000") ?? "-");
                                var hasMiddle = !string.IsNullOrWhiteSpace(middleShow) || !string.IsNullOrWhiteSpace(Model.MiddleMaterial) || !string.IsNullOrWhiteSpace(Model.MiddleMaterialActual);
                            }
                            <div class="d-flex align-items-end @(!hasMiddle ? "opacity-25" : "")">
                                <span class="label-main" style="width: 110px;">2) Middle :</span>
                                <div class="dots-fill ps-3" style="min-width: 350px;"><span class="hand-ink">@(Model.MiddleMaterialActual ?? Model.MiddleMaterial)</span></div>
                                <span class="label-main mx-4">No.Lot :</span>
                                <div class="dots-fill ps-3" style="min-width: 300px;">
                                    <span class="hand-ink" style="font-size: 1.2rem;">@middleShow</span>
                                </div>
                                <span class="label-main mx-4">SG :</span>
                                <div class="dots-fill ps-3" style="min-width: 150px;">
                                    <span class="hand-ink" style="font-size: 1.2rem;">@(hasMiddle ? middleSGShow : "")</span>
                                </div>
                            </div>
                            <div class="d-flex align-items-end">
                                <span class="label-main" style="width: 110px;">3) Outer :</span>
                                <div class="dots-fill ps-3" style="min-width: 350px;"><span class="hand-ink">@(Model.OuterMaterialActual ?? Model.OuterMaterial)</span></div>
                                <span class="label-main mx-4">No.Lot :</span>
                                <div class="dots-fill ps-3" style="min-width: 300px;">
                                    <span class="hand-ink" style="font-size: 1.2rem;">
                                        @{
                                            var outerLots = Model.MaterialLots.Where(x => x.LayerType == "OUTER").Select(x => x.LotNumber).ToList();
                                            var outerShow = outerLots.Any() ? string.Join(", ", outerLots) : Model.OuterMaterialLotNo;
                                        }
                                        @outerShow
                                    </span>
                                </div>
                                <span class="label-main mx-4">SG :</span>
                                <div class="dots-fill ps-3" style="min-width: 150px;">
                                    <span class="hand-ink" style="font-size: 1.2rem;">
                                        @{
                                            var outerSGs = Model.MaterialLots.Where(x => x.LayerType == "OUTER" && x.SGValue.HasValue).Select(x => x.SGValue!.Value).ToList();
                                            var outerSGShow = outerSGs.Any() ? ((decimal)outerSGs.Average()).ToString("0.000") : (Model.OuterMaterialSG?.ToString("0.000") ?? "-");
                                        }
                                        @outerSGShow
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ROW 4: FOOTER WIDE -->
                    <div class="row mt-5 pt-5 align-items-end">
                        <div class="col-12">
                            <div class="fw-bold mb-1" style="font-size: 13px;">NOTE :</div>
                            <div style="font-size: 13px; border: 1px solid #000; padding: 15px; width: 100%; min-height: 80px;">
                                JANGAN MENJALANKAN PRODUKSI SEBELUM CHECKSHEET INI DI CHECK OLEH SUPERVISOR.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    }
    else if (currentPortal == "dimension")
    {
        <div id="printArea" class="hud-container fade-in">
            <!-- PORTAL 2: DIMENSION (App Sync Layout) -->
            <div class="content-card shadow-2xl mx-auto mb-4" style="background: rgba(15, 23, 42, 0.8); border: 2px solid var(--accent-blue); border-radius: 12px; overflow: hidden;">
                <!-- 2. META INFO BAR (Now as Header) -->
                <div class="row g-0 border-bottom-cyber px-3 py-3" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); font-size: 11px;">
                    <div class="col-3"><span class="text-info fw-bold">NO DOC :</span> <span class="text-white">@Model.DocumentNumber</span></div>
                    <div class="col-2"><span class="text-info fw-bold">REVISI :</span> <span class="text-white">@Model.RevisionNumber</span></div>
                    <div class="col-3"><span class="text-info fw-bold">DATE :</span> <span class="text-white">@Model.ProductionDate.ToString("dd/MMM/yyyy")</span></div>
                    <div class="col-2"><span class="text-info fw-bold">SHIFT :</span> <span class="text-white">@Model.Shift</span></div>
                    <div class="col-2 text-end"><span class="text-warning fw-extra-bold fs-6">@Model.HoseType / @Model.Dimension</span></div>
                </div>

                <!-- 3. MAIN DATA TABLE (Fixed Pukul/Jam Matrix) -->
                <div class="p-0">
                    <table class="data-table w-100 text-center" style="border-collapse: collapse;">
                        <thead>
                            <tr style="background: rgba(59, 130, 246, 0.15); color: #60a5fa; font-size: 10px;">
                                <th colspan="4" class="py-1 border-bottom border-primary border-opacity-25 tracking-widest fw-black text-center text-uppercase text-nowrap">PUKUL / JAM</th>
                                @for(int i=0; i<6; i++) {
                                    <th class="p-0 border border-primary border-opacity-25" style="height: 25px;">
                                        <input type="text" class="w-100 h-100 border-0 text-center bg-transparent text-info fw-bold" style="font-size: 10px;" placeholder="00:00" />
                                    </th>
                                }
                            </tr>
                            <tr style="background: rgba(30, 41, 59, 0.7); color: #94a3b8; font-size: 9px;">
                                <th class="p-2 border border-primary border-opacity-25 align-middle">POINT</th>
                                <th class="p-2 border border-primary border-opacity-25 align-middle">FREKUENSI</th>
                                <th class="p-2 border border-primary border-opacity-25 align-middle">STD DIMENSI</th>
                                <th class="p-2 border border-primary border-opacity-25 align-middle" style="width: 70px;">SCALE</th>
                                <th class="p-1 border border-primary border-opacity-25" style="width: 75px;">INITIAL</th>
                                @for(int i=1; i<=5; i++) {
                                    <th class="p-1 border border-primary border-opacity-25">@i</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var master = ViewBag.Masterlist as VelastoProductionSystem.Models.SpsNoDoc;
                                var stdVal = ViewBag.Sps as VelastoProductionSystem.Models.SpsNoDoc;

                                // PRIORITY: SpsMaster (stdVal) > Masterlist > Default
                                decimal idNom = (stdVal != null) ? D(stdVal.InnerTarget, stdVal.ToleranceInner_Asli ?? 11.0m) : D(master?.Dimensi, 11.0m);
                                decimal idTol = (stdVal != null) ? D(stdVal.InnerTol, 0.1m) : DTol(master?.ToleranceInner, 0.1m);
                                decimal tubeNom = (stdVal != null) ? D(stdVal.ThickTarget, stdVal.TebalInner_Asli ?? 1.8m) : D(master?.TebalInner, 1.8m);
                                decimal tubeTol = (stdVal != null) ? D(stdVal.ThickTol, 0.2m) : DTol(master?.ToleranceOuter, 0.2m);
                                decimal coverNom = (stdVal != null) ? D(stdVal.TotalTarget, stdVal.TebalTotal_Asli ?? 3.3m) : D(master?.TebalTotal, 3.3m);
                                decimal coverTol = (stdVal != null) ? D(stdVal.TotalTol, 0.2m) : DTol(master?.ToleranceOuter, 0.2m);

                                var sections = new[] {
                                    new { Label = "Inner Diameter", Nom = idNom, Tol = idTol, Prop = "InnerDiameter" },
                                    new { Label = "In Thick (X)", Nom = tubeNom, Tol = tubeTol, Prop = "InnerThicknessX" },
                                    new { Label = "In Thick (Y)", Nom = tubeNom, Tol = tubeTol, Prop = "InnerThicknessY" },
                                    new { Label = "Total Thick (X)", Nom = coverNom, Tol = coverTol, Prop = "TotalThicknessX" },
                                    new { Label = "Total Thick (Y)", Nom = coverNom, Tol = coverTol, Prop = "TotalThicknessY" }
                                };
                            }

                            @foreach(var sec in sections) {
                                for(int rIdx=0; rIdx<5; rIdx++) {
                                    decimal scaleValue = sec.Nom + (sec.Tol - (sec.Tol * 0.5m * rIdx));
                                    <tr style="height: 22px; border-bottom: 1px solid rgba(59, 130, 246, 0.1);">
                                        @if(rIdx == 0) {
                                            <td rowspan="5" class="p-1 border-end border-primary border-opacity-25 text-start fw-bold text-info" style="font-size: 10px;">@sec.Label</td>
                                            <td rowspan="5" class="border-end border-primary border-opacity-25 text-white-50" style="font-size: 8px;">30m Sekali</td>
                                            <td rowspan="5" class="border-end border-primary border-opacity-25 p-0" style="background: rgba(0,0,0,0.2);">
                                                <div style="display: flex; height: 100%; min-height: 100px; align-items: stretch;">
                                                    <!-- Legend Ref -->
                                                    <div style="width: 45px; background: rgba(30, 41, 59, 0.6); border-right: 1px solid rgba(59, 130, 246, 0.2); font-size: 8px; font-family: monospace; display: flex; flex-direction: column; justify-content: space-around; text-align: right; padding-right: 3px; line-height: 1; color: #94a3b8;">
                                                        <div>@((sec.Nom + sec.Tol).ToString("0.00", System.Globalization.CultureInfo.InvariantCulture))</div>
                                                        <div>@((sec.Nom + sec.Tol/2).ToString("0.00", System.Globalization.CultureInfo.InvariantCulture))</div>
                                                        <div style="color: #fff; font-weight: bold;">@sec.Nom.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)</div>
                                                        <div>@((sec.Nom - sec.Tol/2).ToString("0.00", System.Globalization.CultureInfo.InvariantCulture))</div>
                                                        <div>@((sec.Nom - sec.Tol).ToString("0.00", System.Globalization.CultureInfo.InvariantCulture))</div>
                                                    </div>
                                                    <!-- Main Display -->
                                                    <div style="flex: 1; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 10px; color: #fbbf24; text-align: center; padding: 2px;">
                                                        @sec.Nom.ToString("0.0") ± @sec.Tol.ToString("0.0")
                                                    </div>
                                                </div>
                                            </td>
                                        }
                                        <td class="border-end border-primary border-opacity-25 bg-white-5" style="font-size: 9px; color: #94a3b8;">@scaleValue.ToString("0.00")</td>
                                        @for(int h=0; h<6; h++) {
                                            var reading = h < readings.Count ? readings[h] : null;
                                            var val = (reading != null) ? (decimal?)reading.GetType().GetProperty(sec.Prop)?.GetValue(reading) : null;
                                            bool isMatch = val != null && Math.Abs(val.Value - scaleValue) < (sec.Tol * 0.26m);
                                            
                                            <td class="border-end border-primary border-opacity-25 p-0 position-relative @(isMatch ? "bg-info-glow" : "")">
                                                @if(isMatch) { <span class="val-display" style="font-size: 10px; font-weight: 800; color: white; text-shadow: 0 0 5px #3b82f6;">@val?.ToString("0.00")</span> }
                                            </td>
                                        }
                                    </tr>
                                }
                            }

                            <!-- Spiral & Visual -->
                            <tr style="height: 40px; border-top: 2px solid rgba(59, 130, 246, 0.3);">
                                <td class="p-2 text-start fw-bold text-info" style="font-size: 11px;">Spiral Pitch</td>
                                <td class="text-white-50" style="font-size: 9px;">30m Sekali</td>
                                <td class="text-warning fw-bold" style="font-size: 11px;">
                                    @{
                                        string spiralStr = stdVal?.ToleranceSpiralPitch ?? master?.ToleranceSpiralPitch ?? "38 ± 5";
                                    }
                                    @spiralStr
                                </td>
                                <td class="bg-white-5" style="font-size: 10px;">NOM</td>
                                @for(int h=0; h<6; h++) {
                                    var r = h < readings.Count ? readings[h] : null;
                                    <td class="border-start border-primary border-opacity-25 text-white fw-bold">@r?.SpiralPitch?.ToString("0.0")</td>
                                }
                            </tr>
                            <tr style="height: 45px; border-top: 1px solid rgba(59, 130, 246, 0.3);">
