                                    <label class="mb-0 d-flex align-items-center gap-1" style="font-size: 11px;"><input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" @(Model.QcRes == "UNREAD" ? "checked" : "") style="width:13px; height:13px;"> Tdk Terbaca</label>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- 4. TOTAL MONITORING MATRIX (Paper Theme) -->
                <div class="table-responsive border border-dark mb-2">
                    <table class="grid-form w-100 text-center m-0">
                        <thead>
                            <tr class="bg-light">
                                <th colspan="2" style="width: 180px;" class="text-start ps-2 py-1">INSTRUMENT PARAMETER</th>
                                <th style="width: 80px;">STANDARD</th>
                                <th style="width: 80px;" class="bg-light text-dark py-1">
                                    <span style="font-size: 11px;">@(readings.FirstOrDefault()?.ReadingTime.ToString("HH:mm") ?? "--:--")</span>
                                </th>
                                @for(int i=1; i<=7; i++) { 
                                    var rTime = readings.Skip(i).FirstOrDefault()?.ReadingTime;
                                    <th style="width: 65px;" class="py-1">
                                        <span style="font-size: 11px;">@(rTime?.ToString("HH:mm") ?? "--:--")</span>
                                    </th> 
                                }
                            </tr>
                        </thead>
                        <tbody>
                            <!-- INNER SECTION -->
                            @{
                                var sMaster = ViewBag.Masterlist as VelastoProductionSystem.Models.SpsNoDoc;
                                string F(string? strVal, decimal fallbackVal, string prefix, string suffix) {
                                    string res = "-";
                                    if (!string.IsNullOrWhiteSpace(strVal) && strVal != "-") {
                                        if (strVal.Contains("±", StringComparison.OrdinalIgnoreCase) || strVal.Contains("MAX", StringComparison.OrdinalIgnoreCase) || strVal.Contains("MIN", StringComparison.OrdinalIgnoreCase)) {
                                            res = strVal;
                                        } else {
                                            res = $"{prefix}{strVal}{suffix}";
                                        }
                                    } else if (fallbackVal > 0) {
                                        res = $"{prefix}{fallbackVal}{suffix}";
                                    }
                                    return res;
                                }

                                string FormatVal(object? val, string unit) {
                                    if (val == null) return "";
                                    string vStr = "";
                                    if (val is decimal d) vStr = d.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
                                    else vStr = val.ToString() ?? "";
                                    
                                    if (string.IsNullOrWhiteSpace(vStr)) return "";
                                    return vStr + (string.IsNullOrEmpty(unit) ? "" : $" {unit}");
                                }

                                var innerRows = new[] {
                                    new { L = "HEAD TEMP.", K = "HeadTempInner", S = F(sMaster?.HeadTemp1, std?.HeadTemp1_Asli ?? 0, "", "±5"), U = "°C" },
                                    new { L = "CYLINDER 1", K = "Cylinder1TempInner", S = F(sMaster?.Cylinder1_1, std?.Cylinder1_1_Asli ?? 0, "", "±5"), U = "°C" },
                                    new { L = "CYLINDER 2", K = "Cylinder2TempInner", S = F(sMaster?.Cylinder2_1, std?.Cylinder1_2_Asli ?? 0, "", "±5"), U = "°C" },
                                    new { L = "CYLINDER 3", K = "Cylinder3TempInner", S = F(null, std?.Cylinder1_3_Asli ?? 0, "", "±5"), U = "°C" },
                                    new { L = "SCREW TEMP.", K = "ScrewTempInner", S = F(sMaster?.ScrewTemp1, D(std?.ScrewTemp1, 0), "", "±5"), U = "°C" },
                                    new { L = "SCREW SPEED", K = "ScrewSpeedInner", S = F(sMaster?.ScrewSpeed1, D(std?.ScrewSpeed1, 0), "", "±2.5"), U = "rpm" },
                                    new { L = "FEED ROLL", K = "FeedRollRatioInner", S = F(sMaster?.Feed1, D(std?.FeedRollRatio1, 0), "MAX ", ""), U = "%" },
                                    new { L = "PRESSURE", K = "PressureInner", S = F(sMaster?.Pressure1, D(std?.Pressure1, 0), "MAX ", ""), U = "MPa" }
                                };
                            }
                            @for(int r = 0; r < innerRows.Length; r++) {
                                <tr>
                                    @if(r == 0) { <td rowspan="@innerRows.Length" class="hud-vertical-label">INNER TUBE</td> }
                                    <td class="text-start ps-2 pe-1 py-1 fw-bold">@innerRows[r].L @(string.IsNullOrEmpty(innerRows[r].U) ? "" : $"({innerRows[r].U})")</td>
                                    <td class="small opacity-50 fw-bold">@innerRows[r].S</td>
                                    <td class="p-0 bg-light"><input type="text" class="input-transparent text-dark fw-bold" value="@FormatVal(Model.GetType().GetProperty("Init" + innerRows[r].K)?.GetValue(Model) ?? readings.FirstOrDefault()?.GetType().GetProperty(innerRows[r].K)?.GetValue(readings.FirstOrDefault()), innerRows[r].U)" /></td>
                                    @for(int i=1; i<=7; i++) {
                                        <td class="p-0">
                                            <input type="text" class="input-transparent" value="@FormatVal(readings.Skip(i).FirstOrDefault()?.GetType().GetProperty(innerRows[r].K)?.GetValue(readings.Skip(i).FirstOrDefault()), innerRows[r].U)" />
                                        </td>
                                    }
                                </tr>
                            }

                            <!-- OUTER SECTION -->
                            <tr class="bg-dark text-white"><td colspan="11" style="height: 4px; padding: 0;"></td></tr>
                            @{
                                var outerRows = new[] {
                                    new { L = "HEAD TEMP.", K = "HeadTempOuter", S = F(sMaster?.HeadTemp2, std?.HeadTemp2_Asli ?? 0, "", "±5"), U = "°C" },
                                    new { L = "CYLINDER 1", K = "Cylinder1TempOuter", S = F(sMaster?.Cylinder1_2, std?.Cylinder2_1_Asli ?? 0, "", "±5"), U = "°C" },
                                    new { L = "CYLINDER 2", K = "Cylinder2TempOuter", S = F(sMaster?.Cylinder2_2, std?.Cylinder2_2_Asli ?? 0, "", "±5"), U = "°C" },
                                    new { L = "CYLINDER 3", K = "Cylinder3TempOuter", S = F(null, std?.Cylinder2_3_Asli ?? 0, "", "±5"), U = "°C" },
                                    new { L = "SCREW TEMP.", K = "ScrewTempOuter", S = F(sMaster?.ScrewTemp2, D(std?.ScrewTemp2, 0), "", "±5"), U = "°C" },
                                    new { L = "SCREW SPEED", K = "ScrewSpeedOuter", S = F(sMaster?.ScrewSpeed2, D(std?.ScrewSpeed2, 0), "", "±2.5"), U = "rpm" },
                                    new { L = "FEED ROLL", K = "FeedRollRatioOuter", S = F(sMaster?.Feed2, D(std?.FeedRollRatio2, 0), "MAX ", ""), U = "%" },
                                    new { L = "PRESSURE", K = "PressureOuter", S = F(sMaster?.Pressure2, D(std?.Pressure2, 0), "MAX ", ""), U = "MPa" }
                                };
                            }
                            @for(int r = 0; r < outerRows.Length; r++) {
                                <tr>
                                    @if(r == 0) { <td rowspan="@outerRows.Length" class="hud-vertical-label">OUTER COVER</td> }
                                    <td class="text-start ps-2 pe-1 py-1 fw-bold">@outerRows[r].L @(string.IsNullOrEmpty(outerRows[r].U) ? "" : $"({outerRows[r].U})")</td>
                                    <td class="small opacity-50 fw-bold">@outerRows[r].S</td>
                                    <td class="p-0 bg-light"><input type="text" class="input-transparent text-dark fw-bold" value="@FormatVal(Model.GetType().GetProperty("Init" + outerRows[r].K)?.GetValue(Model) ?? readings.FirstOrDefault()?.GetType().GetProperty(outerRows[r].K)?.GetValue(readings.FirstOrDefault()), outerRows[r].U)" /></td>
                                    @for(int i=1; i<=7; i++) {
                                        <td class="p-0">
                                            <input type="text" class="input-transparent" value="@FormatVal(readings.Skip(i).FirstOrDefault()?.GetType().GetProperty(outerRows[r].K)?.GetValue(readings.Skip(i).FirstOrDefault()), outerRows[r].U)" />
                                        </td>
                                    }
                                </tr>
                            }

                            <!-- SPIRAL & OTHERS -->
                            <tr class="bg-secondary text-white"><td colspan="11" style="height: 4px; padding: 0;"></td></tr>
                            @{
                                var otherRows = new[] {
                                    new { L = "SPIRAL SPEED", K = "SpiralSpeed", S = F(null, D(std?.SpiralSpeed, 0), "", "±20"), U = "rpm" },
                                    new { L = "SPIRAL PITCH", K = "SpiralPitchSetting", S = F(sMaster?.ToleranceSpiralPitch, D(std?.SpiralPitchSetting, 0), "", "±5"), U = "mm" },
                                    new { L = "PRESET VALVE", K = "PresetValue", S = F(null, D(std?.PresetValue, 0), "", ""), U = "mm" },
                                    new { L = "CONTROL VAL.", K = "ControlValue", S = (std?.ControlValue ?? "-"), U = "mm" },
                                    new { L = "HOSE SPEED", K = "HoseSpeed", S = (std?.HoseSpeed ?? "-"), U = "m/min" },
                                    new { L = "TAKEUP SPEED", K = "TakeupConveyorSpeed", S = (sMaster?.TakeUpConveyorSpeed ?? std?.TakeUpConveyorSpeed ?? "-"), U = "m/min" },
                                    new { L = "COOL SPEED", K = "CoolConveyorSpeed", S = (std?.CoolConveyorSpeed ?? "-"), U = "m/min" },
                                    new { L = "CONV. RATIO", K = "ConveyorRatio", S = (std?.ConveyorRatio ?? "-"), U = "%" },
                                    new { L = "CHILLER TEMP", K = "ChillerWaterTemp", S = (sMaster?.ChillerWaterTemp ?? std?.ChillerWaterTemp ?? "-"), U = "°C" },
                                    new { L = "CATERPIL. GAP", K = "CaterpillarGap", S = (std?.CaterpillarGap ?? "-"), U = "mm" },
                                    new { L = "SURFACE", K = "UnsmoothSurface", S = (std?.UnsmoothSurface ?? "OK"), U = "" }
                                };
                            }
                            @for(int r = 0; r < otherRows.Length; r++) {
                                <tr>
                                    @if(r == 0) { <td rowspan="@otherRows.Length" class="hud-vertical-label">MISC</td> }
                                    <td class="text-start ps-2 pe-1 py-1 fw-bold">@otherRows[r].L @(string.IsNullOrEmpty(otherRows[r].U) ? "" : $"({otherRows[r].U})")</td>
                                    <td class="small opacity-50 fw-bold">@otherRows[r].S</td>
                                    <td class="p-0 bg-light"><input type="text" class="input-transparent text-dark fw-bold" value="@FormatVal(Model.GetType().GetProperty("Init" + otherRows[r].K)?.GetValue(Model) ?? readings.FirstOrDefault()?.GetType().GetProperty(otherRows[r].K)?.GetValue(readings.FirstOrDefault()), otherRows[r].U)" /></td>
                                    @for(int i=1; i<=7; i++) {
                                        <td class="p-0">
                                            <input type="text" class="input-transparent" value="@FormatVal(readings.Skip(i).FirstOrDefault()?.GetType().GetProperty(otherRows[r].K)?.GetValue(readings.Skip(i).FirstOrDefault()), otherRows[r].U)" />
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- 5. WASTE PERFORMANCE (Paper Theme) -->
                <div class="row m-0">
                    <div class="col-12 p-0">
                        <table class="grid-form w-100 text-center m-0">
                            <tbody>
                                <tr class="bg-light">
                                    <th rowspan="6" class="align-middle fw-bold text-center border-end-0 border-bottom-0" style="width: 30px; background: #f0f0f0;">
                                        <div style="font-size: 9px; line-height: 1.1; font-weight: 800;">W<br/>A<br/>S<br/>T<br/>E</div>
                                    </th>
                                    <th colspan="2" class="align-middle py-2 border-end-0 text-uppercase" style="font-size: 0.75rem;">Initial Setting</th>
                                    <th class="align-middle border-end-0 text-uppercase" style="width: 15%; font-size: 0.75rem;">Awal</th>
                                    <th class="align-middle border-end border-dark text-uppercase" style="width: 15%; font-size: 0.75rem;">Akhir</th>
                                    <th class="align-middle border-bottom-0 text-start ps-2 pt-2 text-uppercase" style="width: 30%; font-size: 0.75rem;">Note :</th>
                                </tr>
                                <tr class="bg-light">
                                    <th colspan="2" class="align-middle py-2 border-end-0 text-uppercase" style="font-size: 0.75rem;">Berat (kg)</th>
                                    <th class="align-middle border-end-0 border-bottom-0" style="background-color: #fff;"></th>
                                    <th class="align-middle border-end border-dark border-bottom-0" style="background-color: #fff;"></th>
                                    <td rowspan="5" class="align-top text-start text-dark p-2 border-bottom-0" style="font-size: 11px; background-color: #f8f9fa;">
                                        Lakukan pengecekan parameter pada saat<br/>awal, tengah & akhir proses.
                                    </td>
                                </tr>
                                <tr>
                                    <td rowspan="2" class="text-start ps-2 align-middle border-bottom-0 fw-bold border-end-0 text-uppercase" style="font-size: 0.7rem; width: 140px; background-color: #f8f9fa;">Dandori Awal<br/><span class="fw-normal">(Cleaning)</span></td>
                                    <td class="text-start ps-2 border-end-0 text-uppercase" style="font-size: 0.7rem; width: 60px;">Inner</td>
                                    <td class="p-0 border-end-0"><input type="text" class="input-transparent text-center h-100 py-1" value="@(Model.DAI_Awal ?? Model.WasteInnerAwal?.ToString())" /></td>
                                    <td class="p-0 border-end border-dark"><input type="text" class="input-transparent text-center h-100 py-1" value="@(Model.DAI_Akhir ?? Model.WasteInnerAkhir?.ToString())" /></td>
                                </tr>
                                <tr>
                                    <td class="text-start ps-2 border-end-0 text-uppercase" style="font-size: 0.7rem;">Cover</td>
                                    <td class="p-0 border-end-0"><input type="text" class="input-transparent text-center h-100 py-1" value="@(Model.DAC_Awal ?? Model.WasteCoverAwal?.ToString())" /></td>
                                    <td class="p-0 border-end border-dark"><input type="text" class="input-transparent text-center h-100 py-1" value="@(Model.DAC_Akhir ?? Model.WasteCoverAkhir?.ToString())" /></td>
                                </tr>
                                <tr>
                                    <td rowspan="2" class="text-start ps-2 align-middle border-bottom-0 fw-bold border-end-0 text-uppercase" style="font-size: 0.7rem; background-color: #f8f9fa;">Dandori Akhir<br/><span class="fw-normal">(Remain Material)</span></td>
                                    <td class="text-start ps-2 border-end-0 text-uppercase" style="font-size: 0.7rem;">Inner</td>
                                    <td class="p-0 border-end-0"><input type="text" class="input-transparent text-center h-100 py-1" value="@(Model.DRAI_Awal ?? Model.WasteWeightAwal?.ToString())" /></td>
                                    <td class="p-0 border-end border-dark"><input type="text" class="input-transparent text-center h-100 py-1" value="@(Model.DRAI_Akhir ?? Model.WasteWeightAkhir?.ToString())" /></td>
                                </tr>
                                <tr>
                                    <td class="text-start ps-2 border-bottom-0 border-end-0 text-uppercase" style="font-size: 0.7rem;">Cover</td>
                                    <td class="p-0 border-bottom-0 border-end-0"><input type="text" class="input-transparent text-center h-100 py-1" value="@Model.DRAC_Awal" /></td>
                                    <td class="p-0 border-bottom-0 border-end border-dark"><input type="text" class="input-transparent text-center h-100 py-1" value="@Model.DRAC_Akhir" /></td>
                                </tr>
