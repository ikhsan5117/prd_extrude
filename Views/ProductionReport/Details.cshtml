                                @for(int h=0; h<6; h++) {
                                    var r = h < readings.Count ? readings[h] : null;
                                    <td class="border-start border-primary border-opacity-25 @(r?.VisualCheck == "NG" ? "text-danger" : "text-success") fw-black">@r?.VisualCheck</td>
                                }
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- 4. FOOTER NOTE & ATTENTION -->
                <div class="row g-0 border-top-cyber" style="background: rgba(15, 23, 42, 0.5);">
                    <div class="col-7 p-2 border-end border-primary border-opacity-25 text-start">
