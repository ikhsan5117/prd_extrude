                <!-- 4. TOTAL MONITORING MATRIX (Paper Theme) -->
                <div class="table-responsive border border-dark mb-2">
                    <table class="grid-form w-100 text-center m-0">
                        <thead>
                            <tr class="bg-light">
                                <th colspan="2" width="220" class="text-start ps-2 py-2">INSTRUMENT PARAMETER</th>
                                <th width="100">STANDARD</th>
                                <th width="100" class="bg-info bg-opacity-10 text-primary">INITIAL</th>
                                @for(int i=1; i<=7; i++) { <th width="9%">#@i</th> }
                            </tr>
                        </thead>
                        <tbody>
                            <!-- INNER SECTION -->
                            @{
                                var sMaster = ViewBag.Masterlist as VelastoProductionSystem.Models.MasterlistSpsDoubleLayer;
                                string F(string? strVal, decimal fallbackVal, string prefix, string suffix) {
                                    if (!string.IsNullOrWhiteSpace(strVal) && strVal != "-") {
                                        if (strVal.Contains("±", StringComparison.OrdinalIgnoreCase) || strVal.Contains("MAX", StringComparison.OrdinalIgnoreCase) || strVal.Contains("MIN", StringComparison.OrdinalIgnoreCase)) return strVal;
                                        return $"{prefix}{strVal}{suffix}";
                                    }
                                    if (fallbackVal > 0) return $"{prefix}{fallbackVal}{suffix}";
                                    return "-";
                                }

                                var innerRows = new[] {
                                    new { L = "HEAD TEMP.", K = "HeadTempInner", S = F(sMaster?.HeadTemp1, std.HeadTemp, "", "±5") },
                                    new { L = "CYLINDER 1", K = "Cylinder1TempInner", S = F(sMaster?.Cylinder1_1, std.Cylinder1Temp, "", "±5") },
                                    new { L = "CYLINDER 2", K = "Cylinder2TempInner", S = F(sMaster?.Cylinder2_1, std.Cylinder2Temp, "", "±5") },
                                    new { L = "CYLINDER 3", K = "Cylinder3TempInner", S = F(null, std.Cylinder3Temp, "", "±5") },
                                    new { L = "SCREW TEMP.", K = "ScrewTempInner", S = F(sMaster?.ScrewTemp1, std.ScrewTemp, "", "±5") },
                                    new { L = "SCREW SPEED", K = "ScrewSpeedInner", S = F(sMaster?.ScrewSpeed1, std.ScrewSpeed, "", "±2") },
                                    new { L = "FEED ROLL", K = "FeedRollRatioInner", S = F(sMaster?.Feed1, std.FeedRollRatio, "Max ", "") },
                                    new { L = "PRESSURE", K = "PressureInner", S = F(sMaster?.Pressure1, std.Pressure, "Max ", "") }
                                };
                            }
                            @for(int r = 0; r < innerRows.Length; r++) {
                                <tr>
                                    @if(r == 0) { <td rowspan="@innerRows.Length" class="hud-vertical-label">INNER TUBE</td> }
                                    <td class="text-end pe-2 py-1 fw-bold">@innerRows[r].L</td>
                                    <td class="small opacity-50 fw-bold">@innerRows[r].S</td>
                                    <td class="p-0 bg-info bg-opacity-10"><input type="text" class="input-transparent text-primary fw-bold" value="@(Model.GetType().GetProperty("Init" + innerRows[r].K)?.GetValue(Model) ?? readings.FirstOrDefault()?.GetType().GetProperty(innerRows[r].K)?.GetValue(readings.FirstOrDefault()) ?? "")" /></td>
                                    @for(int i=1; i<=7; i++) {
                                        <td class="p-0">
                                            <input type="text" class="input-transparent" value="@(readings.Skip(i).FirstOrDefault()?.GetType().GetProperty(innerRows[r].K)?.GetValue(readings.Skip(i).FirstOrDefault()) ?? "")" />
                                        </td>
                                    }
                                </tr>
                            }

                            <!-- OUTER SECTION -->
                            <tr class="bg-dark text-white"><td colspan="11" style="height: 4px; padding: 0;"></td></tr>
                            @{
                                var outerRows = new[] {
                                    new { L = "HEAD TEMP.", K = "HeadTempOuter", S = F(sMaster?.HeadTemp2, std.HeadTemp, "", "±5") },
                                    new { L = "CYLINDER 1", K = "Cylinder1TempOuter", S = F(sMaster?.Cylinder1_2, std.Cylinder1Temp, "", "±5") },
                                    new { L = "CYLINDER 2", K = "Cylinder2TempOuter", S = F(sMaster?.Cylinder2_2, std.Cylinder2Temp, "", "±5") },
                                    new { L = "CYLINDER 3", K = "Cylinder3TempOuter", S = F(null, std.Cylinder3Temp, "", "±5") },
                                    new { L = "SCREW TEMP.", K = "ScrewTempOuter", S = F(sMaster?.ScrewTemp2, std.ScrewTemp, "", "±5") },
                                    new { L = "SCREW SPEED", K = "ScrewSpeedOuter", S = F(sMaster?.ScrewSpeed2, std.ScrewSpeed, "", "±2") },
                                    new { L = "FEED ROLL", K = "FeedRollRatioOuter", S = F(sMaster?.Feed2, std.FeedRollRatio, "Max ", "") },
                                    new { L = "PRESSURE", K = "PressureOuter", S = F(sMaster?.Pressure2, std.Pressure, "Max ", "") }
                                };
                            }
                            @for(int r = 0; r < outerRows.Length; r++) {
                                <tr>
                                    @if(r == 0) { <td rowspan="@outerRows.Length" class="hud-vertical-label">OUTER COVER</td> }
                                    <td class="text-end pe-2 py-1 fw-bold">@outerRows[r].L</td>
                                    <td class="small opacity-50 fw-bold">@outerRows[r].S</td>
                                    <td class="p-0 bg-info bg-opacity-10"><input type="text" class="input-transparent text-primary fw-bold" value="@(Model.GetType().GetProperty("Init" + outerRows[r].K)?.GetValue(Model) ?? readings.FirstOrDefault()?.GetType().GetProperty(outerRows[r].K)?.GetValue(readings.FirstOrDefault()) ?? "")" /></td>
                                    @for(int i=1; i<=7; i++) {
                                        <td class="p-0">
                                            <input type="text" class="input-transparent" value="@(readings.Skip(i).FirstOrDefault()?.GetType().GetProperty(outerRows[r].K)?.GetValue(readings.Skip(i).FirstOrDefault()) ?? "")" />
                                        </td>
                                    }
                                </tr>
                            }

                            <!-- SPIRAL & OTHERS -->
                            <tr class="bg-secondary text-white"><td colspan="11" style="height: 4px; padding: 0;"></td></tr>
                            @{
                                var otherRows = new[] {
                                    new { L = "SPIRAL SPEED", K = "SpiralSpeed", S = F(null, std.SpiralSpeed, "", "±20") },
                                    new { L = "SPIRAL PITCH", K = "SpiralPitchSetting", S = F(null, std.SpiralPitch, "", "±5") },
                                    new { L = "HOSE SPEED", K = "HoseSpeed", S = "3.4±2" },
                                    new { L = "CONV. RATIO", K = "ConveyorRatio", S = "100±10" }
                                };
                            }
                            @for(int r = 0; r < otherRows.Length; r++) {
                                <tr>
                                    @if(r == 0) { <td rowspan="@otherRows.Length" class="hud-vertical-label">MISC</td> }
                                    <td class="text-end pe-2 py-1 fw-bold">@otherRows[r].L</td>
                                    <td class="small opacity-50 fw-bold">@otherRows[r].S</td>
                                    <td class="p-0 bg-info bg-opacity-10"><input type="text" class="input-transparent text-primary fw-bold" value="@(Model.GetType().GetProperty("Init" + otherRows[r].K)?.GetValue(Model) ?? readings.FirstOrDefault()?.GetType().GetProperty(otherRows[r].K)?.GetValue(readings.FirstOrDefault()) ?? "")" /></td>
                                    @for(int i=1; i<=7; i++) {
                                        <td class="p-0">
                                            <input type="text" class="input-transparent" value="@(readings.Skip(i).FirstOrDefault()?.GetType().GetProperty(otherRows[r].K)?.GetValue(readings.Skip(i).FirstOrDefault()) ?? "")" />
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

