@model VelastoProductionSystem.Models.ProductionReport

@{
    ViewData["Title"] = "Production Monitoring Dashboard";
    var readings = Model.ProductionReadings.OrderBy(r => r.ReadingTime).ToList();
    var std = Model.StandardParameterSetting ?? new VelastoProductionSystem.Models.StandardParameterSetting();
    var currentPortal = Context.Request.Query["portal"].ToString();
}

<div class="production-dashboard-sapphire fade-in">
    <!-- PORTAL SELECTION / TOGGLE (No Print) -->
    <div class="d-flex justify-content-center gap-3 mb-4 no-print header-sapphire-glass p-3">
        <a href="?portal=parameter" class="portal-btn @(currentPortal == "parameter" || string.IsNullOrEmpty(currentPortal) ? "active" : "")">
            <i class="bi bi-gear-wide-connected fs-4"></i>
            <div>
                <span class="small fw-bold d-block text-white-50">OPERATOR 1</span>
                <span class="fw-black">PARAMETER SETTING</span>
            </div>
        </a>
        <a href="?portal=dimension" class="portal-btn @(currentPortal == "dimension" ? "active" : "")">
            <i class="bi bi-rulers fs-4"></i>
            <div>
                <span class="small fw-bold d-block text-white-50">OPERATOR 2</span>
                <span class="fw-black">DIMENSION REPORT</span>
            </div>
        </a>
        
        <div class="ms-auto d-flex align-items-center gap-2">
            <button onclick="window.print()" class="btn btn-outline-glass btn-sm">
                <i class="bi bi-printer me-1"></i> PRINT
            </button>
            <button type="button" class="btn btn-danger-glass btn-sm" data-bs-toggle="modal" data-bs-target="#finishProductionModal">
                <i class="bi bi-flag-fill me-1"></i> FINISH
            </button>
        </div>
    </div>

    @if (currentPortal == "dimension")
    {
        <div class="hud-container fade-in">
            <!-- PORTAL 2: DIMENSION (App Sync Layout) -->
            <div class="content-card shadow-2xl mx-auto mb-4" style="background: rgba(15, 23, 42, 0.8); border: 2px solid var(--accent-blue); border-radius: 12px; overflow: hidden;">
                <!-- 1. HEADER SYNC WITH APP -->
                <div class="p-3 border-bottom-cyber" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);">
                    <div class="row align-items-center">
                        <div class="col-4">
                            <div class="d-flex align-items-center gap-2">
                                <div style="width: 40px; height: 40px; background: #3b82f6; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                    <span style="font-weight: 900; font-size: 20px; color: white;">V</span>
                                </div>
                                <div>
                                    <div style="font-weight: 900; font-size: 16px; color: #60a5fa; line-height: 1;">VELASTO</div>
                                    <div style="font-size: 8px; color: #94a3b8; border-bottom: 1px solid #3b82f6; letter-spacing: 2px;">INDONESIA</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-4 text-center">
                            <h5 class="fw-black text-white mb-0 text-uppercase tracking-widest">Extruder Production Report</h5>
                            <div class="text-info fw-bold extra-small">(Dimension)</div>
                        </div>
                        <div class="col-4 d-flex justify-content-end">
                            <table class="signature-table" style="width: 180px; border: 1px solid #3b82f6; font-size: 9px; background: rgba(15,23,42,0.5);">
                                <tr style="background: #3b82f6; color: white; font-weight: bold;">
                                    <th class="p-1 border text-center">PREPARED</th>
                                    <th class="p-1 border text-center">CHECKED</th>
                                    <th class="p-1 border text-center">APPROVED</th>
                                </tr>
                                <tr style="height: 40px;">
                                    <td class="border text-center align-middle text-info fw-bold">@Model.CreatedBy</td>
                                    <td class="border text-center align-middle text-white-50">@Model.CheckedBy</td>
                                    <td class="border text-center align-middle text-white-50">@Model.ApprovedBy</td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- 2. META INFO BAR -->
                <div class="row g-0 border-bottom-cyber px-3 py-2" style="background: rgba(30, 41, 59, 0.4); font-size: 11px;">
                    <div class="col-3"><span class="text-info fw-bold">NO DOC :</span> <span class="text-white">@Model.DocumentNumber</span></div>
                    <div class="col-2"><span class="text-info fw-bold">REVISI :</span> <span class="text-white">@Model.RevisionNumber</span></div>
                    <div class="col-3"><span class="text-info fw-bold">DATE :</span> <span class="text-white">@Model.ProductionDate.ToString("dd/MMM/yyyy")</span></div>
                    <div class="col-2"><span class="text-info fw-bold">SHIFT :</span> <span class="text-white">@Model.Shift</span></div>
                    <div class="col-2 text-end"><span class="text-warning fw-bold">@Model.HoseType / @Model.Dimension</span></div>
                </div>

                <!-- 3. MAIN DATA TABLE (Fixed Pukul/Jam Matrix) -->
                <div class="p-0">
                    <table class="data-table w-100 text-center" style="border-collapse: collapse;">
                        <thead>
                            <tr style="background: rgba(59, 130, 246, 0.15); color: #60a5fa; font-size: 10px;">
                                <th colspan="4" class="py-1 border-bottom border-primary border-opacity-25 tracking-widest fw-black text-center text-uppercase text-nowrap">PUKUL / JAM</th>
                                @for(int i=0; i<6; i++) {
                                    <th class="p-0 border border-primary border-opacity-25" style="height: 25px;">
                                        <input type="text" class="w-100 h-100 border-0 text-center bg-transparent text-info fw-bold" style="font-size: 10px;" placeholder="00:00" />
                                    </th>
                                }
                            </tr>
                            <tr style="background: rgba(30, 41, 59, 0.7); color: #94a3b8; font-size: 9px;">
                                <th class="p-2 border border-primary border-opacity-25 align-middle">POINT</th>
                                <th class="p-2 border border-primary border-opacity-25 align-middle">FREKUENSI</th>
                                <th class="p-2 border border-primary border-opacity-25 align-middle">STD DIMENSI</th>
                                <th class="p-2 border border-primary border-opacity-25 align-middle" style="width: 70px;">SCALE</th>
                                <th class="p-1 border border-primary border-opacity-25" style="width: 75px;">INITIAL</th>
                                @for(int i=1; i<=5; i++) {
                                    <th class="p-1 border border-primary border-opacity-25">@i</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var stdVal = Model.StandardParameterSetting;
                                var master = (VelastoProductionSystem.Models.MasterlistSpsDoubleLayer)ViewBag.Masterlist;

                                // Helper to parse string to decimal
                                decimal D(string s, decimal def) => decimal.TryParse(s, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out decimal v) ? v : def;

                                // Override standards if masterlist is present and std is null/zero
                                decimal idNom = stdVal?.InnerDie > 0 ? stdVal.InnerDie : (master != null ? D(master.Dimensi, 11.0m) : 11.0m);
                                decimal idTol = stdVal?.ToleranceDie > 0 ? stdVal.ToleranceDie : (master != null ? D(master.ToleranceInner, 0.2m) : 0.2m);
                                decimal tubeNom = stdVal?.TubeDie > 0 ? stdVal.TubeDie : (master != null ? D(master.TebalInner, 1.8m) : 1.8m);
                                decimal tubeTol = stdVal?.Tol_TubeDie > 0 ? stdVal.Tol_TubeDie : 0.2m;
                                decimal coverNom = stdVal?.CoverDie > 0 ? stdVal.CoverDie : (master != null ? D(master.TebalTotal, 3.3m) : 3.3m);
                                decimal coverTol = stdVal?.Tol_CoverDie > 0 ? stdVal.Tol_CoverDie : (master != null ? D(master.ToleranceOuter, 0.2m) : 0.2m);

                                var sections = new[] {
                                    new { Label = "Inner Diameter", Nom = idNom, Tol = idTol, Prop = "InnerDiameter" },
                                    new { Label = "In Thick (X)", Nom = tubeNom, Tol = tubeTol, Prop = "InnerThicknessX" },
                                    new { Label = "In Thick (Y)", Nom = tubeNom, Tol = tubeTol, Prop = "InnerThicknessY" },
                                    new { Label = "Total Thick (X)", Nom = coverNom, Tol = coverTol, Prop = "TotalThicknessX" },
                                    new { Label = "Total Thick (Y)", Nom = coverNom, Tol = coverTol, Prop = "TotalThicknessY" }
                                };
                            }

                            @foreach(var sec in sections) {
                                for(int rIdx=0; rIdx<5; rIdx++) {
                                    decimal scaleValue = sec.Nom + (sec.Tol - (sec.Tol * 0.5m * rIdx));
                                    <tr style="height: 22px; border-bottom: 1px solid rgba(59, 130, 246, 0.1);">
                                        @if(rIdx == 0) {
                                            <td rowspan="5" class="p-1 border-end border-primary border-opacity-25 text-start fw-bold text-info" style="font-size: 10px;">@sec.Label</td>
                                            <td rowspan="5" class="border-end border-primary border-opacity-25 text-white-50" style="font-size: 8px;">30m Sekali</td>
                                            <td rowspan="5" class="border-end border-primary border-opacity-25 text-warning fw-bold" style="font-size: 10px;">@sec.Nom.ToString("0.0") ± @sec.Tol.ToString("0.0")</td>
                                        }
                                        <td class="border-end border-primary border-opacity-25 bg-white-5" style="font-size: 9px; color: #94a3b8;">@scaleValue.ToString("0.00")</td>
                                        @for(int h=0; h<6; h++) {
                                            var reading = h < readings.Count ? readings[h] : null;
                                            var val = (decimal?)reading?.GetType().GetProperty(sec.Prop)?.GetValue(reading);
                                            bool isMatch = val != null && Math.Abs(val.Value - scaleValue) < (sec.Tol * 0.26m);
                                            
                                            <td class="border-end border-primary border-opacity-25 p-0 position-relative @(isMatch ? "bg-info-glow" : "")">
                                                @if(isMatch) { <span class="val-display" style="font-size: 10px; font-weight: 800; color: white; text-shadow: 0 0 5px #3b82f6;">@val?.ToString("0.00")</span> }
                                            </td>
                                        }
                                    </tr>
                                }
                            }

                            <!-- Spiral & Visual -->
                            <tr style="height: 40px; border-top: 2px solid rgba(59, 130, 246, 0.3);">
                                <td class="p-2 text-start fw-bold text-info" style="font-size: 11px;">Spiral Pitch</td>
                                <td class="text-white-50" style="font-size: 9px;">30m Sekali</td>
                                <td class="text-warning fw-bold" style="font-size: 11px;">@(std?.SpiralPitch ?? 38) ± @(std?.Tol_SpiralPitch ?? 5)</td>
                                <td class="bg-white-5" style="font-size: 10px;">NOM</td>
                                @for(int h=0; h<6; h++) {
                                    var r = h < readings.Count ? readings[h] : null;
                                    <td class="border-start border-primary border-opacity-25 text-white fw-bold">@r?.SpiralPitch?.ToString("0.0")</td>
                                }
                            </tr>
                            <tr style="height: 45px; border-top: 1px solid rgba(59, 130, 246, 0.3);">
                                <td class="p-2 text-start fw-bold text-info" style="font-size: 11px;">Visual Check</td>
                                <td class="text-white-50" style="font-size: 9px;">30m Sekali</td>
                                <td colspan="2" class="text-start ps-2 py-1 lh-1 text-white-50" style="font-size: 9px; opacity: 0.7;">No Burry, No Line, No Bubble, No Scratch</td>
                                @for(int h=0; h<6; h++) {
                                    var r = h < readings.Count ? readings[h] : null;
                                    <td class="border-start border-primary border-opacity-25 @(r?.VisualCheck == "NG" ? "text-danger" : "text-success") fw-black">@r?.VisualCheck</td>
                                }
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- 4. FOOTER NOTE & ATTENTION -->
                <div class="row g-0 border-top-cyber" style="background: rgba(15, 23, 42, 0.5);">
                    <div class="col-7 p-2 border-end border-primary border-opacity-25 text-start">
                        <span class="text-info extra-small opacity-50">Note :</span>
                        <div class="text-white-50 font-size-8 ms-2 mt-1">@Model.Remark</div>
                    </div>
                    <div class="col-5 p-2 text-start">
                        <div class="text-warning extra-small opacity-75">Attention :</div>
                        <div class="text-white-50 font-size-7 ps-2 mt-1 lh-sm">
                            1. Operator wajib menggunakan APD lengkap<br/>
                            2. Periksa Dies Sebelum dan sesudah proses<br/>
                            3. Parameter harus sesuai Standard Parameter Setting (SPS)
                        </div>
                    </div>
                </div>
            </div>

            <!-- ACTIONS -->
            <div class="no-print d-flex justify-content-center gap-3 mt-2 mb-4">
                <button type="button" class="btn btn-primary px-4 rounded-pill shadow" data-bs-toggle="modal" data-bs-target="#addDimModal">
                    <i class="bi bi-plus-circle me-2"></i> INPUT DATA QUALITY JAM @(readings.Count + 1)
                </button>
                <button onclick="window.print()" class="btn btn-outline-info px-4 rounded-pill">
                    <i class="bi bi-printer me-2"></i> PRINT REPORT
                </button>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary px-4 rounded-pill">
                    <i class="bi bi-arrow-left me-2"></i> BACK TO LIST
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- ============================================= -->
        <!-- PORTAL 1: PARAMETER SETTING (Modern HUD)      -->
        <!-- ============================================= -->
        <div class="bg-white p-4">
            <div class="paper-replica shadow-2xl mx-auto mb-5 p-4">
            <div class="paper-padding text-uppercase" style="font-size: 10px;">
                
                <!-- 1. HEADER & INFO SECTION -->
                <div class="border-form-bold mb-2 bg-white text-dark">
                    <!-- TOP ROW -->
                    <div class="row g-0 border-bottom-form-bold">
                        <!-- Logo -->
                        <div class="col-3 border-end-form p-2 d-flex align-items-center justify-content-center">
                             <div class="d-flex align-items-center mb-1">
                                <h4 class="fw-black text-secondary mb-0 me-2" style="font-family: Arial Black, sans-serif; letter-spacing: -1px; font-size: 32px; transform: scaleX(1.2);">V</h4>
                                <div>
                                    <h5 class="fw-black text-secondary mb-0" style="letter-spacing: 2px; font-size: 20px; line-height: 1;">VELASTO</h5>
                                    <div class="super-small fw-bold text-secondary" style="letter-spacing: 4px; font-size: 7px;">I N D O N E S I A</div>
                                </div>
                             </div>
                        </div>
                        <!-- Title -->
                        <div class="col-5 border-end-form p-2 d-flex flex-column justify-content-center align-items-center text-center">
                            <h6 class="fw-bold mb-1" style="font-size: 16px; letter-spacing: 0.5px;">Extruder Production Report</h6>
                            <div class="fw-bold" style="font-size: 14px;">(Parameter Setting)</div>
                        </div>
                        <!-- Signature Block -->
                        <div class="col-4">
                            <table class="w-100 h-100 text-center m-0 border-0" style="font-size: 10px; table-layout: fixed;">
                                <tr style="height: 20px;">
                                    <td class="border-end-form border-bottom-form align-middle">Disetujui</td>
                                    <td class="border-end-form border-bottom-form align-middle">Diperiksa</td>
                                    <td class="border-bottom-form align-middle">Dibuat</td>
                                </tr>
                                <tr>
                                    <td class="border-end-form border-bottom-form" style="height: 35px;"></td>
                                    <td class="border-end-form border-bottom-form"></td>
                                    <td class="border-bottom-form" style="position: relative;">
                                        <!-- Simulated Signature Placeholder -->
                                    </td>
                                </tr>
                                <tr style="height: 15px;">
                                    <td class="border-end-form"></td>
                                    <td class="border-end-form"></td>
                                    <td></td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <!-- BOTTOM ROW -->
                    <div class="row g-0 h-100">
                        <!-- Info Block (No. Doc, Date, etc.) -->
                        <div class="col-5 border-end-form">
                            <table class="w-100 m-0 border-0 text-start fw-bold" style="font-size: 10px;">
                                <tr>
                                    <td style="width: 70px;" class="border-bottom-form py-1 ps-2">NO. DOC.</td>
                                    <td style="width: 15px;" class="border-bottom-form py-1 text-center">:</td>
                                    <td class="border-bottom-form py-1 pe-2 ps-1">@Model.DocumentNumber</td>
                                </tr>
                                <tr>
                                    <td class="border-bottom-form py-1 ps-2">DATE</td>
                                    <td class="border-bottom-form py-1 text-center">:</td>
                                    <td class="border-bottom-form py-1 pe-2">
                                        <input type="text" class="input-transparent text-start w-100 text-dark fw-bold ps-1" value='@(Model.ProductionDate.ToString("dd.MM.yy"))' />
                                    </td>
                                </tr>
                                <tr>
                                    <td class="border-bottom-form py-1 ps-2">SHIFT</td>
                                    <td class="border-bottom-form py-1 text-center">:</td>
                                    <td class="border-bottom-form py-1 pe-2">
                                        <input type="text" class="input-transparent text-start w-100 text-dark fw-bold ps-1" value='@Model.Shift' />
                                    </td>
                                </tr>
                                <tr>
                                    <td class="border-bottom-form py-1 ps-2">CUST.</td>
                                    <td class="border-bottom-form py-1 text-center">:</td>
                                    <td class="border-bottom-form py-1 pe-2 ps-1">@(string.IsNullOrEmpty(Model.CustomerName) ? "-" : Model.CustomerName)</td>
                                </tr>
                                <tr>
                                    <td class="py-1 ps-2">TIPE</td>
                                    <td class="py-1 text-center">:</td>
                                    <td class="py-1 pe-2 ps-1">@Model.HoseType @Model.Dimension</td>
                                </tr>
                            </table>
                        </div>
                        
                        <!-- EMBEL/LEMBAR Block -->
                        <div class="col-1 border-end-form d-flex align-items-center justify-content-center p-0">
                            <table class="p-0 border-form m-0 text-center" style="width: 45px; font-size: 8px;">
                                <tr><td class="border-bottom-form bg-light p-0">EMBEL</td></tr>
                                <tr><td class="fw-bold p-0">1</td></tr>
                            </table>
                        </div>
                        
                        <!-- Revision Table -->
                        <div class="col-6">
                            <table class="w-100 h-100 m-0 border-0 text-center align-middle" style="font-size: 9px; table-layout: fixed;">
                                <tr class="border-bottom-form" style="height: 22px;">
                                    <td class="border-end-form" style="width: 25%;">No. Rev.</td>
                                    <td class="border-end-form" style="width: 50%;">Description</td>
                                    <td style="width: 25%;">Date</td>
                                </tr>
                                <tr class="border-bottom-form"><td class="border-end-form"></td><td class="border-end-form"></td><td></td></tr>
                                <tr class="border-bottom-form"><td class="border-end-form"></td><td class="border-end-form"></td><td></td></tr>
                                <tr><td class="border-end-form"></td><td class="border-end-form"></td><td></td></tr>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- 3. TOP GRID (Material, Dies, Mesh) -->
                <div class="row g-0 border-form mb-0">
                    <!-- MATERIAL & DIES -->
                    <div class="col-6 border-end-form">
                         <table class="w-100 grid-form border-0">
                            <!-- MATERIAL SECTION -->
                            <tr>
                                <th width="30" rowspan="4" class="align-middle text-center p-0 border-bottom-0" style="writing-mode: vertical-rl; transform: rotate(180deg); background:#f0f0f0; letter-spacing: 2px;">MATERIAL</th>
                                <th colspan="2" style="background:#f0f0f0; border-bottom: 0;"></th>
                                <th width="80" style="background:#f0f0f0;" class="text-center">STANDARD</th>
                                <th width="100" style="background:#f0f0f0;" class="text-center">ACTUAL</th>
                                <th width="120" style="background:#f0f0f0;" class="text-center border-end-0">NO. LOT</th>
                                <th rowspan="4" width="2" style="background:#f4f4f4;" class="border-start-form"></th>
                            </tr>
                            <tr>
                                <td colspan="2" class="text-start ps-2">INNER(MATERIAL)</td>
                                <td class="text-center">@(Model.InnerMaterial ?? "-")</td>
                                <td class="p-0 border-end-0"><input type="text" class="input-transparent w-100 h-100 text-center fw-bold text-primary" value="@(Model.InnerMaterialActual ?? Model.InnerMaterial ?? "")" /></td>
                                <td class="p-0 border-end-0"><input type="text" class="input-transparent w-100 h-100 text-center text-dark" value="@(Model.InnerMaterialLotNo == "0" ? "" : Model.InnerMaterialLotNo)" placeholder="" /></td>
                            </tr>
                            <tr>
                                <td colspan="2" class="text-start ps-2">OUTER(MATERIAL)</td>
                                <td class="text-center">@(Model.OuterMaterial ?? "-")</td>
                                <td class="p-0 border-end-0"><input type="text" class="input-transparent w-100 h-100 text-center fw-bold text-primary" value="@(Model.OuterMaterialActual ?? Model.OuterMaterial ?? "")" /></td>
                                <td class="p-0 border-end-0"><input type="text" class="input-transparent w-100 h-100 text-center text-dark" value="@(Model.OuterMaterialLotNo == "0" ? "" : Model.OuterMaterialLotNo)" placeholder="" /></td>
                            </tr>
                            <tr>
                                <td colspan="2" class="text-start ps-2">YARN</td>
                                <td class="text-center">ARAMID</td>
                                <td class="p-0 border-end-0"><input type="text" class="input-transparent w-100 h-100 text-center fw-bold text-primary" value="@(Model.YarnActual ?? Model.Yarn ?? "ARAMID")" /></td>
                                <td class="p-0 border-end-0 bg-light"><input type="text" class="input-transparent w-100 h-100 text-center text-dark" value="@(Model.YarnLotNo == "0" ? "" : Model.YarnLotNo)" placeholder="" /></td>
                            </tr>
                            
                            @{
                                var mSps = ViewBag.Masterlist as VelastoProductionSystem.Models.MasterlistSpsDoubleLayer;
                                string FDie(string? fromSps, decimal stdVal, string hardcode) {
                                    if (!string.IsNullOrEmpty(fromSps) && fromSps != "-" && fromSps != "0") return fromSps;
                                    if (stdVal != 0) return stdVal.ToString();
                                    return hardcode;
                                }
                            }
                            <!-- DIES DIMENSION SECTION -->
                            <tr class="border-top-form">
                                <th width="30" rowspan="7" class="align-middle text-center p-0" style="writing-mode: vertical-rl; transform: rotate(180deg); background:#f0f0f0; letter-spacing: 2px;">DIES DIMENSION</th>
                                <th style="background:#f0f0f0;" class="text-start ps-2">DIES</th>
                                <th width="100" style="background:#f0f0f0;" class="text-center">CEK VISUAL</th>
                                <th width="90" style="background:#f0f0f0;" class="text-center">STANDARD</th>
                                <th width="60" style="background:#f0f0f0;" class="text-center">BEFORE</th>
                                <th width="60" style="background:#f0f0f0; border-right: 0 !important;" class="text-center">AFTER</th>
                            </tr>
                            <tr>
                                <td class="text-start ps-2">Ø NIPPLE DIE</td>
                                <td class="p-0 align-middle">
                                    <div class="d-flex justify-content-center gap-1 align-items-center h-100" style="font-size: 10px;">
                                        <label class="mb-0 d-flex align-items-center gap-1">OK <input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" @(Model.NippleDieOK ? "checked" : "") style="width:14px; height:14px; margin-top:-1px!important;"></label>
                                        <label class="mb-0 d-flex align-items-center gap-1">NG <input type="checkbox" class="form-check-input m-0 rounded-0 border-dark" @(!Model.NippleDieOK && Model.Status != "NOW PRODUCING" ? "checked" : "") style="width:14px; height:14px; margin-top:-1px!important;"></label>
                                    </div>
