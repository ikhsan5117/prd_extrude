<!DOCTYPE html>
<html lang="id" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Velasto Production System</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Animated Background -->
    <div class="animated-bg"></div>

    <!-- Global SVG Gradient Definition -->
    <svg width="0" height="0" class="position-absolute" style="visibility: hidden;">
        <defs>
            <linearGradient id="nav-icon-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#00f2fe;stop-opacity:1" />
                <stop offset="100%" style="stop-color:#4facfe;stop-opacity:1" />
            </linearGradient>
        </defs>
    </svg>
    
    <!-- Top Navbar -->
    <nav class="top-navbar no-print">
        <div class="navbar-content">
            <div class="navbar-left">
                <button class="sidebar-toggle" id="sidebarToggle">
                    <i class="bi bi-list"></i>
                </button>
                <div class="brand">
                    <i class="bi bi-gear-fill"></i>
                    <span>VELASTO Production System</span>
                </div>
            </div>
            <div class="navbar-right">
                @if (!string.IsNullOrEmpty(Context.Session.GetString("UserName")))
                {
                    <div class="d-flex align-items-center me-2 me-md-3 border-end pe-2 pe-md-3 border-white border-opacity-10">
                        <div class="text-end me-3 d-none d-md-block">
                            <div class="text-white-50 super-small text-uppercase fw-bold" style="font-size: 0.6rem; letter-spacing: 1px;">Operator</div>
                            <div class="text-info fw-bold" style="font-size: 0.85rem;">@Context.Session.GetString("UserName")</div>
                        </div>
                        <div class="text-end me-2 me-md-3">
                            <div class="text-white-50 super-small text-uppercase fw-bold d-none d-md-block" style="font-size: 0.6rem; letter-spacing: 1px;">Machine</div>
                            <div class="text-warning fw-bold" style="font-size: 0.85rem;">
                                <i class="bi bi-cpu-fill d-inline-block d-md-none text-white-50 me-1"></i>
                                @Context.Session.GetString("MachineName")
                            </div>
                        </div>
                        <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger btn-sm border-0 rounded-circle" title="Change User/Machine">
                            <i class="bi bi-box-arrow-right"></i>
                        </a>
                    </div>
                }
                <div class="status-indicator">
                    <span class="status-dot pulse"></span>
                    <span>System Online</span>
                </div>
                <div class="datetime">
                    <i class="bi bi-calendar3"></i>
                    <span id="currentDateTime">@DateTime.Now.ToString("dd MMM yyyy HH:mm")</span>
                </div>
            </div>
        </div>
    </nav>

    <!-- Sidebar -->
    <aside class="sidebar no-print" id="sidebar">
        <div class="sidebar-header">
            <div class="company-logo">
                <i class="bi bi-hexagon-fill"></i>
            </div>
            <h4>PT. Velasto</h4>
            <p>Manufacturing Facility 4</p>
        </div>

        <nav class="sidebar-nav">
            @if (Context.Session.GetString("IsAdmin") == "true")
            {
                <!-- ADMIN - Full Access -->
                <a asp-controller="Home" asp-action="Index" class="nav-item">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960"><path d="M120-120v-80l80-80v160h-80Zm160 0v-240l80-80v320h-80Zm160 0v-320l80 81v239h-80Zm160 0v-239l80-80v319h-80Zm160 0v-400l80-80v480h-80ZM120-327v-113l280-280 160 160 280-280v113L560-447 400-607 120-327Z"/></svg>
                    <span>Dashboard</span>
                </a>

                <div class="nav-group">
                    <div class="nav-group-title">
                        <i class="bi bi-database"></i>
                        <span>Master Data</span>
                    </div>
                    <a asp-controller="PlanningMaster" asp-action="Index" class="nav-item sub">
                        <i class="bi bi-calendar-check"></i>
                        <span>Planning Master</span>
                    </a>
                    <a asp-controller="MasterlistSpsDoubleLayers" asp-action="Index" class="nav-item sub">
                        <i class="bi bi-layers"></i>
                        <span>SPS Double Layer</span>
                    </a>
                    <a asp-controller="PartMaster" asp-action="Index" class="nav-item sub">
                        <i class="bi bi-gear"></i>
                        <span>Part Master</span>
                    </a>
                    <a asp-controller="ExtrudeUser" asp-action="Index" class="nav-item sub">
                        <i class="bi bi-people"></i>
                        <span>Users</span>
                    </a>
                    <a asp-controller="ExtrudeMachine" asp-action="Index" class="nav-item sub">
                        <i class="bi bi-hdd-rack"></i>
                        <span>Extrude Machine</span>
                    </a>
                </div>

                <div class="nav-group">
                    <div class="nav-group-title">
                        <i class="bi bi-gear-wide-connected"></i>
                        <span>Production</span>
                    </div>
                    <a asp-controller="ProductionReport" asp-action="Create" class="nav-item sub">
                        <i class="bi bi-clipboard2-plus"></i>
                        <span>Form Parameter Setting</span>
                    </a>
                    <a asp-controller="Dimensi" asp-action="Index" class="nav-item sub">
                        <i class="bi bi-rulers"></i>
                        <span>Input Dimensi</span>
                    </a>
                </div>

                <div class="nav-group">
                    <div class="nav-group-title">
                        <i class="bi bi-archive-fill"></i>
                        <span>History Archive</span>
                    </div>
                    <a asp-controller="ProductionReport" asp-action="ParameterHistory" class="nav-item sub">
                        <i class="bi bi-sliders"></i>
                        <span>Parameter History</span>
                    </a>
                    <a asp-controller="Dimensi" asp-action="History" class="nav-item sub">
                        <i class="bi bi-rulers"></i>
                        <span>Dimension History</span>
                    </a>
                </div>
            }
            else
            {
                <!-- OPERATOR - Restricted Access -->
                <div class="nav-group">
                    <div class="nav-group-title">
                        <i class="bi bi-gear-wide-connected"></i>
                        <span>Production</span>
                    </div>
                    <a asp-controller="ProductionReport" asp-action="Create" class="nav-item sub">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960"><path d="M680-80v-400q16 0 31 2.5t29 7.5v380q-14 5-29 7.5T680-80Zm-100-28v-344q14-8 28.5-14.5T640-476v392q-17-3-31.5-9.5T580-108Zm200 0v-344q45 26 72.5 71T880-280q0 56-27.5 101T780-108Zm-240-30q-28-27-44-63.5T480-280q0-42 16-79t44-64v285Zm-60-342ZM370-80l-16-128q-13-5-24.5-12T307-235l-119 50L78-375l103-78q-1-7-1-13.5v-27q0-6.5 1-13.5L78-585l110-190 119 50q11-8 23-15t24-12l16-128h220l16 128q13 5 24.5 12t22.5 15l119-50 110 190-74 56q-22-11-45-18.5T714-558l63-48-39-68-99 42q-22-23-48.5-38.5T533-694l-13-106h-79l-14 106q-31 8-57.5 23.5T321-633l-99-41-39 68 86 64q-5 15-7 30t-2 32q0 16 2 31t7 30l-86 65 39 68 99-42q17 17 36.5 30.5T400-275q1 57 23.5 107T484-80H370Zm41-279q6-20 14.5-38.5T445-433q-11-8-17-20.5t-6-26.5q0-25 17.5-42.5T482-540q14 0 27 6.5t21 17.5q17-11 35-19.5t38-13.5q-18-32-50-51.5T482-620q-59 0-99.5 41T342-480q0 38 18.5 70.5T411-359Z"/></svg>
                        <span class="fw-bold">Form Parameter Setting</span>
                    </a>
                    <a asp-controller="Dimensi" asp-action="Index" class="nav-item sub">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960"><path d="M208-120q-37 0-62.5-25.5T120-208v-548q0-29 27-40.5t47 8.5l90 90-54 54 28 28 54-54 104 104-54 54 28 28 54-54 104 104-54 54 28 28 54-54 104 104-54 54 28 28 54-54 80 80q20 20 8.5 47T756-120H208Zm32-120h332L240-572v332Z"/></svg>
                        <span class="fw-bold">Input Dimensi</span>
                    </a>
                </div>

                <div class="nav-group">
                    <div class="nav-group-title">
                        <i class="bi bi-archive-fill"></i>
                        <span>HISTORY ARCHIVE</span>
                    </div>
                    <a asp-controller="ProductionReport" asp-action="ParameterHistory" class="nav-item sub">
                        <i class="bi bi-sliders"></i>
                        <span>Parameter History</span>
                    </a>
                    <a asp-controller="Dimensi" asp-action="History" class="nav-item sub">
                        <i class="bi bi-rulers"></i>
                        <span>Dimension History</span>
                    </a>
                </div>
            }

        </nav>

        <div class="sidebar-footer">
            <div class="footer-info">
                <i class="bi bi-shield-check"></i>
                <div>
                    <small>Plant 2504</small>
                    <small class="text-muted">Tango Factory</small>
                </div>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content" id="mainContent">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert-glass alert-success">
                <i class="bi bi-check-circle-fill"></i>
                <span>@TempData["SuccessMessage"]</span>
                <button class="alert-close" onclick="this.parentElement.remove()">
                    <i class="bi bi-x"></i>
                </button>
            </div>
        }
        
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert-glass alert-danger">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span>@TempData["ErrorMessage"]</span>
                <button class="alert-close" onclick="this.parentElement.remove()">
                    <i class="bi bi-x"></i>
                </button>
            </div>
        }

        @RenderBody()

        <footer class="footer-content no-print">
            <p>&copy; 2026 PT. Velasto Indonesia - Manufacturing Excellence</p>
        </footer>
    </main>
    @await RenderSectionAsync("StickyFooter", required: false)

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // Sidebar toggle
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebar = document.getElementById('sidebar');
        const mainContent = document.getElementById('mainContent');

        // Check if backdrop exists, create if not
        let backdrop = document.querySelector('.sidebar-backdrop');
        if (!backdrop) {
            backdrop = document.createElement('div');
            backdrop.className = 'sidebar-backdrop';
            document.body.appendChild(backdrop);
        }

        sidebarToggle.addEventListener('click', function() {
            if (window.innerWidth <= 768) {
                sidebar.classList.toggle('show');
                backdrop.classList.toggle('show');
            } else {
                sidebar.classList.toggle('collapsed');
                mainContent.classList.toggle('expanded');
            }
        });

        // Close when backdrop clicked
        backdrop.addEventListener('click', function() {
            sidebar.classList.remove('show');
            backdrop.classList.remove('show');
        });

        // Update datetime every minute
        function updateDateTime() {
            const now = new Date();
            const options = { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' };
            document.getElementById('currentDateTime').textContent = now.toLocaleDateString('id-ID', options);
        }
        setInterval(updateDateTime, 60000);

        // Active nav item highlight
        const currentPath = window.location.pathname;
        document.querySelectorAll('.sidebar-nav .nav-item').forEach(item => {
            if (item.getAttribute('href') === currentPath) {
                item.classList.add('active');
            }
        });

        // Auto-hide alerts after 5 seconds
        document.querySelectorAll('.alert-glass').forEach(alert => {
            setTimeout(() => {
                alert.style.animation = 'slideOut 0.3s ease-out';
                setTimeout(() => alert.remove(), 300);
            }, 5000);
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
