@model VelastoProductionSystem.Controllers.ErrorViewModel

@{
    ViewData["Title"] = "Error";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="bi bi-exclamation-triangle-fill"></i> An Error Occurred</h4>
                </div>
                <div class="card-body">
                    <h5 class="card-title">Something went wrong</h5>
                    <p class="card-text">We're sorry, but an error occurred while processing your request.</p>
                    
                    @if (Model?.ShowRequestId == true)
                    {
                        <div class="alert alert-secondary">
                            <strong>Request ID:</strong> @Model.RequestId
                        </div>
                    }
                    
                    <hr>
                    
                    <h6>Possible issues:</h6>
                    <ul>
                        <li>Database connection error - Make sure SQL Server is running</li>
                        <li>Database not created - Run: <code>dotnet ef database update</code></li>
                        <li>Connection string error - Check appsettings.json</li>
                    </ul>
                    
                    <div class="mt-4">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-velasto">
                            <i class="bi bi-house"></i> Go to Home
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
